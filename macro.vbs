ts.WriteLine "Public Function ReadMappingSheet(wb As Workbook) As MappingRow()"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    Dim mapCount As Long"
ts.WriteLine "    mapCount = 0"
ts.WriteLine "    ReDim mappings(0 To 50)"
ts.WriteLine ""
ts.WriteLine "    ' Find Mapping sheet (case-insensitive)"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    Dim found As Boolean"
ts.WriteLine "    Dim sh As Worksheet"
ts.WriteLine "    For Each sh In wb.Worksheets"
ts.WriteLine "        If LCase$(Trim$(sh.name)) = ""mapping"" Then"
ts.WriteLine "            Set ws = sh"
ts.WriteLine "            found = True"
ts.WriteLine "            Exit For"
ts.WriteLine "        End If"
ts.WriteLine "    Next sh"
ts.WriteLine "    If Not found Then"
ts.WriteLine "        ReDim mappings(0 To 0)"
ts.WriteLine "        ReadMappingSheet = mappings"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Find header row columns"
ts.WriteLine "    Dim headerRow As Long"
ts.WriteLine "    headerRow = 1"
ts.WriteLine "    Dim tabCol As Long, acctCol As Long, holdCol As Long, allocCol As Long, pctCol As Long"
ts.WriteLine "    tabCol = 0: acctCol = 0: holdCol = 0: allocCol = 0: pctCol = 0"
ts.WriteLine ""
ts.WriteLine "    Dim c As Long"
ts.WriteLine "    For c = 1 To 20"
ts.WriteLine "        Dim hdr As String"
ts.WriteLine "        hdr = LCase$(Trim$(CStr(ws.Cells(headerRow, c).Value & """")))"
ts.WriteLine "        Select Case hdr"
ts.WriteLine "            Case ""tab"": tabCol = c"
ts.WriteLine "            Case ""account"": acctCol = c"
ts.WriteLine "            Case ""holdings"": holdCol = c"
ts.WriteLine "            Case ""allocation"": allocCol = c"
ts.WriteLine "            Case ""pct"": pctCol = c"
ts.WriteLine "        End Select"
ts.WriteLine "    Next c"
ts.WriteLine ""
ts.WriteLine "    If tabCol = 0 Or acctCol = 0 Then"
ts.WriteLine "        ReDim mappings(0 To 0)"
ts.WriteLine "        ReadMappingSheet = mappings"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Create regex once for WM suffix stripping"
ts.WriteLine "    Dim reWM As Object"
ts.WriteLine "    Set reWM = RegexHelper.CreateRegex(""\s+WM$"")"
ts.WriteLine ""
ts.WriteLine "    ' Read data rows"
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    For r = 2 To 200"
ts.WriteLine "        Dim tabVal As String"
ts.WriteLine "        tabVal = Trim$(CStr(ws.Cells(r, tabCol).Value & """"))"
ts.WriteLine "        Dim acctVal As String"
ts.WriteLine "        acctVal = Trim$(CStr(ws.Cells(r, acctCol).Value & """"))"
ts.WriteLine ""
ts.WriteLine "        If tabVal = """" Or acctVal = """" Then GoTo NextMapRow"
ts.WriteLine ""
ts.WriteLine "        ' Strip "" WM"" suffix from account"
ts.WriteLine "        acctVal = reWM.Replace(acctVal, """")"
ts.WriteLine ""
ts.WriteLine "        Dim holdVal As String"
ts.WriteLine "        holdVal = """""
ts.WriteLine "        If holdCol > 0 Then holdVal = Trim$(CStr(ws.Cells(r, holdCol).Value & """"))"
ts.WriteLine "        If holdVal = """" Then holdVal = ""all"""
ts.WriteLine ""
ts.WriteLine "        Dim allocVal As String"
ts.WriteLine "        allocVal = """""
ts.WriteLine "        If allocCol > 0 Then allocVal = Trim$(CStr(ws.Cells(r, allocCol).Value & """"))"
ts.WriteLine ""
ts.WriteLine "        Dim pctVal As Double"
ts.WriteLine "        pctVal = 1#"
ts.WriteLine "        If pctCol > 0 Then"
ts.WriteLine "            Dim pctRaw As String"
ts.WriteLine "            pctRaw = Trim$(CStr(ws.Cells(r, pctCol).Value & """"))"
ts.WriteLine "            If pctRaw <> """" Then"
ts.WriteLine "                pctRaw = Replace(pctRaw, ""%"", """")"
ts.WriteLine "                If IsNumeric(pctRaw) Then"
ts.WriteLine "                    pctVal = CDbl(pctRaw)"
ts.WriteLine "                    If pctVal > 1 Then pctVal = pctVal / 100"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        If mapCount > UBound(mappings) Then ReDim Preserve mappings(0 To mapCount + 20)"
ts.WriteLine "        mappings(mapCount).Tab = tabVal"
ts.WriteLine "        mappings(mapCount).Account = acctVal"
ts.WriteLine "        mappings(mapCount).Holdings = holdVal"
ts.WriteLine "        mappings(mapCount).Allocation = allocVal"
ts.WriteLine "        mappings(mapCount).Pct = pctVal"
ts.WriteLine "        mapCount = mapCount + 1"
ts.WriteLine "NextMapRow:"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    ReDim Preserve mappings(0 To IIf(mapCount > 0, mapCount - 1, 0))"
ts.WriteLine "    ReadMappingSheet = mappings"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Master sheet: asset class -> column mapping"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function ReadMasterAssetClasses(wb As Workbook) As Object"
ts.WriteLine "    ' Returns Dictionary: lowercase class name -> column letter"
ts.WriteLine "    Dim map As Object"
ts.WriteLine "    Set map = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = wb.Worksheets(""Master"")"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        Set ReadMasterAssetClasses = map"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Const START_ROW As Long = 5"
ts.WriteLine "    Const END_ROW As Long = 26"
ts.WriteLine "    Const NAME_COL As Long = 4      ' Column D"
ts.WriteLine "    Const ALLOC_START_COL As Long = 8  ' Column H"
ts.WriteLine ""
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    For r = START_ROW To END_ROW"
ts.WriteLine "        Dim name As String"
ts.WriteLine "        name = Trim$(CStr(ws.Cells(r, NAME_COL).Value & """"))"
ts.WriteLine "        If name <> """" Then"
ts.WriteLine "            Dim colIdx As Long"
ts.WriteLine "            colIdx = ALLOC_START_COL + (r - START_ROW)"
ts.WriteLine "            ' Convert column number to letter(s)"
ts.WriteLine "            Dim colLetter As String"
ts.WriteLine "            colLetter = ColNumToLetter(colIdx)"
ts.WriteLine "            map(LCase$(name)) = colLetter"
ts.WriteLine "        End If"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    Set ReadMasterAssetClasses = map"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' Returns the asset class names from the QPR Master sheet (original case)."
ts.WriteLine "' Callers use this to build classification dropdowns instead of hardcoding."
ts.WriteLine "Public Function ReadMasterAssetClassNames(wb As Workbook, ByRef names() As String) As Long"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = wb.Worksheets(""Master"")"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        ReadMasterAssetClassNames = 0"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Const START_ROW As Long = 5"
ts.WriteLine "    Const END_ROW As Long = 26"
ts.WriteLine "    Const NAME_COL As Long = 4      ' Column D"
ts.WriteLine ""
ts.WriteLine "    Dim count As Long"
ts.WriteLine "    count = 0"
ts.WriteLine "    ReDim names(1 To END_ROW - START_ROW + 1)"
ts.WriteLine ""
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    For r = START_ROW To END_ROW"
ts.WriteLine "        Dim n As String"
ts.WriteLine "        n = Trim$(CStr(ws.Cells(r, NAME_COL).Value & """"))"
ts.WriteLine "        If Len(n) > 0 Then"
ts.WriteLine "            count = count + 1"
ts.WriteLine "            names(count) = n"
ts.WriteLine "        End If"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    If count > 0 Then ReDim Preserve names(1 To count)"
ts.WriteLine "    ReadMasterAssetClassNames = count"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function ColNumToLetter(colNum As Long) As String"
ts.WriteLine "    Dim result As String"
ts.WriteLine "    Dim n As Long"
ts.WriteLine "    n = colNum"
ts.WriteLine "    Do While n > 0"
ts.WriteLine "        Dim remainder As Long"
ts.WriteLine "        remainder = ((n - 1) Mod 26)"
ts.WriteLine "        result = Chr$(65 + remainder) & result"
ts.WriteLine "        n = (n - 1) \ 26"
ts.WriteLine "    Loop"
ts.WriteLine "    ColNumToLetter = result"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Find month row"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function FindMonthRow(wb As Workbook, sheetName As String, targetMonth As Long, targetYear As Long) As Long"
ts.WriteLine "    ' Returns row number or 0 if not found"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = wb.Worksheets(sheetName)"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        FindMonthRow = 0"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    For r = 32 To 600"
ts.WriteLine "        Dim cellVal As Variant"
ts.WriteLine "        cellVal = ws.Cells(r, 1).Value"
ts.WriteLine "        If IsEmpty(cellVal) Then GoTo NextRow"
ts.WriteLine ""
ts.WriteLine "        Dim cellDate As Date"
ts.WriteLine "        Dim hasDate As Boolean"
ts.WriteLine "        hasDate = False"
ts.WriteLine ""
ts.WriteLine "        If IsDate(cellVal) Then"
ts.WriteLine "            cellDate = CDate(cellVal)"
ts.WriteLine "            hasDate = True"
ts.WriteLine "        ElseIf IsNumeric(cellVal) Then"
ts.WriteLine "            ' Excel serial date"
ts.WriteLine "            cellDate = CDate(cellVal)"
ts.WriteLine "            hasDate = True"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        If hasDate Then"
ts.WriteLine "            If Month(cellDate) = targetMonth And Year(cellDate) = targetYear Then"
ts.WriteLine "                FindMonthRow = r"
ts.WriteLine "                Exit Function"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "NextRow:"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    FindMonthRow = 0"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Holdings value resolution"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function ResolveHoldingsValue(ext As UBSExtract.StatementExtraction, holdingsSpec As String) As Double"
ts.WriteLine "    Dim spec As String"
ts.WriteLine "    spec = LCase$(Trim$(holdingsSpec))"
ts.WriteLine ""
ts.WriteLine "    If spec = ""all"" Then"
ts.WriteLine "        ResolveHoldingsValue = ext.Summary.ClosingValue"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    If spec = ""cash"" Then"
ts.WriteLine "        Dim cashTotal As Double"
ts.WriteLine "        Dim i As Long"
ts.WriteLine "        For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "            If IsMoneyMarketHolding(ext.Holdings(i).name) Then"
ts.WriteLine "                cashTotal = cashTotal + ext.Holdings(i).Value"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "        ResolveHoldingsValue = cashTotal"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    If IsAssetClassName(spec) Then"
ts.WriteLine "        Dim classTotal As Double"
ts.WriteLine "        For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "            If ext.Holdings(i).AssetType <> """" Then"
ts.WriteLine "                If NormalizeAssetClass(ext.Holdings(i).AssetType) = NormalizeAssetClass(spec) Then"
ts.WriteLine "                    classTotal = classTotal + ext.Holdings(i).Value"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "        ResolveHoldingsValue = classTotal"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Holding/security name or comma-separated list"
ts.WriteLine "    Dim specParts() As String"
ts.WriteLine "    Dim sp As Long"
ts.WriteLine "    Dim trimPart As String"
ts.WriteLine "    Dim nameTotal As Double"
ts.WriteLine "    Dim si As Long"
ts.WriteLine "    nameTotal = 0#"
ts.WriteLine ""
ts.WriteLine "    specParts = Split(holdingsSpec, "","")"
ts.WriteLine "    For sp = LBound(specParts) To UBound(specParts)"
ts.WriteLine "        trimPart = Trim$(specParts(sp))"
ts.WriteLine "        If trimPart = """" Then GoTo NextSpecPart"
ts.WriteLine "        For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "            ' Match holding name (case-insensitive)"
ts.WriteLine "            If StrComp(ext.Holdings(i).Name, trimPart, vbTextCompare) = 0 Then"
ts.WriteLine "                nameTotal = nameTotal + ext.Holdings(i).Value"
ts.WriteLine "                GoTo NextSpecPart"
ts.WriteLine "            End If"
ts.WriteLine "            ' Match security symbol or name within holdings"
ts.WriteLine "            For si = 0 To ext.Holdings(i).SecurityCount - 1"
ts.WriteLine "                If StrComp(ext.Holdings(i).Securities(si).Symbol, trimPart, vbTextCompare) = 0 Or _"
ts.WriteLine "                   StrComp(ext.Holdings(i).Securities(si).Name, trimPart, vbTextCompare) = 0 Then"
ts.WriteLine "                    nameTotal = nameTotal + ext.Holdings(i).Securities(si).Value"
ts.WriteLine "                    GoTo NextSpecPart"
ts.WriteLine "                End If"
ts.WriteLine "            Next si"
ts.WriteLine "        Next i"
ts.WriteLine "NextSpecPart:"
ts.WriteLine "    Next sp"
ts.WriteLine "    ResolveHoldingsValue = nameTotal"
ts.WriteLine "    Exit Function"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Transaction classification (cash flow boundary logic)"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function ClassifyTransaction(tx As UBSExtract.Transaction, ctx As TabContext) As Variant"
ts.WriteLine "    ' Returns effective amount (Double) or Null to exclude"
ts.WriteLine "    Dim act As String"
ts.WriteLine "    act = tx.Activity"
ts.WriteLine ""
ts.WriteLine "    ' Fees handled by caller"
ts.WriteLine "    If IsFeeActivity(act) Then"
ts.WriteLine "        ClassifyTransaction = Null"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' External cash activities"
ts.WriteLine "    If IsExternalCashActivity(act) Then"
ts.WriteLine "        If ctx.HasCash Then"
ts.WriteLine "            ClassifyTransaction = tx.Amount"
ts.WriteLine "        Else"
ts.WriteLine "            ClassifyTransaction = Null"
ts.WriteLine "        End If"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Interest = cash-internal return"
ts.WriteLine "    If IsCashReturnActivity(act) Then"
ts.WriteLine "        ClassifyTransaction = Null"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Cash security transactions are cash-internal"
ts.WriteLine "    If IsCashSecurityTx(tx, ctx.CashSymbols) Then"
ts.WriteLine "        ClassifyTransaction = Null"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Investment transactions: boundary logic"
ts.WriteLine "    Dim secInTab As Boolean"
ts.WriteLine "    secInTab = IsSecurityInTab(tx, ctx)"
ts.WriteLine ""
ts.WriteLine "    If ctx.HasCash And secInTab Then"
ts.WriteLine "        ClassifyTransaction = Null  ' internal transfer"
ts.WriteLine "    ElseIf ctx.HasCash And Not secInTab Then"
ts.WriteLine "        ClassifyTransaction = tx.Amount  ' cash perspective"
ts.WriteLine "    ElseIf Not ctx.HasCash And secInTab Then"
ts.WriteLine "        ClassifyTransaction = -tx.Amount  ' security perspective (negated)"
ts.WriteLine "    Else"
ts.WriteLine "        ClassifyTransaction = Null  ' neither in tab"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function IsCashSecurityTx(tx As UBSExtract.Transaction, cashSymbols As Object) As Boolean"
ts.WriteLine "    If cashSymbols Is Nothing Then"
ts.WriteLine "        IsCashSecurityTx = False"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    If tx.Symbol <> """" And cashSymbols.Exists(UCase$(tx.Symbol)) Then"
ts.WriteLine "        IsCashSecurityTx = True"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine "    If tx.Cusip <> """" And cashSymbols.Exists(UCase$(tx.Cusip)) Then"
ts.WriteLine "        IsCashSecurityTx = True"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim descUpper As String"
ts.WriteLine "    descUpper = UCase$(tx.Description)"
ts.WriteLine ""
ts.WriteLine "    ' Check description against cash symbols"
ts.WriteLine "    Dim key As Variant"
ts.WriteLine "    For Each key In cashSymbols.Keys"
ts.WriteLine "        If InStr(1, descUpper, CStr(key)) > 0 Then"
ts.WriteLine "            IsCashSecurityTx = True"
ts.WriteLine "            Exit Function"
ts.WriteLine "        End If"
ts.WriteLine "    Next key"
ts.WriteLine ""
ts.WriteLine "    ' Fallback: known money market patterns"
ts.WriteLine "    If InStr(1, tx.Description, ""UBS SELECT GOVERNMENT"", vbTextCompare) > 0 Then"
ts.WriteLine "        IsCashSecurityTx = True"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine "    If InStr(1, tx.Description, ""MONEY MARKET"", vbTextCompare) > 0 Then"
ts.WriteLine "        IsCashSecurityTx = True"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    IsCashSecurityTx = False"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function IsSecurityInTab(tx As UBSExtract.Transaction, ctx As TabContext) As Boolean"
ts.WriteLine "    If ctx.HasAll Then"
ts.WriteLine "        IsSecurityInTab = True"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    If ctx.SpecCount = 0 Then"
ts.WriteLine "        IsSecurityInTab = False"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Check symbol"
ts.WriteLine "    If tx.Symbol <> """" Then"
ts.WriteLine "        Dim i As Long"
ts.WriteLine "        For i = 0 To ctx.SpecCount - 1"
ts.WriteLine "            If UCase$(tx.Symbol) = ctx.SecuritySpecs(i) Then"
ts.WriteLine "                IsSecurityInTab = True"
ts.WriteLine "                Exit Function"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Check description"
ts.WriteLine "    Dim descUpper As String"
ts.WriteLine "    descUpper = UCase$(tx.Description)"
ts.WriteLine "    For i = 0 To ctx.SpecCount - 1"
ts.WriteLine "        If InStr(1, descUpper, ctx.SecuritySpecs(i)) > 0 Then"
ts.WriteLine "            IsSecurityInTab = True"
ts.WriteLine "            Exit Function"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    IsSecurityInTab = False"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Transaction resolution (Modified Dietz time-weighting)"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub ResolveTransactions(ext As UBSExtract.StatementExtraction, holdingsSpec As String, _"
ts.WriteLine "    ctx As TabContext, daysInMonth As Long, _"
ts.WriteLine "    ByRef colC As Double, ByRef colD As Double, ByRef fees As Double)"
ts.WriteLine ""
ts.WriteLine "    colC = 0#: colD = 0#: fees = 0#"
ts.WriteLine ""
ts.WriteLine "    Dim spec As String"
ts.WriteLine "    spec = LCase$(Trim$(holdingsSpec))"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
ts.WriteLine "        Dim tx As UBSExtract.Transaction"
ts.WriteLine "        tx = ext.Transactions(i)"
ts.WriteLine ""
ts.WriteLine "        ' For symbol-list specs, filter to matching transactions only"
ts.WriteLine "        If spec <> ""all"" And spec <> ""cash"" And Not IsAssetClassName(spec) Then"
ts.WriteLine "            If Not MatchesTxToSpec(tx, holdingsSpec) Then GoTo NextTx"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Fees"
ts.WriteLine "        If IsFeeActivity(tx.Activity) Then"
ts.WriteLine "            fees = fees + tx.Amount"
ts.WriteLine "            GoTo NextTx"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Classify"
ts.WriteLine "        Dim effective As Variant"
ts.WriteLine "        effective = ClassifyTransaction(tx, ctx)"
ts.WriteLine "        If IsNull(effective) Then GoTo NextTx"
ts.WriteLine ""
ts.WriteLine "        ' Time-weight"
ts.WriteLine "        Dim day As Long"
ts.WriteLine "        day = ParseTxDay(tx.TxDate)"
ts.WriteLine "        If day > 0 And daysInMonth > 0 Then"
ts.WriteLine "            colC = colC + CDbl(effective) * day / daysInMonth"
ts.WriteLine "            colD = colD + (-CDbl(effective)) * (daysInMonth - day) / daysInMonth"
ts.WriteLine "        End If"
ts.WriteLine "NextTx:"
ts.WriteLine "    Next i"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "Public Sub ResolveTransactionsDetailed(ext As UBSExtract.StatementExtraction, holdingsSpec As String, _"
ts.WriteLine "    ctx As TabContext, daysInMonth As Long, rowPct As Double, acctNum As String, _"
ts.WriteLine "    ByRef colC As Double, ByRef colD As Double, ByRef fees As Double, _"
ts.WriteLine "    ByRef details() As CashFlowDetail, ByRef detailCount As Long)"
ts.WriteLine ""
ts.WriteLine "    colC = 0#: colD = 0#: fees = 0#"
ts.WriteLine ""
ts.WriteLine "    Dim spec As String"
ts.WriteLine "    spec = LCase$(Trim$(holdingsSpec))"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim tx As UBSExtract.Transaction"
ts.WriteLine "    Dim effective As Variant"
ts.WriteLine "    Dim day As Long"
ts.WriteLine "    Dim wC As Double"
ts.WriteLine "    Dim wD As Double"
ts.WriteLine ""
ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
ts.WriteLine "        tx = ext.Transactions(i)"
ts.WriteLine ""
ts.WriteLine "        ' For symbol-list specs, filter to matching transactions only"
ts.WriteLine "        If spec <> ""all"" And spec <> ""cash"" And Not IsAssetClassName(spec) Then"
ts.WriteLine "            If Not MatchesTxToSpec(tx, holdingsSpec) Then GoTo NextDetTx"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Fees"
ts.WriteLine "        If IsFeeActivity(tx.Activity) Then"
ts.WriteLine "            fees = fees + tx.Amount"
ts.WriteLine "            GoTo NextDetTx"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Classify"
ts.WriteLine "        effective = ClassifyTransaction(tx, ctx)"
ts.WriteLine "        If IsNull(effective) Then GoTo NextDetTx"
ts.WriteLine ""
ts.WriteLine "        ' Time-weight"
ts.WriteLine "        day = ParseTxDay(tx.TxDate)"
ts.WriteLine "        If day > 0 And daysInMonth > 0 Then"
ts.WriteLine "            wC = CDbl(effective) * day / daysInMonth"
ts.WriteLine "            wD = (-CDbl(effective)) * (daysInMonth - day) / daysInMonth"
ts.WriteLine "            colC = colC + wC"
ts.WriteLine "            colD = colD + wD"
ts.WriteLine ""
ts.WriteLine "            ' Record detail with pct applied to weighted values"
ts.WriteLine "            If detailCount > UBound(details) Then ReDim Preserve details(0 To detailCount + 20)"
ts.WriteLine "            details(detailCount).Account = acctNum"
ts.WriteLine "            details(detailCount).Symbol = tx.Symbol"
ts.WriteLine "            details(detailCount).Description = tx.Description"
ts.WriteLine "            details(detailCount).Activity = tx.Activity"
ts.WriteLine "            details(detailCount).Amount = tx.Amount"
ts.WriteLine "            details(detailCount).TxDate = tx.TxDate"
ts.WriteLine "            details(detailCount).Day = day"
ts.WriteLine "            details(detailCount).DaysInMonth = daysInMonth"
ts.WriteLine "            details(detailCount).Effective = CDbl(effective)"
ts.WriteLine "            details(detailCount).Pct = rowPct"
ts.WriteLine "            details(detailCount).WeightedC = wC * rowPct"
ts.WriteLine "            details(detailCount).WeightedD = wD * rowPct"
ts.WriteLine "            detailCount = detailCount + 1"
ts.WriteLine "        End If"
ts.WriteLine "NextDetTx:"
ts.WriteLine "    Next i"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "Private Function ParseTxDay(dateStr As String) As Long"
ts.WriteLine "    ' Extract day number from ""Mar 15"" format"
ts.WriteLine "    ' Use simple string parsing instead of regex for performance"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim numStr As String"
ts.WriteLine "    For i = 1 To Len(dateStr)"
ts.WriteLine "        Dim c As String"
ts.WriteLine "        c = Mid$(dateStr, i, 1)"
ts.WriteLine "        If c >= ""0"" And c <= ""9"" Then"
ts.WriteLine "            numStr = numStr & c"
ts.WriteLine "        ElseIf numStr <> """" Then"
ts.WriteLine "            Exit For"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine "    If numStr <> """" Then"
ts.WriteLine "        ParseTxDay = CLng(numStr)"
ts.WriteLine "    Else"
ts.WriteLine "        ParseTxDay = 0"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function MatchesTxToSpec(tx As UBSExtract.Transaction, holdingsSpec As String) As Boolean"
ts.WriteLine "    Dim specs() As String"
ts.WriteLine "    specs = Split(holdingsSpec, "","")"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = LBound(specs) To UBound(specs)"
ts.WriteLine "        Dim spec As String"
ts.WriteLine "        spec = UCase$(Trim$(specs(i)))"
ts.WriteLine "        If spec = """" Then GoTo NextSpec"
ts.WriteLine "        If tx.Symbol <> """" And UCase$(tx.Symbol) = spec Then"
ts.WriteLine "            MatchesTxToSpec = True"
ts.WriteLine "            Exit Function"
ts.WriteLine "        End If"
ts.WriteLine "        If InStr(1, UCase$(tx.Description), spec) > 0 Then"
ts.WriteLine "            MatchesTxToSpec = True"
ts.WriteLine "            Exit Function"
ts.WriteLine "        End If"
ts.WriteLine "NextSpec:"
ts.WriteLine "    Next i"
ts.WriteLine "    MatchesTxToSpec = False"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Build cash symbols set"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function BuildCashSymbols(ext As UBSExtract.StatementExtraction) As Object"
ts.WriteLine "    Dim dict As Object"
ts.WriteLine "    Set dict = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    ' Note: without detailed securities, we can only add known cash patterns"
ts.WriteLine "    ' In the full version, this would scan holding.securities for money market funds"
ts.WriteLine "    dict(""SEGXX"") = True  ' UBS Select Government"
ts.WriteLine "    dict(""UBS SELECT GOVERNMENT"") = True"
ts.WriteLine "    dict(""UBS SELECT GOVERNMENTINSTITUTIONAL FUND"") = True"
ts.WriteLine "    dict(""UBS FDIC INSURED DEPOSIT"") = True"
ts.WriteLine "    dict(""UBS FDIC-INSURED DEPOSIT"") = True"
ts.WriteLine ""
ts.WriteLine "    Set BuildCashSymbols = dict"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Build row context"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function BuildRowContext(row As MappingRow, ext As UBSExtract.StatementExtraction, cashSymbols As Object) As TabContext"
ts.WriteLine "    Dim ctx As TabContext"
ts.WriteLine "    Set ctx.CashSymbols = cashSymbols"
ts.WriteLine "    ReDim ctx.SecuritySpecs(0 To 50)"
ts.WriteLine "    ctx.SpecCount = 0"
ts.WriteLine ""
ts.WriteLine "    Dim spec As String"
ts.WriteLine "    spec = LCase$(Trim$(row.Holdings))"
ts.WriteLine ""
ts.WriteLine "    If spec = ""all"" Then"
ts.WriteLine "        ctx.HasAll = True"
ts.WriteLine "        ctx.HasCash = True"
ts.WriteLine "    ElseIf spec = ""cash"" Then"
ts.WriteLine "        ctx.HasCash = True"
ts.WriteLine "    ElseIf IsAssetClassName(spec) Then"
ts.WriteLine "        If IsCashAssetClass(spec) Then ctx.HasCash = True"
ts.WriteLine "        ' Add securities from matching holdings"
ts.WriteLine "        Dim i As Long"
ts.WriteLine "        For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "            If ext.Holdings(i).AssetType <> """" Then"
ts.WriteLine "                If NormalizeAssetClass(ext.Holdings(i).AssetType) = NormalizeAssetClass(spec) Then"
ts.WriteLine "                    ' Without detailed securities, add holding name"
ts.WriteLine "                    If ctx.SpecCount > UBound(ctx.SecuritySpecs) Then ReDim Preserve ctx.SecuritySpecs(0 To ctx.SpecCount + 20)"
ts.WriteLine "                    ctx.SecuritySpecs(ctx.SpecCount) = UCase$(ext.Holdings(i).name)"
ts.WriteLine "                    ctx.SpecCount = ctx.SpecCount + 1"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "    Else"
ts.WriteLine "        ' Symbol list"
ts.WriteLine "        Dim parts() As String"
ts.WriteLine "        parts = Split(row.Holdings, "","")"
ts.WriteLine "        For i = LBound(parts) To UBound(parts)"
ts.WriteLine "            Dim trimmed As String"
ts.WriteLine "            trimmed = UCase$(Trim$(parts(i)))"
ts.WriteLine "            If trimmed <> """" Then"
ts.WriteLine "                If ctx.SpecCount > UBound(ctx.SecuritySpecs) Then ReDim Preserve ctx.SecuritySpecs(0 To ctx.SpecCount + 20)"
ts.WriteLine "                ctx.SecuritySpecs(ctx.SpecCount) = trimmed"
ts.WriteLine "                ctx.SpecCount = ctx.SpecCount + 1"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    BuildRowContext = ctx"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Parse statement date"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function ParseStatementPeriod(period As String) As Variant"
ts.WriteLine "    ' Returns array: (0)=month, (1)=year, (2)=daysInMonth, or Null"
ts.WriteLine "    Dim re As Object"
ts.WriteLine "    Set re = RegexHelper.CreateRegex(""(January|February|March|April|May|June|July|August|September|October|November|December)\s+(\d{4})"")"
ts.WriteLine "    Dim matches As Object"
ts.WriteLine "    Set matches = re.Execute(period)"
ts.WriteLine "    If matches.Count = 0 Then"
ts.WriteLine "        ParseStatementPeriod = Null"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim monthName As String"
ts.WriteLine "    monthName = matches(0).SubMatches(0)"
ts.WriteLine "    Dim yr As Long"
ts.WriteLine "    yr = CLng(matches(0).SubMatches(1))"
ts.WriteLine ""
ts.WriteLine "    Dim mo As Long"
ts.WriteLine "    Select Case monthName"
ts.WriteLine "        Case ""January"": mo = 1: Case ""February"": mo = 2: Case ""March"": mo = 3"
ts.WriteLine "        Case ""April"": mo = 4: Case ""May"": mo = 5: Case ""June"": mo = 6"
ts.WriteLine "        Case ""July"": mo = 7: Case ""August"": mo = 8: Case ""September"": mo = 9"
ts.WriteLine "        Case ""October"": mo = 10: Case ""November"": mo = 11: Case ""December"": mo = 12"
ts.WriteLine "    End Select"
ts.WriteLine ""
ts.WriteLine "    ' Days in month = last day of month"
ts.WriteLine "    Dim lastDay As Long"
ts.WriteLine "    lastDay = Day(DateSerial(yr, mo + 1, 0))"
ts.WriteLine ""
ts.WriteLine "    Dim result(0 To 2) As Long"
ts.WriteLine "    result(0) = mo"
ts.WriteLine "    result(1) = yr"
ts.WriteLine "    result(2) = lastDay"
ts.WriteLine "    ParseStatementPeriod = result"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Main entry point: build and apply QPR updates"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub WriteQPR(ext As UBSExtract.StatementExtraction, qprWb As Workbook, _"
ts.WriteLine "    Optional silent As Boolean = False, Optional ByRef outResult As String = """", _"
ts.WriteLine "    Optional overrides As Object = Nothing)"
ts.WriteLine "    ' Read mapping"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    mappings = ReadMappingSheet(qprWb)"
ts.WriteLine "    If mappings(0).Tab = """" Then"
ts.WriteLine "        If silent Then"
ts.WriteLine "            outResult = ""SKIP: No Mapping sheet found"""
ts.WriteLine "        Else"
ts.WriteLine "            MsgBox ""No Mapping sheet found in QPR workbook."", vbExclamation"
ts.WriteLine "        End If"
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim prevCalc As Long"
ts.WriteLine "    prevCalc = Application.Calculation"
ts.WriteLine "    Application.Calculation = xlCalculationManual"
ts.WriteLine ""
ts.WriteLine "    ' Parse statement date"
ts.WriteLine "    Dim dateInfo As Variant"
ts.WriteLine "    dateInfo = ParseStatementPeriod(ext.Summary.StatementPeriod)"
ts.WriteLine "    If IsNull(dateInfo) Then"
ts.WriteLine "        Application.Calculation = prevCalc"
ts.WriteLine "        If silent Then"
ts.WriteLine "            outResult = ""SKIP: Could not parse period: "" & ext.Summary.StatementPeriod"
ts.WriteLine "        Else"
ts.WriteLine "            MsgBox ""Could not parse statement period: "" & ext.Summary.StatementPeriod, vbExclamation"
ts.WriteLine "        End If"
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim targetMonth As Long: targetMonth = dateInfo(0)"
ts.WriteLine "    Dim targetYear As Long: targetYear = dateInfo(1)"
ts.WriteLine "    Dim daysInMonth As Long: daysInMonth = dateInfo(2)"
ts.WriteLine ""
ts.WriteLine "    ' Read asset class mapping from Master sheet"
ts.WriteLine "    Dim assetClassMap As Object"
ts.WriteLine "    Set assetClassMap = ReadMasterAssetClasses(qprWb)"
ts.WriteLine ""
ts.WriteLine "    ' Build cash symbols"
ts.WriteLine "    Dim cashSymbols As Object"
ts.WriteLine "    Set cashSymbols = BuildCashSymbols(ext)"
ts.WriteLine ""
ts.WriteLine "    ' Validate Holdings specs against known asset classes"
ts.WriteLine "    Dim vmi As Long"
ts.WriteLine "    Dim vSpec As String"
ts.WriteLine "    Dim specWarnings As String"
ts.WriteLine "    specWarnings = """""
ts.WriteLine "    ' Validate Allocation column against Master sheet asset classes"
ts.WriteLine "    For vmi = 0 To UBound(mappings)"
ts.WriteLine "        If mappings(vmi).Tab = """" Then GoTo NextValidateAlloc"
ts.WriteLine "        Dim vAlloc As String"
ts.WriteLine "        vAlloc = Trim$(mappings(vmi).Allocation)"
ts.WriteLine "        If vAlloc = """" Then GoTo NextValidateAlloc"
ts.WriteLine "        If Not assetClassMap.Exists(LCase$(vAlloc)) Then"
ts.WriteLine "            specWarnings = specWarnings & ""Allocation '"" & vAlloc & ""' on tab '"" & _"
ts.WriteLine "                mappings(vmi).Tab & ""' (account "" & mappings(vmi).Account & _"
ts.WriteLine "                "") does not match any asset class in the Master sheet"" & vbCrLf"
ts.WriteLine "        End If"
ts.WriteLine "NextValidateAlloc:"
ts.WriteLine "    Next vmi"
ts.WriteLine ""
ts.WriteLine "    ' Backup QPR workbook before writing (once per path per session)"
ts.WriteLine "    Dim qprPath As String"
ts.WriteLine "    Dim backupPath As String"
ts.WriteLine "    Dim dotPos As Long"
ts.WriteLine "    Dim baseName As String"
ts.WriteLine "    Dim ext2 As String"
ts.WriteLine "    qprPath = qprWb.FullName"
ts.WriteLine "    If mBackedUpPaths Is Nothing Then Set mBackedUpPaths = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    If Not mBackedUpPaths.Exists(qprPath) Then"
ts.WriteLine "        dotPos = InStrRev(qprPath, ""."")"
ts.WriteLine "        If dotPos > 0 Then"
ts.WriteLine "            baseName = Left$(qprPath, dotPos - 1)"
ts.WriteLine "            ext2 = Mid$(qprPath, dotPos)"
ts.WriteLine "        Else"
ts.WriteLine "            baseName = qprPath"
ts.WriteLine "            ext2 = """""
ts.WriteLine "        End If"
ts.WriteLine "        backupPath = baseName & ""_backup_"" & Format$(Now, ""yyyymmdd\_hhmmss"") & ext2"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        qprWb.SaveCopyAs backupPath"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "        ' Verify backup exists and has non-zero size before proceeding"
ts.WriteLine "        If Dir(backupPath) = """" Then"
ts.WriteLine "            Err.Raise vbObjectError + 20, ""QPRWriter"", _"
ts.WriteLine "                ""QPR backup failed -- backup file was not created at: "" & backupPath"
ts.WriteLine "        ElseIf FileLen(backupPath) = 0 Then"
ts.WriteLine "            Err.Raise vbObjectError + 21, ""QPRWriter"", _"
ts.WriteLine "                ""QPR backup failed -- backup file is empty at: "" & backupPath"
ts.WriteLine "        End If"
ts.WriteLine "        mBackedUpPaths(qprPath) = True"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Group mappings by tab and check if this account has any mapping rows"
ts.WriteLine "    Dim tabGroups As Object"
ts.WriteLine "    Set tabGroups = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    Dim mi As Long"
ts.WriteLine "    Dim hasAccountMapping As Boolean"
ts.WriteLine "    hasAccountMapping = False"
ts.WriteLine "    For mi = 0 To UBound(mappings)"
ts.WriteLine "        If mappings(mi).Tab = """" Then GoTo NextMapping"
ts.WriteLine "        If mappings(mi).Account = ext.Summary.AccountNumber Then hasAccountMapping = True"
ts.WriteLine "        Dim tabKey As String"
ts.WriteLine "        tabKey = mappings(mi).Tab"
ts.WriteLine "        If Not tabGroups.Exists(tabKey) Then"
ts.WriteLine "            tabGroups(tabKey) = mi & """"  ' Store indices as comma-separated string"
ts.WriteLine "        Else"
ts.WriteLine "            tabGroups(tabKey) = tabGroups(tabKey) & "","" & mi"
ts.WriteLine "        End If"
ts.WriteLine "NextMapping:"
ts.WriteLine "    Next mi"
ts.WriteLine ""
ts.WriteLine "    If Not hasAccountMapping Then"
ts.WriteLine "        Application.Calculation = prevCalc"
ts.WriteLine "        If silent Then"
ts.WriteLine "            outResult = ext.Summary.AccountNumber & "": SKIP: No mapping rows found for this account"""
ts.WriteLine "        Else"
ts.WriteLine "            MsgBox ""No mapping rows found for account "" & ext.Summary.AccountNumber, vbExclamation"
ts.WriteLine "        End If"
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Process each tab"
ts.WriteLine "    Dim updateCount As Long"
ts.WriteLine "    updateCount = 0"
ts.WriteLine "    Dim warningMsg As String"
ts.WriteLine ""
ts.WriteLine "    ' Init overwrite tracker (persists across WriteQPR calls within a batch)"
ts.WriteLine "    If mOverwriteChecked Is Nothing Then Set mOverwriteChecked = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim tabName As Variant"
ts.WriteLine "    For Each tabName In tabGroups.Keys"
ts.WriteLine "        ' Find month row"
ts.WriteLine "        Dim monthRow As Long"
ts.WriteLine "        monthRow = FindMonthRow(qprWb, CStr(tabName), targetMonth, targetYear)"
ts.WriteLine "        If monthRow = 0 Then"
ts.WriteLine "            warningMsg = warningMsg & ""Could not find month row in sheet '"" & tabName & ""'"" & vbCrLf"
ts.WriteLine "            GoTo NextTab"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Check if this row already has data (once per QPR/tab/row, not per account)"
ts.WriteLine "        Dim overwriteKey As String"
ts.WriteLine "        overwriteKey = qprWb.FullName & ""|"" & CStr(tabName) & ""|"" & monthRow"
ts.WriteLine "        If Not mOverwriteChecked.Exists(overwriteKey) Then"
ts.WriteLine "            mOverwriteChecked(overwriteKey) = True"
ts.WriteLine "            Dim chkWs As Worksheet"
ts.WriteLine "            Set chkWs = Nothing"
ts.WriteLine "            On Error Resume Next"
ts.WriteLine "            Set chkWs = qprWb.Worksheets(CStr(tabName))"
ts.WriteLine "            On Error GoTo 0"
ts.WriteLine "            If Not chkWs Is Nothing Then"
ts.WriteLine "                Dim existingVal As Double"
ts.WriteLine "                existingVal = 0#"
ts.WriteLine "                If IsNumeric(chkWs.Range(""B"" & monthRow).Value) Then"
ts.WriteLine "                    existingVal = CDbl(chkWs.Range(""B"" & monthRow).Value)"
ts.WriteLine "                End If"
ts.WriteLine "                If existingVal <> 0 Then"
ts.WriteLine "                    warningMsg = warningMsg & ""Row for "" & MonthName(targetMonth) & "" "" & _"
ts.WriteLine "                        targetYear & "" already has data ($"" & Format$(existingVal, ""#,##0.00"") & _"
ts.WriteLine "                        "" in "" & CStr(tabName) & ""!B"" & monthRow & ""). Overwriting."" & vbCrLf"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Process mapping rows for this tab"
ts.WriteLine "        Dim indices() As String"
ts.WriteLine "        indices = Split(tabGroups(tabName), "","")"
ts.WriteLine ""
ts.WriteLine "        Dim totalValue As Double: totalValue = 0#"
ts.WriteLine "        Dim totalColC As Double: totalColC = 0#"
ts.WriteLine "        Dim totalColD As Double: totalColD = 0#"
ts.WriteLine "        Dim totalFees As Double: totalFees = 0#"
ts.WriteLine "        Dim feesAccountDone As Object"
ts.WriteLine "        Set feesAccountDone = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "        ' Allocation values: Dict of lowercase class name -> total value"
ts.WriteLine "        Dim allocValues As Object"
ts.WriteLine "        Set allocValues = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "        Dim matched As Boolean: matched = False"
ts.WriteLine ""
ts.WriteLine "        Dim ii As Long"
ts.WriteLine "        For ii = LBound(indices) To UBound(indices)"
ts.WriteLine "            Dim rowIdx As Long"
ts.WriteLine "            rowIdx = CLng(indices(ii))"
ts.WriteLine "            Dim row As MappingRow"
ts.WriteLine "            row = mappings(rowIdx)"
ts.WriteLine ""
ts.WriteLine "            ' Check account matches"
ts.WriteLine "            If row.Account <> ext.Summary.AccountNumber Then GoTo NextRow"
ts.WriteLine ""
ts.WriteLine "            matched = True"
ts.WriteLine ""
ts.WriteLine "            ' Holdings value"
ts.WriteLine "            Dim holdValue As Double"
ts.WriteLine "            holdValue = ResolveHoldingsValue(ext, row.Holdings)"
ts.WriteLine "            totalValue = totalValue + holdValue * row.Pct"
ts.WriteLine ""
ts.WriteLine "            ' Transaction resolution"
ts.WriteLine "            Dim ctx As TabContext"
ts.WriteLine "            ctx = BuildRowContext(row, ext, cashSymbols)"
ts.WriteLine "            Dim rowColC As Double, rowColD As Double, rowFees As Double"
ts.WriteLine "            ResolveTransactions ext, row.Holdings, ctx, daysInMonth, rowColC, rowColD, rowFees"
ts.WriteLine "            totalColC = totalColC + rowColC * row.Pct"
ts.WriteLine "            totalColD = totalColD + rowColD * row.Pct"
ts.WriteLine ""
ts.WriteLine "            ' Only count fees once per account"
ts.WriteLine "            If Not feesAccountDone.Exists(row.Account) Then"
ts.WriteLine "                totalFees = totalFees + rowFees"
ts.WriteLine "                feesAccountDone(row.Account) = True"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            ' Allocation"
ts.WriteLine "            If row.Allocation <> """" Then"
ts.WriteLine "                Dim allocKey As String"
ts.WriteLine "                allocKey = LCase$(row.Allocation)"
ts.WriteLine "                If Not allocValues.Exists(allocKey) Then allocValues(allocKey) = 0#"
ts.WriteLine "                allocValues(allocKey) = allocValues(allocKey) + holdValue * row.Pct"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            ' Classification overrides: add securities to allocation buckets"
ts.WriteLine "            If Not overrides Is Nothing Then"
ts.WriteLine "                Dim si As Long"
ts.WriteLine "                Dim hi As Long"
ts.WriteLine "                For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "                    For si = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                        Dim sec As UBSExtract.SecurityDetail"
ts.WriteLine "                        sec = ext.Holdings(hi).Securities(si)"
ts.WriteLine "                        Dim overKey As String"
ts.WriteLine "                        overKey = UCase$(sec.Symbol) & ""|"" & ext.Summary.AccountNumber"
ts.WriteLine "                        If sec.Symbol <> """" And overrides.Exists(overKey) Then"
ts.WriteLine "                            Dim overClass As String"
ts.WriteLine "                            overClass = LCase$(CStr(overrides(overKey)))"
ts.WriteLine "                            If Not allocValues.Exists(overClass) Then allocValues(overClass) = 0#"
ts.WriteLine "                            allocValues(overClass) = allocValues(overClass) + sec.Value * row.Pct"
ts.WriteLine "                        End If"
ts.WriteLine "                    Next si"
ts.WriteLine "                Next hi"
ts.WriteLine "            End If"
ts.WriteLine "NextRow:"
ts.WriteLine "        Next ii"
ts.WriteLine ""
ts.WriteLine "        ' Skip this tab if no mapping rows matched the current account"
ts.WriteLine "        If Not matched Then GoTo NextTab"
ts.WriteLine ""
ts.WriteLine "        ' Write to cells"
ts.WriteLine "        Dim ws As Worksheet"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        Set ws = qprWb.Worksheets(CStr(tabName))"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "        If ws Is Nothing Then"
ts.WriteLine "            warningMsg = warningMsg & ""Sheet '"" & tabName & ""' not found"" & vbCrLf"
ts.WriteLine "            GoTo NextTab"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' B column: month-end value"
ts.WriteLine "        ws.Range(""B"" & monthRow).Value = Round(totalValue, 2)"
ts.WriteLine "        updateCount = updateCount + 1"
ts.WriteLine ""
ts.WriteLine "        ' C column: time-weighted cash flows"
ts.WriteLine "        If Round(totalColC, 2) <> 0 Then"
ts.WriteLine "            ws.Range(""C"" & monthRow).Value = Round(totalColC, 2)"
ts.WriteLine "            updateCount = updateCount + 1"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' D column: time-weighted cash flows"
ts.WriteLine "        If Round(totalColD, 2) <> 0 Then"
ts.WriteLine "            ws.Range(""D"" & monthRow).Value = Round(totalColD, 2)"
ts.WriteLine "            updateCount = updateCount + 1"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' H23: advisory fees (always write, even if 0)"
ts.WriteLine "        ws.Range(""H23"").Value = Round(totalFees, 2)"
ts.WriteLine "        updateCount = updateCount + 1"
ts.WriteLine ""
ts.WriteLine "        ' Allocation columns"
ts.WriteLine "        Dim allocName As Variant"
ts.WriteLine "        For Each allocName In allocValues.Keys"
ts.WriteLine "            If assetClassMap.Exists(allocName) Then"
ts.WriteLine "                Dim allocCol As String"
ts.WriteLine "                allocCol = assetClassMap(allocName)"
ts.WriteLine "                Dim allocAmt As Double"
ts.WriteLine "                allocAmt = Round(CDbl(allocValues(allocName)), 2)"
ts.WriteLine "                If allocAmt <> 0 Then"
ts.WriteLine "                    ws.Range(allocCol & monthRow).Value = allocAmt"
ts.WriteLine "                    updateCount = updateCount + 1"
ts.WriteLine "                End If"
ts.WriteLine "            Else"
ts.WriteLine "                warningMsg = warningMsg & ""Unknown asset class '"" & allocName & ""' in tab '"" & tabName & ""'"" & vbCrLf"
ts.WriteLine "            End If"
ts.WriteLine "        Next allocName"
ts.WriteLine ""
ts.WriteLine "NextTab:"
ts.WriteLine "    Next tabName"
ts.WriteLine ""
ts.WriteLine "    ' Post-write validation: check allocation sum vs closing value per tab"
ts.WriteLine "    Dim valTabName As Variant"
ts.WriteLine "    Dim valWs As Worksheet"
ts.WriteLine "    Dim valMonthRow As Long"
ts.WriteLine "    Dim valClosing As Double"
ts.WriteLine "    Dim valAllocSum As Double"
ts.WriteLine "    Dim valAllocCol As String"
ts.WriteLine "    Dim valAllocClass As Variant"
ts.WriteLine "    Dim valCellVal As Double"
ts.WriteLine ""
ts.WriteLine "    ' Re-iterate tabs to validate written values"
ts.WriteLine "    For Each valTabName In tabGroups.Keys"
ts.WriteLine "        valMonthRow = FindMonthRow(qprWb, CStr(valTabName), targetMonth, targetYear)"
ts.WriteLine "        If valMonthRow = 0 Then GoTo NextValTab"
ts.WriteLine ""
ts.WriteLine "        Set valWs = Nothing"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        Set valWs = qprWb.Worksheets(CStr(valTabName))"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "        If valWs Is Nothing Then GoTo NextValTab"
ts.WriteLine ""
ts.WriteLine "        ' Read back closing value from B column"
ts.WriteLine "        valClosing = 0#"
ts.WriteLine "        If IsNumeric(valWs.Range(""B"" & valMonthRow).Value) Then"
ts.WriteLine "            valClosing = CDbl(valWs.Range(""B"" & valMonthRow).Value)"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Sum allocation columns"
ts.WriteLine "        valAllocSum = 0#"
ts.WriteLine "        For Each valAllocClass In assetClassMap.Keys"
ts.WriteLine "            valAllocCol = CStr(assetClassMap(valAllocClass))"
ts.WriteLine "            valCellVal = 0#"
ts.WriteLine "            If IsNumeric(valWs.Range(valAllocCol & valMonthRow).Value) Then"
ts.WriteLine "                valCellVal = CDbl(valWs.Range(valAllocCol & valMonthRow).Value)"
ts.WriteLine "            End If"
ts.WriteLine "            valAllocSum = valAllocSum + valCellVal"
ts.WriteLine "        Next valAllocClass"
ts.WriteLine ""
ts.WriteLine "        ' Check if allocation sum is close to closing value (within $1)"
ts.WriteLine "        If valAllocSum > 0 And Abs(valAllocSum - valClosing) > 1 Then"
ts.WriteLine "            warningMsg = warningMsg & ""[VALIDATION: allocation sum $"" & _"
ts.WriteLine "                Format$(valAllocSum, ""#,##0.00"") & "" != closing $"" & _"
ts.WriteLine "                Format$(valClosing, ""#,##0.00"") & "" for tab "" & CStr(valTabName) & ""]"" & vbCrLf"
ts.WriteLine "        End If"
ts.WriteLine "NextValTab:"
ts.WriteLine "    Next valTabName"
ts.WriteLine ""
ts.WriteLine "    Application.Calculation = prevCalc"
ts.WriteLine ""
ts.WriteLine "    ' Build result message -- warnings ALWAYS go to outResult"
ts.WriteLine "    Dim resultMsg As String"
ts.WriteLine "    ' Prepend spec warnings to warningMsg"
ts.WriteLine "    If specWarnings <> """" Then warningMsg = specWarnings & warningMsg"
ts.WriteLine ""
ts.WriteLine "    resultMsg = ext.Summary.AccountNumber & "": "" & updateCount & "" cells written"""
ts.WriteLine "    If warningMsg <> """" Then"
ts.WriteLine "        resultMsg = resultMsg & "" [WARNING: "" & Replace(Replace(warningMsg, vbCrLf, ""; ""), ""; ; "", ""; "") & ""]"""
ts.WriteLine "    End If"
ts.WriteLine "    outResult = resultMsg"
ts.WriteLine "    If Not silent Then"
ts.WriteLine "        MsgBox ""QPR updated: "" & updateCount & "" cells written."" & _"
ts.WriteLine "               IIf(warningMsg <> """", vbCrLf & vbCrLf & ""Warnings:"" & vbCrLf & warningMsg, """"), _"
ts.WriteLine "               vbInformation, ""QPR Writer"""
ts.WriteLine "    End If"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' NOTE: WriteQPRMulti was removed because VBA cannot store UDTs in a Dictionary."
ts.WriteLine "' For multi-account processing, use BatchExtractToQPR (calls WriteQPR per file)."
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Unclassified securities detection"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "' Activities that indicate security-level transactions (for unclassified detection)"
ts.WriteLine "Public Function IsSecurityTxActivity(act As String) As Boolean"
ts.WriteLine "    Select Case act"
ts.WriteLine "        Case ""Sale"", ""Purchase"", ""Reinvestment"", ""Dividend"", ""Distribution"", _"
ts.WriteLine "             ""St Cap Gain"", ""Lt Cap Gain"", ""Receive Dtc"", ""Deliver Dtc"", _"
ts.WriteLine "             ""Call Redemption"", ""Cash In Lieu"""
ts.WriteLine "            IsSecurityTxActivity = True"
ts.WriteLine "        Case Else"
ts.WriteLine "            IsSecurityTxActivity = False"
ts.WriteLine "    End Select"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' Find securities in the portfolio that aren't covered by any QPR mapping row."
ts.WriteLine "' Returns count of unclassified securities; populates securities() array."
ts.WriteLine "Public Function FindUnclassifiedSecurities( _"
ts.WriteLine "    portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    qprWb As Workbook, _"
ts.WriteLine "    ByRef securities() As UnclassifiedSecurity _"
ts.WriteLine ") As Long"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    Dim mapCount As Long"
ts.WriteLine "    Dim count As Long"
ts.WriteLine "    Dim seen As Object"
ts.WriteLine "    Dim acctRows As Object"
ts.WriteLine "    Dim mi As Long"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine "    Dim ti As Long"
ts.WriteLine "    Dim si As Long"
ts.WriteLine "    Dim hi As Long"
ts.WriteLine "    Dim ext As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim acctNum As String"
ts.WriteLine "    Dim rowIndices() As String"
ts.WriteLine "    Dim hasAll As Boolean"
ts.WriteLine "    Dim coveredSpecs As Object"
ts.WriteLine "    Dim cashSyms As Object"
ts.WriteLine "    Dim unmatchedAmounts As Object"
ts.WriteLine "    Dim unmatchedDescs As Object"
ts.WriteLine "    Dim unmatchedSymbols As Object"
ts.WriteLine "    Dim txKey As String"
ts.WriteLine "    Dim dedupeKey As String"
ts.WriteLine "    Dim holdingSecIds As Object"
ts.WriteLine "    Dim tx As UBSExtract.Transaction"
ts.WriteLine "    Dim netAmt As Double"
ts.WriteLine "    Dim inHoldings As Boolean"
ts.WriteLine "    Dim key As Variant"
ts.WriteLine "    Dim rowIdx As Long"
ts.WriteLine "    Dim row As MappingRow"
ts.WriteLine "    Dim spec As String"
ts.WriteLine "    ' Variables for holdings pass (Item 1.4)"
ts.WriteLine "    Dim holdIdx As Long"
ts.WriteLine "    Dim secIdx As Long"
ts.WriteLine "    Dim holdSec As UBSExtract.SecurityDetail"
ts.WriteLine "    Dim holdSymKey As String"
ts.WriteLine "    Dim holdDedupeKey As String"
ts.WriteLine "    Dim holdDesc As String"
ts.WriteLine "    Dim groupHasAnyCoverage As Boolean"
ts.WriteLine "    Dim unmappedSecIds As Object  ' Securities from entirely unmapped holding groups"
ts.WriteLine "    Dim cashKey2 As Variant"
ts.WriteLine "    Dim isCashSec As Boolean"
ts.WriteLine ""
ts.WriteLine "    count = 0"
ts.WriteLine "    ReDim securities(1 To 1)"
ts.WriteLine "    Set seen = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    ' Read mapping"
ts.WriteLine "    mappings = ReadMappingSheet(qprWb)"
ts.WriteLine "    If mappings(0).Tab = """" Then"
ts.WriteLine "        FindUnclassifiedSecurities = 0"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Find actual mapping count"
ts.WriteLine "    mapCount = UBound(mappings)"
ts.WriteLine "    If mappings(0).Tab = """" And mapCount = 0 Then"
ts.WriteLine "        FindUnclassifiedSecurities = 0"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Group mapping rows by account number"
ts.WriteLine "    Set acctRows = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    For mi = 0 To mapCount"
ts.WriteLine "        If mappings(mi).Tab = """" Then GoTo NextMapIdx"
ts.WriteLine "        Dim acctKey As String"
ts.WriteLine "        acctKey = mappings(mi).Account"
ts.WriteLine "        If Not acctRows.Exists(acctKey) Then"
ts.WriteLine "            acctRows(acctKey) = CStr(mi)"
ts.WriteLine "        Else"
ts.WriteLine "            acctRows(acctKey) = acctRows(acctKey) & "","" & CStr(mi)"
ts.WriteLine "        End If"
ts.WriteLine "NextMapIdx:"
ts.WriteLine "    Next mi"
ts.WriteLine ""
ts.WriteLine "    ' Process each account in portfolio"
ts.WriteLine "    For ai = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        acctNum = portfolio.Accounts(ai).AccountNumber"
ts.WriteLine "        ext = portfolio.Accounts(ai).Extraction"
ts.WriteLine ""
ts.WriteLine "        If Not acctRows.Exists(acctNum) Then GoTo NextAcct"
ts.WriteLine ""
ts.WriteLine "        ' Parse row indices for this account"
ts.WriteLine "        rowIndices = Split(acctRows(acctNum), "","")"
ts.WriteLine ""
ts.WriteLine "        ' Check if any row has ""all"" holdings"
ts.WriteLine "        hasAll = False"
ts.WriteLine "        For si = LBound(rowIndices) To UBound(rowIndices)"
ts.WriteLine "            rowIdx = CLng(rowIndices(si))"
ts.WriteLine "            If LCase$(Trim$(mappings(rowIdx).Holdings)) = ""all"" Then"
ts.WriteLine "                hasAll = True"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next si"
ts.WriteLine "        If hasAll Then GoTo NextAcct"
ts.WriteLine ""
ts.WriteLine "        ' Build union of covered specs (uppercase) and cash symbols"
ts.WriteLine "        Set coveredSpecs = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "        Set cashSyms = BuildCashSymbols(ext)"
ts.WriteLine ""
ts.WriteLine "        ' Add cash symbols to covered"
ts.WriteLine "        For Each key In cashSyms.Keys"
ts.WriteLine "            coveredSpecs(CStr(key)) = True"
ts.WriteLine "        Next key"
ts.WriteLine ""
ts.WriteLine "        For si = LBound(rowIndices) To UBound(rowIndices)"
ts.WriteLine "            rowIdx = CLng(rowIndices(si))"
ts.WriteLine "            row = mappings(rowIdx)"
ts.WriteLine "            spec = LCase$(Trim$(row.Holdings))"
ts.WriteLine ""
ts.WriteLine "            If spec = ""cash"" Then"
ts.WriteLine "                ' Cash symbols already added"
ts.WriteLine "            ElseIf IsAssetClassName(spec) Then"
ts.WriteLine "                ' Add securities from matching asset class holdings"
ts.WriteLine "                For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "                    If ext.Holdings(hi).AssetType <> """" Then"
ts.WriteLine "                        If NormalizeAssetClass(ext.Holdings(hi).AssetType) = NormalizeAssetClass(spec) Then"
ts.WriteLine "                            coveredSpecs(UCase$(ext.Holdings(hi).name)) = True"
ts.WriteLine "                            ' Also add individual security symbols/names"
ts.WriteLine "                            Dim sci As Long"
ts.WriteLine "                            For sci = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                                If ext.Holdings(hi).Securities(sci).Symbol <> """" Then"
ts.WriteLine "                                    coveredSpecs(UCase$(ext.Holdings(hi).Securities(sci).Symbol)) = True"
ts.WriteLine "                                End If"
ts.WriteLine "                                If ext.Holdings(hi).Securities(sci).name <> """" Then"
ts.WriteLine "                                    coveredSpecs(UCase$(ext.Holdings(hi).Securities(sci).name)) = True"
ts.WriteLine "                                End If"
ts.WriteLine "                            Next sci"
ts.WriteLine "                        End If"
ts.WriteLine "                    End If"
ts.WriteLine "                Next hi"
ts.WriteLine "            Else"
ts.WriteLine "                ' Symbol list"
ts.WriteLine "                Dim parts() As String"
ts.WriteLine "                parts = Split(row.Holdings, "","")"
ts.WriteLine "                Dim pi As Long"
ts.WriteLine "                For pi = LBound(parts) To UBound(parts)"
ts.WriteLine "                    Dim trimSpec As String"
ts.WriteLine "                    trimSpec = UCase$(Trim$(parts(pi)))"
ts.WriteLine "                    If trimSpec <> """" Then coveredSpecs(trimSpec) = True"
ts.WriteLine "                Next pi"
ts.WriteLine "            End If"
ts.WriteLine "        Next si"
ts.WriteLine ""
ts.WriteLine "        ' Build set of current holding security IDs (for departed detection)"
ts.WriteLine "        Set holdingSecIds = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "        For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "            For sci = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                If ext.Holdings(hi).Securities(sci).Symbol <> """" Then"
ts.WriteLine "                    holdingSecIds(UCase$(ext.Holdings(hi).Securities(sci).Symbol)) = True"
ts.WriteLine "                End If"
ts.WriteLine "                If ext.Holdings(hi).Securities(sci).name <> """" Then"
ts.WriteLine "                    holdingSecIds(UCase$(ext.Holdings(hi).Securities(sci).name)) = True"
ts.WriteLine "                End If"
ts.WriteLine "            Next sci"
ts.WriteLine "        Next hi"
ts.WriteLine ""
ts.WriteLine "        ' Build set of security IDs from entirely unmapped holding groups."
ts.WriteLine "        ' Transactions involving these should not be flagged as unclassified"
ts.WriteLine "        ' (the holding group is intentionally excluded from QPR mappings)."
ts.WriteLine "        Set unmappedSecIds = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "        For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "            If IsMoneyMarketHolding(ext.Holdings(hi).name) Then GoTo NextUnmappedGroup"
ts.WriteLine "            groupHasAnyCoverage = False"
ts.WriteLine "            If coveredSpecs.Exists(UCase$(ext.Holdings(hi).name)) Then"
ts.WriteLine "                groupHasAnyCoverage = True"
ts.WriteLine "            Else"
ts.WriteLine "                For sci = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                    If ext.Holdings(hi).Securities(sci).Symbol <> """" Then"
ts.WriteLine "                        If coveredSpecs.Exists(UCase$(ext.Holdings(hi).Securities(sci).Symbol)) Then"
ts.WriteLine "                            groupHasAnyCoverage = True"
ts.WriteLine "                            Exit For"
ts.WriteLine "                        End If"
ts.WriteLine "                    End If"
ts.WriteLine "                    If ext.Holdings(hi).Securities(sci).name <> """" Then"
ts.WriteLine "                        If coveredSpecs.Exists(UCase$(ext.Holdings(hi).Securities(sci).name)) Then"
ts.WriteLine "                            groupHasAnyCoverage = True"
ts.WriteLine "                            Exit For"
ts.WriteLine "                        End If"
ts.WriteLine "                    End If"
ts.WriteLine "                Next sci"
ts.WriteLine "            End If"
ts.WriteLine "            If Not groupHasAnyCoverage Then"
ts.WriteLine "                ' Add all securities from this unmapped group"
ts.WriteLine "                unmappedSecIds(UCase$(ext.Holdings(hi).name)) = True"
ts.WriteLine "                For sci = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                    If ext.Holdings(hi).Securities(sci).Symbol <> """" Then"
ts.WriteLine "                        unmappedSecIds(UCase$(ext.Holdings(hi).Securities(sci).Symbol)) = True"
ts.WriteLine "                    End If"
ts.WriteLine "                    If ext.Holdings(hi).Securities(sci).name <> """" Then"
ts.WriteLine "                        unmappedSecIds(UCase$(ext.Holdings(hi).Securities(sci).name)) = True"
ts.WriteLine "                    End If"
ts.WriteLine "                Next sci"
ts.WriteLine "            End If"
ts.WriteLine "NextUnmappedGroup:"
ts.WriteLine "        Next hi"
ts.WriteLine ""
ts.WriteLine "        ' Scan transactions for unmatched security activities"
ts.WriteLine "        Set unmatchedAmounts = CreateObject(""Scripting.Dictionary"")  ' dedupeKey -> net amount"
ts.WriteLine "        Set unmatchedDescs = CreateObject(""Scripting.Dictionary"")    ' dedupeKey -> description"
ts.WriteLine "        Set unmatchedSymbols = CreateObject(""Scripting.Dictionary"")  ' dedupeKey -> symbol"
ts.WriteLine ""
ts.WriteLine "        For ti = 0 To ext.TransactionCount - 1"
ts.WriteLine "            tx = ext.Transactions(ti)"
ts.WriteLine "            If Not IsSecurityTxActivity(tx.Activity) Then GoTo NextTx2"
ts.WriteLine ""
ts.WriteLine "            ' Skip cash securities"
ts.WriteLine "            If IsCashSecurityTx(tx, cashSyms) Then GoTo NextTx2"
ts.WriteLine ""
ts.WriteLine "            ' Skip covered specs"
ts.WriteLine "            If MatchesCoveredSpecs(tx, coveredSpecs) Then GoTo NextTx2"
ts.WriteLine ""
ts.WriteLine "            ' Skip securities from entirely unmapped holding groups"
ts.WriteLine "            If tx.Symbol <> """" And unmappedSecIds.Exists(UCase$(tx.Symbol)) Then GoTo NextTx2"
ts.WriteLine "            If MatchesUnmappedGroup(tx, unmappedSecIds) Then GoTo NextTx2"
ts.WriteLine ""
ts.WriteLine "            ' Build key"
ts.WriteLine "            If tx.Symbol <> """" Then"
ts.WriteLine "                txKey = UCase$(tx.Symbol)"
ts.WriteLine "            Else"
ts.WriteLine "                txKey = UCase$(Replace(tx.Description, "" "", """"))"
ts.WriteLine "            End If"
ts.WriteLine "            dedupeKey = acctNum & "":"" & txKey"
ts.WriteLine ""
ts.WriteLine "            ' Accumulate amount"
ts.WriteLine "            If Not unmatchedAmounts.Exists(dedupeKey) Then"
ts.WriteLine "                unmatchedAmounts(dedupeKey) = tx.Amount"
ts.WriteLine "                unmatchedDescs(dedupeKey) = tx.Description"
ts.WriteLine "                unmatchedSymbols(dedupeKey) = IIf(tx.Symbol <> """", UCase$(tx.Symbol), """")"
ts.WriteLine "            Else"
ts.WriteLine "                unmatchedAmounts(dedupeKey) = CDbl(unmatchedAmounts(dedupeKey)) + tx.Amount"
ts.WriteLine "            End If"
ts.WriteLine "NextTx2:"
ts.WriteLine "        Next ti"
ts.WriteLine ""
ts.WriteLine "        ' Flag unmatched securities with net amount >= $0.01"
ts.WriteLine "        For Each key In unmatchedAmounts.Keys"
ts.WriteLine "            dedupeKey = CStr(key)"
ts.WriteLine "            If seen.Exists(dedupeKey) Then GoTo NextUnmatched"
ts.WriteLine ""
ts.WriteLine "            netAmt = CDbl(unmatchedAmounts(dedupeKey))"
ts.WriteLine "            If Abs(netAmt) < 0.01 Then GoTo NextUnmatched"
ts.WriteLine ""
ts.WriteLine "            ' Check if departed"
ts.WriteLine "            Dim sym As String"
ts.WriteLine "            sym = CStr(unmatchedSymbols(dedupeKey))"
ts.WriteLine "            inHoldings = False"
ts.WriteLine "            If sym <> """" And holdingSecIds.Exists(sym) Then inHoldings = True"
ts.WriteLine ""
ts.WriteLine "            seen(dedupeKey) = True"
ts.WriteLine "            count = count + 1"
ts.WriteLine "            If count > UBound(securities) Then ReDim Preserve securities(1 To count + 10)"
ts.WriteLine "            securities(count).Symbol = sym"
ts.WriteLine "            securities(count).Description = CStr(unmatchedDescs(dedupeKey))"
ts.WriteLine "            securities(count).AccountNumber = acctNum"
ts.WriteLine "            securities(count).IsDeparted = Not inHoldings"
ts.WriteLine "NextUnmatched:"
ts.WriteLine "        Next key"
ts.WriteLine ""
ts.WriteLine "        ' === Pass 2: Scan holdings for unclassified securities ==="
ts.WriteLine "        For holdIdx = 0 To ext.HoldingCount - 1"
ts.WriteLine "            ' Skip money market holdings (always covered by cash)"
ts.WriteLine "            If IsMoneyMarketHolding(ext.Holdings(holdIdx).name) Then GoTo NextHoldCheck"
ts.WriteLine ""
ts.WriteLine "            ' Skip entirely unmapped holding groups -- these are intentionally"
ts.WriteLine "            ' excluded (shown in ""Unmapped Holdings""), not unclassified."
ts.WriteLine "            ' A group is unmapped if neither its name nor any of its securities"
ts.WriteLine "            ' appear in coveredSpecs."
ts.WriteLine "            groupHasAnyCoverage = False"
ts.WriteLine "            If coveredSpecs.Exists(UCase$(ext.Holdings(holdIdx).name)) Then"
ts.WriteLine "                groupHasAnyCoverage = True"
ts.WriteLine "            Else"
ts.WriteLine "                For secIdx = 0 To ext.Holdings(holdIdx).SecurityCount - 1"
ts.WriteLine "                    If ext.Holdings(holdIdx).Securities(secIdx).Symbol <> """" Then"
ts.WriteLine "                        If coveredSpecs.Exists(UCase$(ext.Holdings(holdIdx).Securities(secIdx).Symbol)) Then"
ts.WriteLine "                            groupHasAnyCoverage = True"
ts.WriteLine "                            Exit For"
ts.WriteLine "                        End If"
ts.WriteLine "                    End If"
ts.WriteLine "                    If ext.Holdings(holdIdx).Securities(secIdx).name <> """" Then"
ts.WriteLine "                        If coveredSpecs.Exists(UCase$(ext.Holdings(holdIdx).Securities(secIdx).name)) Then"
ts.WriteLine "                            groupHasAnyCoverage = True"
ts.WriteLine "                            Exit For"
ts.WriteLine "                        End If"
ts.WriteLine "                    End If"
ts.WriteLine "                Next secIdx"
ts.WriteLine "            End If"
ts.WriteLine "            If Not groupHasAnyCoverage Then GoTo NextHoldCheck"
ts.WriteLine ""
ts.WriteLine "            For secIdx = 0 To ext.Holdings(holdIdx).SecurityCount - 1"
ts.WriteLine "                holdSec = ext.Holdings(holdIdx).Securities(secIdx)"
ts.WriteLine ""
ts.WriteLine "                ' Skip zero-value securities"
ts.WriteLine "                If Abs(holdSec.Value) < 0.01 Then GoTo NextSecCheck"
ts.WriteLine ""
ts.WriteLine "                ' Build key for this security"
ts.WriteLine "                If holdSec.Symbol <> """" Then"
ts.WriteLine "                    holdSymKey = UCase$(holdSec.Symbol)"
ts.WriteLine "                ElseIf holdSec.name <> """" Then"
ts.WriteLine "                    holdSymKey = UCase$(Replace(holdSec.name, "" "", """"))"
ts.WriteLine "                Else"
ts.WriteLine "                    GoTo NextSecCheck"
ts.WriteLine "                End If"
ts.WriteLine ""
ts.WriteLine "                ' Skip if covered by any mapping spec"
ts.WriteLine "                If holdSec.Symbol <> """" And coveredSpecs.Exists(UCase$(holdSec.Symbol)) Then GoTo NextSecCheck"
ts.WriteLine "                If holdSec.name <> """" And coveredSpecs.Exists(UCase$(holdSec.name)) Then GoTo NextSecCheck"
ts.WriteLine ""
ts.WriteLine "                ' Skip cash securities"
ts.WriteLine "                If holdSec.Symbol <> """" And cashSyms.Exists(UCase$(holdSec.Symbol)) Then GoTo NextSecCheck"
ts.WriteLine "                If holdSec.name <> """" Then"
ts.WriteLine "                    isCashSec = False"
ts.WriteLine "                    For Each cashKey2 In cashSyms.Keys"
ts.WriteLine "                        If InStr(1, UCase$(holdSec.name), CStr(cashKey2)) > 0 Then"
ts.WriteLine "                            isCashSec = True"
ts.WriteLine "                            Exit For"
ts.WriteLine "                        End If"
ts.WriteLine "                    Next cashKey2"
ts.WriteLine "                    If isCashSec Then GoTo NextSecCheck"
ts.WriteLine "                End If"
ts.WriteLine ""
ts.WriteLine "                ' Deduplicate against transaction pass"
ts.WriteLine "                holdDedupeKey = acctNum & "":"" & holdSymKey"
ts.WriteLine "                If seen.Exists(holdDedupeKey) Then GoTo NextSecCheck"
ts.WriteLine ""
ts.WriteLine "                ' This holding security is unclassified"
ts.WriteLine "                seen(holdDedupeKey) = True"
ts.WriteLine "                count = count + 1"
ts.WriteLine "                If count > UBound(securities) Then ReDim Preserve securities(1 To count + 10)"
ts.WriteLine "                securities(count).Symbol = IIf(holdSec.Symbol <> """", UCase$(holdSec.Symbol), """")"
ts.WriteLine "                holdDesc = holdSec.name"
ts.WriteLine "                If holdDesc = """" Then holdDesc = holdSec.Symbol"
ts.WriteLine "                securities(count).Description = holdDesc"
ts.WriteLine "                securities(count).AccountNumber = acctNum"
ts.WriteLine "                securities(count).IsDeparted = False"
ts.WriteLine "NextSecCheck:"
ts.WriteLine "            Next secIdx"
ts.WriteLine "NextHoldCheck:"
ts.WriteLine "        Next holdIdx"
ts.WriteLine ""
ts.WriteLine "NextAcct:"
ts.WriteLine "    Next ai"
ts.WriteLine ""
ts.WriteLine "    If count > 0 Then ReDim Preserve securities(1 To count)"
ts.WriteLine "    FindUnclassifiedSecurities = count"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' Helper: check if transaction matches any covered spec"
ts.WriteLine "Private Function MatchesUnmappedGroup(tx As UBSExtract.Transaction, unmappedSecIds As Object) As Boolean"
ts.WriteLine "    If unmappedSecIds.count = 0 Then"
ts.WriteLine "        MatchesUnmappedGroup = False"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine "    If tx.Description = """" Then"
ts.WriteLine "        MatchesUnmappedGroup = False"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine "    Dim descUp As String"
ts.WriteLine "    descUp = UCase$(tx.Description)"
ts.WriteLine "    Dim umKey As Variant"
ts.WriteLine "    For Each umKey In unmappedSecIds.Keys"
ts.WriteLine "        If InStr(1, descUp, CStr(umKey)) > 0 Then"
ts.WriteLine "            MatchesUnmappedGroup = True"
ts.WriteLine "            Exit Function"
ts.WriteLine "        End If"
ts.WriteLine "    Next umKey"
ts.WriteLine "    MatchesUnmappedGroup = False"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function MatchesCoveredSpecs(tx As UBSExtract.Transaction, coveredSpecs As Object) As Boolean"
ts.WriteLine "    If coveredSpecs.count = 0 Then"
ts.WriteLine "        MatchesCoveredSpecs = False"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine "    ' Check symbol directly"
ts.WriteLine "    If tx.Symbol <> """" And coveredSpecs.Exists(UCase$(tx.Symbol)) Then"
ts.WriteLine "        MatchesCoveredSpecs = True"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine "    ' Check description against covered specs"
ts.WriteLine "    Dim descUpper As String"
ts.WriteLine "    descUpper = UCase$(tx.Description)"
ts.WriteLine "    Dim key As Variant"
ts.WriteLine "    For Each key In coveredSpecs.Keys"
ts.WriteLine "        If InStr(1, descUpper, CStr(key)) > 0 Then"
ts.WriteLine "            MatchesCoveredSpecs = True"
ts.WriteLine "            Exit Function"
ts.WriteLine "        End If"
ts.WriteLine "    Next key"
ts.WriteLine "    MatchesCoveredSpecs = False"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' QPR Analysis: Find Uncovered Accounts"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function FindUncoveredAccounts( _"
ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    ByRef qprWb As Workbook, _"
ts.WriteLine "    ByRef accounts() As UncoveredAccount _"
ts.WriteLine ") As Long"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    Dim mappedAccts As Object"
ts.WriteLine "    Dim count As Long"
ts.WriteLine "    Dim mi As Long"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine ""
ts.WriteLine "    count = 0"
ts.WriteLine "    ReDim accounts(0 To 10)"
ts.WriteLine ""
ts.WriteLine "    ' Read mapping and build set of referenced account numbers"
ts.WriteLine "    mappings = ReadMappingSheet(qprWb)"
ts.WriteLine "    Set mappedAccts = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    If mappings(0).Tab <> """" Then"
ts.WriteLine "        For mi = 0 To UBound(mappings)"
ts.WriteLine "            If mappings(mi).Account <> """" Then"
ts.WriteLine "                mappedAccts(mappings(mi).Account) = True"
ts.WriteLine "            End If"
ts.WriteLine "        Next mi"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Check each portfolio account"
ts.WriteLine "    For ai = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        Dim acctNum As String"
ts.WriteLine "        acctNum = portfolio.Accounts(ai).Extraction.Summary.AccountNumber"
ts.WriteLine "        If Not mappedAccts.Exists(acctNum) Then"
ts.WriteLine "            If count > UBound(accounts) Then ReDim Preserve accounts(0 To count + 10)"
ts.WriteLine "            accounts(count).AccountNumber = acctNum"
ts.WriteLine "            accounts(count).AccountName = portfolio.Accounts(ai).Extraction.Summary.AccountName"
ts.WriteLine "            accounts(count).ClosingValue = portfolio.Accounts(ai).Extraction.Summary.ClosingValue"
ts.WriteLine "            count = count + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next ai"
ts.WriteLine ""
ts.WriteLine "    FindUncoveredAccounts = count"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' QPR Analysis: Find Unmapped Holdings"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function FindUnmappedHoldings( _"
ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    ByRef qprWb As Workbook, _"
ts.WriteLine "    ByRef holdings() As UnmappedHolding _"
ts.WriteLine ") As Long"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    Dim acctRows As Object"
ts.WriteLine "    Dim count As Long"
ts.WriteLine "    Dim mi As Long"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine "    Dim hi As Long"
ts.WriteLine "    Dim si As Long"
ts.WriteLine "    Dim ri As Long"
ts.WriteLine "    Dim acctNum As String"
ts.WriteLine "    Dim ext As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim rowIndices() As String"
ts.WriteLine "    Dim rowIdx As Long"
ts.WriteLine "    Dim row As MappingRow"
ts.WriteLine "    Dim hasAll As Boolean"
ts.WriteLine "    Dim hasCashRow As Boolean"
ts.WriteLine "    Dim coveredAssetClasses As Object"
ts.WriteLine "    Dim coveredSpecs As Object"
ts.WriteLine "    Dim spec As String"
ts.WriteLine "    Dim key As Variant"
ts.WriteLine "    Dim parts() As String"
ts.WriteLine "    Dim pi As Long"
ts.WriteLine "    Dim trimSpec As String"
ts.WriteLine "    Dim holdName As String"
ts.WriteLine "    Dim holdAsset As String"
ts.WriteLine "    Dim anyCovered As Boolean"
ts.WriteLine "    Dim secName As String"
ts.WriteLine ""
ts.WriteLine "    count = 0"
ts.WriteLine "    ReDim holdings(0 To 20)"
ts.WriteLine ""
ts.WriteLine "    mappings = ReadMappingSheet(qprWb)"
ts.WriteLine "    If mappings(0).Tab = """" Then"
ts.WriteLine "        FindUnmappedHoldings = 0"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Group mapping rows by account number"
ts.WriteLine "    Set acctRows = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    For mi = 0 To UBound(mappings)"
ts.WriteLine "        If mappings(mi).Tab <> """" Then"
ts.WriteLine "            If Not acctRows.Exists(mappings(mi).Account) Then"
ts.WriteLine "                acctRows(mappings(mi).Account) = CStr(mi)"
ts.WriteLine "            Else"
ts.WriteLine "                acctRows(mappings(mi).Account) = acctRows(mappings(mi).Account) & "","" & CStr(mi)"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    Next mi"
ts.WriteLine ""
ts.WriteLine "    ' Check each portfolio account"
ts.WriteLine "    For ai = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        acctNum = portfolio.Accounts(ai).Extraction.Summary.AccountNumber"
ts.WriteLine "        ext = portfolio.Accounts(ai).Extraction"
ts.WriteLine ""
ts.WriteLine "        If Not acctRows.Exists(acctNum) Then GoTo NextUmAcct"
ts.WriteLine ""
ts.WriteLine "        rowIndices = Split(acctRows(acctNum), "","")"
ts.WriteLine ""
ts.WriteLine "        ' Check if any row has ""all"" or ""cash"""
ts.WriteLine "        hasAll = False"
ts.WriteLine "        hasCashRow = False"
ts.WriteLine "        For ri = LBound(rowIndices) To UBound(rowIndices)"
ts.WriteLine "            rowIdx = CLng(rowIndices(ri))"
ts.WriteLine "            spec = LCase$(Trim$(mappings(rowIdx).Holdings))"
ts.WriteLine "            If spec = ""all"" Then hasAll = True"
ts.WriteLine "            If spec = ""cash"" Then hasCashRow = True"
ts.WriteLine "        Next ri"
ts.WriteLine "        If hasAll Then GoTo NextUmAcct"
ts.WriteLine ""
ts.WriteLine "        ' Build covered asset classes and covered specs (symbols/names)"
ts.WriteLine "        Set coveredAssetClasses = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "        Set coveredSpecs = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "        For ri = LBound(rowIndices) To UBound(rowIndices)"
ts.WriteLine "            rowIdx = CLng(rowIndices(ri))"
ts.WriteLine "            row = mappings(rowIdx)"
ts.WriteLine "            spec = LCase$(Trim$(row.Holdings))"
ts.WriteLine ""
ts.WriteLine "            If spec = ""cash"" Then"
ts.WriteLine "                ' Cash row -- covered via hasCashRow flag"
ts.WriteLine "            ElseIf IsAssetClassName(spec) Then"
ts.WriteLine "                coveredAssetClasses(NormalizeAssetClass(spec)) = True"
ts.WriteLine "                ' Also add individual security symbols/names from this asset class"
ts.WriteLine "                For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "                    If ext.Holdings(hi).AssetType <> """" Then"
ts.WriteLine "                        If NormalizeAssetClass(ext.Holdings(hi).AssetType) = NormalizeAssetClass(spec) Then"
ts.WriteLine "                            coveredSpecs(UCase$(ext.Holdings(hi).name)) = True"
ts.WriteLine "                            For si = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                                If ext.Holdings(hi).Securities(si).Symbol <> """" Then"
ts.WriteLine "                                    coveredSpecs(UCase$(ext.Holdings(hi).Securities(si).Symbol)) = True"
ts.WriteLine "                                End If"
ts.WriteLine "                                If ext.Holdings(hi).Securities(si).name <> """" Then"
ts.WriteLine "                                    coveredSpecs(UCase$(ext.Holdings(hi).Securities(si).name)) = True"
ts.WriteLine "                                End If"
ts.WriteLine "                            Next si"
ts.WriteLine "                        End If"
ts.WriteLine "                    End If"
ts.WriteLine "                Next hi"
ts.WriteLine "            Else"
ts.WriteLine "                ' Symbol list"
ts.WriteLine "                parts = Split(row.Holdings, "","")"
ts.WriteLine "                For pi = LBound(parts) To UBound(parts)"
ts.WriteLine "                    trimSpec = UCase$(Trim$(parts(pi)))"
ts.WriteLine "                    If trimSpec <> """" Then coveredSpecs(trimSpec) = True"
ts.WriteLine "                Next pi"
ts.WriteLine "            End If"
ts.WriteLine "        Next ri"
ts.WriteLine ""
ts.WriteLine "        ' Check each holding for coverage"
ts.WriteLine "        For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "            holdName = ext.Holdings(hi).name"
ts.WriteLine "            holdAsset = ext.Holdings(hi).AssetType"
ts.WriteLine ""
ts.WriteLine "            ' Skip zero-value holdings"
ts.WriteLine "            If Abs(ext.Holdings(hi).Value) < 0.01 Then GoTo NextUmHold"
ts.WriteLine ""
ts.WriteLine "            ' Cash holdings: only skip if there IS a cash row"
ts.WriteLine "            If IsMoneyMarketHolding(holdName) And hasCashRow Then GoTo NextUmHold"
ts.WriteLine ""
ts.WriteLine "            ' Check if asset class is covered"
ts.WriteLine "            If holdAsset <> """" Then"
ts.WriteLine "                If coveredAssetClasses.Exists(NormalizeAssetClass(holdAsset)) Then GoTo NextUmHold"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            ' Check if holding name is covered"
ts.WriteLine "            If coveredSpecs.Exists(UCase$(holdName)) Then GoTo NextUmHold"
ts.WriteLine ""
ts.WriteLine "            ' Check securities"
ts.WriteLine "            anyCovered = False"
ts.WriteLine "            For si = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                If ext.Holdings(hi).Securities(si).Symbol <> """" Then"
ts.WriteLine "                    If coveredSpecs.Exists(UCase$(ext.Holdings(hi).Securities(si).Symbol)) Then"
ts.WriteLine "                        anyCovered = True"
ts.WriteLine "                        Exit For"
ts.WriteLine "                    End If"
ts.WriteLine "                End If"
ts.WriteLine "                If ext.Holdings(hi).Securities(si).name <> """" Then"
ts.WriteLine "                    If coveredSpecs.Exists(UCase$(ext.Holdings(hi).Securities(si).name)) Then"
ts.WriteLine "                        anyCovered = True"
ts.WriteLine "                        Exit For"
ts.WriteLine "                    End If"
ts.WriteLine "                End If"
ts.WriteLine "            Next si"
ts.WriteLine "            If anyCovered Then GoTo NextUmHold"
ts.WriteLine ""
ts.WriteLine "            ' This holding is unmapped -- collect security names"
ts.WriteLine "            If count > UBound(holdings) Then ReDim Preserve holdings(0 To count + 20)"
ts.WriteLine "            holdings(count).AccountNumber = acctNum"
ts.WriteLine "            holdings(count).AssetClass = holdAsset"
ts.WriteLine "            holdings(count).HoldingName = holdName"
ts.WriteLine "            holdings(count).Value = ext.Holdings(hi).Value"
ts.WriteLine "            holdings(count).SecurityNameCount = 0"
ts.WriteLine "            ReDim holdings(count).SecurityNames(0 To ext.Holdings(hi).SecurityCount)"
ts.WriteLine "            For si = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                secName = ext.Holdings(hi).Securities(si).name"
ts.WriteLine "                If secName = """" Then secName = ext.Holdings(hi).Securities(si).Symbol"
ts.WriteLine "                If secName <> """" Then"
ts.WriteLine "                    holdings(count).SecurityNames(holdings(count).SecurityNameCount) = secName"
ts.WriteLine "                    holdings(count).SecurityNameCount = holdings(count).SecurityNameCount + 1"
ts.WriteLine "                End If"
ts.WriteLine "            Next si"
ts.WriteLine "            count = count + 1"
ts.WriteLine "NextUmHold:"
ts.WriteLine "        Next hi"
ts.WriteLine "NextUmAcct:"
ts.WriteLine "    Next ai"
ts.WriteLine ""
ts.WriteLine "    FindUnmappedHoldings = count"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' QPR Analysis: Find Phantom Mappings"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function FindPhantomMappings( _"
ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    ByRef qprWb As Workbook, _"
ts.WriteLine "    ByRef phantoms() As PhantomMapping _"
ts.WriteLine ") As Long"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    Dim count As Long"
ts.WriteLine "    Dim mi As Long"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine "    Dim hi As Long"
ts.WriteLine "    Dim si As Long"
ts.WriteLine "    Dim seen As Object"
ts.WriteLine "    Dim spec As String"
ts.WriteLine "    Dim ext As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim holdingIds As Object"
ts.WriteLine "    Dim foundMatch As Boolean"
ts.WriteLine "    Dim dedupeKey As String"
ts.WriteLine "    Dim parts() As String"
ts.WriteLine "    Dim pi As Long"
ts.WriteLine "    Dim trimmed As String"
ts.WriteLine "    Dim upperSpec As String"
ts.WriteLine "    Dim idKey As Variant"
ts.WriteLine ""
ts.WriteLine "    count = 0"
ts.WriteLine "    ReDim phantoms(0 To 10)"
ts.WriteLine ""
ts.WriteLine "    mappings = ReadMappingSheet(qprWb)"
ts.WriteLine "    If mappings(0).Tab = """" Then"
ts.WriteLine "        FindPhantomMappings = 0"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Build map of account number -> extraction index"
ts.WriteLine "    Dim acctMap As Object"
ts.WriteLine "    Set acctMap = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    For ai = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        acctMap(portfolio.Accounts(ai).Extraction.Summary.AccountNumber) = ai"
ts.WriteLine "    Next ai"
ts.WriteLine ""
ts.WriteLine "    ' Check each mapping row"
ts.WriteLine "    Set seen = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    For mi = 0 To UBound(mappings)"
ts.WriteLine "        If mappings(mi).Tab = """" Then GoTo NextPhantom"
ts.WriteLine "        spec = LCase$(Trim$(mappings(mi).Holdings))"
ts.WriteLine ""
ts.WriteLine "        ' ""all"" and ""cash"" are always valid"
ts.WriteLine "        If spec = ""all"" Or spec = ""cash"" Then GoTo NextPhantom"
ts.WriteLine ""
ts.WriteLine "        ' Account not in portfolio -- not a phantom (that's uncovered, different concept)"
ts.WriteLine "        If Not acctMap.Exists(mappings(mi).Account) Then GoTo NextPhantom"
ts.WriteLine ""
ts.WriteLine "        ai = CLng(acctMap(mappings(mi).Account))"
ts.WriteLine "        ext = portfolio.Accounts(ai).Extraction"
ts.WriteLine ""
ts.WriteLine "        If IsAssetClassName(spec) Then"
ts.WriteLine "            ' Asset class spec: check if any holding has this asset class"
ts.WriteLine "            foundMatch = False"
ts.WriteLine "            For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "                If ext.Holdings(hi).AssetType <> """" Then"
ts.WriteLine "                    If NormalizeAssetClass(ext.Holdings(hi).AssetType) = NormalizeAssetClass(spec) Then"
ts.WriteLine "                        foundMatch = True"
ts.WriteLine "                        Exit For"
ts.WriteLine "                    End If"
ts.WriteLine "                End If"
ts.WriteLine "            Next hi"
ts.WriteLine "            If Not foundMatch Then"
ts.WriteLine "                dedupeKey = mappings(mi).Account & ""|"" & mappings(mi).Tab & ""|"" & spec"
ts.WriteLine "                If Not seen.Exists(dedupeKey) Then"
ts.WriteLine "                    seen(dedupeKey) = True"
ts.WriteLine "                    If count > UBound(phantoms) Then ReDim Preserve phantoms(0 To count + 10)"
ts.WriteLine "                    phantoms(count).Account = mappings(mi).Account"
ts.WriteLine "                    phantoms(count).Tab = mappings(mi).Tab"
ts.WriteLine "                    phantoms(count).HoldingsSpec = mappings(mi).Holdings"
ts.WriteLine "                    count = count + 1"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        Else"
ts.WriteLine "            ' Individual security specs -- build set of all holding IDs"
ts.WriteLine "            Set holdingIds = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "            For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "                holdingIds(UCase$(ext.Holdings(hi).name)) = True"
ts.WriteLine "                For si = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                    If ext.Holdings(hi).Securities(si).Symbol <> """" Then"
ts.WriteLine "                        holdingIds(UCase$(ext.Holdings(hi).Securities(si).Symbol)) = True"
ts.WriteLine "                    End If"
ts.WriteLine "                    If ext.Holdings(hi).Securities(si).name <> """" Then"
ts.WriteLine "                        holdingIds(UCase$(ext.Holdings(hi).Securities(si).name)) = True"
ts.WriteLine "                    End If"
ts.WriteLine "                Next si"
ts.WriteLine "            Next hi"
ts.WriteLine ""
ts.WriteLine "            ' Check each comma-separated spec term"
ts.WriteLine "            parts = Split(mappings(mi).Holdings, "","")"
ts.WriteLine "            For pi = LBound(parts) To UBound(parts)"
ts.WriteLine "                trimmed = Trim$(parts(pi))"
ts.WriteLine "                If trimmed = """" Then GoTo NextSpecPart"
ts.WriteLine "                upperSpec = UCase$(trimmed)"
ts.WriteLine ""
ts.WriteLine "                ' Exact match"
ts.WriteLine "                If holdingIds.Exists(upperSpec) Then GoTo NextSpecPart"
ts.WriteLine ""
ts.WriteLine "                ' Substring match (word boundary)"
ts.WriteLine "                foundMatch = False"
ts.WriteLine "                For Each idKey In holdingIds.Keys"
ts.WriteLine "                    If InStr(1, CStr(idKey), upperSpec) > 0 Then"
ts.WriteLine "                        foundMatch = True"
ts.WriteLine "                        Exit For"
ts.WriteLine "                    End If"
ts.WriteLine "                Next idKey"
ts.WriteLine "                If foundMatch Then GoTo NextSpecPart"
ts.WriteLine ""
ts.WriteLine "                ' No match -- phantom"
ts.WriteLine "                dedupeKey = mappings(mi).Account & ""|"" & mappings(mi).Tab & ""|"" & upperSpec"
ts.WriteLine "                If Not seen.Exists(dedupeKey) Then"
ts.WriteLine "                    seen(dedupeKey) = True"
ts.WriteLine "                    If count > UBound(phantoms) Then ReDim Preserve phantoms(0 To count + 10)"
ts.WriteLine "                    phantoms(count).Account = mappings(mi).Account"
ts.WriteLine "                    phantoms(count).Tab = mappings(mi).Tab"
ts.WriteLine "                    phantoms(count).HoldingsSpec = trimmed"
ts.WriteLine "                    count = count + 1"
ts.WriteLine "                End If"
ts.WriteLine "NextSpecPart:"
ts.WriteLine "            Next pi"
ts.WriteLine "        End If"
ts.WriteLine "NextPhantom:"
ts.WriteLine "    Next mi"
ts.WriteLine ""
ts.WriteLine "    FindPhantomMappings = count"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' QPR Analysis: Preview Cell Updates (read-only)"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function PreviewCellUpdates( _"
ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    ByRef qprWb As Workbook, _"
ts.WriteLine "    ByRef updates() As CellUpdate, _"
ts.WriteLine "    Optional overrides As Object = Nothing _"
ts.WriteLine ") As Long"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    Dim count As Long"
ts.WriteLine "    Dim mi As Long"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine "    Dim tabGroups As Object"
ts.WriteLine "    Dim tabName As Variant"
ts.WriteLine "    Dim indices() As String"
ts.WriteLine "    Dim ii As Long"
ts.WriteLine "    Dim rowIdx As Long"
ts.WriteLine "    Dim row As MappingRow"
ts.WriteLine "    Dim ext As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim dateInfo As Variant"
ts.WriteLine "    Dim targetMonth As Long"
ts.WriteLine "    Dim targetYear As Long"
ts.WriteLine "    Dim daysInMonth As Long"
ts.WriteLine "    Dim assetClassMap As Object"
ts.WriteLine "    Dim cashSymbols As Object"
ts.WriteLine "    Dim tabKey As String"
ts.WriteLine "    Dim monthRow As Long"
ts.WriteLine "    Dim totalValue As Double"
ts.WriteLine "    Dim totalColC As Double"
ts.WriteLine "    Dim totalColD As Double"
ts.WriteLine "    Dim totalFees As Double"
ts.WriteLine "    Dim feesAccountDone As Object"
ts.WriteLine "    Dim allocValues As Object"
ts.WriteLine "    Dim matched As Boolean"
ts.WriteLine "    Dim holdValue As Double"
ts.WriteLine "    Dim ctx As TabContext"
ts.WriteLine "    Dim rowColC As Double"
ts.WriteLine "    Dim rowColD As Double"
ts.WriteLine "    Dim rowFees As Double"
ts.WriteLine "    Dim allocKey As String"
ts.WriteLine "    Dim allocName As Variant"
ts.WriteLine "    Dim valueDetails() As HoldingsDetail"
ts.WriteLine "    Dim valueDetailCount As Long"
ts.WriteLine "    Dim valueDetailAlloc() As String"
ts.WriteLine "    Dim allCashFlowDetails() As CashFlowDetail"
ts.WriteLine "    Dim cashFlowDetailCount As Long"
ts.WriteLine "    Dim detIdx As Long"
ts.WriteLine "    Dim allocSubset() As HoldingsDetail"
ts.WriteLine "    Dim allocSubCount As Long"
ts.WriteLine ""
ts.WriteLine "    count = 0"
ts.WriteLine "    ReDim updates(0 To 50)"
ts.WriteLine ""
ts.WriteLine "    mappings = ReadMappingSheet(qprWb)"
ts.WriteLine "    If mappings(0).Tab = """" Then"
ts.WriteLine "        PreviewCellUpdates = 0"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Set assetClassMap = ReadMasterAssetClasses(qprWb)"
ts.WriteLine ""
ts.WriteLine "    ' Process each account in portfolio"
ts.WriteLine "    For ai = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        ext = portfolio.Accounts(ai).Extraction"
ts.WriteLine ""
ts.WriteLine "        dateInfo = ParseStatementPeriod(ext.Summary.StatementPeriod)"
ts.WriteLine "        If IsNull(dateInfo) Then GoTo NextPrevAcct"
ts.WriteLine ""
ts.WriteLine "        targetMonth = dateInfo(0)"
ts.WriteLine "        targetYear = dateInfo(1)"
ts.WriteLine "        daysInMonth = dateInfo(2)"
ts.WriteLine ""
ts.WriteLine "        Set cashSymbols = BuildCashSymbols(ext)"
ts.WriteLine ""
ts.WriteLine "        ' Group mappings by tab for this account"
ts.WriteLine "        Set tabGroups = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "        For mi = 0 To UBound(mappings)"
ts.WriteLine "            If mappings(mi).Tab = """" Then GoTo NextPrevMap"
ts.WriteLine "            If mappings(mi).Account <> ext.Summary.AccountNumber Then GoTo NextPrevMap"
ts.WriteLine "            tabKey = mappings(mi).Tab"
ts.WriteLine "            If Not tabGroups.Exists(tabKey) Then"
ts.WriteLine "                tabGroups(tabKey) = CStr(mi)"
ts.WriteLine "            Else"
ts.WriteLine "                tabGroups(tabKey) = tabGroups(tabKey) & "","" & CStr(mi)"
ts.WriteLine "            End If"
ts.WriteLine "NextPrevMap:"
ts.WriteLine "        Next mi"
ts.WriteLine ""
ts.WriteLine "        ' Process each tab"
ts.WriteLine "        For Each tabName In tabGroups.Keys"
ts.WriteLine "            monthRow = FindMonthRow(qprWb, CStr(tabName), targetMonth, targetYear)"
ts.WriteLine "            If monthRow = 0 Then GoTo NextPrevTab"
ts.WriteLine ""
ts.WriteLine "            indices = Split(tabGroups(tabName), "","")"
ts.WriteLine "            totalValue = 0#: totalColC = 0#: totalColD = 0#: totalFees = 0#"
ts.WriteLine "            Set feesAccountDone = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "            Set allocValues = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "            matched = False"
ts.WriteLine "            ReDim valueDetails(0 To 20)"
ts.WriteLine "            valueDetailCount = 0"
ts.WriteLine "            ReDim valueDetailAlloc(0 To 20)"
ts.WriteLine "            ReDim allCashFlowDetails(0 To 50)"
ts.WriteLine "            cashFlowDetailCount = 0"
ts.WriteLine ""
ts.WriteLine "            For ii = LBound(indices) To UBound(indices)"
ts.WriteLine "                rowIdx = CLng(indices(ii))"
ts.WriteLine "                row = mappings(rowIdx)"
ts.WriteLine "                If row.Account <> ext.Summary.AccountNumber Then GoTo NextPrevRow"
ts.WriteLine ""
ts.WriteLine "                matched = True"
ts.WriteLine ""
ts.WriteLine "                holdValue = ResolveHoldingsValue(ext, row.Holdings)"
ts.WriteLine "                totalValue = totalValue + holdValue * row.Pct"
ts.WriteLine ""
ts.WriteLine "                ' Collect holdings detail"
ts.WriteLine "                If valueDetailCount > UBound(valueDetails) Then"
ts.WriteLine "                    ReDim Preserve valueDetails(0 To valueDetailCount + 20)"
ts.WriteLine "                    ReDim Preserve valueDetailAlloc(0 To valueDetailCount + 20)"
ts.WriteLine "                End If"
ts.WriteLine "                valueDetails(valueDetailCount).Account = ext.Summary.AccountNumber"
ts.WriteLine "                valueDetails(valueDetailCount).HoldingsSpec = row.Holdings"
ts.WriteLine "                valueDetails(valueDetailCount).Pct = row.Pct"
ts.WriteLine "                valueDetails(valueDetailCount).RawValue = holdValue"
ts.WriteLine "                valueDetails(valueDetailCount).WeightedValue = holdValue * row.Pct"
ts.WriteLine "                valueDetailAlloc(valueDetailCount) = IIf(row.Allocation <> """", LCase$(row.Allocation), """")"
ts.WriteLine "                valueDetailCount = valueDetailCount + 1"
ts.WriteLine ""
ts.WriteLine "                ctx = BuildRowContext(row, ext, cashSymbols)"
ts.WriteLine "                ResolveTransactionsDetailed ext, row.Holdings, ctx, daysInMonth, row.Pct, _"
ts.WriteLine "                    ext.Summary.AccountNumber, rowColC, rowColD, rowFees, _"
ts.WriteLine "                    allCashFlowDetails, cashFlowDetailCount"
ts.WriteLine "                totalColC = totalColC + rowColC * row.Pct"
ts.WriteLine "                totalColD = totalColD + rowColD * row.Pct"
ts.WriteLine ""
ts.WriteLine "                If Not feesAccountDone.Exists(row.Account) Then"
ts.WriteLine "                    totalFees = totalFees + rowFees"
ts.WriteLine "                    feesAccountDone(row.Account) = True"
ts.WriteLine "                End If"
ts.WriteLine ""
ts.WriteLine "                If row.Allocation <> """" Then"
ts.WriteLine "                    allocKey = LCase$(row.Allocation)"
ts.WriteLine "                    If Not allocValues.Exists(allocKey) Then allocValues(allocKey) = 0#"
ts.WriteLine "                    allocValues(allocKey) = allocValues(allocKey) + holdValue * row.Pct"
ts.WriteLine "                End If"
ts.WriteLine ""
ts.WriteLine "                ' Classification overrides"
ts.WriteLine "                If Not overrides Is Nothing Then"
ts.WriteLine "                    Dim hi As Long"
ts.WriteLine "                    Dim si As Long"
ts.WriteLine "                    For hi = 0 To ext.HoldingCount - 1"
ts.WriteLine "                        For si = 0 To ext.Holdings(hi).SecurityCount - 1"
ts.WriteLine "                            Dim sec As UBSExtract.SecurityDetail"
ts.WriteLine "                            sec = ext.Holdings(hi).Securities(si)"
ts.WriteLine "                            Dim overKey As String"
ts.WriteLine "                            overKey = UCase$(sec.Symbol) & ""|"" & ext.Summary.AccountNumber"
ts.WriteLine "                            If sec.Symbol <> """" And overrides.Exists(overKey) Then"
ts.WriteLine "                                Dim overClass As String"
ts.WriteLine "                                overClass = LCase$(CStr(overrides(overKey)))"
ts.WriteLine "                                If Not allocValues.Exists(overClass) Then allocValues(overClass) = 0#"
ts.WriteLine "                                allocValues(overClass) = allocValues(overClass) + sec.Value * row.Pct"
ts.WriteLine "                                ' Track override detail"
ts.WriteLine "                                If valueDetailCount > UBound(valueDetails) Then"
ts.WriteLine "                                    ReDim Preserve valueDetails(0 To valueDetailCount + 20)"
ts.WriteLine "                                    ReDim Preserve valueDetailAlloc(0 To valueDetailCount + 20)"
ts.WriteLine "                                End If"
ts.WriteLine "                                valueDetails(valueDetailCount).Account = ext.Summary.AccountNumber"
ts.WriteLine "                                valueDetails(valueDetailCount).HoldingsSpec = sec.Symbol"
ts.WriteLine "                                valueDetails(valueDetailCount).Pct = row.Pct"
ts.WriteLine "                                valueDetails(valueDetailCount).RawValue = sec.Value"
ts.WriteLine "                                valueDetails(valueDetailCount).WeightedValue = sec.Value * row.Pct"
ts.WriteLine "                                valueDetailAlloc(valueDetailCount) = overClass"
ts.WriteLine "                                valueDetailCount = valueDetailCount + 1"
ts.WriteLine "                            End If"
ts.WriteLine "                        Next si"
ts.WriteLine "                    Next hi"
ts.WriteLine "                End If"
ts.WriteLine "NextPrevRow:"
ts.WriteLine "            Next ii"
ts.WriteLine ""
ts.WriteLine "            If Not matched Then GoTo NextPrevTab"
ts.WriteLine ""
ts.WriteLine "            ' Record updates (same logic as WriteQPR, but append to array)"
ts.WriteLine "            Dim sheetName As String"
ts.WriteLine "            sheetName = CStr(tabName)"
ts.WriteLine ""
ts.WriteLine "            ' B: month-end value"
ts.WriteLine "            If count > UBound(updates) Then ReDim Preserve updates(0 To count + 20)"
ts.WriteLine "            updates(count).Sheet = sheetName"
ts.WriteLine "            updates(count).Cell = ""B"" & monthRow"
ts.WriteLine "            updates(count).Description = ext.Summary.AccountNumber & "" closing value"""
ts.WriteLine "            updates(count).Value = Round(totalValue, 2)"
ts.WriteLine "            updates(count).HoldingsDetailCount = valueDetailCount"
ts.WriteLine "            If valueDetailCount > 0 Then"
ts.WriteLine "                ReDim updates(count).HoldingsDetails(0 To valueDetailCount - 1)"
ts.WriteLine "                For detIdx = 0 To valueDetailCount - 1"
ts.WriteLine "                    updates(count).HoldingsDetails(detIdx) = valueDetails(detIdx)"
ts.WriteLine "                Next detIdx"
ts.WriteLine "            End If"
ts.WriteLine "            count = count + 1"
ts.WriteLine ""
ts.WriteLine "            ' C: time-weighted"
ts.WriteLine "            If Round(totalColC, 2) <> 0 Then"
ts.WriteLine "                If count > UBound(updates) Then ReDim Preserve updates(0 To count + 20)"
ts.WriteLine "                updates(count).Sheet = sheetName"
ts.WriteLine "                updates(count).Cell = ""C"" & monthRow"
ts.WriteLine "                updates(count).Description = ext.Summary.AccountNumber & "" time-weighted (C)"""
ts.WriteLine "                updates(count).Value = Round(totalColC, 2)"
ts.WriteLine "                updates(count).CashFlowDetailCount = cashFlowDetailCount"
ts.WriteLine "                If cashFlowDetailCount > 0 Then"
ts.WriteLine "                    ReDim updates(count).CashFlowDetails(0 To cashFlowDetailCount - 1)"
ts.WriteLine "                    For detIdx = 0 To cashFlowDetailCount - 1"
ts.WriteLine "                        updates(count).CashFlowDetails(detIdx) = allCashFlowDetails(detIdx)"
ts.WriteLine "                    Next detIdx"
ts.WriteLine "                End If"
ts.WriteLine "                count = count + 1"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            ' D: time-weighted"
ts.WriteLine "            If Round(totalColD, 2) <> 0 Then"
ts.WriteLine "                If count > UBound(updates) Then ReDim Preserve updates(0 To count + 20)"
ts.WriteLine "                updates(count).Sheet = sheetName"
ts.WriteLine "                updates(count).Cell = ""D"" & monthRow"
ts.WriteLine "                updates(count).Description = ext.Summary.AccountNumber & "" time-weighted (D)"""
ts.WriteLine "                updates(count).Value = Round(totalColD, 2)"
ts.WriteLine "                updates(count).CashFlowDetailCount = cashFlowDetailCount"
ts.WriteLine "                If cashFlowDetailCount > 0 Then"
ts.WriteLine "                    ReDim updates(count).CashFlowDetails(0 To cashFlowDetailCount - 1)"
ts.WriteLine "                    For detIdx = 0 To cashFlowDetailCount - 1"
ts.WriteLine "                        updates(count).CashFlowDetails(detIdx) = allCashFlowDetails(detIdx)"
ts.WriteLine "                    Next detIdx"
ts.WriteLine "                End If"
ts.WriteLine "                count = count + 1"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            ' H23: fees"
ts.WriteLine "            If count > UBound(updates) Then ReDim Preserve updates(0 To count + 20)"
ts.WriteLine "            updates(count).Sheet = sheetName"
ts.WriteLine "            updates(count).Cell = ""H23"""
ts.WriteLine "            updates(count).Description = ext.Summary.AccountNumber & "" advisory fees"""
ts.WriteLine "            updates(count).Value = Round(totalFees, 2)"
ts.WriteLine "            count = count + 1"
ts.WriteLine ""
ts.WriteLine "            ' Allocation columns"
ts.WriteLine "            For Each allocName In allocValues.Keys"
ts.WriteLine "                If assetClassMap.Exists(allocName) Then"
ts.WriteLine "                    Dim allocCol As String"
ts.WriteLine "                    allocCol = assetClassMap(allocName)"
ts.WriteLine "                    Dim allocAmt As Double"
ts.WriteLine "                    allocAmt = Round(CDbl(allocValues(allocName)), 2)"
ts.WriteLine "                    If allocAmt <> 0 Then"
ts.WriteLine "                        If count > UBound(updates) Then ReDim Preserve updates(0 To count + 20)"
ts.WriteLine "                        updates(count).Sheet = sheetName"
ts.WriteLine "                        updates(count).Cell = allocCol & monthRow"
ts.WriteLine "                        updates(count).Description = ext.Summary.AccountNumber & "" allocation: "" & CStr(allocName)"
ts.WriteLine "                        updates(count).Value = allocAmt"
ts.WriteLine "                        ' Filter holdingsDetails for this allocation class"
ts.WriteLine "                        allocSubCount = 0"
ts.WriteLine "                        ReDim allocSubset(0 To 10)"
ts.WriteLine "                        For detIdx = 0 To valueDetailCount - 1"
ts.WriteLine "                            If valueDetailAlloc(detIdx) = CStr(allocName) Then"
ts.WriteLine "                                If allocSubCount > UBound(allocSubset) Then ReDim Preserve allocSubset(0 To allocSubCount + 5)"
ts.WriteLine "                                allocSubset(allocSubCount) = valueDetails(detIdx)"
ts.WriteLine "                                allocSubCount = allocSubCount + 1"
ts.WriteLine "                            End If"
ts.WriteLine "                        Next detIdx"
ts.WriteLine "                        updates(count).HoldingsDetailCount = allocSubCount"
ts.WriteLine "                        If allocSubCount > 0 Then"
ts.WriteLine "                            ReDim updates(count).HoldingsDetails(0 To allocSubCount - 1)"
ts.WriteLine "                            For detIdx = 0 To allocSubCount - 1"
ts.WriteLine "                                updates(count).HoldingsDetails(detIdx) = allocSubset(detIdx)"
ts.WriteLine "                            Next detIdx"
ts.WriteLine "                        End If"
ts.WriteLine "                        count = count + 1"
ts.WriteLine "                    End If"
ts.WriteLine "                End If"
ts.WriteLine "            Next allocName"
ts.WriteLine "NextPrevTab:"
ts.WriteLine "        Next tabName"
ts.WriteLine "NextPrevAcct:"
ts.WriteLine "    Next ai"
ts.WriteLine ""
ts.WriteLine "    PreviewCellUpdates = count"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' QPR Analysis: Convenience wrapper"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function AnalyzeQPR( _"
ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    ByRef qprWb As Workbook, _"
ts.WriteLine "    Optional overrides As Object = Nothing _"
ts.WriteLine ") As QprAnalysis"
ts.WriteLine "    Dim result As QprAnalysis"
ts.WriteLine ""
ts.WriteLine "    result.UncoveredCount = FindUncoveredAccounts(portfolio, qprWb, result.UncoveredAccounts)"
ts.WriteLine "    result.UnmappedCount = FindUnmappedHoldings(portfolio, qprWb, result.UnmappedHoldings)"
ts.WriteLine "    result.PhantomCount = FindPhantomMappings(portfolio, qprWb, result.PhantomMappings)"
ts.WriteLine "    result.UpdateCount = PreviewCellUpdates(portfolio, qprWb, result.CellUpdates, overrides)"
ts.WriteLine ""
ts.WriteLine "    ' Validate Allocation column against Master sheet asset classes"
ts.WriteLine "    Dim assetClassMap As Object"
ts.WriteLine "    Set assetClassMap = ReadMasterAssetClasses(qprWb)"
ts.WriteLine "    Dim mappings() As MappingRow"
ts.WriteLine "    mappings = ReadMappingSheet(qprWb)"
ts.WriteLine ""
ts.WriteLine "    result.WarningCount = 0"
ts.WriteLine "    ReDim result.Warnings(0 To 10)"
ts.WriteLine "    Dim seenAlloc As Object"
ts.WriteLine "    Set seenAlloc = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim wi As Long"
ts.WriteLine "    For wi = 0 To UBound(mappings)"
ts.WriteLine "        If mappings(wi).Tab = """" Then GoTo NextWarnAlloc"
ts.WriteLine "        Dim wAlloc As String"
ts.WriteLine "        wAlloc = Trim$(mappings(wi).Allocation)"
ts.WriteLine "        If wAlloc = """" Then GoTo NextWarnAlloc"
ts.WriteLine "        ' Dedupe by allocation name"
ts.WriteLine "        If seenAlloc.Exists(LCase$(wAlloc)) Then GoTo NextWarnAlloc"
ts.WriteLine "        seenAlloc(LCase$(wAlloc)) = True"
ts.WriteLine "        If Not assetClassMap.Exists(LCase$(wAlloc)) Then"
ts.WriteLine "            If result.WarningCount > UBound(result.Warnings) Then _"
ts.WriteLine "                ReDim Preserve result.Warnings(0 To result.WarningCount + 10)"
ts.WriteLine "            result.Warnings(result.WarningCount) = ""Allocation '"" & wAlloc & _"
ts.WriteLine "                ""' does not match any asset class in the Master sheet"""
ts.WriteLine "            result.WarningCount = result.WarningCount + 1"
ts.WriteLine "        End If"
ts.WriteLine "NextWarnAlloc:"
ts.WriteLine "    Next wi"
ts.WriteLine ""
ts.WriteLine "    AnalyzeQPR = result"
ts.WriteLine "End Function"
ts.WriteLine ""
