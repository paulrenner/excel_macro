  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine ""
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        MsgBox ""No 'Config' sheet found. Run EnsureConfigSheet first."", vbExclamation, ""Review Incomplete"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp"
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        MsgBox ""Config sheet is empty (no data rows)."", vbExclamation, ""Review Incomplete"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Build list of distinct non-Done clients"
  ts.WriteLine "    clientCount = 0"
  ts.WriteLine "    ReDim clients(1 To lastRow - 1)"
  ts.WriteLine ""
  ts.WriteLine "    For r = 2 To lastRow"
  ts.WriteLine "        clientName = Trim$(CStr(ws.Cells(r, 1).Value & """"))"
  ts.WriteLine "        If Len(clientName) = 0 Then GoTo NextRIRow"
  ts.WriteLine "        status = Trim$(CStr(ws.Cells(r, 4).Value & """"))"
  ts.WriteLine "        If status = ""Done"" Then GoTo NextRIRow"
  ts.WriteLine ""
  ts.WriteLine "        ' Add to distinct list if not already there"
  ts.WriteLine "        found = False"
  ts.WriteLine "        For j = 1 To clientCount"
  ts.WriteLine "            If clients(j) = clientName Then"
  ts.WriteLine "                found = True"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If Not found Then"
  ts.WriteLine "            clientCount = clientCount + 1"
  ts.WriteLine "            clients(clientCount) = clientName"
  ts.WriteLine "        End If"
  ts.WriteLine "NextRIRow:"
  ts.WriteLine "    Next r"
  ts.WriteLine ""
  ts.WriteLine "    If clientCount = 0 Then"
  ts.WriteLine "        MsgBox ""All clients already processed."", vbInformation, ""Review Incomplete"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    QPRWriter.ClearBackupTracking"
  ts.WriteLine ""
  ts.WriteLine "    processedCount = 0"
  ts.WriteLine "    skippedCount = 0"
  ts.WriteLine "    clientErrorCount = 0"
  ts.WriteLine ""
  ts.WriteLine "    For ci = 1 To clientCount"
  ts.WriteLine "        On Error GoTo RIClientError"
  ts.WriteLine ""
  ts.WriteLine "        ' Collect PDF/QPR rows for this client"
  ts.WriteLine "        clientRowCount = 0"
  ts.WriteLine "        For r = 2 To lastRow"
  ts.WriteLine "            If Trim$(CStr(ws.Cells(r, 1).Value & """")) = clients(ci) Then"
  ts.WriteLine "                If Len(Trim$(CStr(ws.Cells(r, 2).Value & """"))) > 0 Then"
  ts.WriteLine "                    clientRowCount = clientRowCount + 1"
  ts.WriteLine "                    ReDim Preserve clientPdfs(1 To clientRowCount)"
  ts.WriteLine "                    ReDim Preserve clientQprs(1 To clientRowCount)"
  ts.WriteLine "                    ReDim Preserve clientRowNums(1 To clientRowCount)"
  ts.WriteLine "                    clientPdfs(clientRowCount) = Trim$(CStr(ws.Cells(r, 2).Value & """"))"
  ts.WriteLine "                    clientQprs(clientRowCount) = Trim$(CStr(ws.Cells(r, 3).Value & """"))"
  ts.WriteLine "                    clientRowNums(clientRowCount) = r"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next r"
  ts.WriteLine ""
  ts.WriteLine "        If clientRowCount = 0 Then GoTo NextRIClient"
  ts.WriteLine ""
  ts.WriteLine "        ' Process with auto-pass (same as RunSingleClient)"
  ts.WriteLine "        clientResult = ProcessOneClient(clients(ci), clientPdfs, clientQprs, _"
  ts.WriteLine "            clientRowCount, True, ""Review "" & ci & ""/"" & clientCount & "" ("" & clients(ci) & ""): "")"
  ts.WriteLine ""
  ts.WriteLine "        Application.StatusBar = """""
  ts.WriteLine ""
  ts.WriteLine "        ' If user closed viewer without submitting, skip marking Done"
  ts.WriteLine "        If Not clientResult.AutoCompleted And Not clientResult.ViewerWroteQPR _"
  ts.WriteLine "           And InStr(1, clientResult.StatusText, ""Viewer closed without submitting"") > 0 Then"
  ts.WriteLine "            skippedCount = skippedCount + 1"
  ts.WriteLine "            GoTo NextRIClient"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Mark all client rows as Done and write notes"
  ts.WriteLine "        Dim pi As Long"
  ts.WriteLine "        For pi = 1 To clientRowCount"
  ts.WriteLine "            ws.Cells(clientRowNums(pi), 4).Value = ""Done"""
  ts.WriteLine "            ws.Cells(clientRowNums(pi), 5).Value = clientResult.Notes"
  ts.WriteLine "        Next pi"
  ts.WriteLine "        ThisWorkbook.Save"
  ts.WriteLine ""
  ts.WriteLine "        processedCount = processedCount + 1"
  ts.WriteLine "        GoTo NextRIClient"
  ts.WriteLine ""
  ts.WriteLine "RIClientError:"
  ts.WriteLine "        clientErrorCount = clientErrorCount + 1"
  ts.WriteLine "        errMsg = Err.Description"
  ts.WriteLine "        On Error Resume Next"
  ts.WriteLine "        PDFCrypto.ReleaseCrypto"
  ts.WriteLine "        ViewerSheet.ResetAllViewerState"
  ts.WriteLine "        On Error GoTo 0"
  ts.WriteLine "        Err.Clear"
  ts.WriteLine ""
  ts.WriteLine "NextRIClient:"
  ts.WriteLine "    Next ci"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine ""
  ts.WriteLine "    summaryMsg = processedCount & "" of "" & clientCount & "" incomplete client(s) processed."""
  ts.WriteLine "    If skippedCount > 0 Then"
  ts.WriteLine "        summaryMsg = summaryMsg & vbCrLf & skippedCount & "" skipped (viewer closed without submitting)."""
  ts.WriteLine "    End If"
  ts.WriteLine "    If clientErrorCount > 0 Then"
  ts.WriteLine "        summaryMsg = summaryMsg & vbCrLf & clientErrorCount & "" had errors."""
  ts.WriteLine "    End If"
  ts.WriteLine "    MsgBox summaryMsg, IIf(clientErrorCount > 0, vbExclamation, vbInformation), ""Review Incomplete"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' 11. Config CSV Import / Export"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' The Config sheet data (Client, PDF path, QPR path, Status, Status Detail, Notes) is"
  ts.WriteLine "' persisted to ExcelMacroConfig.csv in the workbook directory so that"
  ts.WriteLine "' rebuilding the .xlsm does not lose paths.  The CSV lives outside the .xlsm"
  ts.WriteLine "' and is gitignored (contains PII / local paths)."
  ts.WriteLine ""
  ts.WriteLine "Private Function ConfigCsvPath() As String"
  ts.WriteLine "    ConfigCsvPath = ThisWorkbook.Path & ""\ExcelMacroConfig.csv"""
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "''' Escape a field for CSV output (RFC 4180)."
  ts.WriteLine "Private Function CsvEscape(ByVal s As String) As String"
  ts.WriteLine "    If InStr(1, s, "","") > 0 Or InStr(1, s, """""""") > 0 Or InStr(1, s, vbLf) > 0 Or InStr(1, s, vbCr) > 0 Then"
  ts.WriteLine "        CsvEscape = """""""" & Replace(s, """""""", """""""""""") & """""""""
  ts.WriteLine "    Else"
  ts.WriteLine "        CsvEscape = s"
  ts.WriteLine "    End If"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "''' Parse one line of CSV respecting quoted fields.  Returns array of field strings."
  ts.WriteLine "Private Function CsvSplitLine(ByVal line As String) As String()"
  ts.WriteLine "    Dim fields() As String"
  ts.WriteLine "    Dim fieldCount As Long"
  ts.WriteLine "    fieldCount = 0"
  ts.WriteLine "    ReDim fields(0 To 4)  ' expect 5 columns"
  ts.WriteLine ""
  ts.WriteLine "    Dim pos As Long"
  ts.WriteLine "    pos = 1"
  ts.WriteLine "    Dim fieldStart As Long"
  ts.WriteLine "    Dim inQuote As Boolean"
  ts.WriteLine "    Dim ch As String"
  ts.WriteLine "    Dim curField As String"
  ts.WriteLine ""
  ts.WriteLine "    Do While pos <= Len(line) + 1"
  ts.WriteLine "        curField = """""
  ts.WriteLine "        inQuote = False"
  ts.WriteLine "        If pos <= Len(line) And Mid$(line, pos, 1) = """""""" Then"
  ts.WriteLine "            ' Quoted field"
  ts.WriteLine "            inQuote = True"
  ts.WriteLine "            pos = pos + 1"
  ts.WriteLine "            Do While pos <= Len(line)"
  ts.WriteLine "                ch = Mid$(line, pos, 1)"
  ts.WriteLine "                If ch = """""""" Then"
  ts.WriteLine "                    If pos < Len(line) And Mid$(line, pos + 1, 1) = """""""" Then"
  ts.WriteLine "                        curField = curField & """""""""
  ts.WriteLine "                        pos = pos + 2"
  ts.WriteLine "                    Else"
  ts.WriteLine "                        pos = pos + 1 ' closing quote"
  ts.WriteLine "                        Exit Do"
  ts.WriteLine "                    End If"
  ts.WriteLine "                Else"
  ts.WriteLine "                    curField = curField & ch"
  ts.WriteLine "                    pos = pos + 1"
  ts.WriteLine "                End If"
  ts.WriteLine "            Loop"
  ts.WriteLine "            ' skip comma after closing quote"
  ts.WriteLine "            If pos <= Len(line) And Mid$(line, pos, 1) = "","" Then pos = pos + 1"
  ts.WriteLine "        Else"
  ts.WriteLine "            ' Unquoted field"
  ts.WriteLine "            fieldStart = pos"
  ts.WriteLine "            Do While pos <= Len(line)"
  ts.WriteLine "                If Mid$(line, pos, 1) = "","" Then Exit Do"
  ts.WriteLine "                pos = pos + 1"
  ts.WriteLine "            Loop"
  ts.WriteLine "            If pos > fieldStart Then"
  ts.WriteLine "                curField = Mid$(line, fieldStart, pos - fieldStart)"
  ts.WriteLine "            End If"
  ts.WriteLine "            pos = pos + 1 ' skip comma"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        If fieldCount > UBound(fields) Then ReDim Preserve fields(0 To fieldCount)"
  ts.WriteLine "        fields(fieldCount) = curField"
  ts.WriteLine "        fieldCount = fieldCount + 1"
  ts.WriteLine ""
  ts.WriteLine "        If pos > Len(line) + 1 Then Exit Do"
  ts.WriteLine "    Loop"
  ts.WriteLine ""
  ts.WriteLine "    ' Pad to 5 columns"
  ts.WriteLine "    If fieldCount - 1 < 4 Then ReDim Preserve fields(0 To 4)"
  ts.WriteLine ""
  ts.WriteLine "    CsvSplitLine = fields"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Sub ExportConfigCsvSilent()"
  ts.WriteLine "    ' Silent version — no MsgBox, errors swallowed. Used for auto-save during batch."
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    If ws Is Nothing Then Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row"
  ts.WriteLine "    If lastRow < 2 Then Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "    Dim csvPath As String"
  ts.WriteLine "    csvPath = ConfigCsvPath()"
  ts.WriteLine "    Dim f As Integer"
  ts.WriteLine "    f = FreeFile"
  ts.WriteLine "    On Error GoTo SilentExportErr"
  ts.WriteLine "    Open csvPath For Output As #f"
  ts.WriteLine "    Print #f, ""Client,PDF File Path,QPR / Template Path,Status,Status Detail,Notes"""
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    For r = 2 To lastRow"
  ts.WriteLine "        If Len(Trim$(CStr(ws.Cells(r, 1).Value & """"))) > 0 Or _"
  ts.WriteLine "           Len(Trim$(CStr(ws.Cells(r, 2).Value & """"))) > 0 Then"
  ts.WriteLine "            Print #f, CsvEscape(CStr(ws.Cells(r, 1).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 2).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 3).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 4).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 5).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 6).Value & """"))"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next r"
  ts.WriteLine "    Close #f"
  ts.WriteLine "    Exit Sub"
  ts.WriteLine "SilentExportErr:"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Close #f"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ExportConfigCsv()"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    Dim f As Integer"
  ts.WriteLine "    Dim csvPath As String"
  ts.WriteLine "    Dim line As String"
  ts.WriteLine "    Dim dataRows As Long"
  ts.WriteLine ""
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine ""
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        MsgBox ""No Config sheet found. Nothing to export."", vbExclamation, ""Export Config"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp"
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        MsgBox ""Config sheet has no data rows to export."", vbExclamation, ""Export Config"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    csvPath = ConfigCsvPath()"
  ts.WriteLine "    f = FreeFile"
  ts.WriteLine "    On Error GoTo ExportErr"
  ts.WriteLine "    Open csvPath For Output As #f"
  ts.WriteLine ""
  ts.WriteLine "    ' Header"
  ts.WriteLine "    Print #f, ""Client,PDF File Path,QPR / Template Path,Status,Status Detail,Notes"""
  ts.WriteLine ""
  ts.WriteLine "    ' Data rows"
  ts.WriteLine "    dataRows = 0"
  ts.WriteLine "    For r = 2 To lastRow"
  ts.WriteLine "        If Len(Trim$(CStr(ws.Cells(r, 1).Value & """"))) > 0 Or _"
  ts.WriteLine "           Len(Trim$(CStr(ws.Cells(r, 2).Value & """"))) > 0 Then"
  ts.WriteLine "            line = CsvEscape(CStr(ws.Cells(r, 1).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 2).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 3).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 4).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 5).Value & """")) & "","" & _"
  ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 6).Value & """"))"
  ts.WriteLine "            Print #f, line"
  ts.WriteLine "            dataRows = dataRows + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next r"
  ts.WriteLine ""
  ts.WriteLine "    Close #f"
  ts.WriteLine ""
  ts.WriteLine "    MsgBox ""Exported "" & dataRows & "" rows to:"" & vbCrLf & csvPath, _"
  ts.WriteLine "           vbInformation, ""Export Config"""
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "ExportErr:"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Close #f"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    MsgBox ""Error exporting config: "" & Err.Description, vbExclamation, ""Export Config"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ImportConfigCsv()"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim csvPath As String"
  ts.WriteLine "    Dim f As Integer"
  ts.WriteLine "    Dim line As String"
  ts.WriteLine "    Dim fields() As String"
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    Dim dataRows As Long"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine ""
  ts.WriteLine "    csvPath = ConfigCsvPath()"
  ts.WriteLine "    If Dir(csvPath) = """" Then"
  ts.WriteLine "        MsgBox ""No config file found at:"" & vbCrLf & csvPath & vbCrLf & vbCrLf & _"
  ts.WriteLine "               ""Export from the Config sheet first, or create the file manually."", _"
  ts.WriteLine "               vbExclamation, ""Import Config"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Ensure Config sheet exists (creates if needed, preserves existing data)"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        EnsureConfigSheet"
  ts.WriteLine "        Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Clear existing data rows (keep header)"
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row"
  ts.WriteLine "    If lastRow >= 2 Then"
  ts.WriteLine "        ws.Range(""A2:F"" & lastRow).ClearContents"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Read CSV"
  ts.WriteLine "    f = FreeFile"
  ts.WriteLine "    On Error GoTo ImportErr"
  ts.WriteLine "    Open csvPath For Input As #f"
  ts.WriteLine ""
  ts.WriteLine "    ' Skip header line"
  ts.WriteLine "    If Not EOF(f) Then Line Input #f, line"
  ts.WriteLine ""
  ts.WriteLine "    r = 2"
  ts.WriteLine "    dataRows = 0"
  ts.WriteLine "    Do While Not EOF(f)"
  ts.WriteLine "        Line Input #f, line"
  ts.WriteLine "        If Len(Trim$(line)) = 0 Then GoTo NextImportLine"
  ts.WriteLine ""
  ts.WriteLine "        fields = CsvSplitLine(line)"
  ts.WriteLine "        ws.Cells(r, 1).Value = fields(0)"
  ts.WriteLine "        ws.Cells(r, 2).Value = fields(1)"
  ts.WriteLine "        ws.Cells(r, 3).Value = fields(2)"
  ts.WriteLine "        ws.Cells(r, 4).Value = fields(3)"
  ts.WriteLine "        ws.Cells(r, 5).Value = fields(4)"
  ts.WriteLine "        If UBound(fields) >= 5 Then ws.Cells(r, 6).Value = fields(5)"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        dataRows = dataRows + 1"
  ts.WriteLine "NextImportLine:"
  ts.WriteLine "    Loop"
  ts.WriteLine ""
  ts.WriteLine "    Close #f"
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "ImportErr:"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Close #f"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
