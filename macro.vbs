ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function BuildPortfolioAllocationSection( _"
ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    ByVal totalClosing As Double _"
ts.WriteLine ") As String"
ts.WriteLine "    ' Aggregate allocations across all accounts using canonical PDF order"
ts.WriteLine "    Dim canonCat(0 To 6) As String"
ts.WriteLine "    canonCat(0) = ""Cash and money balances"""
ts.WriteLine "    canonCat(1) = ""Cash alternatives"""
ts.WriteLine "    canonCat(2) = ""Equities"""
ts.WriteLine "    canonCat(3) = ""Fixed income"""
ts.WriteLine "    canonCat(4) = ""Non-traditional"""
ts.WriteLine "    canonCat(5) = ""Commodities"""
ts.WriteLine "    canonCat(6) = ""Other"""
ts.WriteLine ""
ts.WriteLine "    Dim catVals(0 To 6) As Double"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim j As Long"
ts.WriteLine "    Dim k As Long"
ts.WriteLine "    Dim alloc As UBSExtract.AssetAllocation"
ts.WriteLine ""
ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        For j = 0 To portfolio.Accounts(i).Extraction.AllocationCount - 1"
ts.WriteLine "            alloc = portfolio.Accounts(i).Extraction.Allocations(j)"
ts.WriteLine "            If alloc.Value = 0 Then GoTo NextPortAlloc"
ts.WriteLine "            For k = 0 To 6"
ts.WriteLine "                If canonCat(k) = alloc.Category Then"
ts.WriteLine "                    catVals(k) = catVals(k) + alloc.Value"
ts.WriteLine "                    Exit For"
ts.WriteLine "                End If"
ts.WriteLine "            Next k"
ts.WriteLine "NextPortAlloc:"
ts.WriteLine "        Next j"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Check if any category has a value"
ts.WriteLine "    Dim hasAny As Boolean"
ts.WriteLine "    For i = 0 To 6"
ts.WriteLine "        If catVals(i) <> 0 Then hasAny = True: Exit For"
ts.WriteLine "    Next i"
ts.WriteLine "    If Not hasAny Then"
ts.WriteLine "        BuildPortfolioAllocationSection = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim rows As String"
ts.WriteLine "    Dim pct As Double"
ts.WriteLine "    Dim totalVal As Double"
ts.WriteLine "    rows = """""
ts.WriteLine "    totalVal = 0"
ts.WriteLine ""
ts.WriteLine "    For i = 0 To 6"
ts.WriteLine "        If catVals(i) = 0 Then GoTo NextPortRow"
ts.WriteLine "        If totalClosing <> 0 Then pct = (catVals(i) / totalClosing) * 100 Else pct = 0"
ts.WriteLine "        totalVal = totalVal + catVals(i)"
ts.WriteLine "        rows = rows & ""<tr><td>"" & Esc(canonCat(i)) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""">"" & Fmt(catVals(i)) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""">"" & FmtPct(pct) & ""</td></tr>"" & vbLf"
ts.WriteLine "NextPortRow:"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    Dim totalPct As Double"
ts.WriteLine "    If totalClosing <> 0 Then totalPct = (totalVal / totalClosing) * 100 Else totalPct = 0"
ts.WriteLine "    rows = rows & ""<tr style=""""font-weight:600;""""><td>Total</td>"" & _"
ts.WriteLine "           ""<td class=""""num"""">"" & Fmt(totalVal) & ""</td>"" & _"
ts.WriteLine "           ""<td class=""""num"""">"" & FmtPct(totalPct) & ""</td></tr>"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    Dim h As String"
ts.WriteLine "    h = ""<div class=""""section"""">"" & vbLf"
ts.WriteLine "    h = h & ""<button class=""""section-toggle"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" onclick=""""toggleSection(this)"""">"" & _"
ts.WriteLine "            ""<span>Asset Allocation</span><span class=""""arrow"""">&#9654;</span></button>"" & vbLf"
ts.WriteLine "    h = h & ""<div class=""""section-body""""><div class=""""section-pad"""">"" & vbLf"
ts.WriteLine "    h = h & ""<table><thead><tr><th>Category</th><th class=""""num"""">Value</th>"" & _"
ts.WriteLine "            ""<th class=""""num"""">%</th></tr></thead><tbody>"" & vbLf"
ts.WriteLine "    h = h & rows"
ts.WriteLine "    h = h & ""</tbody></table></div></div></div>"" & vbLf"
ts.WriteLine "    BuildPortfolioAllocationSection = h"
ts.WriteLine "End Function"
ts.WriteLine ""
