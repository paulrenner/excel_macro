  ts.WriteLine "' 7. Extract PDF and show embedded viewer"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ExtractAndShowViewer()"
  ts.WriteLine "    ' Reset all viewer state from any previous session"
  ts.WriteLine "    ViewerSheet.ResetAllViewerState"
  ts.WriteLine ""
  ts.WriteLine "    Dim fileResult As Variant"
  ts.WriteLine "    Dim portfolio As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim rawText As String"
  ts.WriteLine "    Dim combinedRawText As String"
  ts.WriteLine "    Dim summaryRefs As UBSSummary.SummaryReferences"
  ts.WriteLine "    Dim mergedSummaryRefs As UBSSummary.SummaryReferences"
  ts.WriteLine "    Dim pdfSummaryRefs As UBSSummary.SummaryReferences"
  ts.WriteLine "    Dim pdfPortfolios() As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim fileCount As Long"
  ts.WriteLine "    Dim fi As Long"
  ts.WriteLine ""
  ts.WriteLine "    fileResult = Application.GetOpenFilename( _"
  ts.WriteLine "        FileFilter:=""PDF Files (*.pdf), *.pdf"", _"
  ts.WriteLine "        Title:=""Select UBS Statement PDF(s)"", _"
  ts.WriteLine "        MultiSelect:=True)"
  ts.WriteLine ""
  ts.WriteLine "    If Not IsArray(fileResult) Then"
  ts.WriteLine "        ' Single file or cancelled"
  ts.WriteLine "        If fileResult = False Then Exit Sub"
  ts.WriteLine "        ' Single file selected -- wrap in array"
  ts.WriteLine "        ReDim pdfPortfolios(1 To 1)"
  ts.WriteLine "        fileCount = 1"
  ts.WriteLine "    Else"
  ts.WriteLine "        fileCount = UBound(fileResult) - LBound(fileResult) + 1"
  ts.WriteLine "        ReDim pdfPortfolios(1 To fileCount)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    On Error GoTo ViewerError"
  ts.WriteLine ""
  ts.WriteLine "    combinedRawText = """""
  ts.WriteLine "    mergedSummaryRefs.AccountCount = 0"
  ts.WriteLine "    mergedSummaryRefs.ChangeCount = 0"
  ts.WriteLine "    ReDim mergedSummaryRefs.Accounts(0 To 15)"
  ts.WriteLine "    ReDim mergedSummaryRefs.Changes(0 To 15)"
  ts.WriteLine ""
  ts.WriteLine "    ' Extract all selected PDFs"
  ts.WriteLine "    For fi = 1 To fileCount"
  ts.WriteLine "        Dim filePath As String"
  ts.WriteLine "        If fileCount = 1 And Not IsArray(fileResult) Then"
  ts.WriteLine "            filePath = CStr(fileResult)"
  ts.WriteLine "        Else"
  ts.WriteLine "            filePath = CStr(fileResult(fi))"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        Application.StatusBar = ""Extracting PDF "" & fi & ""/"" & fileCount & ""..."""
  ts.WriteLine ""
  ts.WriteLine "        rawText = """""
  ts.WriteLine "        pdfPortfolios(fi) = ExtractPDFToPortfolioFull(filePath, rawText, pdfSummaryRefs)"
  ts.WriteLine ""
  ts.WriteLine "        If pdfSummaryRefs.ChangeCount > 0 Then"
  ts.WriteLine "            UBSSummary.MergeSummaryRefs mergedSummaryRefs, pdfSummaryRefs"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        If Len(combinedRawText) > 0 Then combinedRawText = combinedRawText & vbLf & vbLf"
  ts.WriteLine "        combinedRawText = combinedRawText & ""--- PDF: "" & Dir(filePath) & "" ---"" & vbLf & rawText"
  ts.WriteLine "    Next fi"
  ts.WriteLine ""
  ts.WriteLine "    ' Merge portfolios"
  ts.WriteLine "    If fileCount = 1 Then"
  ts.WriteLine "        portfolio = pdfPortfolios(1)"
  ts.WriteLine "    Else"
  ts.WriteLine "        portfolio = MergePortfolios(pdfPortfolios, fileCount)"
  ts.WriteLine "    End If"
  ts.WriteLine "    summaryRefs = mergedSummaryRefs"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Rendering viewer..."""
  ts.WriteLine ""
  ts.WriteLine "    ' Initialize viewer state and render to worksheet"
  ts.WriteLine "    ViewerSheet.InitState portfolio, combinedRawText"
  ts.WriteLine "    ViewerSheet.SetSummaryRefs summaryRefs"
  ts.WriteLine "    ViewerSheet.SetViewerPortfolio portfolio"
  ts.WriteLine "    ViewerSheet.RenderViewerSheet portfolio"
  ts.WriteLine "    ' Non-blocking -- user interacts via buttons on the sheet"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "ViewerError:"
  ts.WriteLine "    Dim errMsg As String"
  ts.WriteLine "    errMsg = Err.Description"
  ts.WriteLine "    Dim errNum As Long"
  ts.WriteLine "    errNum = Err.Number"
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    PDFCrypto.ReleaseCrypto"
  ts.WriteLine "    ViewerSheet.ResetAllViewerState"
  ts.WriteLine "    MsgBox ""Error "" & errNum & "": "" & errMsg, vbCritical, ""Viewer Error"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
