  ts.WriteLine "Private Function GetOrCreateViewerSheet() As Worksheet"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Viewer"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        Set ws = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count))"
  ts.WriteLine "        ws.Name = ""Viewer"""
  ts.WriteLine "    End If"
  ts.WriteLine "    Set GetOrCreateViewerSheet = ws"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Sub DeleteViewerSheet()"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Application.DisplayAlerts = False"
  ts.WriteLine "    ThisWorkbook.Worksheets(""Viewer"").Delete"
  ts.WriteLine "    Application.DisplayAlerts = True"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "End Sub"
