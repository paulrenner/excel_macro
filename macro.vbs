  ts.WriteLine "    If Not mQprWorkbooks Is Nothing Then"
  ts.WriteLine "        Dim rk As Variant"
  ts.WriteLine "        For Each rk In mQprWorkbooks.Keys"
  ts.WriteLine "            mQprWorkbooks(rk).Close False"
  ts.WriteLine "        Next rk"
  ts.WriteLine "        mQprWorkbooks.RemoveAll"
  ts.WriteLine "    End If"
  ts.WriteLine "    If Not mQprWb Is Nothing Then mQprWb.Close False: Set mQprWb = Nothing"
