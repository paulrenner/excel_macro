ts.WriteLine ""
ts.WriteLine "Public Function ResolveArrayField(ext As UBSExtract.StatementExtraction, _"
ts.WriteLine "                                  ByVal arrayName As String, _"
ts.WriteLine "                                  ByVal columnName As String, _"
ts.WriteLine "                                  ByVal filterStr As String) As Variant"
ts.WriteLine "    Dim lArray As String, lCol As String"
ts.WriteLine "    lArray = LCase$(arrayName)"
ts.WriteLine "    lCol = LCase$(columnName)"
ts.WriteLine ""
ts.WriteLine "    Select Case lArray"
ts.WriteLine "        Case ""holdings"""
ts.WriteLine "            ResolveArrayField = ResolveHoldingsColumn(ext, lCol, filterStr)"
ts.WriteLine "        Case ""transactions"""
ts.WriteLine "            ResolveArrayField = ResolveTransactionsColumn(ext, lCol, filterStr)"
ts.WriteLine "        Case ""allocations"""
ts.WriteLine "            ResolveArrayField = ResolveAllocationsColumn(ext, lCol, filterStr)"
