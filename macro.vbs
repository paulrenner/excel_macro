  ts.WriteLine "Private Function AddButtons(ws As Worksheet, r As Long) As Long"
  ts.WriteLine "    Dim btnLeft As Double"
  ts.WriteLine "    Dim btnTop As Double"
  ts.WriteLine "    Dim btnWidth As Double"
  ts.WriteLine "    Dim btnHeight As Double"
  ts.WriteLine "    Dim btn As Shape"
  ts.WriteLine ""
  ts.WriteLine "    btnTop = ws.Cells(r, 1).Top"
  ts.WriteLine "    btnHeight = 24"
  ts.WriteLine "    btnWidth = 90"
  ts.WriteLine "    btnLeft = ws.Cells(r, 1).Left"
  ts.WriteLine ""
  ts.WriteLine "    If Not mHideAddData Then"
  ts.WriteLine "        ' Add PDF button"
  ts.WriteLine "        Set btn = ws.Shapes.AddFormControl(0, btnLeft, btnTop, btnWidth, btnHeight)  ' xlButtonControl = 0"
  ts.WriteLine "        btn.TextFrame.Characters.Text = ""Add PDF"""
  ts.WriteLine "        btn.OnAction = ""ViewerSheet_AddPDF"""
  ts.WriteLine "        btn.Placement = 3  ' xlFreeFloating"
  ts.WriteLine "        btnLeft = btnLeft + btnWidth + 6"
  ts.WriteLine ""
  ts.WriteLine "        ' Add Excel button"
  ts.WriteLine "        Set btn = ws.Shapes.AddFormControl(0, btnLeft, btnTop, btnWidth, btnHeight)"
  ts.WriteLine "        btn.TextFrame.Characters.Text = ""Add Excel"""
  ts.WriteLine "        btn.OnAction = ""ViewerSheet_AddExcel"""
  ts.WriteLine "        btn.Placement = 3  ' xlFreeFloating"
  ts.WriteLine "        btnLeft = btnLeft + btnWidth + 6"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Close Viewer button"
  ts.WriteLine "    Set btn = ws.Shapes.AddFormControl(0, btnLeft, btnTop, btnWidth, btnHeight)"
  ts.WriteLine "    btn.TextFrame.Characters.Text = ""Close Viewer"""
  ts.WriteLine "    btn.OnAction = ""ViewerSheet_Cleanup"""
  ts.WriteLine "    btn.Placement = 3  ' xlFreeFloating"
  ts.WriteLine "    btnLeft = btnLeft + btnWidth"
  ts.WriteLine ""
  ts.WriteLine "    ' Save position so AddActionButtons can append to same row"
  ts.WriteLine "    mButtonBarLeft = btnLeft"
  ts.WriteLine "    mButtonBarRow = r"
  ts.WriteLine ""
  ts.WriteLine "    ' Set row height to accommodate buttons"
  ts.WriteLine "    ws.Rows(r).RowHeight = 30"
  ts.WriteLine "    AddButtons = r + 1"
  ts.WriteLine "End Function"
