ts.WriteLine "Public Sub MakeFormResizable(ByVal caption As String)"
ts.WriteLine "    ' Adds WS_THICKFRAME (resize border) and WS_MAXIMIZEBOX to a UserForm window"
ts.WriteLine "    Const GWL_STYLE As Long = -16"
ts.WriteLine "    Const WS_THICKFRAME As Long = &H40000"
ts.WriteLine "    Const WS_MAXIMIZEBOX As Long = &H10000"
ts.WriteLine "    Const SWP_FRAMECHANGED As Long = &H20"
ts.WriteLine "    Const SWP_NOMOVE As Long = &H2"
ts.WriteLine "    Const SWP_NOSIZE As Long = &H1"
ts.WriteLine "    Const SWP_NOZORDER As Long = &H4"
ts.WriteLine ""
ts.WriteLine "    #If VBA7 Then"
ts.WriteLine "        Dim hWnd As LongPtr"
ts.WriteLine "    #Else"
ts.WriteLine "        Dim hWnd As Long"
ts.WriteLine "    #End If"
ts.WriteLine ""
ts.WriteLine "    hWnd = FindWindowA(""ThunderDFrame"", caption)"
ts.WriteLine "    If hWnd = 0 Then Exit Sub"
ts.WriteLine ""
ts.WriteLine "    Dim style As Long"
ts.WriteLine "    style = GetWindowLongA(hWnd, GWL_STYLE)"
ts.WriteLine "    style = style Or WS_THICKFRAME Or WS_MAXIMIZEBOX"
ts.WriteLine "    SetWindowLongA hWnd, GWL_STYLE, style"
ts.WriteLine ""
ts.WriteLine "    ' Force window to redraw its frame with the new style"
ts.WriteLine "    SetWindowPos hWnd, 0, 0, 0, 0, 0, _"
ts.WriteLine "        SWP_FRAMECHANGED Or SWP_NOMOVE Or SWP_NOSIZE Or SWP_NOZORDER"
ts.WriteLine "End Sub"
