  ts.WriteLine "        r = r + 1  ' spacer"
  ts.WriteLine "        secStart = r"
  ts.WriteLine "        WriteSubHeader ws, r, ""Phantom Accounts ("" & analysis.PhantomAcctCount & "")"""
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_WARN_BG"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim paH() As String, paS() As Long, paE() As Long, paA() As Long"
