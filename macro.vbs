ts.WriteLine "' ============================================================================"
ts.WriteLine "' HTML patching -- redirect window.external calls to hidden input"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function PatchHTMLForPolling(ByVal html As String) As String"
ts.WriteLine "    ' Injects a hidden input element and replaces window.external calls"
ts.WriteLine "    ' with JavaScript that sets the hidden field value instead."
ts.WriteLine "    '"
ts.WriteLine "    ' The hidden field uses format ""action:data"", e.g.:"
ts.WriteLine "    '   ""classifications:AAPL|U2 12345 WM=Equities;MSFT|U2 12345 WM=Fixed Income"""
ts.WriteLine ""
ts.WriteLine "    Dim patched As String"
ts.WriteLine "    patched = html"
ts.WriteLine ""
ts.WriteLine "    ' Inject the hidden callback field just before </body>"
ts.WriteLine "    Dim callbackField As String"
ts.WriteLine "    callbackField = ""<input type=""""hidden"""" id=""""vba-callback"""" value="""""""">"" & vbLf"
ts.WriteLine "    patched = Replace$(patched, ""</body>"", callbackField & ""</body>"")"
ts.WriteLine ""
ts.WriteLine "    ' Replace window.external.OnAccountSelect(acctNum) calls"
ts.WriteLine "    patched = Replace$(patched, _"
ts.WriteLine "        ""try { window.external.OnAccountSelect(acctNum); } catch(e) { /* browser mode - no callback */ }"", _"
ts.WriteLine "        ""document.getElementById('vba-callback').value = 'account_select:' + acctNum;"")"
ts.WriteLine ""
ts.WriteLine "    ' Replace window.external.OnClassifications(result) calls"
ts.WriteLine "    patched = Replace$(patched, _"
ts.WriteLine "        ""try { window.external.OnClassifications(result); } catch(e) { alert('Classifications: ' + result); }"", _"
ts.WriteLine "        ""document.getElementById('vba-callback').value = 'classifications:' + result;"")"
ts.WriteLine ""
ts.WriteLine "    ' Replace window.external.OnAddPDF() calls"
ts.WriteLine "    patched = Replace$(patched, _"
ts.WriteLine "        ""try { window.external.OnAddPDF(); } catch(e) { /* browser mode */ }"", _"
ts.WriteLine "        ""document.getElementById('vba-callback').value = 'add_pdf:';"")"
ts.WriteLine ""
ts.WriteLine "    ' Replace window.external.OnAddExcel() calls"
ts.WriteLine "    patched = Replace$(patched, _"
ts.WriteLine "        ""try { window.external.OnAddExcel(); } catch(e) { /* browser mode */ }"", _"
ts.WriteLine "        ""document.getElementById('vba-callback').value = 'add_excel:';"")"
ts.WriteLine ""
ts.WriteLine "    PatchHTMLForPolling = patched"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Embedded UserForm with WebBrowser control"
ts.WriteLine "' ============================================================================"
ts.WriteLine "'"
ts.WriteLine "' Creates a UserForm at runtime, adds a WebBrowser control, loads HTML,"
ts.WriteLine "' and shows it as a modal dialog. A DoEvents polling loop checks the"
ts.WriteLine "' hidden callback field. On submit, the form closes and the result"
ts.WriteLine "' string is returned."
ts.WriteLine "'"
ts.WriteLine "' Returns: classification string (e.g. ""XOM|U2 12345=Equities;GE|U2 12345=Cash"")"
ts.WriteLine "'          or empty string if user closed without submitting."
ts.WriteLine ""
ts.WriteLine "Public Function ShowEmbeddedViewer(ByVal html As String) As String"
ts.WriteLine "    On Error GoTo ErrHandler"
ts.WriteLine ""
ts.WriteLine "    Dim patchedHTML As String"
ts.WriteLine "    patchedHTML = PatchHTMLForPolling(html)"
ts.WriteLine ""
ts.WriteLine "    ' Reset result"
ts.WriteLine "    mFormResult = """""
ts.WriteLine "    mFormDone = False"
ts.WriteLine ""
ts.WriteLine "    ' Ensure runtime VBComponents exist (create once, reuse on subsequent calls)."
ts.WriteLine "    ' Modifying VBProject resets VBA error handler state, so we avoid"
ts.WriteLine "    ' Add/Remove on every call -- only create if missing."
ts.WriteLine "    EnsureViewerComponents"
ts.WriteLine ""
ts.WriteLine "    ' If auto-analyze is requested, inject a script that triggers auto_qpr callback on load"
ts.WriteLine "    If mAutoAnalyzeQPR Then"
ts.WriteLine "        mAutoAnalyzeQPR = False  ' consume flag"
ts.WriteLine "        Dim autoScript As String"
ts.WriteLine "        autoScript = ""<script>window.onload=function(){setTimeout(function(){"" & _"
ts.WriteLine "            ""var cb=document.getElementById('vba-callback');if(cb){cb.value='auto_qpr:';}},200);}</script>"""
ts.WriteLine "        ' Insert before </body> or append"
ts.WriteLine "        If InStr(1, patchedHTML, ""</body>"", vbTextCompare) > 0 Then"
ts.WriteLine "            patchedHTML = Replace(patchedHTML, ""</body>"", autoScript & ""</body>"", , 1, vbTextCompare)"
ts.WriteLine "        Else"
ts.WriteLine "            patchedHTML = patchedHTML & autoScript"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Hide Add PDF / Add Excel zone if requested (e.g., Run Single Client)"
ts.WriteLine "    If mHideAddData Then"
ts.WriteLine "        mHideAddData = False  ' consume flag"
ts.WriteLine "        Dim hideScript As String"
ts.WriteLine "        hideScript = ""<script>var adz=document.getElementById('add-data-zone');if(adz)adz.style.display='none';</script>"""
ts.WriteLine "        If InStr(1, patchedHTML, ""</body>"", vbTextCompare) > 0 Then"
ts.WriteLine "            patchedHTML = Replace(patchedHTML, ""</body>"", hideScript & ""</body>"", , 1, vbTextCompare)"
ts.WriteLine "        Else"
ts.WriteLine "            patchedHTML = patchedHTML & hideScript"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Store HTML for the launcher to pass to the form"
ts.WriteLine "    mPendingHTML = patchedHTML"
ts.WriteLine ""
ts.WriteLine "    ' Run the launcher (modeless -- returns immediately)"
ts.WriteLine "    Application.Run ""LaunchViewerForm"""
ts.WriteLine ""
ts.WriteLine "    ' Wait for the form to close or submit (modeless -- Excel stays responsive)"
ts.WriteLine "    Do While Not mFormDone"
ts.WriteLine "        DoEvents"
ts.WriteLine "        SleepMs 50"
ts.WriteLine "    Loop"
ts.WriteLine ""
ts.WriteLine "    ' Release large HTML buffer now that form is closed"
ts.WriteLine "    mPendingHTML = """""
ts.WriteLine ""
ts.WriteLine "    ShowEmbeddedViewer = mFormResult"
ts.WriteLine "    Exit Function"
ts.WriteLine ""
ts.WriteLine "ErrHandler:"
ts.WriteLine "    Dim viewerErrMsg As String"
ts.WriteLine "    viewerErrMsg = Err.Description"
ts.WriteLine "    Dim viewerErrNum As Long"
ts.WriteLine "    viewerErrNum = Err.Number"
ts.WriteLine "    mPendingHTML = """""
ts.WriteLine "    MsgBox ""ShowEmbeddedViewer error "" & viewerErrNum & "": "" & viewerErrMsg, vbExclamation, ""Viewer"""
ts.WriteLine "    ShowEmbeddedViewer = """""
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ---------------------------------------------------------------------------"
ts.WriteLine "' EnsureViewerComponents -- create ViewerFormRT + ViewerLaunchHelper once."
ts.WriteLine "' On subsequent calls, components already exist so no VBProject modification"
ts.WriteLine "' occurs, which preserves VBA error handler state."
ts.WriteLine "' ---------------------------------------------------------------------------"
ts.WriteLine "Private Sub EnsureViewerComponents()"
ts.WriteLine "    Dim vbProj As Object"
ts.WriteLine "    Set vbProj = ThisWorkbook.VBProject"
ts.WriteLine ""
ts.WriteLine "    ' Check if ViewerFormRT already exists"
ts.WriteLine "    Dim frmComp As Object"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set frmComp = vbProj.VBComponents(""ViewerFormRT"")"
ts.WriteLine "    Err.Clear"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine ""
ts.WriteLine "    If frmComp Is Nothing Then"
ts.WriteLine "        ' First run -- create the UserForm with WebBrowser and code-behind"
ts.WriteLine "        Set frmComp = vbProj.VBComponents.Add(3)  ' vbext_ct_MSForm = 3"
ts.WriteLine "        frmComp.Name = ""ViewerFormRT"""
ts.WriteLine ""
ts.WriteLine "        With frmComp.Properties"
ts.WriteLine "            .Item(""Caption"") = ""Statement Viewer"""
ts.WriteLine "            .Item(""Width"") = 900"
ts.WriteLine "            .Item(""Height"") = 600"
ts.WriteLine "        End With"
ts.WriteLine ""
ts.WriteLine "        Dim wb As Object"
ts.WriteLine "        Set wb = frmComp.Designer.Controls.Add(""Shell.Explorer.2"", ""WebBrowser1"")"
ts.WriteLine "        With wb"
ts.WriteLine "            .Left = 0"
ts.WriteLine "            .Top = 0"
ts.WriteLine "            .Width = frmComp.Properties(""InsideWidth"")"
ts.WriteLine "            .Height = frmComp.Properties(""InsideHeight"")"
ts.WriteLine "        End With"
ts.WriteLine ""
ts.WriteLine "        ' Inject code-behind using array+Join"
ts.WriteLine "        Dim codeLines() As String"
ts.WriteLine "        ReDim codeLines(0 To 79)"
ts.WriteLine "        Dim ci As Long"
ts.WriteLine "        ci = 0"
ts.WriteLine "        codeLines(ci) = ""Private mHTML As String"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""Private mPolling As Boolean"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = """": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""Public Property Let HTMLContent(ByVal s As String)"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    mHTML = s"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""End Property"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = """": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""Private Sub UserForm_Activate()"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    ViewerFormLauncher.MakeFormResizable Me.Caption"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    On Error Resume Next"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    WebBrowser1.Navigate """"about:blank"""""": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    Dim wc As Long: wc = 0"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    Do While WebBrowser1.Busy Or WebBrowser1.ReadyState <> 4: DoEvents: wc = wc + 1: If wc > 500 Then Exit Do"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    Loop"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    WebBrowser1.Document.Open"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    WebBrowser1.Document.Write mHTML"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    WebBrowser1.Document.Close"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    On Error GoTo 0"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    mPolling = True: PollLoop"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""End Sub"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = """": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""Private Sub PollLoop()"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    Dim el As Object"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    Dim v As String"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    Do While mPolling"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        DoEvents"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        If Not mPolling Then Exit Do"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        On Error Resume Next"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        Set el = WebBrowser1.Document.getElementById(""""vba-callback"""")"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        On Error GoTo 0"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        If Not el Is Nothing Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""            v = el.Value"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""            If Len(v) > 0 Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                el.Value = """""""""": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                On Error Resume Next"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                If Left$(v, 16) = """"classifications:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.SetFormResult Mid$(v, 17)"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    mPolling = False"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    Me.Hide"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    Exit Sub"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 9) = """"load_qpr:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleLoadQPR WebBrowser1"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 10) = """"apply_qpr:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleApplyQPR WebBrowser1"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 14) = """"recompute_qpr:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleRecomputeQPR WebBrowser1, Mid$(v, 15)"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 8) = """"add_pdf:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleAddPDF WebBrowser1"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 10) = """"add_excel:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleAddExcel WebBrowser1"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 13) = """"load_account:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleLoadAccount WebBrowser1, Mid$(v, 14)"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 14) = """"add_template:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleAddTemplate WebBrowser1"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 16) = """"apply_template:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.HandleApplyTemplate WebBrowser1"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                ElseIf Left$(v, 9) = """"auto_qpr:"""" Then"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                    ViewerFormLauncher.AutoAnalyzeQPR WebBrowser1"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                End If"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""                On Error GoTo 0"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""            End If"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        End If"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""        ViewerFormLauncher.SleepMs 50"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    Loop"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""End Sub"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = """": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""Private Sub UserForm_QueryClose(Cancel As Integer, CloseMode As Integer)"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    mPolling = False"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    ViewerFormLauncher.SetFormDone"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""End Sub"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = """": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""Private Sub UserForm_Resize()"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    On Error Resume Next"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    WebBrowser1.Width = Me.InsideWidth"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""    WebBrowser1.Height = Me.InsideHeight"": ci = ci + 1"
ts.WriteLine "        codeLines(ci) = ""End Sub"": ci = ci + 1"
ts.WriteLine "        ReDim Preserve codeLines(0 To ci - 1)"
ts.WriteLine ""
ts.WriteLine "        frmComp.CodeModule.AddFromString Join(codeLines, vbLf)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Check if ViewerLaunchHelper already exists"
ts.WriteLine "    Dim launchComp As Object"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set launchComp = vbProj.VBComponents(""ViewerLaunchHelper"")"
ts.WriteLine "    Err.Clear"
