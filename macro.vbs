Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, "DataMapper.bas"), True)
ts.WriteLine "Attribute VB_Name = ""DataMapper"""
ts.WriteLine "Option Explicit"
ts.WriteLine ""
ts.WriteLine "' DataMapper.bas -- Generic data mapping engine."
ts.WriteLine "' Reads a _DataMap sheet from any template workbook, resolves field paths"
ts.WriteLine "' against extracted PDF data, and writes values to target cells."
ts.WriteLine "'"
ts.WriteLine "' Provides:"
ts.WriteLine "'   Types:          DataMapRow, ResolvedValue, DataMapAlert, DataMapResult"
ts.WriteLine "'   Parsing:        ReadDataMap"
ts.WriteLine "'   Resolution:     ResolveScalarField, ResolveArrayField, ParseFilterString"
ts.WriteLine "'   Orchestration:  ProcessMapping"
ts.WriteLine "'   Output:         WriteResults, WriteFieldsSheet"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Types"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Type DataMapRow"
ts.WriteLine "    Account As String"
ts.WriteLine "    Field As String"
ts.WriteLine "    Filter As String        ' raw filter string, e.g., ""symbol=AAPL,asset_type=Equity"""
ts.WriteLine "    Pct As Double           ' 0-1, default 1.0"
ts.WriteLine "    TargetSheet As String"
ts.WriteLine "    TargetCell As String"
ts.WriteLine "    RowNum As Long           ' source row in _DataMap (for error reporting)"
ts.WriteLine "End Type"
ts.WriteLine ""
ts.WriteLine "Public Type ResolvedValue"
ts.WriteLine "    TargetSheet As String"
ts.WriteLine "    TargetCell As String"
ts.WriteLine "    Value As Double"
ts.WriteLine "    IsText As Boolean"
ts.WriteLine "    TextValue As String"
ts.WriteLine "    SourceDesc As String     ' e.g., ""WM-12345 holdings[].market_value symbol=AAPL @60%"""
ts.WriteLine "End Type"
ts.WriteLine ""
ts.WriteLine "Public Type DataMapAlert"
ts.WriteLine "    AlertType As String      ' ""warning"", ""phantom"", ""unmapped"""
ts.WriteLine "    Message As String"
ts.WriteLine "    Account As String"
ts.WriteLine "    RowNum As Long           ' 0 if not row-specific"
ts.WriteLine "End Type"
ts.WriteLine ""
ts.WriteLine "Public Type DataMapResult"
ts.WriteLine "    Values() As ResolvedValue"
ts.WriteLine "    ValueCount As Long"
ts.WriteLine "    Alerts() As DataMapAlert"
ts.WriteLine "    AlertCount As Long"
ts.WriteLine "End Type"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Constants"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Const DATAMAP_SHEET As String = ""_DataMap"""
ts.WriteLine "Private Const FIELDS_SHEET As String = ""_Fields"""
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' ReadDataMap -- parse _DataMap sheet into array of DataMapRow"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function ReadDataMap(wb As Workbook, ByRef outRowCount As Long) As DataMapRow()"
ts.WriteLine "    outRowCount = 0"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = wb.Worksheets(DATAMAP_SHEET)"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        Err.Raise 5, ""DataMapper.ReadDataMap"", ""_DataMap sheet not found in "" & wb.Name"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Find last row with data"
ts.WriteLine "    Dim lastRow As Long"
ts.WriteLine "    lastRow = ws.Cells(ws.Rows.count, 1).End(xlUp).Row"
ts.WriteLine "    If lastRow < 2 Then"
ts.WriteLine "        ' Empty or header-only"
ts.WriteLine "        ReDim ReadDataMap(0 To 0)"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim rows() As DataMapRow"
ts.WriteLine "    Dim rowCount As Long"
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    Dim acct As String"
ts.WriteLine "    Dim fld As String"
ts.WriteLine "    Dim tgtSheet As String"
ts.WriteLine "    Dim tgtCell As String"
ts.WriteLine "    Dim mr As DataMapRow"
ts.WriteLine "    Dim pctVal As String"
ts.WriteLine ""
ts.WriteLine "    rowCount = 0"
ts.WriteLine "    ReDim rows(0 To lastRow - 2)  ' max possible"
ts.WriteLine ""
ts.WriteLine "    For r = 2 To lastRow"
ts.WriteLine "        acct = Trim$(CStr(ws.Cells(r, 1).Value))"
ts.WriteLine "        If Len(acct) = 0 Then GoTo NextRow  ' skip blank rows"
ts.WriteLine ""
ts.WriteLine "        fld = Trim$(CStr(ws.Cells(r, 2).Value))"
ts.WriteLine "        If Len(fld) = 0 Then GoTo NextRow"
ts.WriteLine ""
ts.WriteLine "        tgtSheet = Trim$(CStr(ws.Cells(r, 5).Value))"
ts.WriteLine "        If Len(tgtSheet) = 0 Then GoTo NextRow"
ts.WriteLine ""
ts.WriteLine "        tgtCell = Trim$(CStr(ws.Cells(r, 6).Value))"
ts.WriteLine "        If Len(tgtCell) = 0 Then GoTo NextRow"
ts.WriteLine ""
ts.WriteLine "        mr.Account = acct"
ts.WriteLine "        mr.Field = fld"
ts.WriteLine "        mr.Filter = Trim$(CStr(ws.Cells(r, 3).Value))"
ts.WriteLine "        mr.TargetSheet = tgtSheet"
ts.WriteLine "        mr.TargetCell = tgtCell"
ts.WriteLine "        mr.RowNum = r"
ts.WriteLine ""
ts.WriteLine "        ' Parse Pct"
ts.WriteLine "        pctVal = Trim$(CStr(ws.Cells(r, 4).Value))"
ts.WriteLine "        If Len(pctVal) = 0 Then"
ts.WriteLine "            mr.Pct = 1#"
ts.WriteLine "        Else"
ts.WriteLine "            mr.Pct = ParsePct(pctVal)"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        rows(rowCount) = mr"
ts.WriteLine "        rowCount = rowCount + 1"
ts.WriteLine "NextRow:"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    If rowCount = 0 Then"
ts.WriteLine "        ReDim ReadDataMap(0 To 0)"
ts.WriteLine "    Else"
ts.WriteLine "        ReDim Preserve rows(0 To rowCount - 1)"
ts.WriteLine "        ReadDataMap = rows"
ts.WriteLine "    End If"
ts.WriteLine "    outRowCount = rowCount"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' ParsePct -- parse ""60%"", ""0.6"", or plain number to 0-1 range"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function ParsePct(ByVal s As String) As Double"
ts.WriteLine "    If Right$(s, 1) = ""%"" Then"
ts.WriteLine "        s = Left$(s, Len(s) - 1)"
ts.WriteLine "        ParsePct = CDbl(s) / 100#"
ts.WriteLine "    Else"
ts.WriteLine "        Dim v As Double"
ts.WriteLine "        v = CDbl(s)"
ts.WriteLine "        If v > 1# And v <= 100# Then"
ts.WriteLine "            ' Assume percentage if > 1 (e.g., ""60"" means 60%)"
ts.WriteLine "            ParsePct = v / 100#"
ts.WriteLine "        Else"
ts.WriteLine "            ParsePct = v"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' ResolveScalarField -- map dot-path string to StatementExtraction member"
ts.WriteLine "' Returns Empty if field not found."
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function ResolveScalarField(ext As UBSExtract.StatementExtraction, ByVal path As String) As Variant"
ts.WriteLine "    Select Case LCase$(path)"
ts.WriteLine "        ' Top-level scalars"
ts.WriteLine "        Case ""opening_balance"":         ResolveScalarField = ext.Summary.OpeningValue"
ts.WriteLine "        Case ""closing_balance"":         ResolveScalarField = ext.Summary.ClosingValue"
ts.WriteLine "        Case ""cash_activity"":           ResolveScalarField = ext.Summary.NetDepositsWithdrawals"
ts.WriteLine "        Case ""market_change"":           ResolveScalarField = ext.Summary.ChangeInMarketValue"
ts.WriteLine "        Case ""accrued_interest_change"": ResolveScalarField = ext.Summary.ChangeInAccruedInterest"
ts.WriteLine ""
ts.WriteLine "        ' Summary sub-fields"
ts.WriteLine "        Case ""summary.account_name"":            ResolveScalarField = ext.Summary.AccountName"
ts.WriteLine "        Case ""summary.friendly_name"":           ResolveScalarField = ext.Summary.FriendlyName"
ts.WriteLine "        Case ""summary.account_number"":          ResolveScalarField = ext.Summary.AccountNumber"
ts.WriteLine "        Case ""summary.financial_advisor"":       ResolveScalarField = ext.Summary.FinancialAdvisor"
ts.WriteLine "        Case ""summary.statement_period"":        ResolveScalarField = ext.Summary.StatementPeriod"
ts.WriteLine "        Case ""summary.deposits_transferred_in"": ResolveScalarField = ext.Summary.DepositsTransferredIn"
ts.WriteLine "        Case ""summary.net_deposits_withdrawals"": ResolveScalarField = ext.Summary.NetDepositsWithdrawals"
ts.WriteLine "        Case ""summary.dividend_interest_income"": ResolveScalarField = ext.Summary.DividendInterestIncome"
ts.WriteLine "        Case ""summary.market_change_month"":     ResolveScalarField = ext.Summary.ChangeInMarketValueMonth"
ts.WriteLine ""
ts.WriteLine "        ' Income (month only -- no YTD in UDT)"
ts.WriteLine "        Case ""income.total_month"":                  ResolveScalarField = ext.Income.TotalMonth"
ts.WriteLine "        Case ""income.taxable_dividends_month"":      ResolveScalarField = ext.Income.TaxableDividendsMonth"
ts.WriteLine "        Case ""income.tax_exempt_dividends_month"":   ResolveScalarField = ext.Income.TaxExemptDividendsMonth"
ts.WriteLine "        Case ""income.taxable_interest_month"":       ResolveScalarField = ext.Income.TaxableInterestMonth"
ts.WriteLine "        Case ""income.tax_exempt_interest_month"":    ResolveScalarField = ext.Income.TaxExemptInterestMonth"
ts.WriteLine "        Case ""income.miscellaneous_month"":          ResolveScalarField = ext.Income.MiscellaneousMonth"
ts.WriteLine "        Case ""income.accrued_interest_received"":    ResolveScalarField = ext.Income.AccruedInterestReceived"
ts.WriteLine ""
ts.WriteLine "        ' Gains"
ts.WriteLine "        Case ""gains.short_term_month"":      ResolveScalarField = ext.Gains.ShortTermRealizedMonth"
ts.WriteLine "        Case ""gains.short_term_ytd"":        ResolveScalarField = ext.Gains.ShortTermRealizedYtd"
ts.WriteLine "        Case ""gains.long_term_month"":       ResolveScalarField = ext.Gains.LongTermRealizedMonth"
ts.WriteLine "        Case ""gains.long_term_ytd"":         ResolveScalarField = ext.Gains.LongTermRealizedYtd"
ts.WriteLine "        Case ""gains.short_term_unrealized"": ResolveScalarField = ext.Gains.ShortTermUnrealized"
ts.WriteLine "        Case ""gains.long_term_unrealized"":  ResolveScalarField = ext.Gains.LongTermUnrealized"
ts.WriteLine "        Case ""gains.total_realized_month"":  ResolveScalarField = ext.Gains.TotalRealizedMonth"
ts.WriteLine "        Case ""gains.total_realized_ytd"":    ResolveScalarField = ext.Gains.TotalRealizedYtd"
ts.WriteLine "        Case ""gains.total_unrealized"":      ResolveScalarField = ext.Gains.TotalUnrealized"
ts.WriteLine ""
ts.WriteLine "        Case Else"
ts.WriteLine "            ResolveScalarField = Empty"
ts.WriteLine "    End Select"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' IsTextField -- returns True if the field path resolves to a text value"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function IsTextField(ByVal path As String) As Boolean"
ts.WriteLine "    Dim colName As String"
ts.WriteLine "    Select Case LCase$(path)"
ts.WriteLine "        Case ""summary.account_name"", ""summary.friendly_name"", ""summary.account_number"", _"
ts.WriteLine "             ""summary.financial_advisor"", ""summary.statement_period"""
ts.WriteLine "            IsTextField = True"
ts.WriteLine "        Case Else"
ts.WriteLine "            ' Array text fields"
ts.WriteLine "            If InStr(1, path, ""[]."", vbTextCompare) > 0 Then"
ts.WriteLine "                colName = LCase$(Mid$(path, InStr(1, path, ""[]."") + 3))"
ts.WriteLine "                Select Case colName"
ts.WriteLine "                    Case ""description"", ""symbol"", ""cusip"", ""asset_type"", _"
ts.WriteLine "                         ""date"", ""activity"", ""ref_number"", ""category"""
ts.WriteLine "                        IsTextField = True"
ts.WriteLine "                End Select"
ts.WriteLine "            End If"
ts.WriteLine "    End Select"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
