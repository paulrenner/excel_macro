ts.WriteLine "    MsgBox ""Wrote "" & portfolio.AccountCount & "" account(s) to QPR:"" & vbCrLf & vbCrLf & summaryLines, vbInformation, ""QPR Writer"""
ts.WriteLine "    Exit Sub"
