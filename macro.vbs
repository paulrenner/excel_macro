  ts.WriteLine "            prevSheet = cu.Sheet"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "            ' Holdings detail rows (grouped)"
  ts.WriteLine "            If cu.HoldingsDetailCount > 0 Then"
  ts.WriteLine "                Dim hdStart As Long"
  ts.WriteLine "                hdStart = r"
  ts.WriteLine "                ' Detail header"
  ts.WriteLine "                ws.Cells(r, 1).Value = ""Account"""
  ts.WriteLine "                ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "                ws.Cells(r, 1).Font.Size = 9"
  ts.WriteLine "                ws.Cells(r, 1).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                MergeWrite ws, r, 2, 4, ""Holdings"""
  ts.WriteLine "                ws.Range(ws.Cells(r, 2), ws.Cells(r, 4)).Font.Bold = True"
  ts.WriteLine "                ws.Range(ws.Cells(r, 2), ws.Cells(r, 4)).Font.Size = 9"
  ts.WriteLine "                ws.Range(ws.Cells(r, 2), ws.Cells(r, 4)).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                MergeWrite ws, r, 5, 6, ""Value"", -4152"
  ts.WriteLine "                ws.Range(ws.Cells(r, 5), ws.Cells(r, 6)).Font.Bold = True"
  ts.WriteLine "                ws.Range(ws.Cells(r, 5), ws.Cells(r, 6)).Font.Size = 9"
  ts.WriteLine "                ws.Range(ws.Cells(r, 5), ws.Cells(r, 6)).Font.Color = RGB(128, 128, 128)"
