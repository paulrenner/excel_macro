  ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
  ts.WriteLine "        Dim inc As UBSExtract.IncomeDetail"
  ts.WriteLine "        inc = portfolio.Accounts(i).Extraction.Income"
  ts.WriteLine "        totalInc.TaxableDividendsMonth = totalInc.TaxableDividendsMonth + inc.TaxableDividendsMonth"
  ts.WriteLine "        totalInc.TaxExemptDividendsMonth = totalInc.TaxExemptDividendsMonth + inc.TaxExemptDividendsMonth"
  ts.WriteLine "        totalInc.TaxableInterestMonth = totalInc.TaxableInterestMonth + inc.TaxableInterestMonth"
  ts.WriteLine "        totalInc.TaxExemptInterestMonth = totalInc.TaxExemptInterestMonth + inc.TaxExemptInterestMonth"
  ts.WriteLine "        totalInc.MiscellaneousMonth = totalInc.MiscellaneousMonth + inc.MiscellaneousMonth"
  ts.WriteLine "        totalInc.TotalMonth = totalInc.TotalMonth + inc.TotalMonth"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    r = RenderIncomeTable(ws, r, totalInc, ""Income (Portfolio Total)"")"
  ts.WriteLine "    RenderPortfolioIncome = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Portfolio-level gains (aggregated)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderPortfolioGains(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction) As Long"
