  ts.WriteLine "' Template analysis rendering"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderTemplateAnalysis(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef result As DataMapper.DataMapResult, ByVal templateName As String) As Long"
  ts.WriteLine ""
  ts.WriteLine "    WriteGroupHeader ws, r, ""TEMPLATE ANALYSIS "" & ChrW$(8212) & "" "" & templateName"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Collect and render alert sections"
  ts.WriteLine "    Dim ai As Long"
  ts.WriteLine "    Dim tmpMsgs() As String"
  ts.WriteLine "    Dim tmpCount As Long"
  ts.WriteLine ""
  ts.WriteLine "    ' Warnings"
  ts.WriteLine "    ReDim tmpMsgs(0 To result.AlertCount)"
  ts.WriteLine "    tmpCount = 0"
  ts.WriteLine "    For ai = 0 To result.AlertCount - 1"
  ts.WriteLine "        If result.Alerts(ai).AlertType = ""warning"" Then"
  ts.WriteLine "            tmpMsgs(tmpCount) = result.Alerts(ai).Message"
  ts.WriteLine "            tmpCount = tmpCount + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next ai"
  ts.WriteLine "    If tmpCount > 0 Then r = RenderAlertTextList(ws, r, ""Warnings ("" & tmpCount & "")"", tmpMsgs, tmpCount)"
  ts.WriteLine ""
  ts.WriteLine "    ' Phantom Mappings"
  ts.WriteLine "    ReDim tmpMsgs(0 To result.AlertCount)"
  ts.WriteLine "    tmpCount = 0"
  ts.WriteLine "    For ai = 0 To result.AlertCount - 1"
  ts.WriteLine "        If result.Alerts(ai).AlertType = ""phantom"" Then"
  ts.WriteLine "            tmpMsgs(tmpCount) = result.Alerts(ai).Message"
  ts.WriteLine "            tmpCount = tmpCount + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next ai"
  ts.WriteLine "    If tmpCount > 0 Then r = RenderAlertTextList(ws, r, ""Phantom Mappings ("" & tmpCount & "")"", tmpMsgs, tmpCount)"
  ts.WriteLine ""
  ts.WriteLine "    ' Unmapped Holdings"
  ts.WriteLine "    ReDim tmpMsgs(0 To result.AlertCount)"
  ts.WriteLine "    tmpCount = 0"
  ts.WriteLine "    For ai = 0 To result.AlertCount - 1"
  ts.WriteLine "        If result.Alerts(ai).AlertType = ""unmapped"" Then"
  ts.WriteLine "            tmpMsgs(tmpCount) = result.Alerts(ai).Message"
  ts.WriteLine "            tmpCount = tmpCount + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next ai"
  ts.WriteLine "    If tmpCount > 0 Then r = RenderAlertTextList(ws, r, ""Unmapped Holdings ("" & tmpCount & "")"", tmpMsgs, tmpCount)"
  ts.WriteLine ""
  ts.WriteLine "    ' Uncovered Accounts — parse Chr$(1)-delimited messages into UncoveredAccount array"
  ts.WriteLine "    Dim uncoveredCount As Long"
  ts.WriteLine "    uncoveredCount = 0"
  ts.WriteLine "    For ai = 0 To result.AlertCount - 1"
  ts.WriteLine "        If result.Alerts(ai).AlertType = ""uncovered"" Then uncoveredCount = uncoveredCount + 1"
  ts.WriteLine "    Next ai"
  ts.WriteLine "    If uncoveredCount > 0 Then"
  ts.WriteLine "        Dim uncAccts() As QPRWriter.UncoveredAccount"
  ts.WriteLine "        ReDim uncAccts(0 To uncoveredCount - 1)"
  ts.WriteLine "        Dim uIdx As Long"
  ts.WriteLine "        uIdx = 0"
  ts.WriteLine "        Dim uParts() As String"
  ts.WriteLine "        For ai = 0 To result.AlertCount - 1"
  ts.WriteLine "            If result.Alerts(ai).AlertType = ""uncovered"" Then"
  ts.WriteLine "                uParts = Split(result.Alerts(ai).Message, Chr$(1))"
  ts.WriteLine "                uncAccts(uIdx).AccountNumber = uParts(0)"
  ts.WriteLine "                uncAccts(uIdx).AccountName = uParts(1)"
  ts.WriteLine "                If UBound(uParts) >= 2 Then"
  ts.WriteLine "                    If IsNumeric(uParts(2)) Then uncAccts(uIdx).ClosingValue = CDbl(uParts(2))"
  ts.WriteLine "                End If"
  ts.WriteLine "                uIdx = uIdx + 1"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next ai"
  ts.WriteLine "        r = RenderUncoveredTable(ws, r, ""Uncovered Accounts ("" & uncoveredCount & "")"", uncAccts, uncoveredCount)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Phantom Accounts"
  ts.WriteLine "    ReDim tmpMsgs(0 To result.AlertCount)"
  ts.WriteLine "    tmpCount = 0"
  ts.WriteLine "    For ai = 0 To result.AlertCount - 1"
  ts.WriteLine "        If result.Alerts(ai).AlertType = ""phantom_account"" Then"
  ts.WriteLine "            tmpMsgs(tmpCount) = result.Alerts(ai).Message"
  ts.WriteLine "            tmpCount = tmpCount + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next ai"
  ts.WriteLine "    If tmpCount > 0 Then r = RenderAlertTextList(ws, r, ""Phantom Accounts ("" & tmpCount & "")"", tmpMsgs, tmpCount)"
  ts.WriteLine ""
  ts.WriteLine "    r = r + 1  ' spacer after alert sections"
  ts.WriteLine ""
  ts.WriteLine "    ' Cell updates preview — Sheet=A, Cell=B, Account=C, Field=D-F, Filter=G-H, Pct=I, Value=J"
  ts.WriteLine "    If result.ValueCount > 0 Then"
  ts.WriteLine "        ' Build bucket index: group values by Sheet|Cell"
  ts.WriteLine "        Dim bucketDict As Object"
  ts.WriteLine "        Set bucketDict = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "        Dim bucketOrder() As String"
  ts.WriteLine "        Dim bCount As Long"
  ts.WriteLine "        bCount = 0"
  ts.WriteLine "        ReDim bucketOrder(0 To result.ValueCount - 1)"
  ts.WriteLine ""
  ts.WriteLine "        Dim vi As Long"
  ts.WriteLine "        Dim bKey As String"
  ts.WriteLine "        For vi = 0 To result.ValueCount - 1"
  ts.WriteLine "            bKey = result.Values(vi).TargetSheet & ""|"" & result.Values(vi).TargetCell"
  ts.WriteLine "            If Not bucketDict.Exists(bKey) Then"
  ts.WriteLine "                bucketDict(bKey) = CStr(vi)"
  ts.WriteLine "                bucketOrder(bCount) = bKey"
  ts.WriteLine "                bCount = bCount + 1"
  ts.WriteLine "            Else"
  ts.WriteLine "                bucketDict(bKey) = bucketDict(bKey) & "","" & CStr(vi)"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next vi"
  ts.WriteLine ""
  ts.WriteLine "        ' Store bucket count for button label"
  ts.WriteLine "        mTemplateValueCount = bCount"
  ts.WriteLine ""
  ts.WriteLine "        WriteSubHeader ws, r, bCount & "" cell update(s) to apply:"""
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim tvH() As String, tvS() As Long, tvE() As Long, tvA() As Long"
  ts.WriteLine "        ReDim tvH(1 To 7): ReDim tvS(1 To 7): ReDim tvE(1 To 7): ReDim tvA(1 To 7)"
  ts.WriteLine "        tvH(1) = ""Sheet"": tvS(1) = 1: tvE(1) = 1: tvA(1) = -4131"
  ts.WriteLine "        tvH(2) = ""Cell"": tvS(2) = 2: tvE(2) = 2: tvA(2) = -4131"
  ts.WriteLine "        tvH(3) = ""Account"": tvS(3) = 3: tvE(3) = 3: tvA(3) = -4131"
  ts.WriteLine "        tvH(4) = ""Field"": tvS(4) = 4: tvE(4) = 6: tvA(4) = -4131"
  ts.WriteLine "        tvH(5) = ""Filter"": tvS(5) = 7: tvE(5) = 8: tvA(5) = -4131"
  ts.WriteLine "        tvH(6) = ""Pct"": tvS(6) = 9: tvE(6) = 9: tvA(6) = -4152"
  ts.WriteLine "        tvH(7) = ""Value"": tvS(7) = 10: tvE(7) = 10: tvA(7) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, tvH, tvS, tvE, tvA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "        ' Render each bucket"
  ts.WriteLine "        Dim bi As Long"
  ts.WriteLine "        Dim pctStr As String"
  ts.WriteLine "        For bi = 0 To bCount - 1"
  ts.WriteLine "            bKey = bucketOrder(bi)"
  ts.WriteLine "            Dim idxList() As String"
  ts.WriteLine "            idxList = Split(bucketDict(bKey), "","")"
  ts.WriteLine "            Dim idxCount As Long"
  ts.WriteLine "            idxCount = UBound(idxList) + 1"
  ts.WriteLine "            Dim firstIdx As Long"
  ts.WriteLine "            firstIdx = CLng(idxList(0))"
  ts.WriteLine ""
  ts.WriteLine "            If idxCount = 1 Then"
  ts.WriteLine "                ' Single source: flat row"
  ts.WriteLine "                ws.Cells(r, 1).Value = result.Values(firstIdx).TargetSheet"
  ts.WriteLine "                ws.Cells(r, 2).Value = result.Values(firstIdx).TargetCell"
  ts.WriteLine "                ws.Cells(r, 3).Value = result.Values(firstIdx).SourceAccount"
  ts.WriteLine "                MergeWrite ws, r, 4, 6, result.Values(firstIdx).SourceField"
  ts.WriteLine "                MergeWrite ws, r, 7, 8, result.Values(firstIdx).SourceFilter"
  ts.WriteLine "                If result.Values(firstIdx).SourcePct <> 1# Then"
  ts.WriteLine "                    pctStr = Format$(result.Values(firstIdx).SourcePct * 100, ""0"") & ""%"""
  ts.WriteLine "                Else"
  ts.WriteLine "                    pctStr = """""
  ts.WriteLine "                End If"
  ts.WriteLine "                ws.Cells(r, 9).Value = pctStr"
  ts.WriteLine "                ws.Cells(r, 9).HorizontalAlignment = -4152"
  ts.WriteLine "                If result.Values(firstIdx).IsText Then"
  ts.WriteLine "                    ws.Cells(r, 10).Value = result.Values(firstIdx).TextValue"
  ts.WriteLine "                    ws.Cells(r, 10).HorizontalAlignment = -4152"
  ts.WriteLine "                Else"
  ts.WriteLine "                    ws.Cells(r, 10).Value = result.Values(firstIdx).Value"
  ts.WriteLine "                    ws.Cells(r, 10).NumberFormat = ""$ #,##0.00;-$ #,##0.00;""""-"""""""
  ts.WriteLine "                    ws.Cells(r, 10).HorizontalAlignment = -4152"
  ts.WriteLine "                    If result.Values(firstIdx).Value < 0 Then ws.Cells(r, 10).Font.Color = CLR_NEG"
  ts.WriteLine "                End If"
  ts.WriteLine "                r = r + 1"
  ts.WriteLine "            Else"
  ts.WriteLine "                ' Multi-source: summary row with aggregated value"
  ts.WriteLine "                Dim aggValue As Double"
  ts.WriteLine "                aggValue = 0"
  ts.WriteLine "                Dim aggIsText As Boolean"
  ts.WriteLine "                aggIsText = result.Values(firstIdx).IsText"
  ts.WriteLine "                Dim ji As Long"
  ts.WriteLine "                For ji = 0 To idxCount - 1"
  ts.WriteLine "                    If Not result.Values(CLng(idxList(ji))).IsText Then"
  ts.WriteLine "                        aggValue = aggValue + result.Values(CLng(idxList(ji))).Value"
  ts.WriteLine "                    End If"
  ts.WriteLine "                Next ji"
  ts.WriteLine ""
  ts.WriteLine "                ws.Cells(r, 1).Value = result.Values(firstIdx).TargetSheet"
  ts.WriteLine "                ws.Cells(r, 2).Value = result.Values(firstIdx).TargetCell"
  ts.WriteLine "                MergeWrite ws, r, 3, 8, ""("" & idxCount & "" sources)"""
  ts.WriteLine "                If aggIsText Then"
  ts.WriteLine "                    ws.Cells(r, 10).Value = result.Values(firstIdx).TextValue"
  ts.WriteLine "                    ws.Cells(r, 10).HorizontalAlignment = -4152"
  ts.WriteLine "                Else"
  ts.WriteLine "                    ws.Cells(r, 10).Value = aggValue"
  ts.WriteLine "                    ws.Cells(r, 10).NumberFormat = ""$ #,##0.00;-$ #,##0.00;""""-"""""""
  ts.WriteLine "                    ws.Cells(r, 10).HorizontalAlignment = -4152"
  ts.WriteLine "                    If aggValue < 0 Then ws.Cells(r, 10).Font.Color = CLR_NEG"
  ts.WriteLine "                End If"
  ts.WriteLine "                r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "                ' Detail rows (grouped, collapsed by default)"
  ts.WriteLine "                Dim detailStart As Long"
  ts.WriteLine "                detailStart = r"
  ts.WriteLine "                Dim dIdx As Long"
  ts.WriteLine "                For ji = 0 To idxCount - 1"
  ts.WriteLine "                    dIdx = CLng(idxList(ji))"
  ts.WriteLine "                    ws.Cells(r, 3).Value = result.Values(dIdx).SourceAccount"
  ts.WriteLine "                    ws.Cells(r, 3).Font.Size = 9"
  ts.WriteLine "                    MergeWrite ws, r, 4, 6, result.Values(dIdx).SourceField"
  ts.WriteLine "                    ws.Range(ws.Cells(r, 4), ws.Cells(r, 6)).Font.Size = 9"
  ts.WriteLine "                    MergeWrite ws, r, 7, 8, result.Values(dIdx).SourceFilter"
  ts.WriteLine "                    ws.Range(ws.Cells(r, 7), ws.Cells(r, 8)).Font.Size = 9"
  ts.WriteLine "                    If result.Values(dIdx).SourcePct <> 1# Then"
  ts.WriteLine "                        pctStr = Format$(result.Values(dIdx).SourcePct * 100, ""0"") & ""%"""
  ts.WriteLine "                    Else"
  ts.WriteLine "                        pctStr = """""
  ts.WriteLine "                    End If"
  ts.WriteLine "                    ws.Cells(r, 9).Value = pctStr"
  ts.WriteLine "                    ws.Cells(r, 9).HorizontalAlignment = -4152"
  ts.WriteLine "                    ws.Cells(r, 9).Font.Size = 9"
  ts.WriteLine "                    If result.Values(dIdx).IsText Then"
  ts.WriteLine "                        ws.Cells(r, 10).Value = result.Values(dIdx).TextValue"
  ts.WriteLine "                        ws.Cells(r, 10).HorizontalAlignment = -4152"
  ts.WriteLine "                    Else"
  ts.WriteLine "                        ws.Cells(r, 10).Value = result.Values(dIdx).Value"
  ts.WriteLine "                        ws.Cells(r, 10).NumberFormat = ""$ #,##0.00;-$ #,##0.00;""""-"""""""
  ts.WriteLine "                        ws.Cells(r, 10).HorizontalAlignment = -4152"
  ts.WriteLine "                        If result.Values(dIdx).Value < 0 Then ws.Cells(r, 10).Font.Color = CLR_NEG"
  ts.WriteLine "                    End If"
  ts.WriteLine "                    ws.Cells(r, 10).Font.Size = 9"
  ts.WriteLine "                    ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = RGB(248, 249, 250)"
  ts.WriteLine "                    r = r + 1"
  ts.WriteLine "                Next ji"
  ts.WriteLine "                On Error Resume Next"
  ts.WriteLine "                ws.Rows(detailStart & "":"" & r - 1).Group"
  ts.WriteLine "                On Error GoTo 0"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next bi"
  ts.WriteLine "    Else"
  ts.WriteLine "        MergeWrite ws, r, 1, GCOLS, ""No cell updates "" & ChrW$(8212) & "" no mapping rows matched portfolio data."""
  ts.WriteLine "        ws.Cells(r, 1).Font.Italic = True"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' (Apply Template button now rendered in top button bar by AddActionButtons)"
  ts.WriteLine ""
  ts.WriteLine "    RenderTemplateAnalysis = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Unclassified securities section (with data validation dropdowns)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderUnclassifiedSection(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef securities() As QPRWriter.UnclassifiedSecurity, _"
  ts.WriteLine "    ByVal secCount As Long, _"
  ts.WriteLine "    ByRef allocOpts() As String, ByVal optCount As Long) As Long"
  ts.WriteLine ""
  ts.WriteLine "    If secCount = 0 Then"
  ts.WriteLine "        RenderUnclassifiedSection = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    mUnclassStartRow = r"
  ts.WriteLine ""
  ts.WriteLine "    WriteHeader ws, r, ""UNCLASSIFIED SECURITIES ("" & secCount & "")"""
  ts.WriteLine "    ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_WARN_BG"
  ts.WriteLine "    ws.Cells(r, 1).Font.Color = RGB(128, 64, 0)"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Table headers — Symbol=1, Description=2-5, Account=6-7, Classification=8-9"
  ts.WriteLine "    Dim uHdrs() As String, uSC() As Long, uEC() As Long, uAL() As Long"
  ts.WriteLine "    ReDim uHdrs(1 To 4): ReDim uSC(1 To 4): ReDim uEC(1 To 4): ReDim uAL(1 To 4)"
  ts.WriteLine "    uHdrs(1) = ""Symbol"": uSC(1) = 1: uEC(1) = 1: uAL(1) = -4108"
  ts.WriteLine "    uHdrs(2) = ""Description"": uSC(2) = 2: uEC(2) = 5: uAL(2) = -4131"
  ts.WriteLine "    uHdrs(3) = ""Account"": uSC(3) = 6: uEC(3) = 7: uAL(3) = -4131"
  ts.WriteLine "    uHdrs(4) = ""Classification"": uSC(4) = 8: uEC(4) = 9: uAL(4) = -4131"
  ts.WriteLine "    WriteTableHeadersMerged ws, r, uHdrs, uSC, uEC, uAL"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Build validation list"
  ts.WriteLine "    Dim validationList As String"
  ts.WriteLine "    validationList = ""(skip)"""
  ts.WriteLine "    Dim oi As Long"
  ts.WriteLine "    For oi = 1 To optCount"
  ts.WriteLine "        validationList = validationList & "","" & allocOpts(oi)"
  ts.WriteLine "    Next oi"
  ts.WriteLine ""
  ts.WriteLine "    ' Render securities — Symbol=1, Description=2-5, Account=6-7, Dropdown=8-9, Departed=10"
  ts.WriteLine "    Dim si As Long"
  ts.WriteLine "    For si = 1 To secCount"
  ts.WriteLine "        ws.Cells(r, 1).NumberFormat = ""@"""
  ts.WriteLine "        ws.Cells(r, 1).Value = securities(si).Symbol"
  ts.WriteLine "        ws.Cells(r, 1).HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "        MergeWrite ws, r, 2, 5, securities(si).Description"
  ts.WriteLine "        MergeWrite ws, r, 6, 7, securities(si).AccountNumber"
  ts.WriteLine "        ' Data validation dropdown in merged cols 8-9"
  ts.WriteLine "        ws.Range(ws.Cells(r, 8), ws.Cells(r, 9)).Merge"
  ts.WriteLine "        With ws.Cells(r, 8).Validation"
  ts.WriteLine "            .Delete"
  ts.WriteLine "            .Add Type:=3, AlertStyle:=1, Operator:=1, Formula1:=validationList"
  ts.WriteLine "            .IgnoreBlank = True"
  ts.WriteLine "            .InCellDropdown = True"
  ts.WriteLine "        End With"
  ts.WriteLine "        ws.Cells(r, 8).Value = ""(skip)"""
  ts.WriteLine "        If securities(si).IsDeparted Then"
  ts.WriteLine "            ws.Cells(r, 1).Font.Italic = True"
  ts.WriteLine "            ws.Range(ws.Cells(r, 2), ws.Cells(r, 5)).Font.Italic = True"
  ts.WriteLine "            ws.Cells(r, 10).Value = ""(departed)"""
  ts.WriteLine "            ws.Cells(r, 10).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "            ws.Cells(r, 10).Font.Italic = True"
  ts.WriteLine "        End If"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next si"
  ts.WriteLine ""
  ts.WriteLine "    ' (Recompute button now rendered in top button bar by AddActionButtons)"
  ts.WriteLine ""
  ts.WriteLine "    mUnclassEndRow = r - 1"
  ts.WriteLine ""
  ts.WriteLine "    RenderUnclassifiedSection = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Button Handlers (Public Subs assigned to form control buttons)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ViewerSheet_Apply()"
  ts.WriteLine "    On Error GoTo ApplyErr"
  ts.WriteLine ""
  ts.WriteLine "    If mViewerApplied Then"
  ts.WriteLine "        MsgBox ""QPR has already been applied. Use Recompute to re-analyze first."", vbInformation, ""Apply QPR"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    If mQprWb Is Nothing Then"
  ts.WriteLine "        MsgBox ""No QPR workbook loaded."", vbExclamation, ""Apply QPR"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim prevCalc As Long"
  ts.WriteLine "    Dim writeResult As String"
  ts.WriteLine "    Dim totalWritten As Long"
  ts.WriteLine "    Dim summaryParts() As String"
  ts.WriteLine "    Dim summaryPartCount As Long"
  ts.WriteLine "    summaryPartCount = 0"
  ts.WriteLine "    Dim writeWb As Workbook"
  ts.WriteLine ""
  ts.WriteLine "    ' Build QPR path list"
  ts.WriteLine "    Dim qprPaths As Object"
  ts.WriteLine "    Set qprPaths = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    If Not mQprWorkbooks Is Nothing Then"
  ts.WriteLine "        If mQprWorkbooks.Count > 0 Then"
  ts.WriteLine "            Dim mk As Variant"
  ts.WriteLine "            For Each mk In mQprWorkbooks.Keys"
  ts.WriteLine "                qprPaths.Add CStr(mk), mQprWorkbooks(mk)"
  ts.WriteLine "            Next mk"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine "    If qprPaths.Count = 0 Then"
  ts.WriteLine "        Dim singlePath As String"
  ts.WriteLine "        singlePath = mQprPath"
  ts.WriteLine "        If Len(singlePath) = 0 Then singlePath = mQprWb.FullName"
  ts.WriteLine "        qprPaths.Add singlePath, mQprWb"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Writing to QPR..."""
  ts.WriteLine ""
  ts.WriteLine "    ' Close all read-only QPRs before reopening read-write"
  ts.WriteLine "    Dim ck As Variant"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    For Each ck In qprPaths.Keys"
  ts.WriteLine "        Dim roWb As Workbook"
  ts.WriteLine "        Set roWb = qprPaths(ck)"
  ts.WriteLine "        If Not roWb Is Nothing Then"
  ts.WriteLine "            If roWb.ReadOnly Then roWb.Close False"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next ck"
  ts.WriteLine "    On Error GoTo ApplyErr"
  ts.WriteLine "    Set mQprWb = Nothing"
  ts.WriteLine "    If Not mQprWorkbooks Is Nothing Then mQprWorkbooks.RemoveAll"
  ts.WriteLine ""
  ts.WriteLine "    prevCalc = Application.Calculation"
  ts.WriteLine "    Application.Calculation = xlCalculationManual"
  ts.WriteLine "    totalWritten = 0"
  ts.WriteLine ""
  ts.WriteLine "    Dim qprFilesWritten As Long"
  ts.WriteLine "    qprFilesWritten = 0"
  ts.WriteLine ""
  ts.WriteLine "    ' Write to each QPR"
  ts.WriteLine "    Dim pk As Variant"
  ts.WriteLine "    For Each pk In qprPaths.Keys"
  ts.WriteLine "        Dim qprPath As String"
  ts.WriteLine "        qprPath = CStr(pk)"
  ts.WriteLine ""
  ts.WriteLine "        Set writeWb = QPRWriter.GetOpenWorkbook(qprPath)"
  ts.WriteLine "        If writeWb Is Nothing Then"
  ts.WriteLine "            Set writeWb = Workbooks.Open(qprPath, UpdateLinks:=False)"
  ts.WriteLine "            writeWb.Windows(1).Visible = False"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        writeResult = """""
  ts.WriteLine "        QPRWriter.WriteAllQPR mPortfolio, writeWb, True, writeResult, mOverrides"
  ts.WriteLine "        If Left$(writeResult, 4) <> ""SKIP"" Then"
  ts.WriteLine "            summaryPartCount = summaryPartCount + 1"
  ts.WriteLine "            ReDim Preserve summaryParts(1 To summaryPartCount)"
  ts.WriteLine "            summaryParts(summaryPartCount) = writeResult"
  ts.WriteLine "            totalWritten = totalWritten + 1"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Validate QPR before saving"
  ts.WriteLine "        Dim validationOK As Boolean"
  ts.WriteLine "        validationOK = ValidateQprBeforeSave(writeWb)"
  ts.WriteLine "        If Not validationOK Then"
  ts.WriteLine "            Application.Calculation = prevCalc"
  ts.WriteLine "            writeWb.Close False"
  ts.WriteLine "            Set writeWb = Nothing"
  ts.WriteLine "            MsgBox ""QPR validation failed for "" & Dir(qprPath) & _"
  ts.WriteLine "                "" "" & ChrW$(8212) & "" Mapping sheet appears damaged. File was NOT saved."", vbCritical, ""Apply QPR"""
  ts.WriteLine "            Application.StatusBar = """""
  ts.WriteLine "            Exit Sub"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        writeWb.Windows(1).Visible = True"
  ts.WriteLine "        writeWb.Save"
  ts.WriteLine "        writeWb.Close False"
  ts.WriteLine "        Set writeWb = Nothing"
  ts.WriteLine "        qprFilesWritten = qprFilesWritten + 1"
  ts.WriteLine "    Next pk"
  ts.WriteLine ""
  ts.WriteLine "    Application.Calculation = prevCalc"
  ts.WriteLine "    mViewerApplied = True"
  ts.WriteLine ""
  ts.WriteLine "    ' Update status in reserved row"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Viewer"")"
  ts.WriteLine "    If mStatusRow > 0 Then"
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Value = ""QPR updated successfully "" & ChrW$(8212) & "" "" & qprFilesWritten & "" file(s) written"""
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Font.Color = RGB(21, 87, 36)"
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Font.Bold = True"
  ts.WriteLine "        ws.Range(ws.Cells(mStatusRow, 1), ws.Cells(mStatusRow, GCOLS)).Merge"
  ts.WriteLine "        ws.Range(ws.Cells(mStatusRow, 1), ws.Cells(mStatusRow, GCOLS)).Interior.Color = CLR_PASS_BG"
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Select"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim statusMsg As String"
  ts.WriteLine "    statusMsg = ""QPR updated -- "" & totalWritten & "" account(s) written to "" & qprFilesWritten & "" QPR(s)"""
  ts.WriteLine "    Dim lastBak As String"
  ts.WriteLine "    lastBak = QPRWriter.GetLastBackupPath()"
  ts.WriteLine "    If Len(lastBak) > 0 Then statusMsg = statusMsg & "" (backup: "" & Dir(lastBak) & "")"""
  ts.WriteLine "    Application.StatusBar = statusMsg"
  ts.WriteLine "    Application.OnTime Now + TimeSerial(0, 0, 5), ""ClearStatusBar"""
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "ApplyErr:"
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    If Not writeWb Is Nothing Then writeWb.Close False"
  ts.WriteLine "    Application.Calculation = prevCalc"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    MsgBox ""Error applying QPR: "" & Err.Description, vbCritical, ""Apply QPR"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ViewerSheet_ApplyTemplate()"
  ts.WriteLine "    On Error GoTo ApplyTplErr"
  ts.WriteLine ""
  ts.WriteLine "    If mTemplateApplied Then"
  ts.WriteLine "        MsgBox ""Template has already been applied. Use Recompute to re-analyze first."", vbInformation, ""Apply Template"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    If mTemplateWb Is Nothing Then"
  ts.WriteLine "        MsgBox ""No template workbook loaded."", vbExclamation, ""Apply Template"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine "    If mTemplateResult.ValueCount = 0 Then"
  ts.WriteLine "        MsgBox ""No updates to apply."", vbInformation, ""Apply Template"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Writing to template..."""
  ts.WriteLine ""
  ts.WriteLine "    Dim tplPath As String"
  ts.WriteLine "    tplPath = mTemplateWb.FullName"
  ts.WriteLine ""
  ts.WriteLine "    ' Close read-only copy, reopen read-write"
  ts.WriteLine "    If mTemplateWb.ReadOnly Then"
  ts.WriteLine "        mTemplateWb.Close False"
  ts.WriteLine "        Set mTemplateWb = Nothing"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim writeWb As Workbook"
  ts.WriteLine "    Set writeWb = Nothing"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set writeWb = Workbooks(Dir(tplPath))"
  ts.WriteLine "    On Error GoTo ApplyTplErr"
  ts.WriteLine "    If writeWb Is Nothing Then"
  ts.WriteLine "        Set writeWb = Workbooks.Open(tplPath, UpdateLinks:=False)"
  ts.WriteLine "        writeWb.Windows(1).Visible = False"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Backup template before writing"
  ts.WriteLine "    Dim tplDotPos As Long"
  ts.WriteLine "    Dim tplBase As String"
  ts.WriteLine "    Dim tplExt As String"
  ts.WriteLine "    Dim tplBackup As String"
  ts.WriteLine "    tplDotPos = InStrRev(tplPath, ""."")"
  ts.WriteLine "    If tplDotPos > 0 Then"
  ts.WriteLine "        tplBase = Left$(tplPath, tplDotPos - 1)"
  ts.WriteLine "        tplExt = Mid$(tplPath, tplDotPos)"
  ts.WriteLine "    Else"
  ts.WriteLine "        tplBase = tplPath"
  ts.WriteLine "        tplExt = """""
  ts.WriteLine "    End If"
  ts.WriteLine "    tplBackup = tplBase & ""_backup_"" & Format$(Now, ""yyyymmdd\_hhmmss"") & tplExt"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    writeWb.SaveCopyAs tplBackup"
  ts.WriteLine "    On Error GoTo ApplyTplErr"
  ts.WriteLine ""
  ts.WriteLine "    ' Write resolved values"
  ts.WriteLine "    DataMapper.WriteResults writeWb, mTemplateResult"
  ts.WriteLine ""
  ts.WriteLine "    ' Save and show"
  ts.WriteLine "    writeWb.Windows(1).Visible = True"
  ts.WriteLine "    writeWb.Save"
  ts.WriteLine "    writeWb.Close False"
  ts.WriteLine "    Set writeWb = Nothing"
  ts.WriteLine ""
  ts.WriteLine "    mTemplateApplied = True"
  ts.WriteLine ""
  ts.WriteLine "    ' Update status in reserved row"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Viewer"")"
  ts.WriteLine "    If mStatusRow > 0 Then"
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Value = ""Template updated "" & ChrW$(8212) & "" "" & Dir(tplPath) & "" saved"""
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Font.Color = RGB(21, 87, 36)"
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Font.Bold = True"
  ts.WriteLine "        ws.Range(ws.Cells(mStatusRow, 1), ws.Cells(mStatusRow, GCOLS)).Merge"
  ts.WriteLine "        ws.Range(ws.Cells(mStatusRow, 1), ws.Cells(mStatusRow, GCOLS)).Interior.Color = CLR_PASS_BG"
  ts.WriteLine "        ws.Range(ws.Cells(mStatusRow, 1), ws.Cells(mStatusRow, GCOLS)).BorderAround Weight:=4, Color:=RGB(40, 167, 69)"
  ts.WriteLine "        ws.Cells(mStatusRow, 1).Select"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Template updated -- "" & mTemplateResult.ValueCount & "" values written"""
  ts.WriteLine "    Application.OnTime Now + TimeSerial(0, 0, 5), ""ClearStatusBar"""
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "ApplyTplErr:"
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    If Not writeWb Is Nothing Then writeWb.Close False"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    MsgBox ""Error applying template: "" & Err.Description, vbCritical, ""Apply Template"""
  ts.WriteLine "End Sub"
