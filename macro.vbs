ts.WriteLine "    p(41) = ""June 20"": p(42) = ""July 20"": p(43) = ""August 20"": p(44) = ""September 20"": p(45) = ""October 20"""
ts.WriteLine "    p(46) = ""November 20"": p(47) = ""December 20"""
ts.WriteLine "    p(48) = ""Transaction"": p(49) = ""date "": p(50) = ""Cash/ATM transactions"""
