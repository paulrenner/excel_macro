  ts.WriteLine "Public Sub ViewerSheet_AddPDF()"
  ts.WriteLine "    On Error GoTo AddPdfErr"
  ts.WriteLine ""
  ts.WriteLine "    Dim fileResult As Variant"
  ts.WriteLine "    fileResult = Application.GetOpenFilename( _"
  ts.WriteLine "        FileFilter:=""PDF Files (*.pdf), *.pdf"", _"
  ts.WriteLine "        Title:=""Select additional PDF statement(s)"", _"
  ts.WriteLine "        MultiSelect:=True)"
  ts.WriteLine ""
  ts.WriteLine "    If Not IsArray(fileResult) Then"
  ts.WriteLine "        If fileResult = False Then Exit Sub"
  ts.WriteLine "        ' Single file"
  ts.WriteLine "        Dim singleFile(1 To 1) As String"
  ts.WriteLine "        singleFile(1) = CStr(fileResult)"
  ts.WriteLine "        AddPDFFiles singleFile, 1"
  ts.WriteLine "    Else"
  ts.WriteLine "        Dim fileCount As Long"
  ts.WriteLine "        fileCount = UBound(fileResult) - LBound(fileResult) + 1"
  ts.WriteLine "        Dim files() As String"
  ts.WriteLine "        ReDim files(1 To fileCount)"
  ts.WriteLine "        Dim fi As Long"
  ts.WriteLine "        For fi = LBound(fileResult) To UBound(fileResult)"
  ts.WriteLine "            files(fi - LBound(fileResult) + 1) = CStr(fileResult(fi))"
  ts.WriteLine "        Next fi"
  ts.WriteLine "        AddPDFFiles files, fileCount"
  ts.WriteLine "    End If"
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "AddPdfErr:"
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    MsgBox ""Error adding PDF: "" & Err.Description, vbCritical, ""Add PDF"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Sub AddPDFFiles(ByRef files() As String, ByVal fileCount As Long)"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    Dim rawText As String"
  ts.WriteLine "    Dim newSummaryRefs As UBSSummary.SummaryReferences"
  ts.WriteLine "    Dim newPortfolio As UBSSummary.PortfolioExtraction"
  ts.WriteLine ""
  ts.WriteLine "    For i = 1 To fileCount"
  ts.WriteLine "        Application.StatusBar = ""Extracting PDF "" & i & "" of "" & fileCount & ""..."""
  ts.WriteLine ""
  ts.WriteLine "        newPortfolio = PDFExtractorMain.ExtractPDFToPortfolioFull(files(i), rawText, newSummaryRefs)"
  ts.WriteLine ""
  ts.WriteLine "        MergePortfolioInto mAccumulatedPortfolio, newPortfolio"
  ts.WriteLine ""
  ts.WriteLine "        If newSummaryRefs.ChangeCount > 0 Then"
  ts.WriteLine "            UBSSummary.MergeSummaryRefs mSummaryRefs, newSummaryRefs"
  ts.WriteLine "            mHasCoverage = True"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        If Len(mAccumulatedRawText) > 0 Then mAccumulatedRawText = mAccumulatedRawText & vbLf & vbLf"
  ts.WriteLine "        mAccumulatedRawText = mAccumulatedRawText & ""--- PDF: "" & Dir(files(i)) & "" ---"" & vbLf & rawText"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Update portfolio reference and re-render"
  ts.WriteLine "    mPortfolio = mAccumulatedPortfolio"
  ts.WriteLine "    RenderViewerSheet mAccumulatedPortfolio"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Added "" & fileCount & "" PDF(s) -- "" & mAccumulatedPortfolio.AccountCount & "" accounts total"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ViewerSheet_AddExcel()"
  ts.WriteLine "    On Error GoTo AddExcelErr"
  ts.WriteLine ""
  ts.WriteLine "    Dim fileResult As Variant"
  ts.WriteLine "    fileResult = Application.GetOpenFilename( _"
  ts.WriteLine "        FileFilter:=""Excel Files (*.xls*), *.xls*"", _"
  ts.WriteLine "        Title:=""Select Excel workbook(s)"", _"
  ts.WriteLine "        MultiSelect:=True)"
  ts.WriteLine ""
  ts.WriteLine "    If Not IsArray(fileResult) Then"
  ts.WriteLine "        If fileResult = False Then Exit Sub"
  ts.WriteLine "        AddExcelFile CStr(fileResult)"
  ts.WriteLine "    Else"
  ts.WriteLine "        Dim fi As Long"
  ts.WriteLine "        For fi = LBound(fileResult) To UBound(fileResult)"
  ts.WriteLine "            AddExcelFile CStr(fileResult(fi))"
  ts.WriteLine "        Next fi"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Re-render to pick up any new QPR analysis or template results"
  ts.WriteLine "    If Not mQprWb Is Nothing Or Not mTemplateWb Is Nothing Then"
  ts.WriteLine "        If Not mQprWb Is Nothing Then mAutoAnalyzeQPR = True"
  ts.WriteLine "        RenderViewerSheet mAccumulatedPortfolio"
  ts.WriteLine "    End If"
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "AddExcelErr:"
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    MsgBox ""Error loading Excel: "" & Err.Description, vbCritical, ""Add Excel"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Sub AddExcelFile(ByVal filePath As String)"
  ts.WriteLine "    Dim wbName As String"
  ts.WriteLine "    wbName = Dir(filePath)"
  ts.WriteLine "    Dim wb As Workbook"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set wb = Workbooks(wbName)"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    If wb Is Nothing Then"
  ts.WriteLine "        Set wb = Workbooks.Open(filePath, UpdateLinks:=False, ReadOnly:=True)"
  ts.WriteLine "        wb.Windows(1).Visible = False"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Detect workbook type: _DataMap sheet = template, Mapping sheet = QPR"
  ts.WriteLine "    Dim sh As Worksheet"
  ts.WriteLine "    Dim hasDataMap As Boolean, hasMapping As Boolean"
  ts.WriteLine "    For Each sh In wb.Worksheets"
  ts.WriteLine "        If sh.Name = ""_DataMap"" Then hasDataMap = True"
  ts.WriteLine "        If LCase$(Trim$(sh.Name)) = ""mapping"" Then hasMapping = True"
  ts.WriteLine "    Next sh"
  ts.WriteLine ""
  ts.WriteLine "    If hasDataMap Then"
  ts.WriteLine "        ' Template workbook — confirm if replacing existing"
  ts.WriteLine "        If Not mTemplateWb Is Nothing Then"
  ts.WriteLine "            Dim ans As VbMsgBoxResult"
  ts.WriteLine "            ans = MsgBox(""A template is already loaded ("" & Dir(mTemplateWb.FullName) & "")."" & vbLf & vbLf & _"
  ts.WriteLine "                         ""Replace with "" & wbName & ""?"", vbOKCancel Or vbQuestion, ""Add Excel"")"
  ts.WriteLine "            If ans = vbCancel Then"
  ts.WriteLine "                wb.Close False"
  ts.WriteLine "                Exit Sub"
  ts.WriteLine "            End If"
  ts.WriteLine "            On Error Resume Next"
  ts.WriteLine "            mTemplateWb.Close False"
  ts.WriteLine "            On Error GoTo 0"
  ts.WriteLine "            ' Re-open in case closing the old template also closed wb (same file)"
  ts.WriteLine "            Set wb = Nothing"
  ts.WriteLine "            On Error Resume Next"
  ts.WriteLine "            Set wb = Workbooks(wbName)"
  ts.WriteLine "            On Error GoTo 0"
  ts.WriteLine "            If wb Is Nothing Then"
  ts.WriteLine "                Set wb = Workbooks.Open(filePath, UpdateLinks:=False, ReadOnly:=True)"
  ts.WriteLine "                wb.Windows(1).Visible = False"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "        Set mTemplateWb = wb"
  ts.WriteLine "        mTemplateApplied = False"
  ts.WriteLine "        Dim mapRowCount As Long"
  ts.WriteLine "        Dim mapRows() As DataMapper.DataMapRow"
  ts.WriteLine "        mapRows = DataMapper.ReadDataMap(wb, mapRowCount)"
  ts.WriteLine "        If mapRowCount > 0 Then"
  ts.WriteLine "            mTemplateResult = DataMapper.ProcessMapping(mAccumulatedPortfolio, mapRows, mapRowCount)"
  ts.WriteLine "        End If"
  ts.WriteLine "    ElseIf hasMapping Then"
  ts.WriteLine "        ' QPR workbook"
  ts.WriteLine "        If mQprWorkbooks Is Nothing Then Set mQprWorkbooks = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "        If Not mQprWorkbooks.Exists(filePath) Then"
  ts.WriteLine "            mQprWorkbooks.Add filePath, wb"
  ts.WriteLine "        End If"
  ts.WriteLine "        If mQprWb Is Nothing Then"
  ts.WriteLine "            Set mQprWb = wb"
  ts.WriteLine "            mQprPath = filePath"
  ts.WriteLine "        End If"
  ts.WriteLine "    Else"
  ts.WriteLine "        MsgBox ""Workbook '"" & wbName & ""' has neither a _DataMap sheet (template) "" & _"
  ts.WriteLine "               ""nor a Mapping sheet (QPR). File skipped."", vbExclamation, ""Add Excel"""
  ts.WriteLine "        wb.Close False"
  ts.WriteLine "    End If"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ViewerSheet_Recompute()"
  ts.WriteLine "    On Error GoTo RecomputeErr"
  ts.WriteLine ""
  ts.WriteLine "    If mQprWb Is Nothing Then Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Recomputing QPR with updated classifications..."""
  ts.WriteLine ""
  ts.WriteLine "    ' Read dropdown values from the Viewer sheet"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Viewer"")"
  ts.WriteLine ""
  ts.WriteLine "    If mOverrides Is Nothing Then Set mOverrides = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine ""
  ts.WriteLine "    ' Scan the unclassified section for dropdown values"
  ts.WriteLine "    If mUnclassStartRow > 0 And mUnclassEndRow > 0 Then"
  ts.WriteLine "        Dim r As Long"
  ts.WriteLine "        For r = mUnclassStartRow To mUnclassEndRow"
  ts.WriteLine "            Dim sym As String, acct As String, cls As String"
  ts.WriteLine "            sym = UCase$(Trim$(CStr(ws.Cells(r, 1).Value & """")))"
  ts.WriteLine "            acct = Trim$(CStr(ws.Cells(r, 6).Value & """"))"
  ts.WriteLine "            cls = Trim$(CStr(ws.Cells(r, 8).Value & """"))"
  ts.WriteLine "            If Len(sym) > 0 And Len(acct) > 0 And cls <> ""(skip)"" And Len(cls) > 0 Then"
  ts.WriteLine "                Dim key As String"
  ts.WriteLine "                key = sym & ""|"" & acct"
  ts.WriteLine "                If mOverrides.Exists(key) Then"
  ts.WriteLine "                    mOverrides(key) = cls"
  ts.WriteLine "                Else"
  ts.WriteLine "                    mOverrides.Add key, cls"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next r"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Re-render the entire viewer with updated overrides"
  ts.WriteLine "    mAutoAnalyzeQPR = True"
  ts.WriteLine "    mViewerApplied = False"
  ts.WriteLine "    mTemplateApplied = False"
  ts.WriteLine "    RenderViewerSheet mAccumulatedPortfolio"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Recompute complete"""
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "RecomputeErr:"
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    MsgBox ""Error recomputing: "" & Err.Description, vbCritical, ""Recompute"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Public Sub ViewerSheet_Cleanup()"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine ""
  ts.WriteLine "    ' Close all QPR workbooks"
  ts.WriteLine "    If Not mQprWorkbooks Is Nothing Then"
  ts.WriteLine "        Dim ck As Variant"
  ts.WriteLine "        For Each ck In mQprWorkbooks.Keys"
  ts.WriteLine "            mQprWorkbooks(ck).Close False"
  ts.WriteLine "        Next ck"
  ts.WriteLine "        mQprWorkbooks.RemoveAll"
  ts.WriteLine "    End If"
  ts.WriteLine "    If Not mQprWb Is Nothing Then mQprWb.Close False: Set mQprWb = Nothing"
  ts.WriteLine "    If Not mTemplateWb Is Nothing Then mTemplateWb.Close False: Set mTemplateWb = Nothing"
  ts.WriteLine "    ClearAccumulatedState"
  ts.WriteLine ""
  ts.WriteLine "    ' Delete viewer sheet"
  ts.WriteLine "    Application.DisplayAlerts = False"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Viewer"")"
  ts.WriteLine "    If Not ws Is Nothing Then ws.Delete"
  ts.WriteLine "    Application.DisplayAlerts = True"
  ts.WriteLine ""
  ts.WriteLine "    ' Reset state"
  ts.WriteLine "    Set mOverrides = Nothing"
  ts.WriteLine "    mViewerApplied = False"
  ts.WriteLine "    mAutoAnalyzeQPR = False"
  ts.WriteLine "    mHideAddData = False"
  ts.WriteLine "    mQprPath = """""
  ts.WriteLine ""
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' MergePortfolioInto"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Sub MergePortfolioInto(ByRef target As UBSSummary.PortfolioExtraction, ByRef source As UBSSummary.PortfolioExtraction)"
  ts.WriteLine "    Dim i As Long, j As Long, found As Boolean"
  ts.WriteLine ""
  ts.WriteLine "    For i = 0 To source.AccountCount - 1"
  ts.WriteLine "        found = False"
  ts.WriteLine "        For j = 0 To target.AccountCount - 1"
  ts.WriteLine "            If target.Accounts(j).AccountNumber = source.Accounts(i).AccountNumber Then"
  ts.WriteLine "                target.Accounts(j) = source.Accounts(i)"
  ts.WriteLine "                found = True"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If Not found Then"
  ts.WriteLine "            If target.AccountCount > UBound(target.Accounts) Then _"
  ts.WriteLine "                ReDim Preserve target.Accounts(0 To target.AccountCount + 15)"
  ts.WriteLine "            target.Accounts(target.AccountCount) = source.Accounts(i)"
  ts.WriteLine "            target.AccountCount = target.AccountCount + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    For i = 0 To source.LoanAccountCount - 1"
  ts.WriteLine "        found = False"
  ts.WriteLine "        For j = 0 To target.LoanAccountCount - 1"
  ts.WriteLine "            If target.LoanAccounts(j).AccountNumber = source.LoanAccounts(i).AccountNumber Then"
  ts.WriteLine "                target.LoanAccounts(j) = source.LoanAccounts(i)"
  ts.WriteLine "                found = True"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If Not found Then"
  ts.WriteLine "            If target.LoanAccountCount > UBound(target.LoanAccounts) Then _"
  ts.WriteLine "                ReDim Preserve target.LoanAccounts(0 To target.LoanAccountCount + 7)"
  ts.WriteLine "            target.LoanAccounts(target.LoanAccountCount) = source.LoanAccounts(i)"
  ts.WriteLine "            target.LoanAccountCount = target.LoanAccountCount + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' ValidateQprBeforeSave"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ValidateQprBeforeSave(wb As Workbook) As Boolean"
  ts.WriteLine "    On Error GoTo ValidationFail"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim sh As Worksheet"
  ts.WriteLine "    Dim found As Boolean"
  ts.WriteLine "    found = False"
  ts.WriteLine "    For Each sh In wb.Worksheets"
  ts.WriteLine "        If LCase$(Trim$(sh.Name)) = ""mapping"" Then"
  ts.WriteLine "            Set ws = sh"
  ts.WriteLine "            found = True"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next sh"
  ts.WriteLine ""
  ts.WriteLine "    If Not found Then"
  ts.WriteLine "        ValidateQprBeforeSave = True"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim c As Long, hasTab As Boolean, hasAcct As Boolean"
  ts.WriteLine "    For c = 1 To 20"
  ts.WriteLine "        Dim cellVal As Variant"
  ts.WriteLine "        cellVal = ws.Cells(1, c).Value"
  ts.WriteLine "        If Not IsNull(cellVal) Then"
  ts.WriteLine "            Dim hdr As String"
  ts.WriteLine "            hdr = LCase$(Trim$(CStr(cellVal)))"
  ts.WriteLine "            If hdr = ""tab"" Then hasTab = True"
  ts.WriteLine "            If hdr = ""account"" Then hasAcct = True"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next c"
  ts.WriteLine ""
  ts.WriteLine "    If Not hasTab Or Not hasAcct Then"
  ts.WriteLine "        ValidateQprBeforeSave = False"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    lastRow = ws.Cells(ws.Rows.Count, 1).End(-4162).Row"
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        ValidateQprBeforeSave = False"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ValidateQprBeforeSave = True"
  ts.WriteLine "    Exit Function"
  ts.WriteLine ""
  ts.WriteLine "ValidationFail:"
  ts.WriteLine "    ValidateQprBeforeSave = False"
  ts.WriteLine "End Function"
  ts.WriteLine ""
End Sub

Sub WriteModule_PDFExtractorMain(ts)
  ts.WriteLine "Attribute VB_Name = ""PDFExtractorMain"""
  ts.WriteLine "Option Explicit"
  ts.WriteLine ""
  ts.WriteLine "' PDFExtractorMain.bas -- User-facing macros for the VBA PDF Extractor."
  ts.WriteLine "' Ties together: PDFReader + PDFTextExtract + UBSExtract + QPRWriter"
  ts.WriteLine ""
  ts.WriteLine "' Module-level type declarations (must be before any Sub/Function)"
  ts.WriteLine "Private Type ConfigRow"
  ts.WriteLine "    Client As String"
  ts.WriteLine "    PdfPath As String"
  ts.WriteLine "    QprPath As String"
  ts.WriteLine "    RowNum As Long     ' Original row on Config sheet (for marking Done)"
  ts.WriteLine "End Type"
  ts.WriteLine ""
  ts.WriteLine "Private Type ProcessClientResult"
  ts.WriteLine "    Success As Boolean"
  ts.WriteLine "    AutoCompleted As Boolean      ' True = QPR written silently with no warnings"
  ts.WriteLine "    AutoCompletedTemplate As Boolean  ' True = template written silently with no alerts"
  ts.WriteLine "    ViewerWroteQPR As Boolean     ' True = viewer's Apply button wrote QPR"
  ts.WriteLine "    ViewerWroteTemplate As Boolean ' True = viewer's Apply Template button wrote template"
  ts.WriteLine "    StatusText As String          ' Summary for logging/msgbox"
  ts.WriteLine "    Notes As String               ' Informational warnings (uncovered/unmapped/phantom) for Config ""Status Detail"" column"
  ts.WriteLine "End Type"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Helper: write a timestamped line to a log file (append mode)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Sub WriteLog(logFile As String, msg As String)"
  ts.WriteLine "    Dim f As Integer"
  ts.WriteLine "    f = FreeFile"
  ts.WriteLine "    On Error GoTo LogErr"
  ts.WriteLine "    Open logFile For Append As #f"
  ts.WriteLine "    Print #f, ""["" & Format$(Now, ""yyyy-mm-dd hh:nn:ss"") & ""] "" & msg"
  ts.WriteLine "    Close #f"
  ts.WriteLine "    Exit Sub"
  ts.WriteLine "LogErr:"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Close #f"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Helper: build combined text from page array (matches reference format)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function BuildFullText(pages() As String) As String"
  ts.WriteLine "    Dim maxPages As Long"
  ts.WriteLine "    maxPages = UBound(pages) - LBound(pages) + 1"
  ts.WriteLine "    Dim parts() As String"
  ts.WriteLine "    ReDim parts(1 To maxPages)"
  ts.WriteLine "    Dim count As Long"
  ts.WriteLine "    count = 0"
  ts.WriteLine ""
  ts.WriteLine "    Dim pageIdx As Long"
  ts.WriteLine "    For pageIdx = LBound(pages) To UBound(pages)"
  ts.WriteLine "        ' Skip boilerplate pages"
  ts.WriteLine "        If IsBoilerplatePage(pages(pageIdx)) Then GoTo NextPage"
  ts.WriteLine ""
  ts.WriteLine "        count = count + 1"
  ts.WriteLine "        parts(count) = ""=== PAGE "" & count & "" ==="" & vbLf & pages(pageIdx)"
  ts.WriteLine "NextPage:"
  ts.WriteLine "    Next pageIdx"
  ts.WriteLine ""
  ts.WriteLine "    If count = 0 Then"
  ts.WriteLine "        BuildFullText = """""
  ts.WriteLine "    Else"
  ts.WriteLine "        If count < maxPages Then ReDim Preserve parts(1 To count)"
  ts.WriteLine "        BuildFullText = Join(parts, vbLf & vbLf)"
  ts.WriteLine "    End If"
  ts.WriteLine "End Function"
