  ts.WriteLine "Private Function RenderTransactionsTable(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef ext As UBSExtract.StatementExtraction) As Long"
  ts.WriteLine ""
  ts.WriteLine "    If ext.TransactionCount = 0 Then"
  ts.WriteLine "        RenderTransactionsTable = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    WriteSubHeader ws, r, ""Transactions ("" & ext.TransactionCount & "")"""
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    Dim tHdrs() As String, tSC() As Long, tEC() As Long, tAL() As Long"
  ts.WriteLine "    ReDim tHdrs(1 To 5): ReDim tSC(1 To 5): ReDim tEC(1 To 5): ReDim tAL(1 To 5)"
  ts.WriteLine "    tHdrs(1) = ""Date"": tSC(1) = 1: tEC(1) = 1: tAL(1) = -4131"
  ts.WriteLine "    tHdrs(2) = ""Activity"": tSC(2) = 2: tEC(2) = 3: tAL(2) = -4131"
  ts.WriteLine "    tHdrs(3) = ""Description"": tSC(3) = 4: tEC(3) = 8: tAL(3) = -4131"
  ts.WriteLine "    tHdrs(4) = ""Symbol"": tSC(4) = 9: tEC(4) = 9: tAL(4) = -4108"
  ts.WriteLine "    tHdrs(5) = ""Amount"": tSC(5) = 10: tEC(5) = 10: tAL(5) = -4152"
  ts.WriteLine "    WriteTableHeadersMerged ws, r, tHdrs, tSC, tEC, tAL"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Build sorted index by date (insertion sort, earliest first)"
  ts.WriteLine "    Dim sortIdx() As Long, i As Long, j As Long, tmp As Long"
  ts.WriteLine "    ReDim sortIdx(0 To ext.TransactionCount - 1)"
  ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
  ts.WriteLine "        sortIdx(i) = i"
  ts.WriteLine "    Next i"
  ts.WriteLine "    For i = 1 To ext.TransactionCount - 1"
  ts.WriteLine "        tmp = sortIdx(i)"
  ts.WriteLine "        j = i - 1"
  ts.WriteLine "        Do While j >= 0"
  ts.WriteLine "            If CDate(ext.Transactions(sortIdx(j)).TxDate) > CDate(ext.Transactions(tmp).TxDate) Then"
  ts.WriteLine "                sortIdx(j + 1) = sortIdx(j)"
  ts.WriteLine "                j = j - 1"
  ts.WriteLine "            Else"
  ts.WriteLine "                Exit Do"
  ts.WriteLine "            End If"
  ts.WriteLine "        Loop"
  ts.WriteLine "        sortIdx(j + 1) = tmp"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
  ts.WriteLine "        Dim ti As Long"
  ts.WriteLine "        ti = sortIdx(i)"
  ts.WriteLine "        ws.Cells(r, 1).Value = CDate(ext.Transactions(ti).TxDate)"
  ts.WriteLine "        ws.Cells(r, 1).NumberFormat = ""mm/dd/yy"""
  ts.WriteLine "        ws.Cells(r, 1).HorizontalAlignment = -4131  ' xlLeft"
  ts.WriteLine "        MergeWrite ws, r, 2, 3, ext.Transactions(ti).Activity"
  ts.WriteLine "        MergeWrite ws, r, 4, 8, ext.Transactions(ti).Description"
  ts.WriteLine "        ws.Cells(r, 9).NumberFormat = ""@"""
  ts.WriteLine "        ws.Cells(r, 9).Value = ext.Transactions(ti).Symbol"
  ts.WriteLine "        ws.Cells(r, 9).HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "        WriteCurrencyCell ws, r, 10, ext.Transactions(ti).Amount"
  ts.WriteLine "        ' Hairline bottom border"
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).LineStyle = 1  ' xlEdgeBottom, xlContinuous"
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).Weight = 1     ' xlHairline"
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).Color = RGB(200, 200, 200)"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    RenderTransactionsTable = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Data Integrity Checks table"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderChecksTable(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef ext As UBSExtract.StatementExtraction) As Long"
  ts.WriteLine ""
  ts.WriteLine "    If ext.CheckCount = 0 Then"
  ts.WriteLine "        RenderChecksTable = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim allPass As Boolean"
  ts.WriteLine "    allPass = True"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = 0 To ext.CheckCount - 1"
  ts.WriteLine "        If Not ext.Checks(i).Pass Then allPass = False: Exit For"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    Dim badge As String"
  ts.WriteLine "    If allPass Then badge = "" [PASS]"" Else badge = "" [FAIL]"""
  ts.WriteLine "    Dim checksTitle As String"
  ts.WriteLine "    checksTitle = ""Data Integrity Checks ("" & ext.CheckCount & "" checks)"" & badge"
  ts.WriteLine "    WriteSubHeader ws, r, checksTitle"
  ts.WriteLine "    ' Color the badge portion"
  ts.WriteLine "    Dim badgeStart As Long"
  ts.WriteLine "    badgeStart = Len(checksTitle) - Len(badge) + 1"
  ts.WriteLine "    If allPass Then"
  ts.WriteLine "        ws.Cells(r, 1).Characters(badgeStart, Len(badge)).Font.Color = CLR_POS"
  ts.WriteLine "    Else"
  ts.WriteLine "        ws.Cells(r, 1).Characters(badgeStart, Len(badge)).Font.Color = CLR_NEG"
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_FAIL_BG"
  ts.WriteLine "    End If"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Track start of detail rows for grouping"
  ts.WriteLine "    Dim checksDetailStart As Long"
  ts.WriteLine "    checksDetailStart = r"
  ts.WriteLine ""
  ts.WriteLine "    Dim cHdrs() As String, cSC() As Long, cEC() As Long, cAL() As Long"
  ts.WriteLine "    ReDim cHdrs(1 To 4): ReDim cSC(1 To 4): ReDim cEC(1 To 4): ReDim cAL(1 To 4)"
  ts.WriteLine "    cHdrs(1) = ""Check"": cSC(1) = 1: cEC(1) = 5: cAL(1) = -4131"
  ts.WriteLine "    cHdrs(2) = ""Expected"": cSC(2) = 6: cEC(2) = 7: cAL(2) = -4152"
  ts.WriteLine "    cHdrs(3) = ""Calculated"": cSC(3) = 8: cEC(3) = 9: cAL(3) = -4152"
  ts.WriteLine "    cHdrs(4) = ""Status"": cSC(4) = 10: cEC(4) = 10: cAL(4) = -4108"
  ts.WriteLine "    WriteTableHeadersMerged ws, r, cHdrs, cSC, cEC, cAL"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    For i = 0 To ext.CheckCount - 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 5, ext.Checks(i).Name"
  ts.WriteLine "        ' Add tooltip comment explaining the check"
  ts.WriteLine "        Dim tip As String"
  ts.WriteLine "        tip = CheckTooltip(ext.Checks(i).Name)"
  ts.WriteLine "        If Len(tip) > 0 Then ws.Cells(r, 1).AddComment tip"
  ts.WriteLine "        MergeWriteCurrency ws, r, 6, 7, ext.Checks(i).Expected"
  ts.WriteLine "        MergeWriteCurrency ws, r, 8, 9, ext.Checks(i).Actual"
  ts.WriteLine "        SetPassFailCell ws, r, 10, ext.Checks(i).Pass"
  ts.WriteLine "        If Not ext.Checks(i).Pass Then"
  ts.WriteLine "            ' Show diff as comment on status cell since no room for extra column"
  ts.WriteLine "            ws.Cells(r, 10).AddComment ""diff: "" & Fmt(ext.Checks(i).Actual - ext.Checks(i).Expected)"
  ts.WriteLine "        End If"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Group check detail rows and collapse if all pass"
  ts.WriteLine "    If r > checksDetailStart Then"
  ts.WriteLine "        ws.Rows(checksDetailStart & "":"" & r - 1).Group"
  ts.WriteLine "        If allPass Then ws.Rows(checksDetailStart & "":"" & r - 1).Hidden = True"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    RenderChecksTable = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Function CheckTooltip(ByVal checkName As String) As String"
  ts.WriteLine "    Dim tip As String"
  ts.WriteLine "    Select Case checkName"
  ts.WriteLine "        Case ""reconciliation"": tip = ""Opening value + cash activity + market change + accrued interest = closing value"""
  ts.WriteLine "        Case ""holdings_sum"": tip = ""Sum of all holding values = closing value"""
  ts.WriteLine "        Case ""unrealized_gl"": tip = ""Sum of per-holding unrealized gain/loss = total unrealized gain/loss"""
  ts.WriteLine "        Case ""income_transactions"": tip = ""Sum of dividend/interest/distribution transactions + accrued interest received = total monthly income"""
  ts.WriteLine "        Case ""asset_allocation_sum"": tip = ""Sum of asset allocation values = closing value"""
  ts.WriteLine "        Case ""realized_gains_month"": tip = ""Short-term + long-term realized gains = total realized (month)"""
  ts.WriteLine "        Case ""realized_gains_ytd"": tip = ""Short-term + long-term realized gains = total realized (YTD)"""
  ts.WriteLine "        Case ""unrealized_components"": tip = ""Short-term + long-term unrealized = total unrealized"""
  ts.WriteLine "        Case ""detail_rollup"": tip = ""Sum of all security-level values + cash holdings = closing value"""
  ts.WriteLine "        Case ""income_categories_sum_month"": tip = ""Sum of income category breakdowns (dividends, interest, misc) = total monthly income"""
  ts.WriteLine "        Case ""asset_allocation_pct"": tip = ""Sum of asset allocation percentages = 100%"""
  ts.WriteLine "        Case ""deposits_transferred_in"": tip = ""Deposits including investments transferred in = sum of deposit + transfer-in transactions"""
  ts.WriteLine "        Case ""cash_closing"": tip = ""Cash activity summary closing balance = Cash and money balances holding value"""
  ts.WriteLine "        Case ""cash_deposits"": tip = ""Cash activity summary deposits = sum of deposit + transfer-in transactions"""
  ts.WriteLine "        Case ""cash_proceeds"": tip = ""Cash activity summary proceeds = sum of sale/redemption transactions"""
  ts.WriteLine "        Case ""cash_invested"": tip = ""Cash activity summary funds invested = sum of purchase/reinvestment transactions"""
  ts.WriteLine "        Case ""cash_card_payments"": tip = ""Cash activity summary card payments = sum of card payment transactions"""
  ts.WriteLine "        Case ""tnt_closing_value"": tip = ""Summary page closing value = sum of all holdings"""
  ts.WriteLine "        Case ""tnt_closing_value_change_table"": tip = ""Change-in-value table closing value = sum of all holdings"""
  ts.WriteLine "        Case ""tnt_income_month"": tip = ""Summary dividend/interest income = sum of income transactions + accrued interest received"""
  ts.WriteLine "        Case ""tnt_net_deposits_withdrawals"": tip = ""Summary net deposits/withdrawals = sum of non-investment, non-income transactions"""
  ts.WriteLine "        Case ""tnt_market_change"": tip = ""Summary change in market value = derived from reconciliation equation"""
  ts.WriteLine "        Case ""tnt_total_unrealized"": tip = ""Summary total unrealized G/L = sum of per-holding unrealized G/L"""
  ts.WriteLine "    End Select"
  ts.WriteLine "    If Left$(checkName, 15) = ""securities_sum:"" And Len(tip) = 0 Then tip = ""Sum of individual security values within this holding = holding total value"""
  ts.WriteLine "    If Left$(checkName, 22) = ""securities_cost_basis:"" And Len(tip) = 0 Then tip = ""Sum of individual security cost bases = holding total cost basis"""
  ts.WriteLine "    If Left$(checkName, 22) = ""securities_unrealized:"" And Len(tip) = 0 Then tip = ""Sum of individual security unrealized G/L = holding total unrealized G/L"""
  ts.WriteLine "    If Left$(checkName, 13) = ""completeness:"" And Len(tip) = 0 Then tip = ""Verifies this section was found and parsed from the PDF"""
  ts.WriteLine "    CheckTooltip = tip"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Loan account section"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderLoanSection(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef ext As UBSLoanExtract.LoanExtraction, ByVal loanIdx As Long) As Long"
  ts.WriteLine ""
  ts.WriteLine "    Dim startRow As Long"
  ts.WriteLine "    startRow = r"
  ts.WriteLine "    Dim s As UBSLoanExtract.LoanSummary"
  ts.WriteLine "    Dim a As UBSLoanExtract.LoanActivity"
  ts.WriteLine "    s = ext.Summary"
  ts.WriteLine "    a = ext.Activity"
  ts.WriteLine ""
  ts.WriteLine "    ' Header"
  ts.WriteLine "    Dim loanLabel As String"
  ts.WriteLine "    loanLabel = s.AccountName"
  ts.WriteLine "    If Len(loanLabel) = 0 Then loanLabel = ""Loan Account"""
  ts.WriteLine "    WriteHeader ws, r, loanLabel & "" "" & ChrW$(8212) & "" "" & s.AccountNumbers & "" "" & ChrW$(8212) & "" "" & Fmt(s.ClosingBalance)"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Meta"
  ts.WriteLine "    MergeWrite ws, r, 1, 2, ""Type:  "" & s.LoanType"
  ts.WriteLine "    ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "    Dim loanPeriodStr As String"
  ts.WriteLine "    loanPeriodStr = s.StatementPeriod"
  ts.WriteLine "    If Len(loanPeriodStr) > 0 Then"
  ts.WriteLine "        On Error Resume Next"
  ts.WriteLine "        Dim loanPeriodDt As Date"
  ts.WriteLine "        loanPeriodDt = CDate(loanPeriodStr)"
  ts.WriteLine "        If Err.Number = 0 Then"
  ts.WriteLine "            loanPeriodStr = Format$(loanPeriodDt, ""mm/dd/yy"")"
  ts.WriteLine "        Else"
  ts.WriteLine "            Err.Clear"
  ts.WriteLine "        End If"
  ts.WriteLine "        On Error GoTo 0"
  ts.WriteLine "    End If"
  ts.WriteLine "    MergeWrite ws, r, 3, 7, ""Period:  "" & loanPeriodStr"
  ts.WriteLine "    ws.Cells(r, 3).Font.Bold = True"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Key values — 4 cards x 2 cols each"
  ts.WriteLine "    Dim loanLabelRow As Long"
  ts.WriteLine "    loanLabelRow = r"
  ts.WriteLine "    Dim lbls As Variant"
  ts.WriteLine "    lbls = Array(""Closing Balance"", ""Available Credit"", ""Variable Rate"", ""Interest (Month)"")"
  ts.WriteLine "    Dim vals As Variant"
  ts.WriteLine "    vals = Array(s.ClosingBalance, s.AvailableCredit, s.VariableRate, a.InterestMonth)"
  ts.WriteLine "    Dim c As Long"
  ts.WriteLine "    For c = 0 To 3"
  ts.WriteLine "        Dim lc1 As Long, lc2 As Long"
  ts.WriteLine "        lc1 = c * 2 + 1"
  ts.WriteLine "        lc2 = lc1 + 1"
  ts.WriteLine "        With ws.Range(ws.Cells(r, lc1), ws.Cells(r, lc2))"
  ts.WriteLine "            .Merge"
  ts.WriteLine "            .Value = lbls(c)"
  ts.WriteLine "            .Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "            .Font.Size = 9"
  ts.WriteLine "            .HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "        End With"
  ts.WriteLine "    Next c"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    For c = 0 To 3"
  ts.WriteLine "        lc1 = c * 2 + 1"
  ts.WriteLine "        lc2 = lc1 + 1"
  ts.WriteLine "        If c = 2 Then"
  ts.WriteLine "            With ws.Range(ws.Cells(r, lc1), ws.Cells(r, lc2))"
  ts.WriteLine "                .Merge"
  ts.WriteLine "                .Value = CDbl(vals(c)) / 100"
  ts.WriteLine "                .NumberFormat = ""0.000%"""
  ts.WriteLine "                .HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "            End With"
  ts.WriteLine "        Else"
  ts.WriteLine "            MergeWriteCurrency ws, r, lc1, lc2, CDbl(vals(c))"
  ts.WriteLine "            ws.Range(ws.Cells(r, lc1), ws.Cells(r, lc2)).HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "        End If"
  ts.WriteLine "        With ws.Range(ws.Cells(r, lc1), ws.Cells(r, lc2))"
  ts.WriteLine "            .Font.Bold = True"
  ts.WriteLine "            .Font.Size = 12"
  ts.WriteLine "        End With"
  ts.WriteLine "    Next c"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Black border around each loan card"
  ts.WriteLine "    For c = 0 To 3"
  ts.WriteLine "        lc1 = c * 2 + 1"
  ts.WriteLine "        lc2 = lc1 + 1"
  ts.WriteLine "        ws.Range(ws.Cells(loanLabelRow, lc1), ws.Cells(r - 1, lc2)).BorderAround Weight:=2, Color:=RGB(0, 0, 0)"
  ts.WriteLine "    Next c"
  ts.WriteLine ""
  ts.WriteLine "    ' Balance breakdown"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    If s.VariableOpening <> 0 Or s.VariableClosing <> 0 Or s.FixedOpening <> 0 Or s.FixedClosing <> 0 Then"
  ts.WriteLine "        WriteSubHeader ws, r, ""Balance Breakdown"""
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim bbH() As String, bbS() As Long, bbE() As Long, bbA() As Long"
  ts.WriteLine "        ReDim bbH(1 To 3): ReDim bbS(1 To 3): ReDim bbE(1 To 3): ReDim bbA(1 To 3)"
  ts.WriteLine "        bbH(1) = ""Component"": bbS(1) = 1: bbE(1) = 5: bbA(1) = -4131"
  ts.WriteLine "        bbH(2) = ""Opening"": bbS(2) = 6: bbE(2) = 8: bbA(2) = -4152"
  ts.WriteLine "        bbH(3) = ""Closing"": bbS(3) = 9: bbE(3) = 10: bbA(3) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, bbH, bbS, bbE, bbA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "        MergeWrite ws, r, 1, 5, ""Variable Rate Loan"""
  ts.WriteLine "        MergeWriteCurrency ws, r, 6, 8, s.VariableOpening"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, s.VariableClosing"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 5, ""Fixed Rate Loan"""
  ts.WriteLine "        MergeWriteCurrency ws, r, 6, 8, s.FixedOpening"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, s.FixedClosing"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 5, ""Total"""
  ts.WriteLine "        ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "        MergeWriteCurrency ws, r, 6, 8, s.OpeningBalance"
  ts.WriteLine "        ws.Range(ws.Cells(r, 6), ws.Cells(r, 8)).Font.Bold = True"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, s.ClosingBalance"
  ts.WriteLine "        ws.Range(ws.Cells(r, 9), ws.Cells(r, 10)).Font.Bold = True"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Activity summary"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    If a.OpeningMonth <> 0 Or a.ClosingMonth <> 0 Or a.OpeningYtd <> 0 Or a.ClosingYtd <> 0 Then"
  ts.WriteLine "        WriteSubHeader ws, r, ""Activity Summary"""
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim acH() As String, acS() As Long, acE() As Long, acA() As Long"
  ts.WriteLine "        ReDim acH(1 To 3): ReDim acS(1 To 3): ReDim acE(1 To 3): ReDim acA(1 To 3)"
  ts.WriteLine "        acH(1) = ""Category"": acS(1) = 1: acE(1) = 6: acA(1) = -4131"
  ts.WriteLine "        acH(2) = ""Month"": acS(2) = 7: acE(2) = 8: acA(2) = -4152"
  ts.WriteLine "        acH(3) = ""YTD"": acS(3) = 9: acE(3) = 10: acA(3) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, acH, acS, acE, acA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "        MergeWrite ws, r, 1, 6, ""Opening Balances"""
  ts.WriteLine "        MergeWriteCurrency ws, r, 7, 8, a.OpeningMonth"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, a.OpeningYtd"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 6, ""Repayments/Credits"""
  ts.WriteLine "        MergeWriteCurrency ws, r, 7, 8, a.RepaymentsMonth"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, a.RepaymentsYtd"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 6, ""Withdrawals"""
  ts.WriteLine "        MergeWriteCurrency ws, r, 7, 8, a.WithdrawalsMonth"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, a.WithdrawalsYtd"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 6, ""Interest"""
  ts.WriteLine "        MergeWriteCurrency ws, r, 7, 8, a.InterestMonth"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, a.InterestYtd"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 6, ""Closing Balances"""
  ts.WriteLine "        ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "        MergeWriteCurrency ws, r, 7, 8, a.ClosingMonth"
  ts.WriteLine "        ws.Range(ws.Cells(r, 7), ws.Cells(r, 8)).Font.Bold = True"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, a.ClosingYtd"
  ts.WriteLine "        ws.Range(ws.Cells(r, 9), ws.Cells(r, 10)).Font.Bold = True"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Loan transactions"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    If ext.TransactionCount > 0 Then"
  ts.WriteLine "        WriteSubHeader ws, r, ""Loan Transactions ("" & ext.TransactionCount & "")"""
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim ltH() As String, ltS() As Long, ltE() As Long, ltA() As Long"
  ts.WriteLine "        ReDim ltH(1 To 4): ReDim ltS(1 To 4): ReDim ltE(1 To 4): ReDim ltA(1 To 4)"
  ts.WriteLine "        ltH(1) = ""Date"": ltS(1) = 1: ltE(1) = 1: ltA(1) = -4131"
  ts.WriteLine "        ltH(2) = ""Category"": ltS(2) = 2: ltE(2) = 3: ltA(2) = -4131"
  ts.WriteLine "        ltH(3) = ""Description"": ltS(3) = 4: ltE(3) = 7: ltA(3) = -4131"
  ts.WriteLine "        ltH(4) = ""Amount"": ltS(4) = 8: ltE(4) = 10: ltA(4) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, ltH, ltS, ltE, ltA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim ti As Long"
  ts.WriteLine "        For ti = 0 To ext.TransactionCount - 1"
  ts.WriteLine "            On Error Resume Next"
  ts.WriteLine "            ws.Cells(r, 1).Value = CDate(ext.Transactions(ti).TxDate)"
  ts.WriteLine "            If Err.Number <> 0 Then Err.Clear: ws.Cells(r, 1).Value = ext.Transactions(ti).TxDate"
  ts.WriteLine "            On Error GoTo 0"
  ts.WriteLine "            ws.Cells(r, 1).NumberFormat = ""mm/dd/yy"""
  ts.WriteLine "            ws.Cells(r, 1).HorizontalAlignment = -4131  ' xlLeft"
  ts.WriteLine "            MergeWrite ws, r, 2, 3, ext.Transactions(ti).Category"
  ts.WriteLine "            MergeWrite ws, r, 4, 7, ext.Transactions(ti).Description"
  ts.WriteLine "            MergeWriteCurrency ws, r, 8, 10, ext.Transactions(ti).Amount"
  ts.WriteLine "            ' Hairline bottom border"
  ts.WriteLine "            ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).LineStyle = 1"
  ts.WriteLine "            ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).Weight = 1"
  ts.WriteLine "            ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).Color = RGB(200, 200, 200)"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine "        Next ti"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Fixed loan contracts"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    If ext.ContractCount > 0 Then"
  ts.WriteLine "        WriteSubHeader ws, r, ""Fixed Loan Contracts ("" & ext.ContractCount & "")"""
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim fcH() As String, fcS() As Long, fcE() As Long, fcA() As Long"
  ts.WriteLine "        ReDim fcH(1 To 4): ReDim fcS(1 To 4): ReDim fcE(1 To 4): ReDim fcA(1 To 4)"
  ts.WriteLine "        fcH(1) = ""Contract #"": fcS(1) = 1: fcE(1) = 3: fcA(1) = -4131"
  ts.WriteLine "        fcH(2) = ""Period"": fcS(2) = 4: fcE(2) = 6: fcA(2) = -4131"
  ts.WriteLine "        fcH(3) = ""Rate"": fcS(3) = 7: fcE(3) = 8: fcA(3) = -4152"
  ts.WriteLine "        fcH(4) = ""Balance"": fcS(4) = 9: fcE(4) = 10: fcA(4) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, fcH, fcS, fcE, fcA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim ci As Long"
  ts.WriteLine "        For ci = 0 To ext.ContractCount - 1"
  ts.WriteLine "            MergeWrite ws, r, 1, 3, ext.FixedContracts(ci).ContractNumber"
  ts.WriteLine "            MergeWrite ws, r, 4, 6, ext.FixedContracts(ci).Period"
  ts.WriteLine "            With ws.Range(ws.Cells(r, 7), ws.Cells(r, 8))"
  ts.WriteLine "                .Merge"
  ts.WriteLine "                .Value = ext.FixedContracts(ci).Rate / 100"
  ts.WriteLine "                .NumberFormat = ""0.00%"""
  ts.WriteLine "            End With"
  ts.WriteLine "            MergeWriteCurrency ws, r, 9, 10, ext.FixedContracts(ci).Balance"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine "        Next ci"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Group the loan section"
  ts.WriteLine "    If r > startRow + 1 Then"
  ts.WriteLine "        ws.Rows(startRow + 1 & "":"" & r - 1).Group"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    RenderLoanSection = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Coverage check (summary page vs extracted accounts)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderCoverageCheck(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction) As Long"
  ts.WriteLine ""
  ts.WriteLine "    Dim coverage As UBSSummary.CoverageResult"
  ts.WriteLine "    coverage = UBSSummary.BuildCoverageCheck(mSummaryRefs, portfolio)"
  ts.WriteLine ""
  ts.WriteLine "    Dim covStartRow As Long"
  ts.WriteLine "    covStartRow = r"
  ts.WriteLine ""
  ts.WriteLine "    If coverage.AllPresent Then"
  ts.WriteLine "        ' All accounts present — green banner"
  ts.WriteLine "        MergeWrite ws, r, 1, GCOLS, ""Portfolio Coverage: All "" & coverage.TotalSummaryAccounts & _"
  ts.WriteLine "            "" accounts from summary PDF are present."""
  ts.WriteLine "        ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "        ws.Cells(r, 1).Font.Color = RGB(21, 87, 36)"
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_PASS_BG"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Else"
  ts.WriteLine "        ' Missing accounts — yellow warning banner"
  ts.WriteLine "        MergeWrite ws, r, 1, GCOLS, ""Portfolio Coverage: "" & _"
  ts.WriteLine "            (coverage.TotalSummaryAccounts - coverage.MissingAccountCount) & "" of "" & _"
  ts.WriteLine "            coverage.TotalSummaryAccounts & "" accounts extracted. "" & _"
  ts.WriteLine "            coverage.MissingAccountCount & "" missing:"""
  ts.WriteLine "        ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "        ws.Cells(r, 1).Font.Color = RGB(128, 64, 0)"
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_WARN_BG"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "        ' Missing accounts table"
  ts.WriteLine "        Dim maH() As String, maS() As Long, maE() As Long, maA() As Long"
  ts.WriteLine "        ReDim maH(1 To 3): ReDim maS(1 To 3): ReDim maE(1 To 3): ReDim maA(1 To 3)"
  ts.WriteLine "        maH(1) = ""Account"": maS(1) = 1: maE(1) = 3: maA(1) = -4131"
  ts.WriteLine "        maH(2) = ""Name"": maS(2) = 4: maE(2) = 7: maA(2) = -4131"
  ts.WriteLine "        maH(3) = ""Closing Value"": maS(3) = 8: maE(3) = 10: maA(3) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, maH, maS, maE, maA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "        Dim mi As Long"
  ts.WriteLine "        For mi = 0 To coverage.MissingAccountCount - 1"
  ts.WriteLine "            MergeWrite ws, r, 1, 3, coverage.MissingAccounts(mi).AccountNumber"
  ts.WriteLine "            MergeWrite ws, r, 4, 7, coverage.MissingAccounts(mi).FriendlyName"
  ts.WriteLine "            MergeWriteCurrency ws, r, 8, 10, coverage.MissingAccounts(mi).ClosingValue"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine "        Next mi"
  ts.WriteLine ""
  ts.WriteLine "        ' Opening/closing total checks"
  ts.WriteLine "        Dim passLabel As String"
  ts.WriteLine "        passLabel = IIf(coverage.TotalOpeningCheck.Pass, ""PASS"", ""FAIL"")"
  ts.WriteLine "        MergeWrite ws, r, 1, GCOLS, ""Opening total: summary "" & Fmt(coverage.TotalOpeningCheck.Expected) & _"
  ts.WriteLine "            "" vs extracted "" & Fmt(coverage.TotalOpeningCheck.Actual) & ""  ["" & passLabel & ""]"""
  ts.WriteLine "        ws.Cells(r, 1).Font.Size = 9"
  ts.WriteLine "        ws.Cells(r, 1).Font.Color = RGB(128, 64, 0)"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "        passLabel = IIf(coverage.TotalClosingCheck.Pass, ""PASS"", ""FAIL"")"
  ts.WriteLine "        MergeWrite ws, r, 1, GCOLS, ""Closing total: summary "" & Fmt(coverage.TotalClosingCheck.Expected) & _"
  ts.WriteLine "            "" vs extracted "" & Fmt(coverage.TotalClosingCheck.Actual) & ""  ["" & passLabel & ""]"""
  ts.WriteLine "        ws.Cells(r, 1).Font.Size = 9"
  ts.WriteLine "        ws.Cells(r, 1).Font.Color = RGB(128, 64, 0)"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Thick border around entire coverage section"
  ts.WriteLine "    Dim borderColor As Long"
  ts.WriteLine "    If coverage.AllPresent Then borderColor = RGB(40, 167, 69) Else borderColor = RGB(255, 193, 7)"
  ts.WriteLine "    ws.Range(ws.Cells(covStartRow, 1), ws.Cells(r - 1, GCOLS)).BorderAround Weight:=4, Color:=borderColor  ' xlThick"
  ts.WriteLine ""
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    RenderCoverageCheck = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' QPR Analysis rendering"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderAutoQPRAnalysis(ws As Worksheet, r As Long) As Long"
  ts.WriteLine "    On Error GoTo AutoErr"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = ""Analyzing QPR mappings..."""
  ts.WriteLine ""
  ts.WriteLine "    Dim allUpdates As Long"
  ts.WriteLine "    Dim qprCount As Long"
  ts.WriteLine "    allUpdates = 0"
  ts.WriteLine "    qprCount = 0"
  ts.WriteLine ""
  ts.WriteLine "    ' Build QPR list"
  ts.WriteLine "    Dim qprDict As Object"
  ts.WriteLine "    Set qprDict = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    If Not mQprWorkbooks Is Nothing Then"
  ts.WriteLine "        If mQprWorkbooks.Count > 0 Then"
  ts.WriteLine "            Dim qk As Variant"
  ts.WriteLine "            For Each qk In mQprWorkbooks.Keys"
  ts.WriteLine "                qprDict.Add CStr(qk), mQprWorkbooks(qk)"
  ts.WriteLine "            Next qk"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine "    If qprDict.Count = 0 Then qprDict.Add mQprWb.FullName, mQprWb"
  ts.WriteLine ""
  ts.WriteLine "    ' When multiple QPRs are loaded, build union of all mapped accounts"
  ts.WriteLine "    ' so uncovered accounts are computed globally, not per-QPR"
  ts.WriteLine "    Dim globalMapped As Object"
  ts.WriteLine "    Set globalMapped = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    If qprDict.Count > 1 Then"
  ts.WriteLine "        Dim gk As Variant"
  ts.WriteLine "        For Each gk In qprDict.Keys"
  ts.WriteLine "            Dim gMappings() As QPRWriter.MappingRow"
  ts.WriteLine "            gMappings = QPRWriter.ReadMappingSheet(qprDict(gk))"
  ts.WriteLine "            If gMappings(0).Tab <> """" Then"
  ts.WriteLine "                Dim gmi As Long"
  ts.WriteLine "                For gmi = 0 To UBound(gMappings)"
  ts.WriteLine "                    If gMappings(gmi).Account <> """" Then"
  ts.WriteLine "                        globalMapped(gMappings(gmi).Account) = True"
  ts.WriteLine "                    End If"
  ts.WriteLine "                Next gmi"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next gk"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Analyze each QPR"
  ts.WriteLine "    Dim pk As Variant"
  ts.WriteLine "    For Each pk In qprDict.Keys"
  ts.WriteLine "        Dim qWb As Workbook"
  ts.WriteLine "        Set qWb = qprDict(pk)"
  ts.WriteLine "        Dim analysis As QPRWriter.QprAnalysis"
  ts.WriteLine "        analysis = QPRWriter.AnalyzeQPR(mPortfolio, qWb, mOverrides)"
  ts.WriteLine ""
  ts.WriteLine "        ' When multiple QPRs, suppress per-QPR uncovered (shown globally below)"
  ts.WriteLine "        If qprDict.Count > 1 Then analysis.UncoveredCount = 0"
  ts.WriteLine ""
  ts.WriteLine "        Dim qprLabel As String"
  ts.WriteLine "        If qprDict.Count > 1 Then qprLabel = Dir(CStr(pk)) Else qprLabel = """""
  ts.WriteLine ""
  ts.WriteLine "        allUpdates = allUpdates + analysis.UpdateCount"
  ts.WriteLine "        r = RenderQPRAnalysis(ws, r, analysis, qprLabel)"
  ts.WriteLine "        qprCount = qprCount + 1"
  ts.WriteLine "        ' Spacer row between QPR analyses when multiple QPRs"
  ts.WriteLine "        If qprDict.Count > 1 Then r = r + 1"
  ts.WriteLine "    Next pk"
  ts.WriteLine ""
  ts.WriteLine "    ' (Apply QPR button now rendered in top button bar by AddActionButtons)"
  ts.WriteLine ""
  ts.WriteLine "    ' Global uncovered accounts (only when multiple QPRs)"
  ts.WriteLine "    If qprDict.Count > 1 Then"
  ts.WriteLine "        r = RenderGlobalUncovered(ws, r, globalMapped)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Unclassified securities (filter out any with existing overrides)"
  ts.WriteLine "    Dim unclassified() As QPRWriter.UnclassifiedSecurity"
  ts.WriteLine "    Dim unclassCount As Long"
  ts.WriteLine "    unclassCount = QPRWriter.FindUnclassifiedSecurities(mPortfolio, mQprWb, unclassified)"
  ts.WriteLine "    If unclassCount > 0 And Not mOverrides Is Nothing Then"
  ts.WriteLine "        If mOverrides.Count > 0 Then"
  ts.WriteLine "            Dim filtered() As QPRWriter.UnclassifiedSecurity"
  ts.WriteLine "            ReDim filtered(1 To unclassCount)"
  ts.WriteLine "            Dim filteredCount As Long"
  ts.WriteLine "            filteredCount = 0"
  ts.WriteLine "            Dim fi As Long"
  ts.WriteLine "            For fi = 1 To unclassCount"
  ts.WriteLine "                Dim overKey As String"
  ts.WriteLine "                overKey = UCase$(unclassified(fi).Symbol & ""|"" & unclassified(fi).AccountNumber)"
  ts.WriteLine "                If Not mOverrides.Exists(overKey) Then"
  ts.WriteLine "                    filteredCount = filteredCount + 1"
  ts.WriteLine "                    filtered(filteredCount) = unclassified(fi)"
  ts.WriteLine "                End If"
  ts.WriteLine "            Next fi"
  ts.WriteLine "            If filteredCount > 0 Then"
  ts.WriteLine "                ReDim Preserve filtered(1 To filteredCount)"
  ts.WriteLine "                unclassCount = filteredCount"
  ts.WriteLine "                unclassified = filtered"
  ts.WriteLine "            Else"
  ts.WriteLine "                unclassCount = 0"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine "    If unclassCount > 0 Then"
  ts.WriteLine "        mHasUnclassified = True"
  ts.WriteLine "        Dim allocOpts() As String"
  ts.WriteLine "        Dim allocOptCount As Long"
  ts.WriteLine "        allocOptCount = QPRWriter.ReadMasterAssetClassNames(mQprWb, allocOpts)"
  ts.WriteLine "        r = RenderUnclassifiedSection(ws, r, unclassified, unclassCount, allocOpts, allocOptCount)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    mQprUpdateCount = allUpdates"
  ts.WriteLine "    Application.StatusBar = ""QPR analysis complete -- "" & allUpdates & "" updates across "" & qprCount & "" QPR(s)"""
  ts.WriteLine "    RenderAutoQPRAnalysis = r"
  ts.WriteLine "    Exit Function"
  ts.WriteLine ""
  ts.WriteLine "AutoErr:"
