ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Single-client re-run: process one client by name from Config sheet"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub RunSingleClient()"
ts.WriteLine "    ' Reset all viewer state from any previous session"
ts.WriteLine "    ViewerFormLauncher.ResetAllViewerState"
ts.WriteLine "    ViewerHTML.ClearRawPageText"
ts.WriteLine ""
ts.WriteLine "    ' --- Variable declarations ---"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    Dim inputName As String"
ts.WriteLine "    Dim lastRow As Long"
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    Dim clientRowCount As Long"
ts.WriteLine "    Dim clientPdfs() As String"
ts.WriteLine "    Dim clientQprs() As String"
ts.WriteLine "    Dim clientRowNums() As Long"
ts.WriteLine "    Dim cellClient As String"
ts.WriteLine "    Dim pi As Long"
ts.WriteLine "    Dim errMsg As String"
ts.WriteLine "    Dim clientResult As ProcessClientResult"
ts.WriteLine ""
ts.WriteLine "    ' Read config sheet"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine ""
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        MsgBox ""No 'Config' sheet found. Run EnsureConfigSheet first."", vbExclamation, ""Run Single Client"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Show client picker dropdown"
ts.WriteLine "    inputName = ShowClientPicker(ws)"
ts.WriteLine "    If Len(inputName) = 0 Then Exit Sub"
ts.WriteLine ""
ts.WriteLine "    ' Find matching rows (case-insensitive)"
ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp"
ts.WriteLine "    clientRowCount = 0"
ts.WriteLine ""
ts.WriteLine "    For r = 2 To lastRow"
ts.WriteLine "        cellClient = Trim$(CStr(ws.Cells(r, 1).Value & """"))"
ts.WriteLine "        If LCase$(cellClient) = LCase$(inputName) Then"
ts.WriteLine "            If Len(Trim$(CStr(ws.Cells(r, 2).Value & """"))) > 0 Then"
ts.WriteLine "                clientRowCount = clientRowCount + 1"
ts.WriteLine "                ReDim Preserve clientPdfs(1 To clientRowCount)"
ts.WriteLine "                ReDim Preserve clientQprs(1 To clientRowCount)"
ts.WriteLine "                ReDim Preserve clientRowNums(1 To clientRowCount)"
ts.WriteLine "                clientPdfs(clientRowCount) = Trim$(CStr(ws.Cells(r, 2).Value & """"))"
ts.WriteLine "                clientQprs(clientRowCount) = Trim$(CStr(ws.Cells(r, 3).Value & """"))"
ts.WriteLine "                clientRowNums(clientRowCount) = r"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    If clientRowCount = 0 Then"
ts.WriteLine "        MsgBox ""No rows found for client '"" & inputName & ""'."", vbExclamation, ""Run Single Client"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    On Error GoTo SingleClientError"
ts.WriteLine ""
ts.WriteLine "    ' Reset backup tracking"
ts.WriteLine "    QPRWriter.ClearBackupTracking"
ts.WriteLine ""
ts.WriteLine "    ' Process client with auto-pass enabled (shows viewer only if warnings)"
ts.WriteLine "    clientResult = ProcessOneClient(inputName, clientPdfs, clientQprs, _"
ts.WriteLine "        clientRowCount, True, ""Processing "" & inputName & "": "")"
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = """""
ts.WriteLine ""
ts.WriteLine "    ' If user closed viewer without submitting, don't mark Done"
ts.WriteLine "    If Not clientResult.AutoCompleted And Not clientResult.ViewerWroteQPR _"
ts.WriteLine "       And InStr(1, clientResult.StatusText, ""Viewer closed without submitting"") > 0 Then"
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Mark all client rows as Done and write notes"
ts.WriteLine "    For pi = 1 To clientRowCount"
ts.WriteLine "        ws.Cells(clientRowNums(pi), 4).Value = ""Done"""
ts.WriteLine "        ws.Cells(clientRowNums(pi), 5).Value = clientResult.Notes"
ts.WriteLine "    Next pi"
ts.WriteLine ""
ts.WriteLine "    If clientResult.AutoCompleted Then"
ts.WriteLine "        If InStr(1, clientResult.StatusText, ""[WARNING"", vbTextCompare) > 0 Then"
ts.WriteLine "            MsgBox inputName & "": auto-completed (with warnings)."" & vbCrLf & vbCrLf & _"
ts.WriteLine "                   clientResult.StatusText, vbExclamation, ""Run Single Client"""
ts.WriteLine "        Else"
ts.WriteLine "            MsgBox inputName & "": auto-completed (no warnings)."" & vbCrLf & vbCrLf & _"
ts.WriteLine "                   clientResult.StatusText, vbInformation, ""Run Single Client"""
ts.WriteLine "        End If"
ts.WriteLine "    ElseIf clientResult.ViewerWroteQPR Then"
ts.WriteLine "        MsgBox inputName & "": QPR updated via viewer."", vbInformation, ""Run Single Client"""
ts.WriteLine "    End If"
ts.WriteLine "    Exit Sub"
ts.WriteLine ""
ts.WriteLine "SingleClientError:"
ts.WriteLine "    errMsg = Err.Description"
ts.WriteLine "    If Len(errMsg) = 0 Then errMsg = ""Unknown error (Err "" & Err.Number & "")"""
ts.WriteLine "    Application.StatusBar = """""
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    PDFCrypto.ReleaseCrypto"
ts.WriteLine "    ViewerHTML.ClearRawPageText"
ts.WriteLine "    ViewerFormLauncher.ResetAllViewerState"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    MsgBox ""Error processing "" & inputName & "":"" & vbCrLf & vbCrLf & errMsg, vbCritical, ""Run Single Client"""
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Auto batch: process clients that don't need user input, skip the rest"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub RunBatchAuto()"
ts.WriteLine "    ' Two-pass batch: first processes all clients that need no user interaction"
ts.WriteLine "    ' (no unclassified securities), marks the rest ""NeedsReview"", then offers"
ts.WriteLine "    ' to run the interactive viewer for the remaining clients."
ts.WriteLine ""
ts.WriteLine "    ' --- Variable declarations ---"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    Dim rows() As ConfigRow"
ts.WriteLine "    Dim rowCount As Long"
ts.WriteLine "    Dim lastRow As Long"
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    Dim clientName As String"
ts.WriteLine "    Dim pdfPath As String"
ts.WriteLine "    Dim qprPath As String"
ts.WriteLine "    Dim clients() As String"
ts.WriteLine "    Dim clientCount As Long"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim j As Long"
ts.WriteLine "    Dim found As Boolean"
ts.WriteLine "    Dim ci As Long"
ts.WriteLine "    Dim autoProcessed As Long"
ts.WriteLine "    Dim needsReviewCount As Long"
ts.WriteLine "    Dim clientPdfs() As String"
ts.WriteLine "    Dim clientQprs() As String"
ts.WriteLine "    Dim clientRowNums() As Long"
ts.WriteLine "    Dim clientRowCount As Long"
ts.WriteLine "    Dim mergedPortfolio As UBSSummary.PortfolioExtraction"
ts.WriteLine "    Dim pdfPortfolios() As UBSSummary.PortfolioExtraction"
ts.WriteLine "    Dim pi As Long"
ts.WriteLine "    Dim rawText As String"
ts.WriteLine "    Dim unclassified() As QPRWriter.UnclassifiedSecurity"
ts.WriteLine "    Dim unclassCount As Long"
ts.WriteLine "    Dim qprWb As Workbook"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine "    Dim uniqueQprs As Object"
ts.WriteLine "    Dim qprPathKey As Variant"
ts.WriteLine "    Dim batchSummary As String"
ts.WriteLine "    Dim writeResult As String"
ts.WriteLine "    Dim validationErrors As String"
ts.WriteLine "    Dim vi As Long"
ts.WriteLine "    Dim proceed As VbMsgBoxResult"
ts.WriteLine "    Dim pdfSummaryRefs As UBSSummary.SummaryReferences"
ts.WriteLine "    Dim allDone As Boolean"
ts.WriteLine "    Dim needsReviewClients As String"
ts.WriteLine "    Dim status As String"
ts.WriteLine "    Dim summaryMsg As String"
ts.WriteLine "    Dim errMsg As String"
ts.WriteLine "    Dim clientErrorCount As Long"
ts.WriteLine "    Dim failedChecks As Long"
ts.WriteLine "    Dim checkIdx As Long"
ts.WriteLine "    Dim reviewReason As String"
ts.WriteLine "    Dim logFile As String"
ts.WriteLine "    Dim analysis As QPRWriter.QprAnalysis"
ts.WriteLine "    Dim notes As String"
ts.WriteLine ""
ts.WriteLine "    ' Create log file"
ts.WriteLine "    logFile = ThisWorkbook.Path & ""\BatchLog_"" & Format$(Now, ""yyyymmdd_hhmmss"") & "".txt"""
ts.WriteLine ""
ts.WriteLine "    ' Reset backup tracking for this batch run"
ts.WriteLine "    QPRWriter.ClearBackupTracking"
ts.WriteLine ""
ts.WriteLine "    ' Read config sheet"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine ""
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        MsgBox ""No 'Config' sheet found. Run EnsureConfigSheet first."", vbExclamation, ""Auto Batch"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Read rows"
ts.WriteLine "    rowCount = 0"
ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp = -4162"
ts.WriteLine ""
ts.WriteLine "    If lastRow < 2 Then"
ts.WriteLine "        MsgBox ""Config sheet is empty (no data rows)."", vbExclamation, ""Auto Batch"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ReDim rows(1 To lastRow - 1)"
ts.WriteLine ""
ts.WriteLine "    For r = 2 To lastRow"
ts.WriteLine "        clientName = Trim$(CStr(ws.Cells(r, 1).Value & """"))"
ts.WriteLine "        pdfPath = Trim$(CStr(ws.Cells(r, 2).Value & """"))"
ts.WriteLine "        qprPath = Trim$(CStr(ws.Cells(r, 3).Value & """"))"
ts.WriteLine ""
ts.WriteLine "        If Len(clientName) = 0 Or Len(pdfPath) = 0 Then GoTo NextAutoRow"
ts.WriteLine "        rowCount = rowCount + 1"
ts.WriteLine "        rows(rowCount).Client = clientName"
ts.WriteLine "        rows(rowCount).PdfPath = pdfPath"
ts.WriteLine "        rows(rowCount).QprPath = qprPath"
ts.WriteLine "        rows(rowCount).RowNum = r"
ts.WriteLine "NextAutoRow:"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    If rowCount = 0 Then"
ts.WriteLine "        MsgBox ""No valid config rows found."", vbExclamation, ""Auto Batch"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Upfront validation: check all files exist and QPR paths are set"
ts.WriteLine "    validationErrors = """""
ts.WriteLine "    For vi = 1 To rowCount"
ts.WriteLine "        status = CStr(ws.Cells(rows(vi).RowNum, 4).Value & """")"
ts.WriteLine "        If status = ""Done"" Then GoTo NextAutoValidation"
ts.WriteLine "        If Len(rows(vi).QprPath) = 0 Then"
ts.WriteLine "            validationErrors = validationErrors & ""Row "" & rows(vi).RowNum & "" ("" & rows(vi).Client & ""): QPR path is empty"" & vbCrLf"
ts.WriteLine "        ElseIf Dir(rows(vi).QprPath) = """" Then"
ts.WriteLine "            validationErrors = validationErrors & ""Row "" & rows(vi).RowNum & "" ("" & rows(vi).Client & ""): QPR not found: "" & rows(vi).QprPath & vbCrLf"
ts.WriteLine "        End If"
ts.WriteLine "        If Dir(rows(vi).PdfPath) = """" Then"
ts.WriteLine "            validationErrors = validationErrors & ""Row "" & rows(vi).RowNum & "" ("" & rows(vi).Client & ""): PDF not found: "" & rows(vi).PdfPath & vbCrLf"
ts.WriteLine "        End If"
ts.WriteLine "NextAutoValidation:"
ts.WriteLine "    Next vi"
ts.WriteLine ""
ts.WriteLine "    If Len(validationErrors) > 0 Then"
ts.WriteLine "        MsgBox ""Config validation failed -- fix these before running:"" & vbCrLf & vbCrLf & _"
ts.WriteLine "               validationErrors, vbCritical, ""Auto Batch"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Get distinct clients in order"
ts.WriteLine "    clientCount = 0"
ts.WriteLine "    ReDim clients(1 To rowCount)"
ts.WriteLine ""
ts.WriteLine "    For i = 1 To rowCount"
ts.WriteLine "        found = False"
ts.WriteLine "        For j = 1 To clientCount"
ts.WriteLine "            If clients(j) = rows(i).Client Then"
ts.WriteLine "                found = True"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "        If Not found Then"
ts.WriteLine "            clientCount = clientCount + 1"
ts.WriteLine "            clients(clientCount) = rows(i).Client"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    WriteLog logFile, ""Batch started: "" & clientCount & "" clients"""
ts.WriteLine ""
ts.WriteLine "    ' Skip already-done clients"
ts.WriteLine "    autoProcessed = 0"
ts.WriteLine "    needsReviewCount = 0"
ts.WriteLine "    batchSummary = """""
ts.WriteLine "    needsReviewClients = """""
ts.WriteLine ""
ts.WriteLine "    clientErrorCount = 0"
ts.WriteLine ""
ts.WriteLine "    For ci = 1 To clientCount"
ts.WriteLine "        On Error GoTo AutoClientError"
ts.WriteLine "        ' Check if all rows for this client are already Done"
ts.WriteLine "        allDone = True"
ts.WriteLine "        For j = 1 To rowCount"
ts.WriteLine "            If rows(j).Client = clients(ci) Then"
ts.WriteLine "                status = CStr(ws.Cells(rows(j).RowNum, 4).Value & """")"
ts.WriteLine "                If status <> ""Done"" Then"
ts.WriteLine "                    allDone = False"
ts.WriteLine "                    Exit For"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "        If allDone Then"
ts.WriteLine "            autoProcessed = autoProcessed + 1"
ts.WriteLine "            GoTo NextAutoClient"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        Application.StatusBar = ""Auto pass: client "" & ci & ""/"" & clientCount & "" ("" & clients(ci) & "")..."""
ts.WriteLine "        WriteLog logFile, ""Processing client: "" & clients(ci)"
ts.WriteLine ""
ts.WriteLine "        ' Collect PDFs and QPRs for this client"
ts.WriteLine "        clientRowCount = 0"
ts.WriteLine "        For j = 1 To rowCount"
ts.WriteLine "            If rows(j).Client = clients(ci) Then"
ts.WriteLine "                clientRowCount = clientRowCount + 1"
ts.WriteLine "                ReDim Preserve clientPdfs(1 To clientRowCount)"
ts.WriteLine "                ReDim Preserve clientQprs(1 To clientRowCount)"
ts.WriteLine "                ReDim Preserve clientRowNums(1 To clientRowCount)"
ts.WriteLine "                clientPdfs(clientRowCount) = rows(j).PdfPath"
ts.WriteLine "                clientQprs(clientRowCount) = rows(j).QprPath"
ts.WriteLine "                clientRowNums(clientRowCount) = rows(j).RowNum"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine ""
ts.WriteLine "        ' Extract all PDFs for this client"
ts.WriteLine "        ReDim pdfPortfolios(1 To clientRowCount)"
ts.WriteLine ""
ts.WriteLine "        For pi = 1 To clientRowCount"
ts.WriteLine "            Application.StatusBar = ""Auto pass: client "" & ci & ""/"" & clientCount & "" ("" & clients(ci) & ""): PDF "" & pi & ""/"" & clientRowCount"
ts.WriteLine ""
ts.WriteLine "            If Dir(clientPdfs(pi)) = """" Then"
ts.WriteLine "                batchSummary = batchSummary & clients(ci) & "": SKIP PDF not found"" & vbCrLf"
ts.WriteLine "                GoTo NextAutoPdf"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            rawText = """""
ts.WriteLine "            pdfPortfolios(pi) = ExtractPDFToPortfolioFull(clientPdfs(pi), rawText, pdfSummaryRefs)"
ts.WriteLine "            RegexHelper.ClearRegexCache"
ts.WriteLine "            PDFDeflate.ClearInflateCache"
ts.WriteLine "            WriteLog logFile, ""  Extracted PDF: "" & Dir(clientPdfs(pi)) & "" ("" & pdfPortfolios(pi).AccountCount & "" accounts)"""
ts.WriteLine "NextAutoPdf:"
ts.WriteLine "        Next pi"
ts.WriteLine ""
ts.WriteLine "        ' Merge portfolios"
ts.WriteLine "        mergedPortfolio = MergePortfolios(pdfPortfolios, clientRowCount)"
ts.WriteLine ""
ts.WriteLine "        ' Check for unclassified securities"
ts.WriteLine "        ReDim unclassified(1 To 1)"
ts.WriteLine "        unclassCount = 0"
ts.WriteLine ""
ts.WriteLine "        Set uniqueQprs = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "        For pi = 1 To clientRowCount"
ts.WriteLine "            If Len(clientQprs(pi)) > 0 Then"
ts.WriteLine "                If Not uniqueQprs.Exists(clientQprs(pi)) Then"
ts.WriteLine "                    uniqueQprs(clientQprs(pi)) = True"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        Next pi"
ts.WriteLine ""
ts.WriteLine "        For Each qprPathKey In uniqueQprs.Keys"
ts.WriteLine "            If Dir(CStr(qprPathKey)) <> """" Then"
ts.WriteLine "                Set qprWb = Workbooks.Open(CStr(qprPathKey), UpdateLinks:=False, ReadOnly:=True)"
ts.WriteLine "                unclassCount = QPRWriter.FindUnclassifiedSecurities(mergedPortfolio, qprWb, unclassified)"
ts.WriteLine "                analysis = QPRWriter.AnalyzeQPR(mergedPortfolio, qprWb)"
ts.WriteLine "                qprWb.Close False"
ts.WriteLine "                Set qprWb = Nothing"
ts.WriteLine "            End If"
ts.WriteLine "        Next qprPathKey"
ts.WriteLine ""
ts.WriteLine "        ' Build informational notes from AnalyzeQPR (non-blocking warnings)"
ts.WriteLine "        notes = BuildAnalysisNotes(analysis)"
ts.WriteLine ""
ts.WriteLine "        ' Check reconciliation: any failed checks across all accounts?"
ts.WriteLine "        failedChecks = 0"
ts.WriteLine "        For pi = 1 To clientRowCount"
ts.WriteLine "            For ai = 0 To pdfPortfolios(pi).AccountCount - 1"
ts.WriteLine "                For checkIdx = 0 To pdfPortfolios(pi).Accounts(ai).Extraction.CheckCount - 1"
ts.WriteLine "                    If Not pdfPortfolios(pi).Accounts(ai).Extraction.Checks(checkIdx).Pass Then"
ts.WriteLine "                        failedChecks = failedChecks + 1"
ts.WriteLine "                    End If"
ts.WriteLine "                Next checkIdx"
ts.WriteLine "            Next ai"
ts.WriteLine "        Next pi"
ts.WriteLine ""
ts.WriteLine "        ' Decision: auto-process or mark for review"
ts.WriteLine "        If unclassCount > 0 Or failedChecks > 0 Then"
ts.WriteLine "            ' Needs user input -- mark as NeedsReview and skip"
ts.WriteLine "            For pi = 1 To clientRowCount"
ts.WriteLine "                ws.Cells(clientRowNums(pi), 4).Value = ""NeedsReview"""
ts.WriteLine "                ws.Cells(clientRowNums(pi), 5).Value = notes"
ts.WriteLine "            Next pi"
ts.WriteLine "            needsReviewCount = needsReviewCount + 1"
ts.WriteLine "            If Len(needsReviewClients) > 0 Then needsReviewClients = needsReviewClients & "", """
ts.WriteLine "            reviewReason = """""
ts.WriteLine "            If unclassCount > 0 Then reviewReason = unclassCount & "" unclassified"""
ts.WriteLine "            If failedChecks > 0 Then"
ts.WriteLine "                If Len(reviewReason) > 0 Then reviewReason = reviewReason & "", """
ts.WriteLine "                reviewReason = reviewReason & failedChecks & "" failed checks"""
ts.WriteLine "            End If"
ts.WriteLine "            needsReviewClients = needsReviewClients & clients(ci) & "" ("" & reviewReason & "")"""
ts.WriteLine "            batchSummary = batchSummary & clients(ci) & "": NeedsReview ("" & reviewReason & "")"" & vbCrLf"
ts.WriteLine "            WriteLog logFile, ""  NeedsReview: "" & reviewReason"
ts.WriteLine "            GoTo NextAutoClient"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' No unclassified -- write QPR silently"
ts.WriteLine "        For Each qprPathKey In uniqueQprs.Keys"
ts.WriteLine "            If Dir(CStr(qprPathKey)) = """" Then"
ts.WriteLine "                batchSummary = batchSummary & clients(ci) & "": SKIP QPR not found"" & vbCrLf"
ts.WriteLine "                GoTo NextAutoQpr"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            Application.StatusBar = ""Auto pass: client "" & ci & ""/"" & clientCount & "" ("" & clients(ci) & ""): writing QPR..."""
ts.WriteLine "            Set qprWb = QPRWriter.GetOpenWorkbook(CStr(qprPathKey))"
ts.WriteLine "            If qprWb Is Nothing Then"
ts.WriteLine "                Set qprWb = Workbooks.Open(CStr(qprPathKey), UpdateLinks:=False)"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            For pi = 1 To clientRowCount"
ts.WriteLine "                If clientQprs(pi) = CStr(qprPathKey) Then"
ts.WriteLine "                    For ai = 0 To pdfPortfolios(pi).AccountCount - 1"
ts.WriteLine "                        If pdfPortfolios(pi).Accounts(ai).AccountNumber <> """" Then"
ts.WriteLine "                            writeResult = """""
ts.WriteLine "                            QPRWriter.WriteQPR pdfPortfolios(pi).Accounts(ai).Extraction, qprWb, _"
ts.WriteLine "                                True, writeResult"
ts.WriteLine "                            batchSummary = batchSummary & clients(ci) & "": "" & writeResult & vbCrLf"
ts.WriteLine "                            WriteLog logFile, ""  QPR written: "" & writeResult"
ts.WriteLine "                        End If"
ts.WriteLine "                    Next ai"
ts.WriteLine "                End If"
ts.WriteLine "            Next pi"
ts.WriteLine ""
ts.WriteLine "            ' Validate before saving"
ts.WriteLine "            If ValidateQprStructure(qprWb) Then"
ts.WriteLine "                qprWb.Windows(1).Visible = True"
ts.WriteLine "                qprWb.Save"
ts.WriteLine "            Else"
ts.WriteLine "                batchSummary = batchSummary & clients(ci) & "": [WARNING: QPR validation failed -- NOT saved]"" & vbCrLf"
ts.WriteLine "                WriteLog logFile, ""  WARNING: QPR validation failed -- file NOT saved"""
ts.WriteLine "            End If"
ts.WriteLine "            qprWb.Close False"
ts.WriteLine "            Set qprWb = Nothing"
ts.WriteLine "NextAutoQpr:"
ts.WriteLine "        Next qprPathKey"
ts.WriteLine ""
ts.WriteLine "        ' Mark rows Done and write notes"
ts.WriteLine "        For pi = 1 To clientRowCount"
ts.WriteLine "            ws.Cells(clientRowNums(pi), 4).Value = ""Done"""
ts.WriteLine "            ws.Cells(clientRowNums(pi), 5).Value = notes"
ts.WriteLine "        Next pi"
ts.WriteLine ""
ts.WriteLine "        autoProcessed = autoProcessed + 1"
ts.WriteLine "        WriteLog logFile, ""  Complete"""
ts.WriteLine "        GoTo NextAutoClient"
ts.WriteLine ""
ts.WriteLine "AutoClientError:"
ts.WriteLine "        ' Per-client error: log and continue with next client"
ts.WriteLine "        clientErrorCount = clientErrorCount + 1"
ts.WriteLine "        errMsg = Err.Description"
ts.WriteLine "        batchSummary = batchSummary & clients(ci) & "": ERROR -- "" & errMsg & vbCrLf"
ts.WriteLine "        WriteLog logFile, ""  ERROR: "" & errMsg"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        PDFCrypto.ReleaseCrypto"
ts.WriteLine "        If Not qprWb Is Nothing Then qprWb.Close False: Set qprWb = Nothing"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "        Err.Clear"
ts.WriteLine ""
ts.WriteLine "NextAutoClient:"
ts.WriteLine "    Next ci"
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = """""
ts.WriteLine ""
ts.WriteLine "    ' Write final summary to log"
ts.WriteLine "    WriteLog logFile, ""Batch complete: "" & autoProcessed & "" processed, "" & clientErrorCount & "" errors, "" & needsReviewCount & "" needing review"""
ts.WriteLine ""
ts.WriteLine "    ' Summary of auto pass"
ts.WriteLine "    summaryMsg = ""Auto batch pass complete!"" & vbCrLf & _"
ts.WriteLine "                 autoProcessed & "" of "" & clientCount & "" clients processed automatically."" & vbCrLf & _"
ts.WriteLine "                 needsReviewCount & "" client(s) need review."""
ts.WriteLine "    If clientErrorCount > 0 Then"
ts.WriteLine "        summaryMsg = summaryMsg & vbCrLf & clientErrorCount & "" client(s) had errors."""
ts.WriteLine "    End If"
ts.WriteLine "    summaryMsg = summaryMsg & vbCrLf & vbCrLf & ""Log file: "" & logFile"
ts.WriteLine ""
ts.WriteLine "    If Len(batchSummary) > 0 Then"
ts.WriteLine "        If Len(batchSummary) > 1000 Then batchSummary = Left$(batchSummary, 1000) & vbCrLf & ""... (truncated)"""
ts.WriteLine "        summaryMsg = summaryMsg & vbCrLf & vbCrLf & ""Details:"" & vbCrLf & batchSummary"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    If needsReviewCount > 0 Or clientErrorCount > 0 Then"
ts.WriteLine "        ' Offer to run interactive pass for NeedsReview clients"
ts.WriteLine "        proceed = MsgBox(summaryMsg & vbCrLf & vbCrLf & _"
ts.WriteLine "                         ""Run interactive viewer for the "" & needsReviewCount & "" client(s) that need review?"", _"
ts.WriteLine "                         vbYesNo + vbInformation, ""Auto Batch"")"
ts.WriteLine "        If proceed = vbYes Then"
ts.WriteLine "            ' RunBatchFromConfig will pick up NeedsReview rows (they're not ""Done"")"
ts.WriteLine "            RunBatchFromConfig"
ts.WriteLine "        End If"
ts.WriteLine "    Else"
ts.WriteLine "        MsgBox summaryMsg, vbInformation, ""Auto Batch"""
ts.WriteLine "    End If"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Helper: parse classification result string into overrides Dictionary"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function ParseClassificationResult(classResult As String) As Object"
ts.WriteLine "    ' Parses ""SYM1|ACCT1=Class1;SYM2|ACCT2=Class2"" into Dictionary"
ts.WriteLine "    ' Key = ""SYM1|ACCT1"" (uppercase), Value = class name string"
ts.WriteLine "    Dim dict As Object"
ts.WriteLine "    Set dict = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    If Len(classResult) = 0 Then"
ts.WriteLine "        Set ParseClassificationResult = dict"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim pairs() As String"
ts.WriteLine "    pairs = Split(classResult, "";"")"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = LBound(pairs) To UBound(pairs)"
ts.WriteLine "        Dim pair As String"
ts.WriteLine "        pair = Trim$(pairs(i))"
ts.WriteLine "        If Len(pair) = 0 Then GoTo NextPair"
ts.WriteLine ""
ts.WriteLine "        Dim eqPos As Long"
ts.WriteLine "        eqPos = InStr(1, pair, ""="")"
ts.WriteLine "        If eqPos = 0 Then GoTo NextPair"
ts.WriteLine ""
ts.WriteLine "        Dim key As String"
ts.WriteLine "        key = UCase$(Left$(pair, eqPos - 1))"
ts.WriteLine "        Dim val As String"
ts.WriteLine "        val = Mid$(pair, eqPos + 1)"
ts.WriteLine ""
ts.WriteLine "        If Len(key) > 0 And Len(val) > 0 Then"
ts.WriteLine "            dict(key) = val"
ts.WriteLine "        End If"
ts.WriteLine "NextPair:"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    Set ParseClassificationResult = dict"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' 11. Config CSV Import / Export"
ts.WriteLine "' ============================================================================"
ts.WriteLine "' The Config sheet data (Client, PDF path, QPR path, Processed status) is"
ts.WriteLine "' persisted to ExcelMacroConfig.csv in the workbook directory so that"
ts.WriteLine "' rebuilding the .xlsm does not lose paths.  The CSV lives outside the .xlsm"
ts.WriteLine "' and is gitignored (contains PII / local paths)."
ts.WriteLine ""
ts.WriteLine "Private Function ConfigCsvPath() As String"
ts.WriteLine "    ConfigCsvPath = ThisWorkbook.Path & ""\ExcelMacroConfig.csv"""
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "''' Escape a field for CSV output (RFC 4180)."
ts.WriteLine "Private Function CsvEscape(ByVal s As String) As String"
ts.WriteLine "    If InStr(1, s, "","") > 0 Or InStr(1, s, """""""") > 0 Or InStr(1, s, vbLf) > 0 Or InStr(1, s, vbCr) > 0 Then"
ts.WriteLine "        CsvEscape = """""""" & Replace(s, """""""", """""""""""") & """""""""
ts.WriteLine "    Else"
ts.WriteLine "        CsvEscape = s"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "''' Parse one line of CSV respecting quoted fields.  Returns array of field strings."
ts.WriteLine "Private Function CsvSplitLine(ByVal line As String) As String()"
ts.WriteLine "    Dim fields() As String"
ts.WriteLine "    Dim fieldCount As Long"
ts.WriteLine "    fieldCount = 0"
ts.WriteLine "    ReDim fields(0 To 4)  ' expect 5 columns"
ts.WriteLine ""
ts.WriteLine "    Dim pos As Long"
ts.WriteLine "    pos = 1"
ts.WriteLine "    Dim fieldStart As Long"
ts.WriteLine "    Dim inQuote As Boolean"
ts.WriteLine "    Dim ch As String"
ts.WriteLine "    Dim curField As String"
ts.WriteLine ""
ts.WriteLine "    Do While pos <= Len(line) + 1"
ts.WriteLine "        curField = """""
ts.WriteLine "        inQuote = False"
ts.WriteLine "        If pos <= Len(line) And Mid$(line, pos, 1) = """""""" Then"
ts.WriteLine "            ' Quoted field"
ts.WriteLine "            inQuote = True"
ts.WriteLine "            pos = pos + 1"
ts.WriteLine "            Do While pos <= Len(line)"
ts.WriteLine "                ch = Mid$(line, pos, 1)"
ts.WriteLine "                If ch = """""""" Then"
ts.WriteLine "                    If pos < Len(line) And Mid$(line, pos + 1, 1) = """""""" Then"
ts.WriteLine "                        curField = curField & """""""""
ts.WriteLine "                        pos = pos + 2"
ts.WriteLine "                    Else"
ts.WriteLine "                        pos = pos + 1 ' closing quote"
ts.WriteLine "                        Exit Do"
ts.WriteLine "                    End If"
ts.WriteLine "                Else"
ts.WriteLine "                    curField = curField & ch"
ts.WriteLine "                    pos = pos + 1"
ts.WriteLine "                End If"
ts.WriteLine "            Loop"
ts.WriteLine "            ' skip comma after closing quote"
ts.WriteLine "            If pos <= Len(line) And Mid$(line, pos, 1) = "","" Then pos = pos + 1"
ts.WriteLine "        Else"
ts.WriteLine "            ' Unquoted field"
ts.WriteLine "            fieldStart = pos"
ts.WriteLine "            Do While pos <= Len(line)"
ts.WriteLine "                If Mid$(line, pos, 1) = "","" Then Exit Do"
ts.WriteLine "                pos = pos + 1"
ts.WriteLine "            Loop"
ts.WriteLine "            If pos > fieldStart Then"
ts.WriteLine "                curField = Mid$(line, fieldStart, pos - fieldStart)"
ts.WriteLine "            End If"
ts.WriteLine "            pos = pos + 1 ' skip comma"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        If fieldCount > UBound(fields) Then ReDim Preserve fields(0 To fieldCount)"
ts.WriteLine "        fields(fieldCount) = curField"
ts.WriteLine "        fieldCount = fieldCount + 1"
ts.WriteLine ""
ts.WriteLine "        If pos > Len(line) + 1 Then Exit Do"
ts.WriteLine "    Loop"
ts.WriteLine ""
ts.WriteLine "    ' Pad to 5 columns"
ts.WriteLine "    If fieldCount - 1 < 4 Then ReDim Preserve fields(0 To 4)"
ts.WriteLine ""
ts.WriteLine "    CsvSplitLine = fields"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Public Sub ExportConfigCsv()"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    Dim lastRow As Long"
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    Dim f As Integer"
ts.WriteLine "    Dim csvPath As String"
ts.WriteLine "    Dim line As String"
ts.WriteLine "    Dim dataRows As Long"
ts.WriteLine ""
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine ""
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        MsgBox ""No Config sheet found. Nothing to export."", vbExclamation, ""Export Config"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp"
ts.WriteLine "    If lastRow < 2 Then"
ts.WriteLine "        MsgBox ""Config sheet has no data rows to export."", vbExclamation, ""Export Config"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    csvPath = ConfigCsvPath()"
ts.WriteLine "    f = FreeFile"
ts.WriteLine "    Open csvPath For Output As #f"
ts.WriteLine ""
ts.WriteLine "    ' Header"
ts.WriteLine "    Print #f, ""Client,PDF File Path,QPR Excel Path,Processed,Notes"""
ts.WriteLine ""
ts.WriteLine "    ' Data rows"
ts.WriteLine "    dataRows = 0"
ts.WriteLine "    For r = 2 To lastRow"
ts.WriteLine "        If Len(Trim$(CStr(ws.Cells(r, 1).Value & """"))) > 0 Or _"
ts.WriteLine "           Len(Trim$(CStr(ws.Cells(r, 2).Value & """"))) > 0 Then"
ts.WriteLine "            line = CsvEscape(CStr(ws.Cells(r, 1).Value & """")) & "","" & _"
ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 2).Value & """")) & "","" & _"
ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 3).Value & """")) & "","" & _"
ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 4).Value & """")) & "","" & _"
ts.WriteLine "                   CsvEscape(CStr(ws.Cells(r, 5).Value & """"))"
ts.WriteLine "            Print #f, line"
ts.WriteLine "            dataRows = dataRows + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next r"
ts.WriteLine ""
ts.WriteLine "    Close #f"
ts.WriteLine ""
ts.WriteLine "    MsgBox ""Exported "" & dataRows & "" rows to:"" & vbCrLf & csvPath, _"
ts.WriteLine "           vbInformation, ""Export Config"""
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "Public Sub ImportConfigCsv()"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    Dim csvPath As String"
ts.WriteLine "    Dim f As Integer"
ts.WriteLine "    Dim line As String"
ts.WriteLine "    Dim fields() As String"
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    Dim dataRows As Long"
ts.WriteLine "    Dim lastRow As Long"
ts.WriteLine ""
ts.WriteLine "    csvPath = ConfigCsvPath()"
ts.WriteLine "    If Dir(csvPath) = """" Then"
ts.WriteLine "        MsgBox ""No config file found at:"" & vbCrLf & csvPath & vbCrLf & vbCrLf & _"
ts.WriteLine "               ""Export from the Config sheet first, or create the file manually."", _"
ts.WriteLine "               vbExclamation, ""Import Config"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Ensure Config sheet exists (creates if needed, preserves existing data)"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    If ws Is Nothing Then"
ts.WriteLine "        EnsureConfigSheet"
ts.WriteLine "        Set ws = ThisWorkbook.Worksheets(""Config"")"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Clear existing data rows (keep header)"
ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row"
ts.WriteLine "    If lastRow >= 2 Then"
ts.WriteLine "        ws.Range(""A2:E"" & lastRow).ClearContents"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Read CSV"
ts.WriteLine "    f = FreeFile"
ts.WriteLine "    Open csvPath For Input As #f"
ts.WriteLine ""
ts.WriteLine "    ' Skip header line"
ts.WriteLine "    If Not EOF(f) Then Line Input #f, line"
ts.WriteLine ""
ts.WriteLine "    r = 2"
ts.WriteLine "    dataRows = 0"
ts.WriteLine "    Do While Not EOF(f)"
ts.WriteLine "        Line Input #f, line"
ts.WriteLine "        If Len(Trim$(line)) = 0 Then GoTo NextImportLine"
ts.WriteLine ""
ts.WriteLine "        fields = CsvSplitLine(line)"
ts.WriteLine "        ws.Cells(r, 1).Value = fields(0)"
ts.WriteLine "        ws.Cells(r, 2).Value = fields(1)"
ts.WriteLine "        ws.Cells(r, 3).Value = fields(2)"
ts.WriteLine "        ws.Cells(r, 4).Value = fields(3)"
ts.WriteLine "        ws.Cells(r, 5).Value = fields(4)"
ts.WriteLine "        r = r + 1"
ts.WriteLine "        dataRows = dataRows + 1"
ts.WriteLine "NextImportLine:"
ts.WriteLine "    Loop"
ts.WriteLine ""
ts.WriteLine "    Close #f"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Generic Data Mapping: extract PDF data to any template via _DataMap sheet"
ts.WriteLine "' ============================================================================"
