ts.WriteLine "' Formatting helpers"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function Fmt(ByVal n As Double) As String"
ts.WriteLine "    Dim s As String"
ts.WriteLine "    s = Format$(Abs(n), ""#,##0.00"")"
ts.WriteLine "    If n < 0 Then"
ts.WriteLine "        Fmt = ""-$ "" & s"
ts.WriteLine "    Else"
ts.WriteLine "        Fmt = ""$ "" & s"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function FmtPct(ByVal n As Double) As String"
ts.WriteLine "    FmtPct = Format$(n, ""0.00"") & ""%"""
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function FmtQty(ByVal v As Variant) As String"
ts.WriteLine "    If IsNull(v) Or IsEmpty(v) Then"
ts.WriteLine "        FmtQty = ""&mdash;"""
ts.WriteLine "    Else"
ts.WriteLine "        FmtQty = Format$(CDbl(v), ""#,##0.00##"")"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function FmtPrice(ByVal v As Variant) As String"
ts.WriteLine "    If IsNull(v) Or IsEmpty(v) Then"
ts.WriteLine "        FmtPrice = ""&mdash;"""
ts.WriteLine "    Else"
ts.WriteLine "        FmtPrice = ""$ "" & Format$(CDbl(v), ""#,##0.00##"")"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function CssNeg(ByVal n As Double) As String"
ts.WriteLine "    If n < 0 Then CssNeg = ""color:#c8102e;"" Else CssNeg = """""
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function CssNegV(ByVal v As Variant) As String"
ts.WriteLine "    If IsNull(v) Or IsEmpty(v) Then CssNegV = """": Exit Function"
ts.WriteLine "    If Not IsNumeric(v) Then CssNegV = """": Exit Function"
ts.WriteLine "    If CDbl(v) < 0 Then CssNegV = ""color:#c8102e;"" Else CssNegV = """""
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function CssGL(ByVal n As Double) As String"
ts.WriteLine "    If n < 0 Then"
ts.WriteLine "        CssGL = ""color:#c8102e;"""
ts.WriteLine "    ElseIf n > 0 Then"
ts.WriteLine "        CssGL = ""color:#1b8a2a;"""
ts.WriteLine "    Else"
ts.WriteLine "        CssGL = """""
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function Esc(ByVal s As String) As String"
ts.WriteLine "    Esc = Replace$(s, ""&"", ""&amp;"")"
ts.WriteLine "    Esc = Replace$(Esc, ""<"", ""&lt;"")"
ts.WriteLine "    Esc = Replace$(Esc, "">"", ""&gt;"")"
ts.WriteLine "    Esc = Replace$(Esc, """""""", ""&quot;"")"
ts.WriteLine "    Esc = Replace$(Esc, ""'"", ""&#39;"")"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function Badge(ByVal passed As Boolean) As String"
ts.WriteLine "    If passed Then"
ts.WriteLine "        Badge = ""<span style=""""display:inline-block;padding:2px 10px;border-radius:10px;"" & _"
ts.WriteLine "                ""font-size:11px;font-weight:700;background:#d4edda;color:#155724;"""">&#10003; PASS</span>"""
ts.WriteLine "    Else"
ts.WriteLine "        Badge = ""<span style=""""display:inline-block;padding:2px 10px;border-radius:10px;"" & _"
ts.WriteLine "                ""font-size:11px;font-weight:700;background:#f8d7da;color:#721c24;"""">&#10007; FAIL</span>"""
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function AcSlug(ByVal name As String) As String"
ts.WriteLine "    Dim lower As String"
ts.WriteLine "    lower = LCase$(name)"
ts.WriteLine "    If InStr(1, lower, ""equit"") > 0 Then"
ts.WriteLine "        AcSlug = ""equities"""
ts.WriteLine "    ElseIf InStr(1, lower, ""fixed"") > 0 And InStr(1, lower, ""income"") > 0 Then"
ts.WriteLine "        AcSlug = ""fixed-income"""
ts.WriteLine "    ElseIf InStr(1, lower, ""cash"") > 0 Or InStr(1, lower, ""money"") > 0 Then"
ts.WriteLine "        AcSlug = ""cash"""
ts.WriteLine "    ElseIf InStr(1, lower, ""alternat"") > 0 Or InStr(1, lower, ""non-traditional"") > 0 Then"
ts.WriteLine "        AcSlug = ""alternatives"""
ts.WriteLine "    Else"
ts.WriteLine "        AcSlug = ""default"""
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function AcBadgeHTML(ByVal assetClass As String) As String"
ts.WriteLine "    If Len(assetClass) = 0 Then"
ts.WriteLine "        AcBadgeHTML = """""
ts.WriteLine "    Else"
ts.WriteLine "        AcBadgeHTML = ""<span class=""""ac-badge ac-"" & AcSlug(assetClass) & """""">"" & Esc(assetClass) & ""</span> """
ts.WriteLine "    End If"
ts.WriteLine "End Function"
