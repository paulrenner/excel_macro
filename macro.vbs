ts.WriteLine "    p(66) = ""Minimum Payment"": p(67) = ""Priority"": p(68) = ""UBS Insured Sweep Prgm"": p(69) = ""TOTAL"""
ts.WriteLine "    p(70) = ""Funds used for"": p(71) = ""Your """
ts.WriteLine "    p(72) = ""Taxable dividends"": p(73) = ""Taxable interest"": p(74) = ""Tax-exempt"": p(75) = ""Dividends"""
ts.WriteLine "    p(76) = ""ENQ7"": p(77) = ""continued"": p(78) = ""Page """
ts.WriteLine "    p(79) = ""Int. Charge"": p(80) = ""MEMO:"": p(81) = ""Managed by"""
ts.WriteLine "    p(82) = ""ACCESS"": p(83) = ""Card purchases"": p(84) = ""Business Services Account"""
ts.WriteLine "    GetSkipPrefixes = p"
ts.WriteLine "End Function"
