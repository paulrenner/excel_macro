  ts.WriteLine "        paH(1) = ""Account"": paS(1) = 1: paE(1) = 2: paA(1) = -4131"
  ts.WriteLine "        paH(2) = ""Tab"": paS(2) = 3: paE(2) = 4: paA(2) = -4131"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, paH, paS, paE, paA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim pai As Long"
  ts.WriteLine "        For pai = 0 To analysis.PhantomAcctCount - 1"
  ts.WriteLine "            MergeWrite ws, r, 1, 2, analysis.PhantomAccounts(pai).AccountNumber"
  ts.WriteLine "            MergeWrite ws, r, 3, 4, analysis.PhantomAccounts(pai).Tab"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine "        Next pai"
  ts.WriteLine "        ws.Range(ws.Cells(secStart, 1), ws.Cells(r - 1, GCOLS)).BorderAround Weight:=4, Color:=RGB(255, 193, 7)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Cell Updates preview — Sheet=1-2, Cell=3, Description=4-7, Value=8-10"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    If analysis.UpdateCount > 0 Then"
  ts.WriteLine "        WriteSubHeader ws, r, analysis.UpdateCount & "" cell update(s) to apply:"""
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim cuH() As String, cuS() As Long, cuE() As Long, cuA() As Long"
  ts.WriteLine "        ReDim cuH(1 To 4): ReDim cuS(1 To 4): ReDim cuE(1 To 4): ReDim cuA(1 To 4)"
  ts.WriteLine "        cuH(1) = ""Sheet"": cuS(1) = 1: cuE(1) = 2: cuA(1) = -4131"
  ts.WriteLine "        cuH(2) = ""Cell"": cuS(2) = 3: cuE(2) = 3: cuA(2) = -4131"
  ts.WriteLine "        cuH(3) = ""Description"": cuS(3) = 4: cuE(3) = 7: cuA(3) = -4131"
  ts.WriteLine "        cuH(4) = ""Value"": cuS(4) = 8: cuE(4) = 10: cuA(4) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, cuH, cuS, cuE, cuA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim cui As Long"
  ts.WriteLine "        Dim prevSheet As String"
  ts.WriteLine "        prevSheet = """""
  ts.WriteLine "        For cui = 0 To analysis.UpdateCount - 1"
  ts.WriteLine "            Dim cu As QPRWriter.CellUpdate"
  ts.WriteLine "            cu = analysis.CellUpdates(cui)"
  ts.WriteLine "            Dim hasDetail As Boolean"
  ts.WriteLine "            hasDetail = (cu.HoldingsDetailCount > 0 Or cu.CashFlowDetailCount > 0)"
  ts.WriteLine ""
  ts.WriteLine "            ' Summary row"
  ts.WriteLine "            MergeWrite ws, r, 1, 2, cu.Sheet"
  ts.WriteLine "            ws.Cells(r, 3).Value = cu.Cell"
  ts.WriteLine "            Dim descText As String"
  ts.WriteLine "            descText = cu.Description"
  ts.WriteLine "            If cu.HoldingsDetailCount > 0 Then"
