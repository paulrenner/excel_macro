  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderPortfolioSummary(ws As Worksheet, r As Long, ByRef portfolio As UBSSummary.PortfolioExtraction) As Long"
  ts.WriteLine "    Dim totalOpening As Double, totalClosing As Double"
  ts.WriteLine "    Dim totalDeposits As Double, totalIncome As Double, totalMarket As Double"
  ts.WriteLine "    Dim i As Long, s As UBSExtract.AccountSummary"
  ts.WriteLine ""
  ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
  ts.WriteLine "        s = portfolio.Accounts(i).Extraction.Summary"
  ts.WriteLine "        totalOpening = totalOpening + s.OpeningValue"
  ts.WriteLine "        totalClosing = totalClosing + s.ClosingValue"
  ts.WriteLine "        totalDeposits = totalDeposits + s.NetDepositsWithdrawals"
  ts.WriteLine "        totalIncome = totalIncome + s.DividendInterestIncome"
  ts.WriteLine "        totalMarket = totalMarket + s.ChangeInMarketValue"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Include loan accounts (as negative)"
  ts.WriteLine "    Dim ls As UBSLoanExtract.LoanSummary"
  ts.WriteLine "    For i = 0 To portfolio.LoanAccountCount - 1"
  ts.WriteLine "        ls = portfolio.LoanAccounts(i).Extraction.Summary"
  ts.WriteLine "        totalOpening = totalOpening - ls.OpeningBalance"
  ts.WriteLine "        totalClosing = totalClosing - ls.ClosingBalance"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    WriteHeader ws, r, ""PORTFOLIO SUMMARY "" & ChrW$(8212) & "" "" & Fmt(totalClosing)"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Summary cards row"
  ts.WriteLine "    r = RenderSummaryCards(ws, r, totalOpening, totalClosing, totalDeposits, totalIncome, totalMarket)"
  ts.WriteLine ""
  ts.WriteLine "    ' Account list"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderAccountList(ws, r, portfolio)"
  ts.WriteLine ""
  ts.WriteLine "    ' Portfolio allocation"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderPortfolioAllocation(ws, r, portfolio, totalClosing)"
  ts.WriteLine ""
  ts.WriteLine "    ' Portfolio income"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderPortfolioIncome(ws, r, portfolio)"
  ts.WriteLine ""
  ts.WriteLine "    ' Portfolio gains"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderPortfolioGains(ws, r, portfolio)"
  ts.WriteLine ""
  ts.WriteLine "    RenderPortfolioSummary = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Summary cards (5 key values in a row)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderSummaryCards(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByVal opening As Double, ByVal closing As Double, _"
  ts.WriteLine "    ByVal deposits As Double, ByVal income As Double, _"
  ts.WriteLine "    ByVal market As Double) As Long"
  ts.WriteLine ""
  ts.WriteLine "    Dim labels As Variant"
  ts.WriteLine "    labels = Array(""Opening Value"", ""Deposits/Withdrawals"", ""Income"", ""Market Change"", ""Closing Value"")"
  ts.WriteLine "    Dim values As Variant"
  ts.WriteLine "    values = Array(opening, deposits, income, market, closing)"
  ts.WriteLine ""
  ts.WriteLine "    ' 5 cards x 2 cols each = 10 columns"
  ts.WriteLine "    Dim labelRow As Long"
  ts.WriteLine "    labelRow = r"
  ts.WriteLine "    Dim c As Long"
  ts.WriteLine "    For c = 0 To 4"
  ts.WriteLine "        Dim c1 As Long, c2 As Long"
  ts.WriteLine "        c1 = c * 2 + 1"
  ts.WriteLine "        c2 = c1 + 1"
  ts.WriteLine "        With ws.Range(ws.Cells(r, c1), ws.Cells(r, c2))"
  ts.WriteLine "            .Merge"
  ts.WriteLine "            .Value = labels(c)"
  ts.WriteLine "            .Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "            .Font.Size = 9"
  ts.WriteLine "            .HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "        End With"
  ts.WriteLine "    Next c"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    For c = 0 To 4"
  ts.WriteLine "        c1 = c * 2 + 1"
  ts.WriteLine "        c2 = c1 + 1"
  ts.WriteLine "        MergeWriteCurrency ws, r, c1, c2, CDbl(values(c))"
  ts.WriteLine "        With ws.Range(ws.Cells(r, c1), ws.Cells(r, c2))"
  ts.WriteLine "            .Font.Bold = True"
  ts.WriteLine "            .Font.Size = 12"
  ts.WriteLine "            .HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "        End With"
  ts.WriteLine "    Next c"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Black border around each card"
  ts.WriteLine "    For c = 0 To 4"
  ts.WriteLine "        c1 = c * 2 + 1"
  ts.WriteLine "        c2 = c1 + 1"
  ts.WriteLine "        ws.Range(ws.Cells(labelRow, c1), ws.Cells(r - 1, c2)).BorderAround Weight:=2, Color:=RGB(0, 0, 0)"
  ts.WriteLine "    Next c"
  ts.WriteLine ""
  ts.WriteLine "    RenderSummaryCards = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Account list (account number, name, beginning value, ending value)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderAccountList(ws As Worksheet, r As Long, ByRef portfolio As UBSSummary.PortfolioExtraction) As Long"
  ts.WriteLine "    ' Banner"
  ts.WriteLine "    WriteHeader ws, r, ""Accounts"""
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Column headers: A=Account, B-C=Nickname, D-F=Account Name, G-H=Beginning, I-J=Ending"
  ts.WriteLine "    ws.Cells(r, 1).Value = ""Account"""
  ts.WriteLine "    MergeWrite ws, r, 2, 3, ""Nickname"""
  ts.WriteLine "    MergeWrite ws, r, 4, 6, ""Account Name"""
  ts.WriteLine "    MergeWrite ws, r, 7, 8, ""Beginning Value"", -4152  ' xlRight"
  ts.WriteLine "    MergeWrite ws, r, 9, 10, ""Ending Value"", -4152"
  ts.WriteLine "    ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Font.Bold = True"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    Dim s As UBSExtract.AccountSummary"
  ts.WriteLine "    Dim totalOpening As Double"
  ts.WriteLine "    Dim totalClosing As Double"
  ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
  ts.WriteLine "        s = portfolio.Accounts(i).Extraction.Summary"
  ts.WriteLine "        ws.Cells(r, 1).Value = s.AccountNumber"
  ts.WriteLine "        MergeWrite ws, r, 2, 3, s.FriendlyName"
  ts.WriteLine "        MergeWrite ws, r, 4, 6, s.AccountName"
  ts.WriteLine "        MergeWriteCurrency ws, r, 7, 8, s.OpeningValue"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, s.ClosingValue"
  ts.WriteLine "        totalOpening = totalOpening + s.OpeningValue"
  ts.WriteLine "        totalClosing = totalClosing + s.ClosingValue"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Loan accounts (shown as negative)"
  ts.WriteLine "    Dim ls As UBSLoanExtract.LoanSummary"
  ts.WriteLine "    For i = 0 To portfolio.LoanAccountCount - 1"
  ts.WriteLine "        ls = portfolio.LoanAccounts(i).Extraction.Summary"
  ts.WriteLine "        ws.Cells(r, 1).Value = portfolio.LoanAccounts(i).AccountNumber"
  ts.WriteLine "        MergeWrite ws, r, 2, 3, """""
  ts.WriteLine "        MergeWrite ws, r, 4, 6, ls.AccountName & "" (Loan)"""
  ts.WriteLine "        MergeWriteCurrency ws, r, 7, 8, -ls.OpeningBalance"
  ts.WriteLine "        MergeWriteCurrency ws, r, 9, 10, -ls.ClosingBalance"
  ts.WriteLine "        totalOpening = totalOpening - ls.OpeningBalance"
  ts.WriteLine "        totalClosing = totalClosing - ls.ClosingBalance"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Total row"
  ts.WriteLine "    MergeWrite ws, r, 1, 6, ""Total"""
  ts.WriteLine "    ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "    MergeWriteCurrency ws, r, 7, 8, totalOpening"
  ts.WriteLine "    MergeWriteCurrency ws, r, 9, 10, totalClosing"
  ts.WriteLine "    ws.Range(ws.Cells(r, 7), ws.Cells(r, 10)).Font.Bold = True"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    RenderAccountList = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Portfolio-level allocation (aggregated across accounts)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderPortfolioAllocation(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, ByVal totalClosing As Double) As Long"
  ts.WriteLine ""
  ts.WriteLine "    Dim canonCat(0 To 6) As String"
  ts.WriteLine "    canonCat(0) = ""Cash and money balances"""
  ts.WriteLine "    canonCat(1) = ""Cash alternatives"""
  ts.WriteLine "    canonCat(2) = ""Equities"""
  ts.WriteLine "    canonCat(3) = ""Fixed income"""
  ts.WriteLine "    canonCat(4) = ""Non-traditional"""
  ts.WriteLine "    canonCat(5) = ""Commodities"""
  ts.WriteLine "    canonCat(6) = ""Other"""
  ts.WriteLine ""
  ts.WriteLine "    Dim catVals(0 To 6) As Double"
  ts.WriteLine "    Dim i As Long, j As Long, k As Long"
  ts.WriteLine "    Dim alloc As UBSExtract.AssetAllocation"
  ts.WriteLine "    Dim hasAny As Boolean"
  ts.WriteLine ""
  ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
  ts.WriteLine "        For j = 0 To portfolio.Accounts(i).Extraction.AllocationCount - 1"
  ts.WriteLine "            alloc = portfolio.Accounts(i).Extraction.Allocations(j)"
  ts.WriteLine "            If alloc.Value = 0 Then GoTo NextPortAlloc"
  ts.WriteLine "            For k = 0 To 6"
  ts.WriteLine "                If canonCat(k) = alloc.Category Then"
  ts.WriteLine "                    catVals(k) = catVals(k) + alloc.Value"
  ts.WriteLine "                    Exit For"
  ts.WriteLine "                End If"
  ts.WriteLine "            Next k"
  ts.WriteLine "NextPortAlloc:"
  ts.WriteLine "        Next j"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    For i = 0 To 6"
  ts.WriteLine "        If catVals(i) <> 0 Then hasAny = True: Exit For"
  ts.WriteLine "    Next i"
  ts.WriteLine "    If Not hasAny Then"
  ts.WriteLine "        RenderPortfolioAllocation = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    WriteSubHeader ws, r, ""Asset Allocation"""
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    Dim aHdrs() As String, aSC() As Long, aEC() As Long, aAL() As Long"
  ts.WriteLine "    ReDim aHdrs(1 To 3): ReDim aSC(1 To 3): ReDim aEC(1 To 3): ReDim aAL(1 To 3)"
  ts.WriteLine "    aHdrs(1) = ""Category"": aSC(1) = 1: aEC(1) = 5: aAL(1) = -4131"
  ts.WriteLine "    aHdrs(2) = ""Value"": aSC(2) = 6: aEC(2) = 8: aAL(2) = -4152"
  ts.WriteLine "    aHdrs(3) = ""%"": aSC(3) = 9: aEC(3) = 10: aAL(3) = -4152"
  ts.WriteLine "    WriteTableHeadersMerged ws, r, aHdrs, aSC, aEC, aAL"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    Dim totalVal As Double"
  ts.WriteLine "    For k = 0 To 6"
  ts.WriteLine "        If catVals(k) <> 0 Then"
  ts.WriteLine "            MergeWrite ws, r, 1, 5, canonCat(k)"
  ts.WriteLine "            MergeWriteCurrency ws, r, 6, 8, catVals(k)"
  ts.WriteLine "            If totalClosing <> 0 Then"
  ts.WriteLine "                With ws.Range(ws.Cells(r, 9), ws.Cells(r, 10))"
  ts.WriteLine "                    .Merge"
  ts.WriteLine "                    .Value = catVals(k) / totalClosing"
  ts.WriteLine "                    .NumberFormat = ""0.00%"""
  ts.WriteLine "                End With"
  ts.WriteLine "            End If"
  ts.WriteLine "            totalVal = totalVal + catVals(k)"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next k"
  ts.WriteLine ""
  ts.WriteLine "    ' Total row"
  ts.WriteLine "    MergeWrite ws, r, 1, 5, ""Total"""
  ts.WriteLine "    ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "    MergeWriteCurrency ws, r, 6, 8, totalVal"
  ts.WriteLine "    ws.Range(ws.Cells(r, 6), ws.Cells(r, 8)).Font.Bold = True"
  ts.WriteLine "    If totalClosing <> 0 Then"
  ts.WriteLine "        With ws.Range(ws.Cells(r, 9), ws.Cells(r, 10))"
  ts.WriteLine "            .Merge"
  ts.WriteLine "            .Value = totalVal / totalClosing"
  ts.WriteLine "            .NumberFormat = ""0.00%"""
  ts.WriteLine "            .Font.Bold = True"
  ts.WriteLine "        End With"
  ts.WriteLine "    End If"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    RenderPortfolioAllocation = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Portfolio-level income (aggregated)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderPortfolioIncome(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction) As Long"
  ts.WriteLine ""
  ts.WriteLine "    Dim totalInc As UBSExtract.IncomeDetail"
