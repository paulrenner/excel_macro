  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Public Function CleanAccountName(nameBlockText As String) As String"
  ts.WriteLine "    Dim nameParts() As String"
  ts.WriteLine "    Dim partCount As Long"
  ts.WriteLine "    partCount = 0"
  ts.WriteLine "    ReDim nameParts(0 To 20)"
  ts.WriteLine ""
  ts.WriteLine "    Dim lines() As String"
  ts.WriteLine "    lines = Split(nameBlockText, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = LBound(lines) To UBound(lines)"
  ts.WriteLine "        Dim line As String"
  ts.WriteLine "        line = Trim$(lines(i))"
  ts.WriteLine "        If line = """" Then GoTo NextNameLine"
  ts.WriteLine ""
  ts.WriteLine "        ' Skip city/state/zip"
  ts.WriteLine "        If RegexTest(line, ""^[A-Z]+(?:\s+[A-Z]+){0,2}\s+[A-Z]{2}\s+\d{5}"") Then GoTo NextNameLine"
  ts.WriteLine "        ' Skip street address"
  ts.WriteLine "        If RegexTest(line, ""^\d+\s+.*\b(AVE|ST|RD|DR|BLVD|LN|CT|WAY|PL|CIR|TER|PKWY)\b"", True) Then GoTo NextNameLine"
  ts.WriteLine "        ' Skip PO Box"
  ts.WriteLine "        If RegexTest(line, ""^P\.?O\.?\s*BOX\s+\d+"", True) Then GoTo NextNameLine"
  ts.WriteLine "        ' Skip account type (IRA etc)"
  ts.WriteLine "        If RegexTest(line, ""^(?:TRADITIONAL|ROTH|SEP|ROLLOVER|INHERITED|SIMPLE)[\s-]*(?:IRA|I\.R\.A\.)$"", True) Then GoTo NextNameLine"
  ts.WriteLine "        ' Skip trustee lines without trust words"
  ts.WriteLine "        If RegexTest(line, ""^[A-Z][A-Z.\s]+(?:TRUSTEE|TTEE)$"") Then"
  ts.WriteLine "            If Not RegexTest(line, ""\b(?:TRUST|TR|REV|FAM|IRREV)\b"") Then GoTo NextNameLine"
  ts.WriteLine "        End If"
  ts.WriteLine "        ' Skip boilerplate"
  ts.WriteLine "        If RegexTest(line, ""^(?:Questions about your statement|Call your Financial|=)"") Then GoTo NextNameLine"
  ts.WriteLine ""
  ts.WriteLine "        ' Strip ""Your Financial Advisor:"" and everything after it"
  ts.WriteLine "        Dim reFA As Object"
  ts.WriteLine "        Set reFA = CreateRegex(""\s*Your Financial Advisor:.*"")"
  ts.WriteLine "        line = reFA.Replace(line, """")"
  ts.WriteLine ""
  ts.WriteLine "        ' Strip trailing address"
  ts.WriteLine "        Dim re As Object"
  ts.WriteLine "        Set re = CreateRegex(""\s+\d+\s+[\w\s]+\b(AVE|ST|RD|DR|BLVD|LN|CT|WAY|PL|CIR|TER|PKWY)\b.*"", False, False, True)"
  ts.WriteLine "        line = re.Replace(line, """")"
  ts.WriteLine "        ' Strip trailing city/state/zip (2+ space gap from column merge)"
  ts.WriteLine "        Set re = CreateRegex(""\s{2,}[A-Z]+(?:\s+[A-Z]+){0,2}\s+[A-Z]{2}\s+\d{5}(?:-\d{4})?.*"")"
  ts.WriteLine "        line = re.Replace(line, """")"
  ts.WriteLine "        ' Strip trailing city/state/zip with single-space gap (loan page layout merge)"
  ts.WriteLine "        Set re = CreateRegex(""\s+[A-Z]+(?:\s+[A-Z]+){0,2}\s+(?:AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY|DC)\s+\d{5}(?:-\d{4})?.*"")"
  ts.WriteLine "        line = re.Replace(line, """")"
  ts.WriteLine "        line = Trim$(line)"
  ts.WriteLine "        If line = """" Then GoTo NextNameLine"
  ts.WriteLine ""
  ts.WriteLine "        ' Skip duplicates"
  ts.WriteLine "        Dim accumulated As String"
  ts.WriteLine "        accumulated = JoinArray(nameParts, "" "", partCount)"
  ts.WriteLine "        If accumulated <> """" And InStr(1, accumulated, line) > 0 Then GoTo NextNameLine"
  ts.WriteLine ""
  ts.WriteLine "        nameParts(partCount) = line"
  ts.WriteLine "        partCount = partCount + 1"
  ts.WriteLine "        If partCount > UBound(nameParts) Then ReDim Preserve nameParts(0 To partCount + 10)"
  ts.WriteLine ""
  ts.WriteLine "NextNameLine:"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    Dim result As String"
  ts.WriteLine "    result = JoinArray(nameParts, "" "", partCount)"
  ts.WriteLine "    ' Collapse multiple spaces"
  ts.WriteLine "    Set re = CreateRegex(""\s{2,}"", True)"
  ts.WriteLine "    result = re.Replace(result, "" "")"
  ts.WriteLine "    ' Strip pledge text"
  ts.WriteLine "    Set re = CreateRegex(""\s*Pleg'd Coll Acct-FBO UBS Bank USA"", False, False, True)"
  ts.WriteLine "    result = re.Replace(result, """")"
  ts.WriteLine "    CleanAccountName = Trim$(result)"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Function JoinArray(arr() As String, delimiter As String, count As Long) As String"
  ts.WriteLine "    If count = 0 Then"
  ts.WriteLine "        JoinArray = """""
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine "    Dim tmp() As String"
  ts.WriteLine "    ReDim tmp(0 To count - 1)"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = 0 To count - 1"
  ts.WriteLine "        tmp(i) = arr(i)"
  ts.WriteLine "    Next i"
  ts.WriteLine "    JoinArray = Join(tmp, delimiter)"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Holding number parser"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Sub ParseHoldingNumbers(textAfterName As String, ByRef Value As Double, ByRef CostBasis As Variant, ByRef UnrealizedGL As Variant)"
  ts.WriteLine "    Value = 0#"
  ts.WriteLine "    CostBasis = Null"
  ts.WriteLine "    UnrealizedGL = Null"
  ts.WriteLine ""
  ts.WriteLine "    Dim matches As Object"
  ts.WriteLine "    Set matches = RegexMatchAll(textAfterName, NUM_PAT)"
  ts.WriteLine "    If matches.Count = 0 Then Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "    ' Collect non-percentage numbers"
  ts.WriteLine "    Dim numericVals() As Double"
  ts.WriteLine "    Dim numCount As Long"
  ts.WriteLine "    numCount = 0"
  ts.WriteLine "    ReDim numericVals(0 To matches.Count - 1)"
  ts.WriteLine ""
  ts.WriteLine "    Dim remaining As String"
  ts.WriteLine "    remaining = textAfterName"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = 0 To matches.Count - 1"
  ts.WriteLine "        Dim numStr As String"
  ts.WriteLine "        numStr = matches(i).Value"
  ts.WriteLine "        Dim pos As Long"
  ts.WriteLine "        pos = InStr(1, remaining, numStr)"
  ts.WriteLine "        If pos = 0 Then GoTo NextNum"
  ts.WriteLine "        Dim afterNum As String"
  ts.WriteLine "        afterNum = LTrim$(Mid$(remaining, pos + Len(numStr)))"
  ts.WriteLine "        If Left$(afterNum, 1) = ""%"" Then"
  ts.WriteLine "            remaining = Mid$(afterNum, 2)"
  ts.WriteLine "            GoTo NextNum"
  ts.WriteLine "        End If"
  ts.WriteLine "        numericVals(numCount) = SafeFloat(numStr)"
  ts.WriteLine "        numCount = numCount + 1"
  ts.WriteLine "        remaining = afterNum"
  ts.WriteLine "NextNum:"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    If numCount > 0 Then Value = numericVals(0)"
  ts.WriteLine "    If numCount = 2 Then"
  ts.WriteLine "        CostBasis = numericVals(1)"
  ts.WriteLine "    ElseIf numCount = 3 Then"
  ts.WriteLine "        CostBasis = numericVals(1)"
  ts.WriteLine "        UnrealizedGL = numericVals(2)"
  ts.WriteLine "    ' 4-number layout: Value, CostBasis, [intermediate % or accrued interest], UnrealizedGL"
  ts.WriteLine "    ElseIf numCount >= 4 Then"
  ts.WriteLine "        CostBasis = numericVals(1)"
  ts.WriteLine "        ' Index 2 is an intermediate value (e.g. unrealized % or accrued interest); skip it"
  ts.WriteLine "        UnrealizedGL = numericVals(3)"
  ts.WriteLine "    End If"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Account Summary extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ExtractAccountSummary(text As String) As AccountSummary"
  ts.WriteLine "    Dim summary As AccountSummary"
  ts.WriteLine ""
  ts.WriteLine "    Dim startM() As String: startM = SArr(""Account name:"")"
  ts.WriteLine "    Dim endM() As String: endM = SArr2(""Your account balance sheet"", ""Summary of your assets"")"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    section = ExtractSection(text, startM, endM)"
  ts.WriteLine ""
  ts.WriteLine "    ' Account name"
  ts.WriteLine "    Dim m As Object"
  ts.WriteLine "    Set m = RegexMatch(section, ""Account name:\s*([\s\S]*?)(?=Friendly account name:|Account number:)"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.AccountName = CleanAccountName(m.SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Friendly name"
  ts.WriteLine "    Set m = RegexMatch(section, ""Friendly account name:\s*(.+?)(?:\n|$)"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        Dim fn As String"
  ts.WriteLine "        fn = Trim$(m.SubMatches(0))"
  ts.WriteLine "        ' Strip side-by-side text"
  ts.WriteLine "        Dim re As Object"
  ts.WriteLine "        Set re = CreateRegex(""\s{2,}.*"")"
  ts.WriteLine "        summary.FriendlyName = re.Replace(fn, """")"
  ts.WriteLine "        ' Strip trailing address fragments (CITY STATE ZIP) from right-column bleed"
  ts.WriteLine "        Set re = CreateRegex(""\s+[A-Z][A-Z\s]+\d{5}(-\d{4})?$"")"
  ts.WriteLine "        summary.FriendlyName = re.Replace(summary.FriendlyName, """")"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Account number"
  ts.WriteLine "    Set m = RegexMatch(section, ""Account number:\s*(.+?)(?:\n|$)"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.AccountNumber = Trim$(Replace(m.SubMatches(0), "" WM"", """"))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Financial advisor"
  ts.WriteLine "    Set m = RegexMatch(section, ""Your Financial Advisor:\s*\n\s*(.+?)(?:\n|$)"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.FinancialAdvisor = Trim$(m.SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Statement period"
  ts.WriteLine "    Set m = RegexMatch(section, ""((?:January|February|March|April|May|June|July|August|September|October|November|December)\s+\d{4})"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.StatementPeriod = Trim$(m.SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Your assets (opening/closing)"
  ts.WriteLine "    Set m = RegexMatch(section, ""Your assets\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.OpeningValue = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "        summary.ClosingValue = SafeFloat(m.SubMatches(1))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Add liabilities (already negative via NUM_PAT) to adjust net value"
  ts.WriteLine "    Set m = RegexMatch(section, ""Your liabilities\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.OpeningValue = summary.OpeningValue + SafeFloat(m.SubMatches(0))"
  ts.WriteLine "        summary.ClosingValue = summary.ClosingValue + SafeFloat(m.SubMatches(1))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Loan accounts fallback"
  ts.WriteLine "    If summary.OpeningValue = 0# And summary.ClosingValue = 0# Then"
  ts.WriteLine "        Set m = RegexMatch(section, ""Total loan balance\s+\$?("" & NUM_PAT & "")\s+\$?("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            summary.OpeningValue = -SafeFloat(m.SubMatches(0))"
  ts.WriteLine "            summary.ClosingValue = -SafeFloat(m.SubMatches(1))"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' 529 Plan fallback: extract closing value from ""Your total assets"" table"
  ts.WriteLine "    If summary.OpeningValue = 0# And summary.ClosingValue = 0# Then"
  ts.WriteLine "        If InStr(1, text, ""529 Plan"") > 0 Then"
  ts.WriteLine "            Set m = RegexMatch(text, ""Your total assets[\s\S]*?Total\s+\$?("" & NUM_PAT & "")"")"
  ts.WriteLine "            If Not m Is Nothing Then"
  ts.WriteLine "                summary.ClosingValue = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Change in value section"
  ts.WriteLine "    Dim tl As String"
  ts.WriteLine "    tl = LCase$(text)"
  ts.WriteLine "    Dim changeStart As Long"
  ts.WriteLine "    changeStart = InStr(1, tl, ""change in the value of your account"")"
  ts.WriteLine ""
  ts.WriteLine "    Dim changeSection As String"
  ts.WriteLine "    If changeStart > 0 Then"
  ts.WriteLine "        Dim closePos As Long"
  ts.WriteLine "        closePos = InStr(changeStart, tl, ""closing account value"")"
  ts.WriteLine "        If closePos > 0 Then"
  ts.WriteLine "            Dim le As Long"
  ts.WriteLine "            le = LineEnd(text, closePos)"
  ts.WriteLine "            changeSection = Mid$(text, changeStart, le - changeStart)"
  ts.WriteLine "        Else"
  ts.WriteLine "            changeSection = Mid$(text, changeStart, SECTION_LOOKAHEAD)"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Opening/closing account value (alternative format)"
  ts.WriteLine "    Set m = RegexMatch(changeSection, ""Opening account value\s+\$?("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.OpeningValue = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(changeSection, ""Closing account value\s+\$?("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.ClosingValue = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Deposits transferred in (monthly = SubMatches(0), YTD = SubMatches(1))"
  ts.WriteLine "    Dim deposits As Double"
  ts.WriteLine "    Set m = RegexMatch(changeSection, ""transferred in\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then deposits = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "    ' Withdrawals/out (monthly = SubMatches(0))"
  ts.WriteLine "    Dim withdrawals As Double"
  ts.WriteLine "    Set re = CreateRegex(""^out\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"", False, True)"
  ts.WriteLine "    Dim matches As Object"
  ts.WriteLine "    Set matches = re.Execute(changeSection)"
  ts.WriteLine "    If matches.Count > 0 Then"
  ts.WriteLine "        withdrawals = SafeFloat(matches(0).SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    If deposits = 0# And withdrawals = 0# Then"
  ts.WriteLine "        Set m = RegexMatch(changeSection, ""out\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then withdrawals = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    summary.DepositsTransferredIn = deposits"
  ts.WriteLine "    summary.NetDepositsWithdrawals = deposits + withdrawals"
  ts.WriteLine ""
  ts.WriteLine "    ' Dividend & interest income (SubMatches(0) = Monthly, SubMatches(1) = YTD)"
  ts.WriteLine "    Set m = RegexMatch(changeSection, ""Dividend and interest income\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then summary.DividendInterestIncome = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "    ' Change in market value (SubMatches(0) = Monthly, SubMatches(1) = YTD)"
  ts.WriteLine "    Set m = RegexMatch(changeSection, ""Change in market value\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        summary.ChangeInMarketValue = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "        summary.ChangeInMarketValueMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Change in accrued interest"
  ts.WriteLine "    Set m = RegexMatch(changeSection, ""Change in value of accrued[\s\S]+?interest\s+(-?"" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then summary.ChangeInAccruedInterest = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "    ExtractAccountSummary = summary"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Asset Allocation extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ExtractAssetAllocation(text As String) As AssetAllocation()"
  ts.WriteLine "    Dim allocations() As AssetAllocation"
  ts.WriteLine "    ReDim allocations(0 To 6)"
  ts.WriteLine ""
  ts.WriteLine "    ' Always set category names so fallback logic can use them"
  ts.WriteLine "    allocations(0).Category = ""Cash and money balances"""
  ts.WriteLine "    allocations(1).Category = ""Cash alternatives"""
  ts.WriteLine "    allocations(2).Category = ""Equities"""
  ts.WriteLine "    allocations(3).Category = ""Fixed income"""
  ts.WriteLine "    allocations(4).Category = ""Non-traditional"""
  ts.WriteLine "    allocations(5).Category = ""Commodities"""
  ts.WriteLine "    allocations(6).Category = ""Other"""
  ts.WriteLine ""
  ts.WriteLine "    Dim tl As String"
  ts.WriteLine "    tl = LCase$(text)"
  ts.WriteLine "    Dim summaryPos As Long"
  ts.WriteLine "    summaryPos = InStr(1, tl, ""summary of your assets"")"
  ts.WriteLine "    If summaryPos = 0 Then"
  ts.WriteLine "        ExtractAssetAllocation = allocations"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim totalPos As Long"
  ts.WriteLine "    totalPos = InStr(summaryPos, tl, ""total assets"")"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    If totalPos > 0 Then"
  ts.WriteLine "        Dim le As Long"
  ts.WriteLine "        le = LineEnd(text, totalPos)"
  ts.WriteLine "        section = Mid$(text, summaryPos, le - summaryPos)"
  ts.WriteLine "    Else"
  ts.WriteLine "        Dim startM() As String: startM = SArr(""Summary of your assets"")"
  ts.WriteLine "        Dim endM() As String: endM = SArr(""Total assets"")"
  ts.WriteLine "        section = ExtractSection(text, startM, endM)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim categories(0 To 6) As String"
  ts.WriteLine "    categories(0) = ""Cash and money balances"""
  ts.WriteLine "    categories(1) = ""Cash alternatives"""
  ts.WriteLine "    categories(2) = ""Equities"""
  ts.WriteLine "    categories(3) = ""Fixed income"""
  ts.WriteLine "    categories(4) = ""Non-traditional"""
  ts.WriteLine "    categories(5) = ""Commodities"""
  ts.WriteLine "    categories(6) = ""Other"""
  ts.WriteLine ""
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = 0 To 6"
  ts.WriteLine "        allocations(i).Category = categories(i)"
  ts.WriteLine "        ' Escape special regex chars in category name"
  ts.WriteLine "        Dim escaped As String"
  ts.WriteLine "        escaped = RegexEscape(categories(i))"
  ts.WriteLine "        Dim m As Object"
  ts.WriteLine "        Set m = RegexMatch(section, escaped & ""\s+("" & NUM_PAT & "")\s+(\d+\.\d{2})%"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            allocations(i).Value = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "            allocations(i).Percentage = SafeFloat(m.SubMatches(1))"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ExtractAssetAllocation = allocations"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Function RegexEscape(s As String) As String"
  ts.WriteLine "    RegexEscape = RegexHelper.RegexEscape(s)"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Holdings extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function IsHoldingsBoilerplate(line As String) As Boolean"
  ts.WriteLine "    ' Skip header/footer lines in holdings section"
  ts.WriteLine "    If Left$(line, 13) = ""Percentage of"" Then IsHoldingsBoilerplate = True: Exit Function"
  ts.WriteLine "    If Left$(line, 8) = ""Value on"" Then IsHoldingsBoilerplate = True: Exit Function"
  ts.WriteLine "    If Left$(line, 16) = ""Your total assets"" Then IsHoldingsBoilerplate = True: Exit Function"
  ts.WriteLine "    If Left$(line, 9) = ""* Missing"" Then IsHoldingsBoilerplate = True: Exit Function"
  ts.WriteLine "    If Left$(line, 5) = ""Total"" And Left$(line, 22) <> ""Total accrued interest"" Then"
  ts.WriteLine "        IsHoldingsBoilerplate = True: Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine "    IsHoldingsBoilerplate = False"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Function ExtractHoldings(text As String) As Holding()"
  ts.WriteLine "    Dim startM() As String: startM = SArr2(""Your total assets"", ""Summary of your assets"")"
  ts.WriteLine "    Dim endM() As String: endM = SArr(""Account activity this month"")"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    section = ExtractSection(text, startM, endM)"
  ts.WriteLine ""
  ts.WriteLine "    Dim holdings() As Holding"
  ts.WriteLine "    Dim holdCount As Long"
  ts.WriteLine "    holdCount = 0"
  ts.WriteLine "    ReDim holdings(0 To 30)"
  ts.WriteLine ""
  ts.WriteLine "    Dim currentAssetClass As String"
  ts.WriteLine ""
  ts.WriteLine "    ' Asset type map: holding name -> asset class"
  ts.WriteLine "    Dim holdingNames(0 To 13) As String"
  ts.WriteLine "    Dim assetTypes(0 To 13) As String"
  ts.WriteLine "    holdingNames(0) = ""Cash and money balances"": assetTypes(0) = ""Cash and money balances"""
  ts.WriteLine "    holdingNames(1) = ""Money market funds"": assetTypes(1) = ""Cash alternatives"""
  ts.WriteLine "    holdingNames(2) = ""Common stock"": assetTypes(2) = ""Equities"""
  ts.WriteLine "    holdingNames(3) = ""Municipal securities"": assetTypes(3) = ""Fixed income"""
  ts.WriteLine "    holdingNames(4) = ""Fixed income"": assetTypes(4) = ""Fixed income"""
  ts.WriteLine "    holdingNames(5) = ""Private equity funds"": assetTypes(5) = ""Non-traditional"""
  ts.WriteLine "    holdingNames(6) = ""Hedge funds"": assetTypes(6) = ""Non-traditional"""
  ts.WriteLine "    holdingNames(7) = ""Other investments"": assetTypes(7) = ""Non-traditional"""
  ts.WriteLine "    holdingNames(8) = ""Other equity investments"": assetTypes(8) = ""Equities"""
  ts.WriteLine "    holdingNames(9) = ""Mutual funds"": assetTypes(9) = ""Other"""
  ts.WriteLine "    holdingNames(10) = ""Life insurance"": assetTypes(10) = ""Other"""
  ts.WriteLine "    holdingNames(11) = ""Closed end funds & Exchange traded"": assetTypes(11) = ""Equities"""
  ts.WriteLine "    holdingNames(12) = ""Total accrued interest"": assetTypes(12) = ""Fixed income"""
  ts.WriteLine "    holdingNames(13) = ""Annuities"": assetTypes(13) = ""Other"""
  ts.WriteLine ""
  ts.WriteLine "    ' Asset class prefixes"
  ts.WriteLine "    Dim classPrefixes(0 To 6) As String"
  ts.WriteLine "    Dim classNames(0 To 6) As String"
  ts.WriteLine "    classPrefixes(0) = ""Cash alternatives "": classNames(0) = ""Cash alternatives"""
  ts.WriteLine "    classPrefixes(1) = ""Fixed income "": classNames(1) = ""Fixed income"""
  ts.WriteLine "    classPrefixes(2) = ""Commodities "": classNames(2) = ""Commodities"""
  ts.WriteLine "    classPrefixes(3) = ""Cash "": classNames(3) = ""Cash and money balances"""
  ts.WriteLine "    classPrefixes(4) = ""Equities "": classNames(4) = ""Equities"""
  ts.WriteLine "    classPrefixes(5) = ""Non-traditional "": classNames(5) = ""Non-traditional"""
  ts.WriteLine "    classPrefixes(6) = ""Other "": classNames(6) = ""Other"""
  ts.WriteLine ""
  ts.WriteLine "    Dim lines() As String"
  ts.WriteLine "    lines = Split(section, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    Dim li As Long"
  ts.WriteLine "    For li = LBound(lines) To UBound(lines)"
  ts.WriteLine "        Dim line As String"
  ts.WriteLine "        line = Trim$(lines(li))"
  ts.WriteLine "        If line = """" Then GoTo NextHoldingLine"
  ts.WriteLine "        If RegexTest(line, ""^=== PAGE \d+ ==="") Then GoTo NextHoldingLine"
  ts.WriteLine "        If IsHoldingsBoilerplate(line) Then GoTo NextHoldingLine"
  ts.WriteLine ""
  ts.WriteLine "        ' Check asset class prefixes"
  ts.WriteLine "        Dim rest As String"
  ts.WriteLine "        rest = line"
  ts.WriteLine "        Dim pi As Long"
  ts.WriteLine "        For pi = 0 To 6"
  ts.WriteLine "            If Left$(line, Len(classPrefixes(pi))) = classPrefixes(pi) Then"
  ts.WriteLine "                currentAssetClass = classNames(pi)"
  ts.WriteLine "                Dim after As String"
  ts.WriteLine "                after = LTrim$(Mid$(line, Len(classPrefixes(pi)) + 1))"
  ts.WriteLine "                If Left$(after, 1) = ""*"" Then after = LTrim$(Mid$(after, 2))"
  ts.WriteLine "                ' Check if a holding name follows on same line"
  ts.WriteLine "                Dim hi As Long"
  ts.WriteLine "                For hi = 0 To 13"
  ts.WriteLine "                    If Left$(after, Len(holdingNames(hi))) = holdingNames(hi) Then"
  ts.WriteLine "                        rest = after"
  ts.WriteLine "                        Exit For"
  ts.WriteLine "                    End If"
  ts.WriteLine "                Next hi"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next pi"
  ts.WriteLine ""
  ts.WriteLine "        ' Strip single-letter prefix (A-G)"
  ts.WriteLine "        If Len(rest) >= 2 And Mid$(rest, 2, 1) = "" "" Then"
  ts.WriteLine "            Dim fc As String"
  ts.WriteLine "            fc = Left$(rest, 1)"
  ts.WriteLine "            If fc >= ""A"" And fc <= ""G"" Then"
  ts.WriteLine "                rest = Mid$(rest, 3)"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Strip leading asterisks"
  ts.WriteLine "        Dim re As Object"
  ts.WriteLine "        Set re = CreateRegex(""^\*+\s*"")"
  ts.WriteLine "        Dim restClean As String"
  ts.WriteLine "        restClean = re.Replace(rest, """")"
  ts.WriteLine ""
  ts.WriteLine "        ' Match against holding names"
  ts.WriteLine "        For hi = 0 To 13"
  ts.WriteLine "            If Left$(restClean, Len(holdingNames(hi))) <> holdingNames(hi) Then GoTo NextHolding"
  ts.WriteLine ""
  ts.WriteLine "            Dim afterName As String"
  ts.WriteLine "            afterName = Trim$(Mid$(restClean, Len(holdingNames(hi)) + 1))"
  ts.WriteLine ""
  ts.WriteLine "            ' Special case: ""Closed end funds & Exchange traded"" needs numbers to follow"
  ts.WriteLine "            If holdingNames(hi) = ""Closed end funds & Exchange traded"" Then"
  ts.WriteLine "                If Not RegexTest(afterName, ""^("" & NUM_PAT & "")"") Then GoTo NextHolding"
  ts.WriteLine "            End If"
  ts.WriteLine ""
  ts.WriteLine "            Dim hValue As Double, hCost As Variant, hGL As Variant"
  ts.WriteLine "            ParseHoldingNumbers afterName, hValue, hCost, hGL"
  ts.WriteLine ""
  ts.WriteLine "            ' Skip if no value and no numbers found"
  ts.WriteLine "            If hValue = 0# And Not RegexTest(afterName, NUM_PAT) Then"
  ts.WriteLine "                GoTo NextHolding"
  ts.WriteLine "            End If"
  ts.WriteLine ""
  ts.WriteLine "            ' Money market funds: UBS never shows cost basis (the 2nd number is EAI)"
  ts.WriteLine "            If holdingNames(hi) = ""Money market funds"" Then"
  ts.WriteLine "                hCost = Null"
  ts.WriteLine "                hGL = Null"
  ts.WriteLine "            End If"
  ts.WriteLine ""
  ts.WriteLine "            ' Add holding"
  ts.WriteLine "            If holdCount > UBound(holdings) Then ReDim Preserve holdings(0 To holdCount + 20)"
  ts.WriteLine "            holdings(holdCount).Name = holdingNames(hi)"
  ts.WriteLine "            If currentAssetClass <> """" Then"
  ts.WriteLine "                holdings(holdCount).AssetType = currentAssetClass"
  ts.WriteLine "            Else"
  ts.WriteLine "                holdings(holdCount).AssetType = assetTypes(hi)"
  ts.WriteLine "            End If"
  ts.WriteLine "            holdings(holdCount).Value = hValue"
  ts.WriteLine "            holdings(holdCount).CostBasis = hCost"
  ts.WriteLine "            holdings(holdCount).UnrealizedGL = hGL"
  ts.WriteLine "            ReDim holdings(holdCount).Securities(0 To 0)"
  ts.WriteLine "            holdings(holdCount).SecurityCount = 0"
  ts.WriteLine "            holdCount = holdCount + 1"
  ts.WriteLine "            Exit For"
  ts.WriteLine "NextHolding:"
  ts.WriteLine "        Next hi"
  ts.WriteLine ""
  ts.WriteLine "NextHoldingLine:"
  ts.WriteLine "    Next li"
  ts.WriteLine ""
  ts.WriteLine "    ' Handle ""Closed end funds & Exchange traded products"" spanning two lines."
  ts.WriteLine "    ' May appear multiple times under different asset classes (Equities, Fixed income, Commodities)."
  ts.WriteLine "    ' Produce a separate holding per asset class so QPR allocation routing stays correct."
  ts.WriteLine "    Dim cefMatches As Object"
  ts.WriteLine "    Set cefMatches = RegexMatchAll(section, ""Closed end funds & Exchange traded\s*\n\s*products\s+(.*)"")"
  ts.WriteLine "    Dim ci As Long"
  ts.WriteLine "    For ci = 0 To cefMatches.Count - 1"
  ts.WriteLine "        ' Parse value, cost basis, unrealized GL from the ""products"" line"
  ts.WriteLine "        Dim cefAfterName As String"
  ts.WriteLine "        cefAfterName = cefMatches(ci).SubMatches(0)"
  ts.WriteLine "        Dim cefValue As Double, cefCost As Variant, cefGL As Variant"
  ts.WriteLine "        ParseHoldingNumbers cefAfterName, cefValue, cefCost, cefGL"
  ts.WriteLine ""
  ts.WriteLine "        ' Determine asset class by finding the nearest preceding prefix"
  ts.WriteLine "        Dim cefMatchStart As Long"
  ts.WriteLine "        cefMatchStart = cefMatches(ci).FirstIndex + 1  ' VBA 1-based"
  ts.WriteLine "        Dim textBefore As String"
  ts.WriteLine "        textBefore = Left$(section, cefMatchStart - 1)"
  ts.WriteLine "        Dim cefAssetClass As String"
  ts.WriteLine "        cefAssetClass = ""Equities"""
  ts.WriteLine "        Dim bestPrefixIdx As Long"
  ts.WriteLine "        bestPrefixIdx = -1"
  ts.WriteLine "        Dim cpi As Long"
  ts.WriteLine "        For cpi = 0 To 6"
  ts.WriteLine "            Dim pfxPos As Long"
  ts.WriteLine "            pfxPos = InStrRev(textBefore, classPrefixes(cpi))"
  ts.WriteLine "            If pfxPos > bestPrefixIdx Then"
  ts.WriteLine "                bestPrefixIdx = pfxPos"
  ts.WriteLine "                cefAssetClass = classNames(cpi)"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next cpi"
  ts.WriteLine ""
  ts.WriteLine "        If holdCount > UBound(holdings) Then ReDim Preserve holdings(0 To holdCount + 5)"
  ts.WriteLine "        holdings(holdCount).Name = ""Closed end funds & Exchange traded products"""
  ts.WriteLine "        holdings(holdCount).AssetType = cefAssetClass"
  ts.WriteLine "        holdings(holdCount).Value = cefValue"
  ts.WriteLine "        holdings(holdCount).CostBasis = cefCost"
  ts.WriteLine "        holdings(holdCount).UnrealizedGL = cefGL"
  ts.WriteLine "        ReDim holdings(holdCount).Securities(0 To 0)"
  ts.WriteLine "        holdings(holdCount).SecurityCount = 0"
  ts.WriteLine "        holdCount = holdCount + 1"
  ts.WriteLine "    Next ci"
  ts.WriteLine ""
  ts.WriteLine "    ' Subtract liabilities from cash"
  ts.WriteLine "    Dim liabM As Object"
  ts.WriteLine "    Set liabM = RegexMatch(section, ""Total liabilities\s+-?\$?([\d,]+\.\d{2})"")"
  ts.WriteLine "    If Not liabM Is Nothing Then"
  ts.WriteLine "        Dim liabAmt As Double"
  ts.WriteLine "        liabAmt = SafeFloat(liabM.SubMatches(0))"
  ts.WriteLine "        Dim hIdx As Long"
  ts.WriteLine "        For hIdx = 0 To holdCount - 1"
  ts.WriteLine "            If holdings(hIdx).Name = ""Cash and money balances"" Then"
  ts.WriteLine "                holdings(hIdx).Value = holdings(hIdx).Value - liabAmt"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next hIdx"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ReDim Preserve holdings(0 To IIf(holdCount > 0, holdCount - 1, 0))"
  ts.WriteLine "    ExtractHoldings = holdings"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' 529 Plan holdings extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "' Parses ""529 Plan"" section found on some Investment Account statements."
  ts.WriteLine "' Returns a single Holding named ""529 Plan"" (asset type ""Other"") with each"
  ts.WriteLine "' fund as a SecurityDetail.  Returns an empty array (one blank element) when"
  ts.WriteLine "' the page does not contain a 529 Plan section."
  ts.WriteLine "Private Function Extract529PlanHoldings(text As String) As Holding()"
  ts.WriteLine "    Dim result(0 To 0) As Holding"
  ts.WriteLine "    ReDim result(0).Securities(0 To 0)"
  ts.WriteLine "    result(0).SecurityCount = 0"
  ts.WriteLine ""
  ts.WriteLine "    ' Locate ""529 Plan"" section"
  ts.WriteLine "    Dim planPos As Long"
  ts.WriteLine "    planPos = InStr(1, text, ""529 Plan"")"
  ts.WriteLine "    If planPos = 0 Then"
  ts.WriteLine "        Extract529PlanHoldings = result"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Section runs from ""529 Plan"" to the next ""Total"" line"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    Dim totalPos As Long"
  ts.WriteLine "    totalPos = InStr(planPos, LCase$(text), vbLf & ""total"")"
  ts.WriteLine "    If totalPos > 0 Then"
  ts.WriteLine "        section = Mid$(text, planPos, totalPos - planPos)"
  ts.WriteLine "    Else"
  ts.WriteLine "        section = Mid$(text, planPos, 2000)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Match holding rows: quantity (3 dec), price per share (2-3 dec), value (2 dec)"
  ts.WriteLine "    ' Pattern: name-text  quantity  price  value"
  ts.WriteLine "    ' The name may span the preceding line(s); we capture all three numbers on a single line."
  ts.WriteLine "    Dim rowPat As String"
  ts.WriteLine "    rowPat = ""([\d,]+\.\d{3})\s+([\d,.]+\.\d{2,3})\s+("" & NUM_PAT & "")"""
  ts.WriteLine "    Dim matches As Object"
  ts.WriteLine "    Set matches = RegexMatchAll(section, rowPat)"
  ts.WriteLine ""
  ts.WriteLine "    If matches.Count = 0 Then"
  ts.WriteLine "        Extract529PlanHoldings = result"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Build securities"
  ts.WriteLine "    Dim secs() As SecurityDetail"
  ts.WriteLine "    ReDim secs(0 To matches.Count - 1)"
  ts.WriteLine "    Dim lines() As String"
  ts.WriteLine "    lines = Split(section, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    Dim mi As Long"
  ts.WriteLine "    For mi = 0 To matches.Count - 1"
  ts.WriteLine "        Dim qty As Double: qty = SafeFloat(matches(mi).SubMatches(0))"
  ts.WriteLine "        Dim price As Double: price = SafeFloat(matches(mi).SubMatches(1))"
  ts.WriteLine "        Dim val As Double: val = SafeFloat(matches(mi).SubMatches(2))"
  ts.WriteLine ""
  ts.WriteLine "        ' Find the line containing this match to extract the holding name"
  ts.WriteLine "        Dim matchText As String"
  ts.WriteLine "        matchText = matches(mi).Value"
  ts.WriteLine "        Dim nameParts() As String"
  ts.WriteLine "        Dim namePartCount As Long"
  ts.WriteLine "        namePartCount = 0"
  ts.WriteLine "        ReDim nameParts(0 To 5)"
  ts.WriteLine ""
  ts.WriteLine "        Dim li As Long"
  ts.WriteLine "        For li = LBound(lines) To UBound(lines)"
  ts.WriteLine "            If InStr(1, lines(li), matchText) > 0 Then"
  ts.WriteLine "                ' Name is everything on this line before the numbers"
  ts.WriteLine "                Dim numPos As Long"
  ts.WriteLine "                numPos = InStr(1, lines(li), matches(mi).SubMatches(0))"
  ts.WriteLine "                If numPos > 1 Then"
  ts.WriteLine "                    Dim lineName As String"
  ts.WriteLine "                    lineName = Trim$(Left$(lines(li), numPos - 1))"
  ts.WriteLine "                    If Len(lineName) > 0 Then"
  ts.WriteLine "                        nameParts(namePartCount) = lineName"
  ts.WriteLine "                        namePartCount = namePartCount + 1"
  ts.WriteLine "                    End If"
  ts.WriteLine "                End If"
  ts.WriteLine "                ' Also collect preceding non-blank, non-header lines as name continuation"
  ts.WriteLine "                Dim pi As Long"
  ts.WriteLine "                For pi = li - 1 To LBound(lines) Step -1"
  ts.WriteLine "                    Dim prevLine As String"
  ts.WriteLine "                    prevLine = Trim$(lines(pi))"
  ts.WriteLine "                    If prevLine = """" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 7) = ""Holding"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 8) = ""Price per"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 8) = ""share ($)"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 13) = ""POSITION DATE"" Then Exit For"
  ts.WriteLine "                    If RegexTest(prevLine, ""^\d[\d,]+\.\d{3}"") Then Exit For"
  ts.WriteLine "                    ' This is a name continuation line"
  ts.WriteLine "                    If namePartCount > UBound(nameParts) Then ReDim Preserve nameParts(0 To namePartCount + 5)"
  ts.WriteLine "                    nameParts(namePartCount) = prevLine"
  ts.WriteLine "                    namePartCount = namePartCount + 1"
  ts.WriteLine "                Next pi"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next li"
  ts.WriteLine ""
  ts.WriteLine "        ' Reverse name parts (we collected bottom-up) and join"
  ts.WriteLine "        Dim holdName As String"
  ts.WriteLine "        If namePartCount > 1 Then"
  ts.WriteLine "            Dim reversed() As String"
  ts.WriteLine "            ReDim reversed(0 To namePartCount - 1)"
  ts.WriteLine "            Dim ri As Long"
  ts.WriteLine "            For ri = 0 To namePartCount - 1"
  ts.WriteLine "                reversed(ri) = nameParts(namePartCount - 1 - ri)"
  ts.WriteLine "            Next ri"
  ts.WriteLine "            holdName = Join(reversed, "" "")"
  ts.WriteLine "        ElseIf namePartCount = 1 Then"
  ts.WriteLine "            holdName = nameParts(0)"
  ts.WriteLine "        Else"
  ts.WriteLine "            holdName = ""529 Fund "" & (mi + 1)"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        secs(mi).Name = holdName"
  ts.WriteLine "        secs(mi).Symbol = """""
  ts.WriteLine "        secs(mi).Units = qty"
  ts.WriteLine "        secs(mi).Value = val"
  ts.WriteLine "        secs(mi).CostBasis = Null"
  ts.WriteLine "        secs(mi).UnrealizedGL = Null"
  ts.WriteLine "        secs(mi).IsEscrow = False"
  ts.WriteLine "        secs(mi).CategoryKey = ""529 Plan"""
  ts.WriteLine "        secs(mi).DeathBenefit = Null"
  ts.WriteLine "        secs(mi).LivingBenefit = Null"
  ts.WriteLine "        secs(mi).SurrenderValue = Null"
  ts.WriteLine "        secs(mi).TotalWithdrawal = Null"
  ts.WriteLine "        secs(mi).ContractNumber = """""
  ts.WriteLine "        secs(mi).IssueDate = """""
  ts.WriteLine "    Next mi"
  ts.WriteLine ""
  ts.WriteLine "    ' Sum total value across all 529 securities"
  ts.WriteLine "    Dim totalValue As Double"
  ts.WriteLine "    totalValue = 0#"
  ts.WriteLine "    For mi = 0 To UBound(secs)"
  ts.WriteLine "        totalValue = totalValue + secs(mi).Value"
  ts.WriteLine "    Next mi"
  ts.WriteLine ""
  ts.WriteLine "    result(0).Name = ""529 Plan"""
  ts.WriteLine "    result(0).AssetType = ""Other"""
  ts.WriteLine "    result(0).Value = totalValue"
  ts.WriteLine "    result(0).CostBasis = Null"
  ts.WriteLine "    result(0).UnrealizedGL = Null"
  ts.WriteLine "    result(0).Securities = secs"
  ts.WriteLine "    result(0).SecurityCount = UBound(secs) + 1"
  ts.WriteLine ""
  ts.WriteLine "    Extract529PlanHoldings = result"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Life insurance securities extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "' Parses ""Life insurance"" section found on some statements under"
  ts.WriteLine "' ""Assets held outside UBS Financial Services Inc."""
  ts.WriteLine "' Returns SecurityDetail array with one entry per policy."
  ts.WriteLine "' Caller attaches these to the existing ""Life insurance"" Holding."
  ts.WriteLine "Private Function ExtractLifeInsuranceSecurities(text As String) As SecurityDetail()"
  ts.WriteLine "    Dim noSecs(0 To 0) As SecurityDetail"
  ts.WriteLine "    noSecs(0).Name = """""
  ts.WriteLine ""
  ts.WriteLine "    ' Locate ""Life insurance"" section header (distinct from ""Life insurance"" in"
  ts.WriteLine "    ' ""Your total assets"" table -- look for it on its own line)"
  ts.WriteLine "    Dim secStart As Long"
  ts.WriteLine "    secStart = 0"
  ts.WriteLine "    Dim lines() As String"
  ts.WriteLine "    lines = Split(text, vbLf)"
  ts.WriteLine "    Dim li As Long"
  ts.WriteLine "    For li = LBound(lines) To UBound(lines)"
  ts.WriteLine "        If Trim$(lines(li)) = ""Life insurance"" Then"
  ts.WriteLine "            secStart = li"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next li"
  ts.WriteLine "    If secStart = 0 Then"
  ts.WriteLine "        ExtractLifeInsuranceSecurities = noSecs"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Find section end: ""Your total assets"" or end of text"
  ts.WriteLine "    Dim secEnd As Long"
  ts.WriteLine "    secEnd = UBound(lines)"
  ts.WriteLine "    For li = secStart + 1 To UBound(lines)"
  ts.WriteLine "        Dim trimLine As String"
  ts.WriteLine "        trimLine = Trim$(lines(li))"
  ts.WriteLine "        If Left$(trimLine, 16) = ""Your total asset"" Then"
  ts.WriteLine "            secEnd = li - 1"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next li"
  ts.WriteLine ""
  ts.WriteLine "    ' Build section text for regex matching"
  ts.WriteLine "    Dim secLines() As String"
  ts.WriteLine "    ReDim secLines(0 To secEnd - secStart)"
  ts.WriteLine "    Dim si As Long"
  ts.WriteLine "    For si = secStart To secEnd"
  ts.WriteLine "        secLines(si - secStart) = lines(si)"
  ts.WriteLine "    Next si"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    section = Join(secLines, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    ' Match policy rows: death_benefit (2 dec)  total_premium (3 dec)  value (2 dec)"
  ts.WriteLine "    ' The 3-decimal total premium distinguishes these from other number sequences."
  ts.WriteLine "    Dim rowPat As String"
  ts.WriteLine "    rowPat = ""("" & NUM_PAT & "")\s+([\d,]+\.\d{3})\s+("" & NUM_PAT & "")"""
  ts.WriteLine "    Dim matches As Object"
  ts.WriteLine "    Set matches = RegexMatchAll(section, rowPat)"
  ts.WriteLine ""
  ts.WriteLine "    If matches.Count = 0 Then"
  ts.WriteLine "        ExtractLifeInsuranceSecurities = noSecs"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim secs() As SecurityDetail"
  ts.WriteLine "    ReDim secs(0 To matches.Count - 1)"
  ts.WriteLine "    Dim secLines2() As String"
  ts.WriteLine "    secLines2 = Split(section, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    Dim mi As Long"
  ts.WriteLine "    For mi = 0 To matches.Count - 1"
  ts.WriteLine "        Dim deathBenefit As Double: deathBenefit = SafeFloat(matches(mi).SubMatches(0))"
  ts.WriteLine "        Dim totalPremium As Double: totalPremium = SafeFloat(matches(mi).SubMatches(1))"
  ts.WriteLine "        Dim val As Double: val = SafeFloat(matches(mi).SubMatches(2))"
  ts.WriteLine ""
  ts.WriteLine "        ' Find the line containing this match to extract the policy name"
  ts.WriteLine "        Dim matchText As String"
  ts.WriteLine "        matchText = matches(mi).Value"
  ts.WriteLine "        Dim nameParts() As String"
  ts.WriteLine "        Dim namePartCount As Long"
  ts.WriteLine "        namePartCount = 0"
  ts.WriteLine "        ReDim nameParts(0 To 5)"
  ts.WriteLine ""
  ts.WriteLine "        For li = LBound(secLines2) To UBound(secLines2)"
  ts.WriteLine "            If InStr(1, secLines2(li), matchText) > 0 Then"
  ts.WriteLine "                ' Name is text on this line before the numbers (strip date & contract too)"
  ts.WriteLine "                Dim numPos As Long"
  ts.WriteLine "                numPos = InStr(1, secLines2(li), matches(mi).SubMatches(0))"
  ts.WriteLine "                If numPos > 1 Then"
  ts.WriteLine "                    Dim lineName As String"
  ts.WriteLine "                    lineName = Trim$(Left$(secLines2(li), numPos - 1))"
  ts.WriteLine "                    ' Strip trailing issue date and contract number"
  ts.WriteLine "                    Dim re As Object"
  ts.WriteLine "                    Set re = CreateRegex(""\s+(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\s+\d{1,2},?\s+\d{2,4}\s+\S+\s*$"")"
  ts.WriteLine "                    lineName = re.Replace(lineName, """")"
  ts.WriteLine "                    lineName = Trim$(lineName)"
  ts.WriteLine "                    If Len(lineName) > 0 Then"
  ts.WriteLine "                        nameParts(namePartCount) = lineName"
  ts.WriteLine "                        namePartCount = namePartCount + 1"
  ts.WriteLine "                    End If"
  ts.WriteLine "                End If"
  ts.WriteLine "                ' Collect preceding non-blank, non-header lines as name continuation"
  ts.WriteLine "                Dim pi As Long"
  ts.WriteLine "                For pi = li - 1 To LBound(secLines2) Step -1"
  ts.WriteLine "                    Dim prevLine As String"
  ts.WriteLine "                    prevLine = Trim$(secLines2(pi))"
  ts.WriteLine "                    If prevLine = """" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 7) = ""Holding"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 5) = ""Issue"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 8) = ""Contract"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 5) = ""Death"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 5) = ""Total"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 5) = ""Value"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 9) = ""benefit ("" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 9) = ""premium ("" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 5) = ""AS OF"" Then Exit For"
  ts.WriteLine "                    If Left$(prevLine, 14) = ""Life insurance"" Then Exit For"
  ts.WriteLine "                    If RegexTest(prevLine, ""^[\d,]+\.\d{2}\s"") Then Exit For"
  ts.WriteLine "                    If namePartCount > UBound(nameParts) Then ReDim Preserve nameParts(0 To namePartCount + 5)"
  ts.WriteLine "                    nameParts(namePartCount) = prevLine"
  ts.WriteLine "                    namePartCount = namePartCount + 1"
  ts.WriteLine "                Next pi"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next li"
  ts.WriteLine ""
  ts.WriteLine "        ' Reverse name parts (collected bottom-up) and join"
  ts.WriteLine "        Dim holdName As String"
  ts.WriteLine "        If namePartCount > 1 Then"
  ts.WriteLine "            Dim reversed() As String"
  ts.WriteLine "            ReDim reversed(0 To namePartCount - 1)"
  ts.WriteLine "            Dim ri As Long"
  ts.WriteLine "            For ri = 0 To namePartCount - 1"
  ts.WriteLine "                reversed(ri) = nameParts(namePartCount - 1 - ri)"
  ts.WriteLine "            Next ri"
  ts.WriteLine "            holdName = Join(reversed, "" "")"
  ts.WriteLine "        ElseIf namePartCount = 1 Then"
  ts.WriteLine "            holdName = nameParts(0)"
  ts.WriteLine "        Else"
  ts.WriteLine "            holdName = ""Life Insurance Policy "" & (mi + 1)"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Extract issue date and contract number from the text before numbers"
  ts.WriteLine "        Dim issueDateStr As String: issueDateStr = """""
  ts.WriteLine "        Dim contractNum As String: contractNum = """""
  ts.WriteLine "        If numPos > 1 Then"
  ts.WriteLine "            Dim preNumText As String"
  ts.WriteLine "            preNumText = Left$(secLines2(li), numPos - 1)"
  ts.WriteLine "            Dim dateM As Object"
  ts.WriteLine "            Set dateM = RegexMatch(preNumText, ""((?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\s+\d{1,2},?\s+\d{2,4})\s+(\S+)\s*$"")"
  ts.WriteLine "            If Not dateM Is Nothing Then"
  ts.WriteLine "                issueDateStr = Trim$(dateM.SubMatches(0))"
  ts.WriteLine "                contractNum = Trim$(dateM.SubMatches(1))"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        secs(mi).Name = holdName"
  ts.WriteLine "        secs(mi).Symbol = """""
  ts.WriteLine "        secs(mi).Units = Null"
  ts.WriteLine "        secs(mi).Value = val"
  ts.WriteLine "        secs(mi).CostBasis = totalPremium"
  ts.WriteLine "        secs(mi).UnrealizedGL = Null"
  ts.WriteLine "        secs(mi).IsEscrow = False"
  ts.WriteLine "        secs(mi).CategoryKey = ""Life insurance"""
  ts.WriteLine "        secs(mi).DeathBenefit = deathBenefit"
  ts.WriteLine "        secs(mi).LivingBenefit = Null"
  ts.WriteLine "        secs(mi).SurrenderValue = Null"
  ts.WriteLine "        secs(mi).TotalWithdrawal = Null"
  ts.WriteLine "        secs(mi).ContractNumber = contractNum"
  ts.WriteLine "        secs(mi).IssueDate = issueDateStr"
  ts.WriteLine "    Next mi"
  ts.WriteLine ""
  ts.WriteLine "    ExtractLifeInsuranceSecurities = secs"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Annuity securities extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "' Parses ""Annuities"" section found on some statements under"
  ts.WriteLine "' ""Assets held outside UBS Financial Services Inc."""
  ts.WriteLine "' Table columns: Holding, Death benefit, Living benefit, Surrender value,"
  ts.WriteLine "'   Surrender charge expiration date, Total premium, Total withdrawal, Value"
  ts.WriteLine "' Returns SecurityDetail array with one entry per annuity contract."
  ts.WriteLine "Private Function ExtractAnnuitySecurities(text As String) As SecurityDetail()"
  ts.WriteLine "    Dim noSecs(0 To 0) As SecurityDetail"
  ts.WriteLine "    noSecs(0).Name = """""
  ts.WriteLine ""
  ts.WriteLine "    ' Locate ""Annuities"" section header on its own line"
  ts.WriteLine "    Dim lines() As String"
  ts.WriteLine "    lines = Split(text, vbLf)"
  ts.WriteLine "    Dim secStart As Long"
  ts.WriteLine "    secStart = -1"
  ts.WriteLine "    Dim li As Long"
  ts.WriteLine "    For li = LBound(lines) To UBound(lines)"
  ts.WriteLine "        If Trim$(lines(li)) = ""Annuities"" Then"
  ts.WriteLine "            secStart = li"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next li"
  ts.WriteLine "    If secStart < 0 Then"
  ts.WriteLine "        ExtractAnnuitySecurities = noSecs"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Find section end: ""Your total assets"" or ""Account activity"""
  ts.WriteLine "    Dim secEnd As Long"
  ts.WriteLine "    secEnd = UBound(lines)"
  ts.WriteLine "    For li = secStart + 1 To UBound(lines)"
  ts.WriteLine "        Dim trimLine As String"
  ts.WriteLine "        trimLine = Trim$(lines(li))"
  ts.WriteLine "        If Left$(trimLine, 16) = ""Your total asset"" Or _"
  ts.WriteLine "           Left$(trimLine, 16) = ""Account activity"" Then"
  ts.WriteLine "            secEnd = li - 1"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next li"
  ts.WriteLine ""
  ts.WriteLine "    ' Build section text"
  ts.WriteLine "    Dim secLines() As String"
  ts.WriteLine "    ReDim secLines(0 To secEnd - secStart)"
  ts.WriteLine "    Dim si As Long"
  ts.WriteLine "    For si = secStart To secEnd"
  ts.WriteLine "        secLines(si - secStart) = lines(si)"
  ts.WriteLine "    Next si"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    section = Join(secLines, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    ' Find annuity data rows: lines with 4+ NUM_PAT numbers"
  ts.WriteLine "    ' Columns: death_benefit, living_benefit, surrender_value, total_premium, total_withdrawal, value"
  ts.WriteLine "    ' Some columns may be empty, but we expect at least 4 numbers per row."
  ts.WriteLine "    Dim secs() As SecurityDetail"
  ts.WriteLine "    Dim secCount As Long"
  ts.WriteLine "    secCount = 0"
  ts.WriteLine "    ReDim secs(0 To 3)"
  ts.WriteLine ""
  ts.WriteLine "    Dim sli As Long"
  ts.WriteLine "    For sli = LBound(secLines) To UBound(secLines)"
  ts.WriteLine "        Dim sLine As String"
  ts.WriteLine "        sLine = secLines(sli)"
  ts.WriteLine ""
  ts.WriteLine "        ' Count NUM_PAT matches on this line"
  ts.WriteLine "        Dim numMatches As Object"
  ts.WriteLine "        Set numMatches = RegexMatchAll(sLine, NUM_PAT)"
  ts.WriteLine "        If numMatches.Count < 4 Then GoTo NextAnnuityLine"
  ts.WriteLine ""
  ts.WriteLine "        ' Layout: death_benefit, living_benefit, surrender_value, [gap], total_premium, total_withdrawal, value"
  ts.WriteLine "        ' With 6 numbers: indices 0=death, 1=living, 2=surrender, 3=premium, 4=withdrawal, 5=value"
  ts.WriteLine "        ' With 5 numbers: could be missing living benefit or withdrawal"
  ts.WriteLine "        ' With 4 numbers: death, surrender, premium, value"
  ts.WriteLine "        Dim numCount As Long"
  ts.WriteLine "        numCount = numMatches.Count"
  ts.WriteLine "        Dim annValue As Double"
  ts.WriteLine "        annValue = SafeFloat(numMatches(numCount - 1).Value)"
  ts.WriteLine ""
  ts.WriteLine "        Dim annDeathBenefit As Variant: annDeathBenefit = Null"
  ts.WriteLine "        Dim annLivingBenefit As Variant: annLivingBenefit = Null"
  ts.WriteLine "        Dim annSurrenderValue As Variant: annSurrenderValue = Null"
  ts.WriteLine "        Dim annPremium As Double: annPremium = 0#"
  ts.WriteLine "        Dim annWithdrawal As Variant: annWithdrawal = Null"
  ts.WriteLine ""
  ts.WriteLine "        If numCount >= 6 Then"
  ts.WriteLine "            ' Full layout: death, living, surrender, premium, withdrawal, value"
  ts.WriteLine "            annDeathBenefit = SafeFloat(numMatches(0).Value)"
  ts.WriteLine "            annLivingBenefit = SafeFloat(numMatches(1).Value)"
  ts.WriteLine "            annSurrenderValue = SafeFloat(numMatches(2).Value)"
  ts.WriteLine "            annPremium = SafeFloat(numMatches(numCount - 3).Value)"
  ts.WriteLine "            annWithdrawal = SafeFloat(numMatches(numCount - 2).Value)"
  ts.WriteLine "        ElseIf numCount = 5 Then"
  ts.WriteLine "            ' Missing one column -- assume living benefit absent"
  ts.WriteLine "            annDeathBenefit = SafeFloat(numMatches(0).Value)"
  ts.WriteLine "            annSurrenderValue = SafeFloat(numMatches(1).Value)"
  ts.WriteLine "            annPremium = SafeFloat(numMatches(2).Value)"
  ts.WriteLine "            annWithdrawal = SafeFloat(numMatches(3).Value)"
  ts.WriteLine "        ElseIf numCount = 4 Then"
  ts.WriteLine "            annDeathBenefit = SafeFloat(numMatches(0).Value)"
  ts.WriteLine "            annSurrenderValue = SafeFloat(numMatches(1).Value)"
  ts.WriteLine "            annPremium = SafeFloat(numMatches(2).Value)"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Extract name from this line (text before first number) and preceding lines"
  ts.WriteLine "        Dim nameParts() As String"
  ts.WriteLine "        Dim namePartCount As Long"
  ts.WriteLine "        namePartCount = 0"
  ts.WriteLine "        ReDim nameParts(0 To 5)"
  ts.WriteLine ""
  ts.WriteLine "        Dim firstNumPos As Long"
  ts.WriteLine "        firstNumPos = InStr(1, sLine, numMatches(0).Value)"
  ts.WriteLine "        If firstNumPos > 1 Then"
  ts.WriteLine "            Dim lineName As String"
  ts.WriteLine "            lineName = Trim$(Left$(sLine, firstNumPos - 1))"
  ts.WriteLine "            If Len(lineName) > 0 Then"
  ts.WriteLine "                nameParts(namePartCount) = lineName"
  ts.WriteLine "                namePartCount = namePartCount + 1"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Collect preceding non-blank, non-header lines as name continuation"
  ts.WriteLine "        Dim pi As Long"
  ts.WriteLine "        For pi = sli - 1 To LBound(secLines) Step -1"
  ts.WriteLine "            Dim prevLine As String"
  ts.WriteLine "            prevLine = Trim$(secLines(pi))"
  ts.WriteLine "            If prevLine = """" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 7) = ""Holding"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 5) = ""Death"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 6) = ""Living"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 9) = ""Surrender"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 5) = ""Total"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 5) = ""Value"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 5) = ""AS OF"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 8) = ""CONTRACT"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 4) = ""RATE"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 10) = ""ISSUE DATE"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 10) = ""PORTFOLIOS"" Then Exit For"
  ts.WriteLine "            If Left$(prevLine, 9) = ""Annuities"" Then Exit For"
  ts.WriteLine "            ' Check if it's a data line (starts with numbers)"
  ts.WriteLine "            If RegexTest(prevLine, ""^[\d,]+\.\d{2}\s"") Then Exit For"
  ts.WriteLine "            If namePartCount > UBound(nameParts) Then ReDim Preserve nameParts(0 To namePartCount + 5)"
  ts.WriteLine "            nameParts(namePartCount) = prevLine"
  ts.WriteLine "            namePartCount = namePartCount + 1"
  ts.WriteLine "        Next pi"
  ts.WriteLine ""
  ts.WriteLine "        ' Reverse name parts (collected bottom-up) and join"
  ts.WriteLine "        Dim holdName As String"
  ts.WriteLine "        If namePartCount > 1 Then"
  ts.WriteLine "            Dim reversed() As String"
  ts.WriteLine "            ReDim reversed(0 To namePartCount - 1)"
  ts.WriteLine "            Dim ri As Long"
  ts.WriteLine "            For ri = 0 To namePartCount - 1"
  ts.WriteLine "                reversed(ri) = nameParts(namePartCount - 1 - ri)"
  ts.WriteLine "            Next ri"
  ts.WriteLine "            holdName = Join(reversed, "" "")"
  ts.WriteLine "        ElseIf namePartCount = 1 Then"
  ts.WriteLine "            holdName = nameParts(0)"
  ts.WriteLine "        Else"
  ts.WriteLine "            holdName = ""Annuity "" & (secCount + 1)"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Scan forward from data line for contract/issue/rate details"
  ts.WriteLine "        Dim annContract As String: annContract = """""
  ts.WriteLine "        Dim annIssueDate As String: annIssueDate = """""
  ts.WriteLine "        Dim fi As Long"
  ts.WriteLine "        For fi = sli + 1 To UBound(secLines)"
  ts.WriteLine "            Dim fLine As String"
  ts.WriteLine "            fLine = Trim$(secLines(fi))"
  ts.WriteLine "            If fLine = """" Then Exit For"
  ts.WriteLine "            ' Stop if we hit another data line or section boundary"
  ts.WriteLine "            If RegexTest(fLine, ""^[\d,]+\.\d{2}\s"") Then Exit For"
  ts.WriteLine "            If Left$(fLine, 16) = ""Your total asset"" Then Exit For"
  ts.WriteLine ""
  ts.WriteLine "            Dim cM As Object"
  ts.WriteLine "            If Left$(fLine, 13) = ""CONTRACT NBR:"" Then"
  ts.WriteLine "                annContract = Trim$(Mid$(fLine, 15))"
  ts.WriteLine "            End If"
  ts.WriteLine "            Set cM = RegexMatch(fLine, ""^ISSUE DATE:\s*(.+)"")"
  ts.WriteLine "            If Not cM Is Nothing Then annIssueDate = Trim$(cM.SubMatches(0))"
  ts.WriteLine "        Next fi"
  ts.WriteLine ""
  ts.WriteLine "        If secCount > UBound(secs) Then ReDim Preserve secs(0 To secCount + 3)"
  ts.WriteLine "        secs(secCount).Name = holdName"
  ts.WriteLine "        secs(secCount).Symbol = """""
  ts.WriteLine "        secs(secCount).Units = Null"
  ts.WriteLine "        secs(secCount).Value = annValue"
  ts.WriteLine "        secs(secCount).CostBasis = annPremium"
  ts.WriteLine "        secs(secCount).UnrealizedGL = Null"
  ts.WriteLine "        secs(secCount).IsEscrow = False"
  ts.WriteLine "        secs(secCount).CategoryKey = ""Annuities"""
  ts.WriteLine "        secs(secCount).DeathBenefit = annDeathBenefit"
  ts.WriteLine "        secs(secCount).LivingBenefit = annLivingBenefit"
  ts.WriteLine "        secs(secCount).SurrenderValue = annSurrenderValue"
  ts.WriteLine "        secs(secCount).TotalWithdrawal = annWithdrawal"
  ts.WriteLine "        secs(secCount).ContractNumber = annContract"
  ts.WriteLine "        secs(secCount).IssueDate = annIssueDate"
  ts.WriteLine "        secCount = secCount + 1"
  ts.WriteLine ""
  ts.WriteLine "NextAnnuityLine:"
  ts.WriteLine "    Next sli"
  ts.WriteLine ""
  ts.WriteLine "    If secCount = 0 Then"
  ts.WriteLine "        ExtractAnnuitySecurities = noSecs"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ReDim Preserve secs(0 To secCount - 1)"
  ts.WriteLine "    ExtractAnnuitySecurities = secs"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Transaction extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ExtractTransactions(text As String) As Transaction()"
  ts.WriteLine "    Dim startM() As String: startM = SArr(vbLf & ""Account activity this month"")"
  ts.WriteLine "    Dim endM() As String: endM = SArr2(""Money balance activities"", ""Important information about your statement"")"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    section = ExtractSection(text, startM, endM)"
  ts.WriteLine ""
  ts.WriteLine "    Dim txs() As Transaction"
  ts.WriteLine "    Dim txCount As Long"
  ts.WriteLine "    txCount = 0"
  ts.WriteLine "    ReDim txs(0 To 200)"
  ts.WriteLine ""
  ts.WriteLine "    ' Detect BSA"
  ts.WriteLine "    Dim isBSA As Boolean"
  ts.WriteLine "    isBSA = RegexTest(section, ""Cash and money balance"", True)"
  ts.WriteLine ""
  ts.WriteLine "    Dim lines() As String"
  ts.WriteLine "    lines = Split(section, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    ' Skip prefixes"
  ts.WriteLine "    Dim skipPrefixes() As String"
  ts.WriteLine "    skipPrefixes = GetSkipPrefixes()"
  ts.WriteLine ""
  ts.WriteLine "    ' Whitespace-collapse regex"
  ts.WriteLine "    Dim reWhitespace As Object"
  ts.WriteLine "    Set reWhitespace = RegexHelper.CreateRegex(""\s{2,}"", True)"
  ts.WriteLine ""
  ts.WriteLine "    ' Activity aliases"
  ts.WriteLine "    ' ""Foreign Tax"" -> ""Foreign Tax Withheld"""
  ts.WriteLine "    ' ""Visa Payment"" -> ""Credit Card Payment"""
  ts.WriteLine "    ' ""Foreign"" -> ""Dividend"""
  ts.WriteLine "    ' ""ACH WITHDRAWAL"" -> ""Withdrawal"""
  ts.WriteLine ""
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    i = 0"
  ts.WriteLine "    Do While i <= UBound(lines)"
  ts.WriteLine "        Dim line As String"
  ts.WriteLine "        line = Trim$(lines(i))"
  ts.WriteLine "        If line = """" Then GoTo NextTxLine"
  ts.WriteLine "        If RegexTest(line, ""^=== PAGE \d+ ==="") Then GoTo NextTxLine"
  ts.WriteLine "        If RegexTest(line, ""^Total[\s(a-z]"") Or line = ""Total"" Then GoTo NextTxLine"
  ts.WriteLine "        If RegexTest(line, ""^(?:Closing )?[Cc]ash and money balance\s+\$"") Then GoTo NextTxLine"
  ts.WriteLine ""
  ts.WriteLine "        Dim lineCompact As String"
  ts.WriteLine "        lineCompact = reWhitespace.Replace(line, "" "")"
  ts.WriteLine ""
  ts.WriteLine "        ' Check skip prefixes"
  ts.WriteLine "        Dim parsedLine As String"
  ts.WriteLine "        parsedLine = line"
  ts.WriteLine "        Dim skipped As Boolean"
  ts.WriteLine "        skipped = False"
  ts.WriteLine "        Dim si As Long"
  ts.WriteLine "        For si = LBound(skipPrefixes) To UBound(skipPrefixes)"
  ts.WriteLine "            If Left$(line, Len(skipPrefixes(si))) = skipPrefixes(si) Or _"
  ts.WriteLine "               Left$(lineCompact, Len(skipPrefixes(si))) = skipPrefixes(si) Then"
  ts.WriteLine "                ' Check if section header with date following"
  ts.WriteLine "                If IsSectionHeader(line, lineCompact, skipPrefixes(si)) Then"
  ts.WriteLine "                    Dim restStr As String"
  ts.WriteLine "                    If Left$(line, Len(skipPrefixes(si))) = skipPrefixes(si) Then"
  ts.WriteLine "                        restStr = Mid$(line, Len(skipPrefixes(si)) + 1)"
  ts.WriteLine "                    Else"
  ts.WriteLine "                        restStr = Mid$(lineCompact, Len(skipPrefixes(si)) + 1)"
  ts.WriteLine "                    End If"
  ts.WriteLine "                    Dim dateInRest As Object"
  ts.WriteLine "                    Set dateInRest = RegexMatch(restStr, ""("" & DATE_PAT & "")\s+"")"
  ts.WriteLine "                    If Not dateInRest Is Nothing Then"
  ts.WriteLine "                        parsedLine = Mid$(restStr, dateInRest.FirstIndex + 1)"
  ts.WriteLine "                        parsedLine = Trim$(parsedLine)"
  ts.WriteLine "                        Exit For"
  ts.WriteLine "                    End If"
  ts.WriteLine "                End If"
  ts.WriteLine "                skipped = True"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next si"
  ts.WriteLine "        If skipped Then GoTo NextTxLine"
  ts.WriteLine ""
  ts.WriteLine "        ' Skip orphan metadata"
  ts.WriteLine "        If RegexTest(line, ""^(?:SYMBOL:|CUSIP:|REF#:)"") Then GoTo NextTxLine"
  ts.WriteLine "        ' Skip misc boilerplate"
  ts.WriteLine "        If line = ""ab"" Or Left$(line, 3) = ""ab "" Or line = ""Check"" Or line = ""Checks"" Then GoTo NextTxLine"
  ts.WriteLine "        If RegexTest(line, ""^for\s+(?:January|February|March|April|May|June|July|August|September|October|November|December)\s"") Then GoTo NextTxLine"
  ts.WriteLine ""
  ts.WriteLine "        Dim m As Object"
  ts.WriteLine "        Dim re As Object"
  ts.WriteLine ""
  ts.WriteLine "        ' --- ATM FEE REBATE ---"
  ts.WriteLine "        Set m = RegexMatch(line, ""^ATM FEE REBATE\s+\$?("" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            Dim rebateDate As String"
  ts.WriteLine "            If txCount > 0 Then rebateDate = txs(txCount - 1).TxDate Else rebateDate = """""
  ts.WriteLine "            AddTx txs, txCount, rebateDate, ""Deposit"", ""ATM FEE REBATE"", SafeFloat(m.SubMatches(0)), Null, Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' BSA: strip trailing running balance (require \s before first number; -? for negative amounts)"
  ts.WriteLine "        If isBSA And RegexTest(parsedLine, ""\s-?[\d,]+\.\d{2}\s+[\d,]+\.\d{2}$"") Then"
  ts.WriteLine "            Set re = CreateRegex(""\s+[\d,]+\.\d{2}$"")"
  ts.WriteLine "            parsedLine = re.Replace(parsedLine, """")"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Extract date"
  ts.WriteLine "        Dim dateM As Object"
  ts.WriteLine "        Set dateM = RegexMatch(parsedLine, ""("" & DATE_PAT & "")\s+"")"
  ts.WriteLine "        If dateM Is Nothing Then GoTo NextTxLine"
  ts.WriteLine ""
  ts.WriteLine "        Dim txDate As String"
  ts.WriteLine "        txDate = dateM.SubMatches(0)"
  ts.WriteLine "        Dim afterDate As String"
  ts.WriteLine "        afterDate = Mid$(parsedLine, dateM.FirstIndex + Len(dateM.Value) + 1)"
  ts.WriteLine ""
  ts.WriteLine "        ' Skip BSA balance lines after date"
  ts.WriteLine "        If RegexTest(afterDate, ""^(?:Closing )?[Cc]ash and money balance\b"") Then GoTo NextTxLine"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Balance forward ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^Balance forward\s+\$?("" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            AddTx txs, txCount, txDate, ""Deposit"", ""Balance forward"", SafeFloat(m.SubMatches(0)), Null, Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Simple single-keyword transactions ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^(St Cap Gain|Lt Cap Gain|Cash In Lieu|Bill Payment|Bsa Check|Foreign Tax|Visa Payment|Correction|Transfer|Deposit|Receive|ACH WITHDRAWAL|Withdrawal|Dividend|Interest|Distribution|Refund|Closing|Foreign)\s+(.+?)\s+(-?\$?[\d,]*\.\d{2})$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            Dim activity As String"
  ts.WriteLine "            activity = m.SubMatches(0)"
  ts.WriteLine "            Dim desc As String"
  ts.WriteLine "            desc = Trim$(m.SubMatches(1))"
  ts.WriteLine ""
  ts.WriteLine "            ' Apply aliases"
  ts.WriteLine "            Select Case activity"
  ts.WriteLine "                Case ""Foreign Tax"": activity = ""Foreign Tax Withheld"""
  ts.WriteLine "                Case ""Visa Payment"": activity = ""Credit Card Payment"""
  ts.WriteLine "                Case ""Foreign"": activity = ""Dividend"""
  ts.WriteLine "                Case ""ACH WITHDRAWAL"": activity = ""Withdrawal"""
  ts.WriteLine "            End Select"
  ts.WriteLine ""
  ts.WriteLine "            If isBSA And activity = ""Withdrawal"" And Left$(desc, 7) = ""CHECK #"" Then activity = ""Bsa Check"""
  ts.WriteLine ""
  ts.WriteLine "            AddTx txs, txCount, txDate, activity, desc, SafeFloat(m.SubMatches(2)), Null, Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine ""
  ts.WriteLine "            ' Fix-up: ""Correction Of Int. Charge"""
  ts.WriteLine "            If activity = ""Correction"" Then"
  ts.WriteLine "                If txs(txCount - 1).Description = ""Of"" And i + 1 <= UBound(lines) Then"
  ts.WriteLine "                    Dim nextLine As String"
  ts.WriteLine "                    nextLine = Trim$(lines(i + 1))"
  ts.WriteLine "                    If Left$(nextLine, 11) = ""Int. Charge"" Then"
  ts.WriteLine "                        txs(txCount - 1).Activity = ""Correction Of Int. Charge"""
  ts.WriteLine "                        txs(txCount - 1).Description = Trim$(Mid$(nextLine, 12))"
  ts.WriteLine "                        i = i + 1"
  ts.WriteLine "                        ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "                    End If"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine ""
  ts.WriteLine "            ' Fix-up: ""Interest Charge"""
  ts.WriteLine "            If activity = ""Interest"" Then"
  ts.WriteLine "                If Right$(txs(txCount - 1).Description, 7) = "" Charge"" Then"
  ts.WriteLine "                    txs(txCount - 1).Activity = ""Interest Charge"""
  ts.WriteLine "                    txs(txCount - 1).Description = Left$(txs(txCount - 1).Description, Len(txs(txCount - 1).Description) - 7)"
  ts.WriteLine "                    txs(txCount - 1).Description = Trim$(txs(txCount - 1).Description)"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Fee Charged ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^Fee(?:\s+Charged)?\s+(.+?)\s+(-?"" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            AddTx txs, txCount, txDate, ""Fee Charged"", Trim$(m.SubMatches(0)), SafeFloat(m.SubMatches(1)), Null, Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Credit Card Payment ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^(CREDIT CARD PAYMENT)\s+(-?"" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            AddTx txs, txCount, txDate, ""Credit Card Payment"", m.SubMatches(0), SafeFloat(m.SubMatches(1)), Null, Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Two-date (CashConnect / Visa debit) ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^("" & DATE_PAT & "")\s+(.+?)\s+(-?)\$?("" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            Dim ccDesc As String"
  ts.WriteLine "            ccDesc = Trim$(m.SubMatches(1))"
  ts.WriteLine "            Dim ccAmt As Double"
  ts.WriteLine "            ccAmt = SafeFloat(m.SubMatches(3))"
  ts.WriteLine "            Dim ccActivity As String"
  ts.WriteLine "            If ccDesc = ""CASHCONNECT"" Then ccActivity = ""CashConnect"" Else ccActivity = ""Card Purchase"""
  ts.WriteLine "            AddTx txs, txCount, txDate, ccActivity, ccDesc, -ccAmt, Null, Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Check ---"
  ts.WriteLine "        Set m = RegexMatch(parsedLine, ""^(?:Checks\s+)?\d{4,10}\s+("" & DATE_PAT & "")\s+(.+?)\s+(-?"" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            Dim chkActivity As String"
  ts.WriteLine "            If isBSA Then chkActivity = ""Bsa Check"" Else chkActivity = ""Withdrawal"""
  ts.WriteLine "            AddTx txs, txCount, m.SubMatches(0), chkActivity, Trim$(m.SubMatches(1)), SafeFloat(m.SubMatches(2)), Null, Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Sold/Bought with price ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^(Sold|Bought)\s+(.+?)\s+(-?[\d,]+\.\d{3})\s+(-?[\d,]+\.\d{2,})\s+(-?"" & NUM_PAT & "")(?:\s+("" & NUM_PAT & ""))?$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            Dim sbActivity As String"
  ts.WriteLine "            If m.SubMatches(0) = ""Sold"" Then sbActivity = ""Sale"" Else sbActivity = ""Purchase"""
  ts.WriteLine "            AddTx txs, txCount, txDate, sbActivity, Trim$(m.SubMatches(1)), SafeFloat(m.SubMatches(4)), ParseNum(m.SubMatches(2)), ParseNum(m.SubMatches(3))"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Sold/Bought without price (money market) ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^(Sold|Bought)\s+(.+?)\s+(-?[\d,]+\.\d{3})\s+("" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            If m.SubMatches(0) = ""Sold"" Then sbActivity = ""Sale"" Else sbActivity = ""Purchase"""
  ts.WriteLine "            AddTx txs, txCount, txDate, sbActivity, Trim$(m.SubMatches(1)), SafeFloat(m.SubMatches(3)), ParseNum(m.SubMatches(2)), Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Reinvestment 3-number ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^Reinvestment\s+(.+?)\s+([\d,]+\.\d{2,6})\s+([\d,]+\.\d{2,3})\s+(-?"" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            Dim rDesc As String"
  ts.WriteLine "            rDesc = CleanReinvestmentDesc(Trim$(m.SubMatches(0)))"
  ts.WriteLine "            AddTx txs, txCount, txDate, ""Reinvestment"", rDesc, SafeFloat(m.SubMatches(3)), ParseNum(m.SubMatches(1)), ParseNum(m.SubMatches(2))"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Reinvestment 2-number ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^Reinvestment\s+(.+?)\s+([\d,]+\.\d{2,3})\s+(-?"" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            rDesc = Trim$(m.SubMatches(0))"
  ts.WriteLine "            Dim rPrice As Variant"
  ts.WriteLine "            rPrice = Null"
  ts.WriteLine "            Dim priceM As Object"
  ts.WriteLine "            Set priceM = RegexMatch(rDesc, ""REINVESTED AT\s+([\d.]+)\s+NAV"")"
  ts.WriteLine "            If Not priceM Is Nothing Then rPrice = ParseNum(priceM.SubMatches(0))"
  ts.WriteLine "            rDesc = CleanReinvestmentDesc(rDesc)"
  ts.WriteLine "            AddTx txs, txCount, txDate, ""Reinvestment"", rDesc, SafeFloat(m.SubMatches(2)), ParseNum(m.SubMatches(1)), rPrice"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- DTC transfer ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^(Receive Dtc|Deliver Dtc)\s+(.+?)\s+(-?[\d,]+\.\d{3})\s*(-?"" & NUM_PAT & "")$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            AddTx txs, txCount, txDate, m.SubMatches(0), Trim$(m.SubMatches(1)), SafeFloat(m.SubMatches(3)), ParseNum(m.SubMatches(2)), Null"
  ts.WriteLine "            ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' --- Call Redemption ---"
  ts.WriteLine "        Set m = RegexMatch(afterDate, ""^Call\s+(.+?)\s+(-?[\d,]+\.\d{3})\s*(-?"" & NUM_PAT & "")(?:\s+("" & NUM_PAT & ""))?$"")"
  ts.WriteLine "        If Not m Is Nothing Then"
  ts.WriteLine "            AddTx txs, txCount, txDate, ""Call Redemption"", Trim$(m.SubMatches(0)), SafeFloat(m.SubMatches(2)), ParseNum(m.SubMatches(1)), Null"
  ts.WriteLine "            ' Consume ""Redemption"" continuation"
  ts.WriteLine "            If i + 1 <= UBound(lines) Then"
  ts.WriteLine "                If Left$(lines(i + 1), 10) = ""Redemption"" Then"
  ts.WriteLine "                    Dim redemptionRest As String"
  ts.WriteLine "                    redemptionRest = Trim$(Mid$(lines(i + 1), 11))"
  ts.WriteLine "                    If redemptionRest <> """" Then"
  ts.WriteLine "                        Dim cusipM As Object"
  ts.WriteLine "                        Set cusipM = RegexMatch(redemptionRest, ""^CUSIP:\s*(\S+)"")"
  ts.WriteLine "                        If Not cusipM Is Nothing Then"
  ts.WriteLine "                            txs(txCount - 1).Cusip = cusipM.SubMatches(0)"
  ts.WriteLine "                        Else"
  ts.WriteLine "                            txs(txCount - 1).Description = txs(txCount - 1).Description & "" "" & redemptionRest"
  ts.WriteLine "                        End If"
  ts.WriteLine "                    End If"
  ts.WriteLine "                    i = i + 1"
  ts.WriteLine "                    ConsumeContinuations lines, i, txs, txCount, skipPrefixes"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "            GoTo NextTxLine"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "NextTxLine:"
  ts.WriteLine "        i = i + 1"
  ts.WriteLine "    Loop"
  ts.WriteLine ""
  ts.WriteLine "    ' Post-processing: clean descriptions"
  ts.WriteLine "    Dim ti As Long"
  ts.WriteLine "    For ti = 0 To txCount - 1"
  ts.WriteLine "        ' Strip UNSOLICITED"
  ts.WriteLine "        Set re = CreateRegex(""\s*UNSOLICITED\b"", True)"
  ts.WriteLine "        txs(ti).Description = re.Replace(txs(ti).Description, """")"
  ts.WriteLine "        txs(ti).Description = Trim$(txs(ti).Description)"
  ts.WriteLine ""
  ts.WriteLine "        ' Strip ""PAID ON NNNN"" references"
  ts.WriteLine "        Set re = CreateRegex(""\s*PAID ON \d+(?:\s*AS OF \d{2}/\d{2}/\d{2,4})?(?:\s+(?:St Cap Gain|Lt Cap Gain|Dividend|Interest|Distribution|Deposit|Withdrawal|Refund|Closing|Transfer|Correction|Foreign|Fee|Sold|Bought|Reinvestment))?"")"
  ts.WriteLine "        txs(ti).Description = Trim$(re.Replace(txs(ti).Description, """"))"
  ts.WriteLine ""
  ts.WriteLine "        ' Strip trailing 4-digit code from transfers"
  ts.WriteLine "        Set m = RegexMatch(txs(ti).Description, ""^((?:TO|FROM)\s+U\d\s+\d{5})\s+\d{4}$"")"
  ts.WriteLine "        If Not m Is Nothing Then txs(ti).Description = m.SubMatches(0)"
  ts.WriteLine ""
  ts.WriteLine "        ' Extract inline REF#"
  ts.WriteLine "        Set m = RegexMatch(txs(ti).Description, ""\s*REF#:(\S+)\s*"")"
  ts.WriteLine "        If Not m Is Nothing And txs(ti).RefNumber = """" Then"
  ts.WriteLine "            txs(ti).RefNumber = m.SubMatches(0)"
  ts.WriteLine "            Set re = CreateRegex(""\s*REF#:\S+"")"
  ts.WriteLine "            txs(ti).Description = Trim$(re.Replace(txs(ti).Description, """"))"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Extract inline CUSIP"
  ts.WriteLine "        Set m = RegexMatch(txs(ti).Description, ""\s*CUSIP:\s*(\S+)"")"
  ts.WriteLine "        If Not m Is Nothing And txs(ti).Cusip = """" Then"
  ts.WriteLine "            txs(ti).Cusip = m.SubMatches(0)"
  ts.WriteLine "            Set re = CreateRegex(""\s*CUSIP:\s*\S+"")"
  ts.WriteLine "            txs(ti).Description = Trim$(re.Replace(txs(ti).Description, """"))"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Extract inline SYMBOL"
  ts.WriteLine "        Set m = RegexMatch(txs(ti).Description, ""\s*(?:/\s*)?SYMBOL:\s*(\S+)"")"
  ts.WriteLine "        If Not m Is Nothing And txs(ti).Symbol = """" Then"
  ts.WriteLine "            txs(ti).Symbol = m.SubMatches(0)"
  ts.WriteLine "            Set re = CreateRegex(""\s*(?:/\s*)?SYMBOL:\s*\S+"")"
  ts.WriteLine "            txs(ti).Description = Trim$(re.Replace(txs(ti).Description, """"))"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next ti"
  ts.WriteLine ""
  ts.WriteLine "    ReDim Preserve txs(0 To IIf(txCount > 0, txCount - 1, 0))"
  ts.WriteLine "    ExtractTransactions = txs"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Sub AddTx(txs() As Transaction, ByRef txCount As Long, txDate As String, activity As String, desc As String, amount As Double, quantity As Variant, price As Variant)"
  ts.WriteLine "    If txCount > UBound(txs) Then ReDim Preserve txs(0 To txCount + 100)"
  ts.WriteLine "    txs(txCount).TxDate = txDate"
  ts.WriteLine "    txs(txCount).Activity = activity"
  ts.WriteLine "    txs(txCount).Description = desc"
  ts.WriteLine "    txs(txCount).Amount = amount"
  ts.WriteLine "    txs(txCount).Quantity = quantity"
  ts.WriteLine "    txs(txCount).Price = price"
  ts.WriteLine "    txs(txCount).Cusip = """""
  ts.WriteLine "    txs(txCount).Symbol = """""
  ts.WriteLine "    txs(txCount).RefNumber = """""
  ts.WriteLine "    txCount = txCount + 1"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Sub ConsumeContinuations(lines() As String, ByRef i As Long, txs() As Transaction, txCount As Long, skipPrefixes() As String)"
  ts.WriteLine "    If txCount = 0 Then Exit Sub"
  ts.WriteLine "    Dim lastIdx As Long"
  ts.WriteLine "    lastIdx = txCount - 1"
  ts.WriteLine ""
  ts.WriteLine "    Do While i + 1 <= UBound(lines)"
  ts.WriteLine "        Dim nextLine As String"
  ts.WriteLine "        nextLine = Trim$(lines(i + 1))"
  ts.WriteLine "        If nextLine = """" Then Exit Do"
  ts.WriteLine "        If RegexTest(nextLine, ""^Total[\s(a-z]"") Or nextLine = ""Total"" Then Exit Do"
  ts.WriteLine ""
  ts.WriteLine "        ' Check skip prefixes"
  ts.WriteLine "        Dim si As Long"
  ts.WriteLine "        Dim isSkip As Boolean"
  ts.WriteLine "        isSkip = False"
  ts.WriteLine "        For si = LBound(skipPrefixes) To UBound(skipPrefixes)"
  ts.WriteLine "            If Left$(nextLine, Len(skipPrefixes(si))) = skipPrefixes(si) Then"
  ts.WriteLine "                isSkip = True"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next si"
  ts.WriteLine "        If isSkip Then Exit Do"
  ts.WriteLine ""
  ts.WriteLine "        ' Check if new transaction starts"
  ts.WriteLine "        If RegexTest(nextLine, ""("" & DATE_PAT & "")\s+"") Then Exit Do"
  ts.WriteLine "        If RegexTest(nextLine, ""^ATM FEE REBATE\s+"") Then Exit Do"
  ts.WriteLine "        If RegexTest(nextLine, ""^(?:Checks\s+)?\d{4,10}\s+("" & DATE_PAT & "")"") Then Exit Do"
  ts.WriteLine ""
  ts.WriteLine "        i = i + 1"
  ts.WriteLine ""
  ts.WriteLine "        ' CUSIP line"
  ts.WriteLine "        Dim cm As Object"
  ts.WriteLine "        Set cm = RegexMatch(nextLine, ""^CUSIP:\s*(\S+)"")"
  ts.WriteLine "        If Not cm Is Nothing Then"
  ts.WriteLine "            txs(lastIdx).Cusip = cm.SubMatches(0)"
  ts.WriteLine "            Dim inlineSym As Object"
  ts.WriteLine "            Set inlineSym = RegexMatch(nextLine, ""SYMBOL:\s*(\S+)"")"
  ts.WriteLine "            If Not inlineSym Is Nothing Then txs(lastIdx).Symbol = inlineSym.SubMatches(0)"
  ts.WriteLine "            GoTo NextCont"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' SYMBOL line"
  ts.WriteLine "        Set cm = RegexMatch(nextLine, ""^SYMBOL:\s*(\S+)"")"
  ts.WriteLine "        If Not cm Is Nothing Then"
  ts.WriteLine "            txs(lastIdx).Symbol = cm.SubMatches(0)"
  ts.WriteLine "            GoTo NextCont"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' REF# line"
  ts.WriteLine "        Set cm = RegexMatch(nextLine, ""^REF#:(\S+)"")"
  ts.WriteLine "        If Not cm Is Nothing Then"
  ts.WriteLine "            txs(lastIdx).RefNumber = cm.SubMatches(0)"
  ts.WriteLine "            GoTo NextCont"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Plain continuation"
  ts.WriteLine "        txs(lastIdx).Description = txs(lastIdx).Description & "" "" & nextLine"
  ts.WriteLine "NextCont:"
  ts.WriteLine "    Loop"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Function GetSkipPrefixes() As String()"
  ts.WriteLine "    Dim p(0 To 84) As String"
  ts.WriteLine "    p(0) = ""Date"": p(1) = ""(continued)"": p(2) = ""Account activity"": p(3) = ""Proceeds from"""
  ts.WriteLine "    p(4) = ""For more information"": p(5) = ""Minimum Payment"": p(6) = ""UBS Visa"""
  ts.WriteLine "    p(7) = ""payment information"": p(8) = ""This credit card"": p(9) = ""We provide"""
  ts.WriteLine "    p(10) = ""We do not"": p(11) = ""Card Items"": p(12) = ""The new UBS"": p(13) = ""stunningly"""
  ts.WriteLine "    p(14) = ""EXECUTION"""
  ts.WriteLine "    p(15) = ""Quantity"": p(16) = ""Percentage of"": p(17) = ""Value on"""
  ts.WriteLine "    p(18) = ""Dividend and interest income"": p(19) = ""Investment transactions"""
  ts.WriteLine "    p(20) = ""Account name:"": p(21) = ""Friendly account name:"": p(22) = ""Account number:"""
  ts.WriteLine "    p(23) = ""Account type:"": p(24) = ""Your notes"": p(25) = ""End of statement"""
  ts.WriteLine "    p(26) = ""=== PAGE"": p(27) = ""CNQ7"": p(28) = ""NQ7"""
  ts.WriteLine "    p(29) = ""Resource Management"": p(30) = ""Portfolio Management"": p(31) = ""Retirement Account"""
  ts.WriteLine "    p(32) = ""your statement at the end"": p(33) = ""investment withdrawn for"""
  ts.WriteLine "    p(34) = ""number Date Description"": p(35) = ""USA. UBS"""
  ts.WriteLine "    p(36) = ""January 20"": p(37) = ""February 20"": p(38) = ""March 20"": p(39) = ""April 20"": p(40) = ""May 20"""
  ts.WriteLine "    p(41) = ""June 20"": p(42) = ""July 20"": p(43) = ""August 20"": p(44) = ""September 20"": p(45) = ""October 20"""
  ts.WriteLine "    p(46) = ""November 20"": p(47) = ""December 20"""
  ts.WriteLine "    p(48) = ""Transaction"": p(49) = ""date "": p(50) = ""Cash/ATM transactions"""
  ts.WriteLine "    p(51) = ""Interest (continued)"": p(52) = ""These are transfers"": p(53) = ""did not incur"""
  ts.WriteLine "    p(54) = ""Bill payments"": p(55) = ""Deposits and other"": p(56) = ""Other funds debited"": p(57) = ""Fees """
  ts.WriteLine "    p(58) = ""Card payments"": p(59) = ""My Choice"": p(60) = ""Rewards"": p(61) = ""Opening balance"""
  ts.WriteLine "    p(62) = ""Points earned"": p(63) = ""Closing balance"": p(64) = ""Totalother"": p(65) = ""Totalprofessional"""
  ts.WriteLine "    p(66) = ""Minimum Payment"": p(67) = ""Priority"": p(68) = ""UBS Insured Sweep Prgm"": p(69) = ""TOTAL"""
  ts.WriteLine "    p(70) = ""Funds used for"": p(71) = ""Your """
  ts.WriteLine "    p(72) = ""Taxable dividends"": p(73) = ""Taxable interest"": p(74) = ""Tax-exempt"": p(75) = ""Dividends"""
  ts.WriteLine "    p(76) = ""ENQ7"": p(77) = ""continued"": p(78) = ""Page """
  ts.WriteLine "    p(79) = ""Int. Charge"": p(80) = ""MEMO:"": p(81) = ""Managed by"""
  ts.WriteLine "    p(82) = ""ACCESS"": p(83) = ""Card purchases"": p(84) = ""Business Services Account"""
  ts.WriteLine "    GetSkipPrefixes = p"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Function IsSectionHeader(line As String, lineCompact As String, prefix As String) As Boolean"
  ts.WriteLine "    Dim headers() As String"
  ts.WriteLine "    headers = Split(""Deposits and other|Other funds debited|Bill payments|Fees |Card payments|Dividend and interest income|Taxable dividends|Taxable interest|Tax-exempt|Investment transactions|Checks |Dividends|Interest income"", ""|"")"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = LBound(headers) To UBound(headers)"
  ts.WriteLine "        If Left$(line, Len(headers(i))) = headers(i) Or Left$(lineCompact, Len(headers(i))) = headers(i) Then"
  ts.WriteLine "            IsSectionHeader = True"
  ts.WriteLine "            Exit Function"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine "    IsSectionHeader = False"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Income extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ExtractIncome(text As String) As IncomeDetail"
  ts.WriteLine "    Dim income As IncomeDetail"
  ts.WriteLine ""
  ts.WriteLine "    Dim startM() As String: startM = SArr(""Dividend and interest income"")"
  ts.WriteLine "    Dim endM() As String: endM = SArr3(""Summary of gains and losses"", ""Your assets"", ""Account activity this month"")"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    section = ExtractSection(text, startM, endM)"
  ts.WriteLine ""
  ts.WriteLine "    Dim lines() As String"
  ts.WriteLine "    lines = Split(section, vbLf)"
  ts.WriteLine ""
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = LBound(lines) To UBound(lines)"
  ts.WriteLine "        Dim line As String"
  ts.WriteLine "        line = Trim$(lines(i))"
  ts.WriteLine "        If line = """" Then GoTo NextIncomeLine"
  ts.WriteLine ""
  ts.WriteLine "        Dim m As Object"
  ts.WriteLine ""
  ts.WriteLine "        ' Taxable dividends (or plain ""Dividends"" for IRA)"
  ts.WriteLine "        Set m = RegexMatch(line, ""^(?:Taxable d|D)ividends\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.TaxableDividendsMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "        ' Tax-exempt dividends"
  ts.WriteLine "        Set m = RegexMatch(line, ""^Tax-exempt dividends\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.TaxExemptDividendsMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "        ' Taxable interest"
  ts.WriteLine "        Set m = RegexMatch(line, ""^(?:Taxable i|I)nterest\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.TaxableInterestMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "        ' Tax-exempt interest"
  ts.WriteLine "        Set m = RegexMatch(line, ""^Tax-exempt interest\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.TaxExemptInterestMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "        ' Miscellaneous"
  ts.WriteLine "        Set m = RegexMatch(line, ""^Miscellaneous\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.MiscellaneousMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "        ' Prior year adjustment"
  ts.WriteLine "        Set m = RegexMatch(line, ""^Prior year adjustment\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.MiscellaneousMonth = income.MiscellaneousMonth + SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "        ' Accrued interest received"
  ts.WriteLine "        Set m = RegexMatch(line, ""^Total accrued interest received\s+\$?("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.AccruedInterestReceived = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "        ' Total"
  ts.WriteLine "        Set m = RegexMatch(line, ""^Total dividend & interest\s+\$?("" & NUM_PAT & "")\s+\$?("" & NUM_PAT & "")"")"
  ts.WriteLine "        If Not m Is Nothing Then income.TotalMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "NextIncomeLine:"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Fallback: compute total from categories"
  ts.WriteLine "    If income.TotalMonth = 0# Then"
  ts.WriteLine "        income.TotalMonth = income.TaxableDividendsMonth + income.TaxExemptDividendsMonth + _"
  ts.WriteLine "            income.TaxableInterestMonth + income.TaxExemptInterestMonth + income.MiscellaneousMonth"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ExtractIncome = income"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Gains and Losses extraction"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ExtractGainsLosses(text As String) As GainsAndLosses"
  ts.WriteLine "    Dim gains As GainsAndLosses"
  ts.WriteLine ""
  ts.WriteLine "    Dim tl As String"
  ts.WriteLine "    tl = LCase$(text)"
  ts.WriteLine "    Dim gainsStart As Long"
  ts.WriteLine "    gainsStart = InStr(1, tl, ""summary of gains and losses"")"
  ts.WriteLine "    If gainsStart = 0 Then"
  ts.WriteLine "        ExtractGainsLosses = gains"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim closePos As Long"
  ts.WriteLine "    closePos = InStr(gainsStart, tl, ""closing account value"")"
  ts.WriteLine "    If closePos = 0 Then closePos = gainsStart + SECTION_LOOKAHEAD"
  ts.WriteLine "    Dim le As Long"
  ts.WriteLine "    le = LineEnd(text, closePos)"
  ts.WriteLine "    Dim section As String"
  ts.WriteLine "    section = Mid$(text, gainsStart, le - gainsStart)"
  ts.WriteLine ""
  ts.WriteLine "    Dim m As Object"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(section, ""Short term\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        gains.ShortTermRealizedMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "        gains.ShortTermRealizedYtd = SafeFloat(m.SubMatches(1))"
  ts.WriteLine "        gains.ShortTermUnrealized = SafeFloat(m.SubMatches(2))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(section, ""Long term\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        gains.LongTermRealizedMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "        gains.LongTermRealizedYtd = SafeFloat(m.SubMatches(1))"
  ts.WriteLine "        gains.LongTermUnrealized = SafeFloat(m.SubMatches(2))"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(section, ""Total\s+(-?\$?[\d,]+\.\d{2})\s+(-?\$?[\d,]+\.\d{2})\s+(-?\$?[\d,]+\.\d{2})"")"
  ts.WriteLine "    If Not m Is Nothing Then"
  ts.WriteLine "        gains.TotalRealizedMonth = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "        gains.TotalRealizedYtd = SafeFloat(m.SubMatches(1))"
  ts.WriteLine "        gains.TotalUnrealized = SafeFloat(m.SubMatches(2))"
  ts.WriteLine "    Else"
  ts.WriteLine "        gains.TotalRealizedMonth = gains.ShortTermRealizedMonth + gains.LongTermRealizedMonth"
  ts.WriteLine "        gains.TotalRealizedYtd = gains.ShortTermRealizedYtd + gains.LongTermRealizedYtd"
  ts.WriteLine "        gains.TotalUnrealized = gains.ShortTermUnrealized + gains.LongTermUnrealized"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ExtractGainsLosses = gains"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Reconciliation"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Public Sub RunReconciliation(ext As StatementExtraction, Optional text As String = """")"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    Dim act As String"
  ts.WriteLine "    Dim closingValue As Double"
  ts.WriteLine "    closingValue = ext.Summary.ClosingValue"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 1: reconciliation"
  ts.WriteLine "    ' opening + cashActivity + market_change + accrued = closing"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim cashActivity As Double"
  ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
  ts.WriteLine "        act = ext.Transactions(i).Activity"
  ts.WriteLine "        ' Skip investment activities"
  ts.WriteLine "        If act = ""Sale"" Or act = ""Purchase"" Or act = ""Reinvestment"" Or act = ""Call Redemption"" Or act = ""Cash In Lieu"" Then"
  ts.WriteLine "            ' Investment activity -- skip"
  ts.WriteLine "        Else"
  ts.WriteLine "            cashActivity = cashActivity + ext.Transactions(i).Amount"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Use monthly change in market value for reconciliation"
  ts.WriteLine "    Dim marketChange As Double"
  ts.WriteLine "    If ext.Summary.ChangeInMarketValue <> ext.Summary.ChangeInMarketValueMonth Then"
  ts.WriteLine "        marketChange = ext.Summary.ChangeInMarketValueMonth"
  ts.WriteLine "    Else"
  ts.WriteLine "        marketChange = ext.Summary.ChangeInMarketValue"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    Dim expectedClosing As Double"
  ts.WriteLine "    expectedClosing = ext.Summary.OpeningValue + cashActivity + _"
  ts.WriteLine "        marketChange + ext.Summary.ChangeInAccruedInterest + _"
  ts.WriteLine "        ext.Income.AccruedInterestReceived"
  ts.WriteLine ""
  ts.WriteLine "    AddCheck ext, ""reconciliation"", closingValue, expectedClosing"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 2: holdings_sum"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim holdingsSum As Double"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        holdingsSum = holdingsSum + ext.Holdings(i).Value"
  ts.WriteLine "    Next i"
  ts.WriteLine "    AddCheck ext, ""holdings_sum"", closingValue, holdingsSum"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 3: securities_sum:{name}"
  ts.WriteLine "    ' For each holding with securities, sum(securities.value) = holding.value"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim j As Long"
  ts.WriteLine "    Dim secValSum As Double"
  ts.WriteLine "    Dim hLabel As String"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        If ext.Holdings(i).SecurityCount > 0 Then"
  ts.WriteLine "            secValSum = 0#"
  ts.WriteLine "            For j = 0 To ext.Holdings(i).SecurityCount - 1"
  ts.WriteLine "                secValSum = secValSum + ext.Holdings(i).Securities(j).Value"
  ts.WriteLine "            Next j"
  ts.WriteLine "            If ext.Holdings(i).AssetType <> """" Then"
  ts.WriteLine "                hLabel = ext.Holdings(i).Name & "" ("" & ext.Holdings(i).AssetType & "")"""
  ts.WriteLine "            Else"
  ts.WriteLine "                hLabel = ext.Holdings(i).Name"
  ts.WriteLine "            End If"
  ts.WriteLine "            AddCheck ext, ""securities_sum:"" & hLabel, ext.Holdings(i).Value, secValSum"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 4: unrealized_gl"
  ts.WriteLine "    ' sum(holdings.unrealized_gl) = gains.total_unrealized"
  ts.WriteLine "    ' Skip if no holding has unrealized data"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim hasUnrealizedData As Boolean"
  ts.WriteLine "    hasUnrealizedData = False"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        If Not IsNull(ext.Holdings(i).UnrealizedGL) Then"
  ts.WriteLine "            hasUnrealizedData = True"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine "    If hasUnrealizedData Or ext.Gains.TotalUnrealized = 0 Then"
  ts.WriteLine "        Dim unrealizedSum As Double"
  ts.WriteLine "        unrealizedSum = 0#"
  ts.WriteLine "        For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "            If Not IsNull(ext.Holdings(i).UnrealizedGL) Then"
  ts.WriteLine "                unrealizedSum = unrealizedSum + CDbl(ext.Holdings(i).UnrealizedGL)"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next i"
  ts.WriteLine "        AddCheck ext, ""unrealized_gl"", ext.Gains.TotalUnrealized, unrealizedSum"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 5: income_transactions"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim incomeTxSum As Double"
  ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
  ts.WriteLine "        act = ext.Transactions(i).Activity"
  ts.WriteLine "        If (act = ""Dividend"" Or act = ""Interest"" Or act = ""Distribution"" Or act = ""St Cap Gain"" Or act = ""Lt Cap Gain"") Then"
  ts.WriteLine "            If ext.Transactions(i).Amount > 0 Then"
  ts.WriteLine "                incomeTxSum = incomeTxSum + ext.Transactions(i).Amount"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine "    AddCheck ext, ""income_transactions"", ext.Income.TotalMonth, incomeTxSum + ext.Income.AccruedInterestReceived"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 6: asset_allocation_sum"
  ts.WriteLine "    ' sum(allocation.value) = closing_value"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim hasAllocations As Boolean"
  ts.WriteLine "    hasAllocations = False"
  ts.WriteLine "    Dim allocValSum As Double"
  ts.WriteLine "    allocValSum = 0#"
  ts.WriteLine "    For i = 0 To 6  ' Always 7 allocation categories"
  ts.WriteLine "        If ext.Allocations(i).Value <> 0 Or ext.Allocations(i).Percentage <> 0 Then"
  ts.WriteLine "            hasAllocations = True"
  ts.WriteLine "        End If"
  ts.WriteLine "        allocValSum = allocValSum + ext.Allocations(i).Value"
  ts.WriteLine "    Next i"
  ts.WriteLine "    If hasAllocations Then"
  ts.WriteLine "        AddCheck ext, ""asset_allocation_sum"", closingValue, allocValSum"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 7: realized_gains_month"
  ts.WriteLine "    ' short + long realized month = total realized month"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    If ext.Gains.TotalRealizedMonth <> 0 Or ext.Gains.ShortTermRealizedMonth <> 0 Or ext.Gains.LongTermRealizedMonth <> 0 Then"
  ts.WriteLine "        AddCheck ext, ""realized_gains_month"", ext.Gains.TotalRealizedMonth, _"
  ts.WriteLine "            ext.Gains.ShortTermRealizedMonth + ext.Gains.LongTermRealizedMonth"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 8: realized_gains_ytd"
  ts.WriteLine "    ' short + long realized YTD = total realized YTD"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    If ext.Gains.TotalRealizedYtd <> 0 Or ext.Gains.ShortTermRealizedYtd <> 0 Or ext.Gains.LongTermRealizedYtd <> 0 Then"
  ts.WriteLine "        AddCheck ext, ""realized_gains_ytd"", ext.Gains.TotalRealizedYtd, _"
  ts.WriteLine "            ext.Gains.ShortTermRealizedYtd + ext.Gains.LongTermRealizedYtd"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 9: detail_rollup"
  ts.WriteLine "    ' sum(security values for non-cash) + cash holding values = closing_value"
  ts.WriteLine "    ' Cash holdings = ""Cash and money balances"", ""Money market funds"", ""Total accrued interest"""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim detailSum As Double"
  ts.WriteLine "    Dim hName As String"
  ts.WriteLine "    detailSum = 0#"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        hName = ext.Holdings(i).Name"
  ts.WriteLine "        If hName = ""Cash and money balances"" Or hName = ""Money market funds"" Or hName = ""Total accrued interest"" Then"
  ts.WriteLine "            ' Cash-like holding -- use holding value directly"
  ts.WriteLine "            detailSum = detailSum + ext.Holdings(i).Value"
  ts.WriteLine "        Else"
  ts.WriteLine "            ' Non-cash -- must contribute sum(securities.value); 0 if no securities (exposing gap)"
  ts.WriteLine "            For j = 0 To ext.Holdings(i).SecurityCount - 1"
  ts.WriteLine "                detailSum = detailSum + ext.Holdings(i).Securities(j).Value"
  ts.WriteLine "            Next j"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine "    AddCheck ext, ""detail_rollup"", closingValue, detailSum"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 10: income_categories_sum_month"
  ts.WriteLine "    ' sum(income categories) + accrued_interest_received = total_month"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim catSum As Double"
  ts.WriteLine "    catSum = ext.Income.TaxableDividendsMonth + ext.Income.TaxExemptDividendsMonth _"
  ts.WriteLine "        + ext.Income.TaxableInterestMonth + ext.Income.TaxExemptInterestMonth _"
  ts.WriteLine "        + ext.Income.MiscellaneousMonth + ext.Income.AccruedInterestReceived"
  ts.WriteLine "    If catSum <> 0 And ext.Income.TotalMonth <> 0 Then"
  ts.WriteLine "        AddCheck ext, ""income_categories_sum_month"", ext.Income.TotalMonth, catSum"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 11: unrealized_components"
  ts.WriteLine "    ' short + long unrealized = total unrealized"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    If ext.Gains.TotalUnrealized <> 0 Or ext.Gains.ShortTermUnrealized <> 0 Or ext.Gains.LongTermUnrealized <> 0 Then"
  ts.WriteLine "        AddCheck ext, ""unrealized_components"", ext.Gains.TotalUnrealized, _"
  ts.WriteLine "            ext.Gains.ShortTermUnrealized + ext.Gains.LongTermUnrealized"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 12: securities_cost_basis:{name}"
  ts.WriteLine "    ' Per holding: sum(securities.cost_basis) = holding.cost_basis"
  ts.WriteLine "    ' Skip if holding cost_basis is null or any security has null cost_basis"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim allSecHaveCB As Boolean"
  ts.WriteLine "    Dim secCBSum As Double"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        If ext.Holdings(i).SecurityCount = 0 Then GoTo NextCB"
  ts.WriteLine "        If IsNull(ext.Holdings(i).CostBasis) Then GoTo NextCB"
  ts.WriteLine "        allSecHaveCB = True"
  ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
  ts.WriteLine "            If IsNull(ext.Holdings(i).Securities(j).CostBasis) Then"
  ts.WriteLine "                allSecHaveCB = False"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If Not allSecHaveCB Then GoTo NextCB"
  ts.WriteLine "        secCBSum = 0#"
  ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
  ts.WriteLine "            secCBSum = secCBSum + CDbl(ext.Holdings(i).Securities(j).CostBasis)"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If ext.Holdings(i).AssetType <> """" Then"
  ts.WriteLine "            hLabel = ext.Holdings(i).Name & "" ("" & ext.Holdings(i).AssetType & "")"""
  ts.WriteLine "        Else"
  ts.WriteLine "            hLabel = ext.Holdings(i).Name"
  ts.WriteLine "        End If"
  ts.WriteLine "        AddCheck ext, ""securities_cost_basis:"" & hLabel, CDbl(ext.Holdings(i).CostBasis), secCBSum"
  ts.WriteLine "NextCB:"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 13: securities_unrealized:{name}"
  ts.WriteLine "    ' Per holding: sum(securities.unrealized_gl) = holding.unrealized_gl"
  ts.WriteLine "    ' Skip if holding unrealized_gl is null or any security has null unrealized_gl"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim allSecHaveUR As Boolean"
  ts.WriteLine "    Dim secURSum As Double"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        If ext.Holdings(i).SecurityCount = 0 Then GoTo NextUR"
  ts.WriteLine "        If IsNull(ext.Holdings(i).UnrealizedGL) Then GoTo NextUR"
  ts.WriteLine "        allSecHaveUR = True"
  ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
  ts.WriteLine "            If IsNull(ext.Holdings(i).Securities(j).UnrealizedGL) Then"
  ts.WriteLine "                allSecHaveUR = False"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If Not allSecHaveUR Then GoTo NextUR"
  ts.WriteLine "        secURSum = 0#"
  ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
  ts.WriteLine "            secURSum = secURSum + CDbl(ext.Holdings(i).Securities(j).UnrealizedGL)"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If ext.Holdings(i).AssetType <> """" Then"
  ts.WriteLine "            hLabel = ext.Holdings(i).Name & "" ("" & ext.Holdings(i).AssetType & "")"""
  ts.WriteLine "        Else"
  ts.WriteLine "            hLabel = ext.Holdings(i).Name"
  ts.WriteLine "        End If"
  ts.WriteLine "        AddCheck ext, ""securities_unrealized:"" & hLabel, CDbl(ext.Holdings(i).UnrealizedGL), secURSum"
  ts.WriteLine "NextUR:"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 14: asset_allocation_pct"
  ts.WriteLine "    ' sum(allocation.percentage) approximately = 100% (tolerance: abs(sum - 100) < 0.05)"
  ts.WriteLine "    ' Skip for zero-balance accounts"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    If hasAllocations And closingValue <> 0 Then"
  ts.WriteLine "        Dim pctSum As Double"
  ts.WriteLine "        pctSum = 0#"
  ts.WriteLine "        For i = 0 To 6"
  ts.WriteLine "            pctSum = pctSum + ext.Allocations(i).Percentage"
  ts.WriteLine "        Next i"
  ts.WriteLine "        AddCheckEx ext, ""asset_allocation_pct"", 100#, pctSum, (Abs(pctSum - 100#) < 0.05)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Check 15: deposits_transferred_in"
  ts.WriteLine "    ' account_summary.deposits_transferred_in = sum(Deposit txns excl ATM FEE REBATE + positive Transfer txns)"
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    Dim depositTxSum As Double"
  ts.WriteLine "    depositTxSum = 0#"
  ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
  ts.WriteLine "        act = ext.Transactions(i).Activity"
  ts.WriteLine "        If (act = ""Deposit"" Or act = ""Receive"") And ext.Transactions(i).Description <> ""ATM FEE REBATE"" Then"
  ts.WriteLine "            depositTxSum = depositTxSum + ext.Transactions(i).Amount"
  ts.WriteLine "        ElseIf act = ""Transfer"" And ext.Transactions(i).Amount > 0 Then"
  ts.WriteLine "            depositTxSum = depositTxSum + ext.Transactions(i).Amount"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine "    If ext.Summary.DepositsTransferredIn <> 0 Or depositTxSum <> 0 Then"
  ts.WriteLine "        AddCheck ext, ""deposits_transferred_in"", ext.Summary.DepositsTransferredIn, depositTxSum"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    ' Checks 16-20: Cash activity summary cross-validation"
  ts.WriteLine "    ' These compare the ""Cash activity summary"" section (independent data source)"
  ts.WriteLine "    ' against extracted transactions and holdings."
  ts.WriteLine "    ' ---------------------------------------------------------------"
  ts.WriteLine "    If Len(text) > 0 Then"
  ts.WriteLine "        Dim cashClosing As Variant"
  ts.WriteLine "        Dim cashDeposits As Variant"
  ts.WriteLine "        Dim cashProceeds As Variant"
  ts.WriteLine "        Dim cashInvested As Variant"
  ts.WriteLine "        Dim cashCardPay As Variant"
  ts.WriteLine "        ExtractCashActivitySummary text, cashClosing, cashDeposits, cashProceeds, cashInvested, cashCardPay"
  ts.WriteLine ""
  ts.WriteLine "        ' Check 16: cash_closing"
  ts.WriteLine "        ' Cash activity ""Closing balances"" = ""Cash and money balances"" holding value"
  ts.WriteLine "        If Not IsNull(cashClosing) Then"
  ts.WriteLine "            Dim cashHoldingVal As Variant"
  ts.WriteLine "            cashHoldingVal = Null"
  ts.WriteLine "            For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "                If ext.Holdings(i).Name = ""Cash and money balances"" Then"
  ts.WriteLine "                    cashHoldingVal = ext.Holdings(i).Value"
  ts.WriteLine "                    Exit For"
  ts.WriteLine "                End If"
  ts.WriteLine "            Next i"
  ts.WriteLine "            If Not IsNull(cashHoldingVal) Then"
  ts.WriteLine "                AddCheck ext, ""cash_closing"", CDbl(cashClosing), CDbl(cashHoldingVal)"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Single pass over transactions to classify into cash activity buckets"
  ts.WriteLine "        Dim cDepositSum As Double"
  ts.WriteLine "        Dim cSaleSum As Double"
  ts.WriteLine "        Dim cInvestedSum As Double"
  ts.WriteLine "        Dim cCardSum As Double"
  ts.WriteLine "        cDepositSum = 0#"
  ts.WriteLine "        cSaleSum = 0#"
  ts.WriteLine "        cInvestedSum = 0#"
  ts.WriteLine "        cCardSum = 0#"
  ts.WriteLine "        For i = 0 To ext.TransactionCount - 1"
  ts.WriteLine "            act = ext.Transactions(i).Activity"
  ts.WriteLine "            If act = ""Deposit"" And ext.Transactions(i).Description <> ""ATM FEE REBATE"" Then"
  ts.WriteLine "                cDepositSum = cDepositSum + ext.Transactions(i).Amount"
  ts.WriteLine "            ElseIf act = ""Transfer"" And ext.Transactions(i).Amount > 0 Then"
  ts.WriteLine "                cDepositSum = cDepositSum + ext.Transactions(i).Amount"
  ts.WriteLine "            ElseIf act = ""Sale"" Or act = ""Call Redemption"" Or act = ""Cash In Lieu"" Then"
  ts.WriteLine "                cSaleSum = cSaleSum + ext.Transactions(i).Amount"
  ts.WriteLine "            ElseIf act = ""Purchase"" Or act = ""Reinvestment"" Then"
  ts.WriteLine "                cInvestedSum = cInvestedSum + ext.Transactions(i).Amount"
  ts.WriteLine "            ElseIf act = ""Credit Card Payment"" Or act = ""Card Purchase"" Then"
  ts.WriteLine "                cCardSum = cCardSum + ext.Transactions(i).Amount"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next i"
  ts.WriteLine ""
  ts.WriteLine "        ' Check 17: cash_deposits"
  ts.WriteLine "        ' Cash activity deposits = sum(Deposit + Transfer-in txns, excl ATM FEE REBATE)"
  ts.WriteLine "        ' Skipped when securities transfers are detected (deposits_transferred_in != cash deposits)"
  ts.WriteLine "        If Not IsNull(cashDeposits) Then"
  ts.WriteLine "            Dim hasSecTransfers As Boolean"
  ts.WriteLine "            hasSecTransfers = (Abs(Round((ext.Summary.DepositsTransferredIn - CDbl(cashDeposits)) * 100, 0)) <> 0)"
  ts.WriteLine "            If Not hasSecTransfers Then"
  ts.WriteLine "                AddCheck ext, ""cash_deposits"", CDbl(cashDeposits), cDepositSum"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Check 18: cash_proceeds"
  ts.WriteLine "        ' Cash activity proceeds = sum(Sale + Call Redemption + Cash In Lieu txn amounts)"
  ts.WriteLine "        If Not IsNull(cashProceeds) Then"
  ts.WriteLine "            AddCheck ext, ""cash_proceeds"", CDbl(cashProceeds), cSaleSum"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Check 19: cash_invested"
  ts.WriteLine "        ' Cash activity funds invested = sum(Purchase + Reinvestment amounts)"
  ts.WriteLine "        If Not IsNull(cashInvested) Then"
  ts.WriteLine "            AddCheck ext, ""cash_invested"", CDbl(cashInvested), cInvestedSum"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Check 20: cash_card_payments"
  ts.WriteLine "        ' Cash activity card payments = sum(Credit Card Payment + Card Purchase amounts)"
  ts.WriteLine "        If Not IsNull(cashCardPay) Then"
  ts.WriteLine "            AddCheck ext, ""cash_card_payments"", CDbl(cashCardPay), cCardSum"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' Extract cash activity summary values from raw statement text."
  ts.WriteLine "' Returns Null for any value not found in the text."
  ts.WriteLine "Private Sub ExtractCashActivitySummary(text As String, _"
  ts.WriteLine "    ByRef closingBalance As Variant, ByRef deposits As Variant, _"
  ts.WriteLine "    ByRef proceeds As Variant, ByRef fundsInvested As Variant, _"
  ts.WriteLine "    ByRef cardPayments As Variant)"
  ts.WriteLine ""
  ts.WriteLine "    closingBalance = Null"
  ts.WriteLine "    deposits = Null"
  ts.WriteLine "    proceeds = Null"
  ts.WriteLine "    fundsInvested = Null"
  ts.WriteLine "    cardPayments = Null"
  ts.WriteLine ""
  ts.WriteLine "    Dim m As Object"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(text, ""Closing balances\s+\$([\d,]+\.\d{2})"")"
  ts.WriteLine "    If Not m Is Nothing Then closingBalance = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(text, ""Deposits and other funds credited\s+([\d,]+\.\d{2})"")"
  ts.WriteLine "    If Not m Is Nothing Then deposits = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(text, ""Proceeds from investment transactions\s+([\d,]+\.\d{2})"")"
  ts.WriteLine "    If Not m Is Nothing Then proceeds = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(text, ""bought\s+(-?[\d,]+\.\d{2})"")"
  ts.WriteLine "    If Not m Is Nothing Then fundsInvested = SafeFloat(m.SubMatches(0))"
  ts.WriteLine ""
  ts.WriteLine "    Set m = RegexMatch(text, ""Card payments\s+(-?[\d,]+\.\d{2})"")"
  ts.WriteLine "    If Not m Is Nothing Then cardPayments = SafeFloat(m.SubMatches(0))"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Sub AddCheck(ext As StatementExtraction, checkName As String, expected As Double, actual As Double)"
  ts.WriteLine "    If ext.CheckCount > UBound(ext.Checks) Then ReDim Preserve ext.Checks(0 To ext.CheckCount + 10)"
  ts.WriteLine "    ext.Checks(ext.CheckCount).name = checkName"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Expected = expected"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Actual = actual"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Diff = Round(expected - actual, 2)"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Pass = (Abs(Round((expected - actual) * 100, 0)) = 0)"
  ts.WriteLine "    ext.CheckCount = ext.CheckCount + 1"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Sub AddCheckEx(ext As StatementExtraction, checkName As String, expected As Double, actual As Double, passed As Boolean)"
  ts.WriteLine "    If ext.CheckCount > UBound(ext.Checks) Then ReDim Preserve ext.Checks(0 To ext.CheckCount + 10)"
  ts.WriteLine "    ext.Checks(ext.CheckCount).name = checkName"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Expected = expected"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Actual = actual"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Diff = Round(expected - actual, 2)"
  ts.WriteLine "    ext.Checks(ext.CheckCount).Pass = passed"
  ts.WriteLine "    ext.CheckCount = ext.CheckCount + 1"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' Validate extraction completeness -- flag warnings when expected sections appear"
  ts.WriteLine "' in the raw text but nothing was extracted (likely SafeFloat masking missing data)"
  ts.WriteLine "Private Sub ValidateExtraction(ByRef ext As StatementExtraction, ByVal text As String)"
  ts.WriteLine "    ' Warn if both opening and closing are zero on a non-loan account"
  ts.WriteLine "    ' (loan accounts legitimately lack these values)"
  ts.WriteLine "    If ext.Summary.OpeningValue = 0 And ext.Summary.ClosingValue = 0 Then"
  ts.WriteLine "        ' Only warn if the text doesn't literally show $0.00 values"
  ts.WriteLine "        If InStr(1, text, ""Account value"", vbTextCompare) > 0 Or _"
  ts.WriteLine "           InStr(1, text, ""Your assets"", vbTextCompare) > 0 Then"
  ts.WriteLine "            If InStr(1, text, ""0.00"" & vbLf, vbTextCompare) = 0 Then"
  ts.WriteLine "                AddCheckEx ext, ""completeness:summary_values"", 1, 0, False"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if ""Asset allocation"" header present but no allocations extracted"
  ts.WriteLine "    If InStr(1, text, ""Asset allocation"", vbTextCompare) > 0 Then"
  ts.WriteLine "        Dim allocFound As Long"
  ts.WriteLine "        Dim ai As Long"
  ts.WriteLine "        For ai = 0 To ext.AllocationCount - 1"
  ts.WriteLine "            If ext.Allocations(ai).Value <> 0 Then allocFound = allocFound + 1"
  ts.WriteLine "        Next ai"
  ts.WriteLine "        If allocFound = 0 Then"
  ts.WriteLine "            AddCheckEx ext, ""completeness:asset_allocation"", 1, 0, False"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if ""Holdings"" section header present but no holdings extracted"
  ts.WriteLine "    If InStr(1, text, ""Holdings"", vbTextCompare) > 0 And ext.HoldingCount = 0 Then"
  ts.WriteLine "        ' Exclude cases where only ""Cash and money balances"" appears (no holdings expected)"
  ts.WriteLine "        If InStr(1, text, ""Common stock"", vbTextCompare) > 0 Or _"
  ts.WriteLine "           InStr(1, text, ""Municipal securities"", vbTextCompare) > 0 Or _"
  ts.WriteLine "           InStr(1, text, ""Money market funds"", vbTextCompare) > 0 Or _"
  ts.WriteLine "           InStr(1, text, ""Private equity"", vbTextCompare) > 0 Then"
  ts.WriteLine "            AddCheckEx ext, ""completeness:holdings"", 1, 0, False"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if transaction date patterns exist but no transactions extracted"
  ts.WriteLine "    If ext.TransactionCount = 0 Then"
  ts.WriteLine "        Dim rxTxDate As Object"
  ts.WriteLine "        Set rxTxDate = RegexMatch(text, ""\d{2}/\d{2}/\d{2,4}\s+(Buy|Sell|Dividend|Interest|Transfer|Reinvest)"")"
  ts.WriteLine "        If Not rxTxDate Is Nothing Then"
  ts.WriteLine "            AddCheckEx ext, ""completeness:transactions"", 1, 0, False"
  ts.WriteLine "        End If"
  ts.WriteLine "        Set rxTxDate = Nothing"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if statement period was not extracted"
  ts.WriteLine "    If Len(ext.Summary.StatementPeriod) = 0 Then"
  ts.WriteLine "        AddCheckEx ext, ""completeness:statement_period"", 1, 0, False"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if account number was not extracted"
  ts.WriteLine "    If Len(ext.Summary.AccountNumber) = 0 Then"
  ts.WriteLine "        AddCheckEx ext, ""completeness:account_identity"", 1, 0, False"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if income detail section present but nothing extracted"
  ts.WriteLine "    ' Use ""Total dividend & interest"" (detail section footer) to avoid"
  ts.WriteLine "    ' matching the summary table's ""Dividend and interest income"" line"
  ts.WriteLine "    If InStr(1, text, ""Total dividend & interest"", vbTextCompare) > 0 Then"
  ts.WriteLine "        If ext.Income.TotalMonth = 0 Then"
  ts.WriteLine "            Dim incPos As Long"
  ts.WriteLine "            incPos = InStr(1, text, ""Total dividend & interest"", vbTextCompare)"
  ts.WriteLine "            Dim incSlice As String"
  ts.WriteLine "            incSlice = Mid$(text, incPos, 200)"
  ts.WriteLine "            If Not RegexMatch(incSlice, ""[1-9][\d,]*\.\d{2}"") Is Nothing Then"
  ts.WriteLine "                AddCheckEx ext, ""completeness:income"", 1, 0, False"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if gains header present but nothing extracted"
  ts.WriteLine "    If InStr(1, text, ""Summary of gains and losses"", vbTextCompare) > 0 Then"
  ts.WriteLine "        If ext.Gains.TotalRealizedMonth = 0 And ext.Gains.TotalRealizedYtd = 0 _"
  ts.WriteLine "           And ext.Gains.TotalUnrealized = 0 Then"
  ts.WriteLine "            Dim gainsPos As Long"
  ts.WriteLine "            gainsPos = InStr(1, text, ""Summary of gains and losses"", vbTextCompare)"
  ts.WriteLine "            Dim gainsSlice As String"
  ts.WriteLine "            gainsSlice = Mid$(text, gainsPos, 500)"
  ts.WriteLine "            If Not RegexMatch(gainsSlice, ""\d+\.\d{2}"") Is Nothing Then"
  ts.WriteLine "                AddCheckEx ext, ""completeness:gains"", 1, 0, False"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Warn if too few major section headers found (possible format change)"
  ts.WriteLine "    Dim hdrCount As Long"
  ts.WriteLine "    hdrCount = 0"
  ts.WriteLine "    If InStr(1, text, ""Account name:"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
  ts.WriteLine "    If InStr(1, text, ""Your assets"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
  ts.WriteLine "    If InStr(1, text, ""Summary of your assets"", vbTextCompare) > 0 Or _"
  ts.WriteLine "       InStr(1, text, ""Your total assets"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
  ts.WriteLine "    If InStr(1, text, ""Account activity this month"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
  ts.WriteLine "    If InStr(1, text, ""Dividend and interest income"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
  ts.WriteLine "    If InStr(1, text, ""Summary of gains and losses"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
  ts.WriteLine "    If hdrCount < 3 Then"
  ts.WriteLine "        AddCheckEx ext, ""completeness:section_headers"", 3, CDbl(hdrCount), False"
  ts.WriteLine "    End If"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
