ts.WriteLine "Public Function ExtractFromText(ByVal text As String) As StatementExtraction"
ts.WriteLine "    Dim result As StatementExtraction"
ts.WriteLine ""
ts.WriteLine "    ' Initialize dynamic arrays"
ts.WriteLine "    ReDim result.Allocations(0 To 6)"
ts.WriteLine "    ReDim result.Holdings(0 To 0)"
ts.WriteLine "    ReDim result.Transactions(0 To 0)"
ts.WriteLine "    ReDim result.Checks(0 To 40)"
ts.WriteLine ""
ts.WriteLine "    result.Summary = ExtractAccountSummary(text)"
ts.WriteLine "    result.Allocations = ExtractAssetAllocation(text)"
ts.WriteLine "    result.AllocationCount = 7"
ts.WriteLine ""
ts.WriteLine "    Dim h() As Holding"
ts.WriteLine "    h = ExtractHoldings(text)"
ts.WriteLine "    result.Holdings = h"
ts.WriteLine "    result.HoldingCount = UBound(h) + 1"
ts.WriteLine "    If result.HoldingCount = 1 And result.Holdings(0).Name = """" Then result.HoldingCount = 0"
ts.WriteLine ""
ts.WriteLine "    ' Merge 529 Plan holdings (if present)"
ts.WriteLine "    Dim h529() As Holding"
ts.WriteLine "    h529 = Extract529PlanHoldings(text)"
ts.WriteLine "    If h529(0).SecurityCount > 0 Then"
ts.WriteLine "        If result.HoldingCount > UBound(result.Holdings) Then _"
ts.WriteLine "            ReDim Preserve result.Holdings(0 To result.HoldingCount + 1)"
ts.WriteLine "        result.Holdings(result.HoldingCount) = h529(0)"
ts.WriteLine "        result.HoldingCount = result.HoldingCount + 1"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Attach life insurance policy securities to existing ""Life insurance"" holding"
ts.WriteLine "    Dim liSecs() As SecurityDetail"
ts.WriteLine "    liSecs = ExtractLifeInsuranceSecurities(text)"
ts.WriteLine "    If liSecs(0).Name <> """" Then"
ts.WriteLine "        Dim liIdx As Long"
ts.WriteLine "        For liIdx = 0 To result.HoldingCount - 1"
ts.WriteLine "            If result.Holdings(liIdx).Name = ""Life insurance"" Then"
ts.WriteLine "                result.Holdings(liIdx).Securities = liSecs"
ts.WriteLine "                result.Holdings(liIdx).SecurityCount = UBound(liSecs) + 1"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next liIdx"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Attach annuity contract securities to existing ""Annuities"" holding"
ts.WriteLine "    Dim anSecs() As SecurityDetail"
ts.WriteLine "    anSecs = ExtractAnnuitySecurities(text)"
ts.WriteLine "    If anSecs(0).Name <> """" Then"
ts.WriteLine "        Dim anIdx As Long"
ts.WriteLine "        For anIdx = 0 To result.HoldingCount - 1"
ts.WriteLine "            If result.Holdings(anIdx).Name = ""Annuities"" Then"
ts.WriteLine "                result.Holdings(anIdx).Securities = anSecs"
ts.WriteLine "                result.Holdings(anIdx).SecurityCount = UBound(anSecs) + 1"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next anIdx"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Attach detailed securities to holdings"
ts.WriteLine "    Dim secs() As SecurityDetail"
ts.WriteLine "    secs = ExtractDetailedSecurities(text)"
ts.WriteLine "    Dim secCount As Long"
ts.WriteLine "    ' Derive count from returned array (first entry with empty Name = unused slot)"
ts.WriteLine "    secCount = UBound(secs) + 1"
ts.WriteLine "    If secCount = 1 And secs(0).Name = """" And secs(0).Value = 0 Then secCount = 0"
ts.WriteLine "    AttachSecuritiesToHoldings result.Holdings, result.HoldingCount, secs, secCount"
ts.WriteLine ""
ts.WriteLine "    ' Aggregate security-level unrealized GL to holdings where holding-level is missing"
ts.WriteLine "    Dim aggHi As Long"
ts.WriteLine "    For aggHi = 0 To result.HoldingCount - 1"
ts.WriteLine "        If result.Holdings(aggHi).SecurityCount > 0 Then"
ts.WriteLine "            Dim aggSecUr As Double: aggSecUr = 0#"
ts.WriteLine "            Dim aggHasUr As Boolean: aggHasUr = False"
ts.WriteLine "            Dim aggSi As Long"
ts.WriteLine "            For aggSi = 0 To result.Holdings(aggHi).SecurityCount - 1"
ts.WriteLine "                If Not IsNull(result.Holdings(aggHi).Securities(aggSi).UnrealizedGL) Then"
ts.WriteLine "                    aggHasUr = True"
ts.WriteLine "                    aggSecUr = aggSecUr + CDbl(result.Holdings(aggHi).Securities(aggSi).UnrealizedGL)"
ts.WriteLine "                End If"
ts.WriteLine "            Next aggSi"
ts.WriteLine "            If aggHasUr And IsNull(result.Holdings(aggHi).UnrealizedGL) Then"
ts.WriteLine "                result.Holdings(aggHi).UnrealizedGL = aggSecUr"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    Next aggHi"
ts.WriteLine ""
ts.WriteLine "    ' Fallback: derive asset allocation from holdings when PDF lacks allocation section"
ts.WriteLine "    Dim allocEmpty As Boolean: allocEmpty = True"
ts.WriteLine "    Dim aci As Long"
ts.WriteLine "    For aci = 0 To 6"
ts.WriteLine "        If result.Allocations(aci).Value <> 0 Or result.Allocations(aci).Percentage <> 0 Then"
ts.WriteLine "            allocEmpty = False: Exit For"
ts.WriteLine "        End If"
ts.WriteLine "    Next aci"
ts.WriteLine "    If allocEmpty And result.HoldingCount > 0 Then"
ts.WriteLine "        Dim closingVal As Double"
ts.WriteLine "        closingVal = result.Summary.ClosingValue"
ts.WriteLine "        Dim hi As Long"
ts.WriteLine "        For hi = 0 To result.HoldingCount - 1"
ts.WriteLine "            Dim at As String: at = result.Holdings(hi).AssetType"
ts.WriteLine "            Dim catIdx As Long: catIdx = -1"
ts.WriteLine "            Select Case at"
ts.WriteLine "                Case ""Cash and money balances"": catIdx = 0"
ts.WriteLine "                Case ""Cash alternatives"": catIdx = 1"
ts.WriteLine "                Case ""Equities"": catIdx = 2"
ts.WriteLine "                Case ""Fixed income"": catIdx = 3"
ts.WriteLine "                Case ""Non-traditional"": catIdx = 4"
ts.WriteLine "                Case ""Commodities"": catIdx = 5"
ts.WriteLine "                Case ""Other"": catIdx = 6"
ts.WriteLine "            End Select"
ts.WriteLine "            If catIdx >= 0 Then"
ts.WriteLine "                result.Allocations(catIdx).Value = result.Allocations(catIdx).Value + result.Holdings(hi).Value"
ts.WriteLine "            End If"
ts.WriteLine "        Next hi"
ts.WriteLine "        ' Compute percentages from closing value"
ts.WriteLine "        If closingVal <> 0 Then"
ts.WriteLine "            For aci = 0 To 6"
ts.WriteLine "                If result.Allocations(aci).Value <> 0 Then"
ts.WriteLine "                    result.Allocations(aci).Percentage = Round(result.Allocations(aci).Value / closingVal * 100, 2)"
ts.WriteLine "                End If"
ts.WriteLine "            Next aci"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim t() As Transaction"
ts.WriteLine "    t = ExtractTransactions(text)"
ts.WriteLine "    Dim mainTxCount As Long"
ts.WriteLine "    mainTxCount = UBound(t) + 1"
ts.WriteLine "    If mainTxCount = 1 And t(0).Activity = """" Then mainTxCount = 0"
ts.WriteLine ""
ts.WriteLine "    If mainTxCount = 0 Then"
ts.WriteLine "        ReDim result.Transactions(0 To 0)"
ts.WriteLine "        result.TransactionCount = 0"
ts.WriteLine "    Else"
ts.WriteLine "        ReDim result.Transactions(0 To mainTxCount - 1)"
ts.WriteLine "        Dim ti As Long"
ts.WriteLine "        For ti = 0 To mainTxCount - 1"
ts.WriteLine "            result.Transactions(ti) = t(ti)"
ts.WriteLine "        Next ti"
ts.WriteLine "        result.TransactionCount = mainTxCount"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    result.Income = ExtractIncome(text)"
ts.WriteLine "    result.Gains = ExtractGainsLosses(text)"
ts.WriteLine ""
ts.WriteLine "    ' Run reconciliation"
ts.WriteLine "    RunReconciliation result, text"
ts.WriteLine ""
ts.WriteLine "    ' Validate extraction completeness (warns on likely missing data)"
ts.WriteLine "    ValidateExtraction result, text"
ts.WriteLine ""
ts.WriteLine "    ExtractFromText = result"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Public Sub ResetExtractState()"
ts.WriteLine "    ' Reset module-level state between extractions"
ts.WriteLine "    mSecCount = 0"
ts.WriteLine "    Erase mSecEntries"
ts.WriteLine "    mSecConstsInit = False"
ts.WriteLine "    mCatCount = 0"
ts.WriteLine "    mACCount = 0"
ts.WriteLine "    mNameRejectCount = 0"
ts.WriteLine "    mNormPatCount = 0"
ts.WriteLine "    mHFSkipCount = 0"
ts.WriteLine "    mPESkipCount = 0"
ts.WriteLine "    mBoilerplatePat = """""
ts.WriteLine "    RegexHelper.ClearRegexCache"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.Close

