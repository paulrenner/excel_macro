ts.WriteLine "' ============================================================================"
ts.WriteLine "' ComputeGlobalUncovered -- find accounts not covered by any loaded QPR"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function ComputeGlobalUncovered() As String"
ts.WriteLine "    If mQprWorkbooks Is Nothing Then"
ts.WriteLine "        ComputeGlobalUncovered = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine "    If mQprWorkbooks.count = 0 Then"
ts.WriteLine "        ComputeGlobalUncovered = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Union all mapped account numbers across all QPR workbooks"
ts.WriteLine "    Dim mappedAccts As Object"
ts.WriteLine "    Set mappedAccts = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim k As Variant"
ts.WriteLine "    Dim wb As Workbook"
ts.WriteLine "    Dim ws As Object"
ts.WriteLine "    Dim lastRow As Long"
ts.WriteLine "    Dim r As Long"
ts.WriteLine "    Dim acctVal As String"
ts.WriteLine ""
ts.WriteLine "    For Each k In mQprWorkbooks.Keys"
ts.WriteLine "        Set wb = mQprWorkbooks(k)"
ts.WriteLine "        ' Look for Mapping sheet"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        Set ws = wb.Worksheets(""Mapping"")"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "        If Not ws Is Nothing Then"
ts.WriteLine "            lastRow = ws.Cells(ws.Rows.count, 1).End(-4162).Row  ' xlUp"
ts.WriteLine "            For r = 2 To lastRow"
ts.WriteLine "                acctVal = Trim$(CStr(ws.Cells(r, 1).Value))"
ts.WriteLine "                If Len(acctVal) > 0 Then"
ts.WriteLine "                    If Not mappedAccts.Exists(acctVal) Then mappedAccts.Add acctVal, True"
ts.WriteLine "                End If"
ts.WriteLine "            Next r"
ts.WriteLine "            Set ws = Nothing"
ts.WriteLine "        End If"
ts.WriteLine "    Next k"
ts.WriteLine ""
ts.WriteLine "    ' Find extracted accounts not in mapped set"
ts.WriteLine "    Dim uncoveredAccts() As String"
ts.WriteLine "    Dim uncoveredNames() As String"
ts.WriteLine "    Dim uncoveredVals() As Double"
ts.WriteLine "    Dim uncoveredCount As Long"
ts.WriteLine "    uncoveredCount = 0"
ts.WriteLine "    ReDim uncoveredAccts(0 To mAccumulatedPortfolio.AccountCount)"
ts.WriteLine "    ReDim uncoveredNames(0 To mAccumulatedPortfolio.AccountCount)"
ts.WriteLine "    ReDim uncoveredVals(0 To mAccumulatedPortfolio.AccountCount)"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = 0 To mAccumulatedPortfolio.AccountCount - 1"
ts.WriteLine "        Dim acctNum As String"
ts.WriteLine "        acctNum = mAccumulatedPortfolio.Accounts(i).AccountNumber"
ts.WriteLine "        If Not mappedAccts.Exists(acctNum) Then"
ts.WriteLine "            uncoveredAccts(uncoveredCount) = acctNum"
ts.WriteLine "            uncoveredNames(uncoveredCount) = mAccumulatedPortfolio.Accounts(i).Extraction.Summary.AccountName"
ts.WriteLine "            uncoveredVals(uncoveredCount) = mAccumulatedPortfolio.Accounts(i).Extraction.Summary.ClosingValue"
ts.WriteLine "            uncoveredCount = uncoveredCount + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    If uncoveredCount = 0 Then"
ts.WriteLine "        ComputeGlobalUncovered = ""<div class=""""coverage-pass"""" style=""""margin-top:12px;"""">"" & _"
ts.WriteLine "            ""<strong style=""""color:#155724;font-size:14px;"""">&#10003; All "" & _"
ts.WriteLine "            mAccumulatedPortfolio.AccountCount & "" extracted accounts are covered by loaded QPR workbook(s).</strong></div>"""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim h As String"
ts.WriteLine "    h = ""<div class=""""coverage-fail"""" style=""""margin-top:12px;"""">"" & vbLf"
ts.WriteLine "    h = h & ""<strong style=""""color:#856404;font-size:14px;"""">&#9888; "" & uncoveredCount & _"
ts.WriteLine "            "" extracted account(s) not covered by any loaded QPR:</strong>"" & vbLf"
ts.WriteLine "    h = h & ""<div style=""""margin-top:8px;"""">"" & vbLf"
ts.WriteLine "    h = h & ""<table class=""""qpr-table""""><thead><tr><th>Account</th><th>Name</th>"" & _"
ts.WriteLine "            ""<th class=""""num"""">Closing Value</th></tr></thead><tbody>"" & vbLf"
ts.WriteLine "    For i = 0 To uncoveredCount - 1"
ts.WriteLine "        h = h & ""<tr><td>"" & uncoveredAccts(i) & ""</td>"" & _"
ts.WriteLine "                ""<td>"" & uncoveredNames(i) & ""</td>"" & _"
ts.WriteLine "                ""<td class=""""num"""">"" & Format$(uncoveredVals(i), ""#,##0.00"") & ""</td></tr>"" & vbLf"
ts.WriteLine "    Next i"
ts.WriteLine "    h = h & ""</tbody></table></div></div>"" & vbLf"
ts.WriteLine "    ComputeGlobalUncovered = h"
ts.WriteLine "End Function"
