' ExcelMacroInstaller.vbs — Self-contained VBA installer
' Generated by vba/build.mjs — do not edit manually
'
' Double-click to run. It will:
'   1. Write embedded .bas files to a temp folder
'   2. Open Excel with a new workbook
'   3. Import all modules and add the RegExp reference
'   4. Leave Excel open — you save it as .xlsm yourself
'   5. Clean up temp files

Option Explicit

Dim fso, tempDir
Set fso = CreateObject("Scripting.FileSystemObject")

' Create temp directory for .bas files
tempDir = fso.BuildPath(fso.GetSpecialFolder(2), "PDFExtractor_build")
If Not fso.FolderExists(tempDir) Then fso.CreateFolder(tempDir)

' Module names in dependency order
Dim modules(11)
  modules(0) = "RegexHelper.bas"
  modules(1) = "PDFCrypto.bas"
  modules(2) = "PDFDeflate.bas"
  modules(3) = "PDFReader.bas"
  modules(4) = "PDFTextExtract.bas"
  modules(5) = "UBSExtract.bas"
  modules(6) = "UBSLoanExtract.bas"
  modules(7) = "UBSSummary.bas"
  modules(8) = "QPRWriter.bas"
  modules(9) = "DataMapper.bas"
  modules(10) = "ViewerSheet.bas"
  modules(11) = "PDFExtractorMain.bas"

' Write each .bas file to temp directory (line by line, no giant strings)
Dim ts
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(0)), True)
  WriteModule_RegexHelper ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(1)), True)
  WriteModule_PDFCrypto ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(2)), True)
  WriteModule_PDFDeflate ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(3)), True)
  WriteModule_PDFReader ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(4)), True)
  WriteModule_PDFTextExtract ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(5)), True)
  WriteModule_UBSExtract ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(6)), True)
  WriteModule_UBSLoanExtract ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(7)), True)
  WriteModule_UBSSummary ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(8)), True)
  WriteModule_QPRWriter ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(9)), True)
  WriteModule_DataMapper ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(10)), True)
  WriteModule_ViewerSheet ts
  ts.Close
  Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, modules(11)), True)
  WriteModule_PDFExtractorMain ts
  ts.Close

' Start Excel (visible)
Dim xl, wb
Set xl = CreateObject("Excel.Application")
xl.Visible = True

' Check VBA access
On Error Resume Next
Set wb = xl.Workbooks.Add
Dim testAccess
testAccess = wb.VBProject.VBComponents.Count
If Err.Number <> 0 Then
  xl.Quit
  Cleanup
  MsgBox "ERROR: VBA project access is blocked." & vbCrLf & vbCrLf & _
    "Enable it: File > Options > Trust Center > Trust Center Settings >" & vbCrLf & _
    "  Macro Settings > check 'Trust access to the VBA project object model'", _
    vbCritical, "PDFExtractor Setup"
  WScript.Quit 1
End If
On Error GoTo 0

' Import each .bas file
Dim i, filePath, importCount
importCount = 0
For i = 0 To UBound(modules)
  filePath = fso.BuildPath(tempDir, modules(i))
  On Error Resume Next
  wb.VBProject.VBComponents.Import filePath
  If Err.Number <> 0 Then
    Dim importErr
    importErr = Err.Description
    On Error GoTo 0
    wb.Close False
    xl.Quit
    Cleanup
    MsgBox "ERROR importing " & modules(i) & ":" & vbCrLf & importErr, _
      vbCritical, "PDFExtractor Setup"
    WScript.Quit 1
  End If
  On Error GoTo 0
  importCount = importCount + 1
Next

' Add reference to Microsoft VBScript Regular Expressions 5.5
On Error Resume Next
wb.VBProject.References.AddFromGuid "{3F4DACA7-160D-11D2-A8E9-00104B365C9F}", 5, 5
On Error GoTo 0

' Set up Main sheet with buttons
On Error Resume Next
xl.Run "PDFExtractorMain.SetupMainSheet"
On Error GoTo 0

' Delete default Sheet1 and activate Main
On Error Resume Next
Dim sht
For Each sht In wb.Worksheets
  If sht.Name = "Sheet1" And wb.Worksheets.Count > 1 Then
    xl.DisplayAlerts = False
    sht.Delete
    xl.DisplayAlerts = True
    Exit For
  End If
Next
wb.Worksheets("Main").Activate
On Error GoTo 0

' Clean up temp files
Cleanup

MsgBox "Setup complete! Imported " & importCount & " modules with Main sheet." & vbCrLf & vbCrLf & _
  "Excel is open with your workbook. Save it as:" & vbCrLf & _
  "  File > Save As > Excel Macro.xlsm" & vbCrLf & _
  "  (choose 'Excel Macro-Enabled Workbook')", _
  vbInformation, "Excel Macro Setup"

Set wb = Nothing
Set xl = Nothing
Set fso = Nothing
WScript.Quit 0

Sub Cleanup()
  On Error Resume Next
  Dim f
  For Each f In fso.GetFolder(tempDir).Files
    fso.DeleteFile f.Path, True
  Next
  fso.DeleteFolder tempDir, True
  On Error GoTo 0
End Sub

