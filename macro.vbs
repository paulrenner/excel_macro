ts.WriteLine "' Designed for use with a WebBrowser control (IE11 engine) in a UserForm."
ts.WriteLine "' All CSS is inline-compatible: no CSS variables, no grid-template-rows,"
ts.WriteLine "' no ::before pseudo-elements. Toggles use display:none/block via JS."
ts.WriteLine "'"
ts.WriteLine "' Public API:"
ts.WriteLine "'   RenderPortfolioHTML(portfolio) -- full multi-account portfolio HTML"
ts.WriteLine "'   RenderSingleHTML(ext)         -- single account HTML"
ts.WriteLine "'"
ts.WriteLine "' window.external callbacks (patched by ViewerFormLauncher for embedded use):"
ts.WriteLine "'   window.external.OnAccountSelect(accountNumber)"
ts.WriteLine "'   window.external.OnClassifications(resultString)"
ts.WriteLine ""
