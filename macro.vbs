  ts.WriteLine "' Helper: build informational notes string from QPR analysis"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function BuildAnalysisNotes(analysis As QPRWriter.QprAnalysis, _"
  ts.WriteLine "        Optional globalUncovered As Long = -1) As String"
  ts.WriteLine "    Dim notes As String"
  ts.WriteLine "    Dim uncCount As Long"
  ts.WriteLine "    notes = """""
  ts.WriteLine "    ' Use global uncovered count when provided; fall back to per-QPR"
  ts.WriteLine "    If globalUncovered >= 0 Then uncCount = globalUncovered Else uncCount = analysis.UncoveredCount"
  ts.WriteLine "    If uncCount > 0 Then"
  ts.WriteLine "        notes = notes & uncCount & "" uncovered account(s); """
  ts.WriteLine "    End If"
  ts.WriteLine "    If analysis.UnmappedCount > 0 Then"
  ts.WriteLine "        notes = notes & analysis.UnmappedCount & "" unmapped holding(s); """
  ts.WriteLine "    End If"
  ts.WriteLine "    If analysis.PhantomCount > 0 Then"
  ts.WriteLine "        notes = notes & analysis.PhantomCount & "" phantom mapping(s); """
  ts.WriteLine "    End If"
  ts.WriteLine "    ' Trim trailing ""; """
  ts.WriteLine "    If Len(notes) > 2 Then notes = Left$(notes, Len(notes) - 2)"
  ts.WriteLine "    BuildAnalysisNotes = notes"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Helper: validate QPR workbook structure before saving"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ValidateQprStructure(wb As Workbook) As Boolean"
  ts.WriteLine "    On Error GoTo VFail"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim sh As Worksheet"
  ts.WriteLine "    Dim found As Boolean"
  ts.WriteLine "    found = False"
  ts.WriteLine "    For Each sh In wb.Worksheets"
  ts.WriteLine "        If LCase$(Trim$(sh.name)) = ""mapping"" Then"
  ts.WriteLine "            Set ws = sh"
  ts.WriteLine "            found = True"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next sh"
  ts.WriteLine ""
  ts.WriteLine "    If Not found Then"
  ts.WriteLine "        ' No Mapping sheet -- might be OK for some QPR formats"
  ts.WriteLine "        ValidateQprStructure = True"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Check header row has Tab and Account columns"
  ts.WriteLine "    Dim c As Long"
  ts.WriteLine "    Dim hasTab As Boolean"
  ts.WriteLine "    Dim hasAcct As Boolean"
  ts.WriteLine "    Dim cellVal As Variant"
  ts.WriteLine "    hasTab = False"
  ts.WriteLine "    hasAcct = False"
  ts.WriteLine "    For c = 1 To 20"
  ts.WriteLine "        cellVal = ws.Cells(1, c).Value"
  ts.WriteLine "        If Not IsNull(cellVal) Then"
  ts.WriteLine "            Dim hdr As String"
  ts.WriteLine "            hdr = LCase$(Trim$(CStr(cellVal)))"
  ts.WriteLine "            If hdr = ""tab"" Then hasTab = True"
  ts.WriteLine "            If hdr = ""account"" Then hasAcct = True"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next c"
  ts.WriteLine ""
  ts.WriteLine "    If Not hasTab Or Not hasAcct Then"
  ts.WriteLine "        ValidateQprStructure = False"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Check at least one data row exists"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    lastRow = ws.Cells(ws.Rows.count, 1).End(-4162).row  ' xlUp = -4162"
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        ValidateQprStructure = False"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ValidateQprStructure = True"
  ts.WriteLine "    Exit Function"
  ts.WriteLine ""
  ts.WriteLine "VFail:"
  ts.WriteLine "    ValidateQprStructure = False"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Helper: merge multiple PDF portfolios into one combined portfolio"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function MergePortfolios(pdfPortfolios() As UBSSummary.PortfolioExtraction, _"
  ts.WriteLine "                                  pdfCount As Long) As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim result As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim totalAccts As Long"
  ts.WriteLine "    Dim totalLoans As Long"
  ts.WriteLine "    Dim pi As Long"
  ts.WriteLine "    Dim j As Long"
  ts.WriteLine "    Dim acctIdx As Long"
  ts.WriteLine "    Dim loanIdx As Long"
  ts.WriteLine ""
  ts.WriteLine "    ' Count totals"
  ts.WriteLine "    totalAccts = 0"
  ts.WriteLine "    totalLoans = 0"
  ts.WriteLine "    For pi = 1 To pdfCount"
  ts.WriteLine "        totalAccts = totalAccts + pdfPortfolios(pi).AccountCount"
  ts.WriteLine "        totalLoans = totalLoans + pdfPortfolios(pi).LoanAccountCount"
  ts.WriteLine "    Next pi"
  ts.WriteLine ""
  ts.WriteLine "    result.AccountCount = totalAccts"
  ts.WriteLine "    result.LoanAccountCount = totalLoans"
  ts.WriteLine "    result.WarningCount = 0"
  ts.WriteLine "    ReDim result.Warnings(0 To 0)"
  ts.WriteLine ""
  ts.WriteLine "    If totalAccts > 0 Then"
  ts.WriteLine "        ReDim result.Accounts(0 To totalAccts - 1)"
  ts.WriteLine "    Else"
  ts.WriteLine "        ReDim result.Accounts(0 To 0)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    If totalLoans > 0 Then"
  ts.WriteLine "        ReDim result.LoanAccounts(0 To totalLoans - 1)"
  ts.WriteLine "    Else"
  ts.WriteLine "        ReDim result.LoanAccounts(0 To 0)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Copy -- assign THEN increment (0-based target)"
  ts.WriteLine "    acctIdx = 0"
  ts.WriteLine "    loanIdx = 0"
  ts.WriteLine ""
  ts.WriteLine "    For pi = 1 To pdfCount"
  ts.WriteLine "        For j = 0 To pdfPortfolios(pi).AccountCount - 1"
  ts.WriteLine "            result.Accounts(acctIdx) = pdfPortfolios(pi).Accounts(j)"
  ts.WriteLine "            acctIdx = acctIdx + 1"
  ts.WriteLine "        Next j"
  ts.WriteLine "        For j = 0 To pdfPortfolios(pi).LoanAccountCount - 1"
  ts.WriteLine "            result.LoanAccounts(loanIdx) = pdfPortfolios(pi).LoanAccounts(j)"
  ts.WriteLine "            loanIdx = loanIdx + 1"
  ts.WriteLine "        Next j"
  ts.WriteLine "    Next pi"
  ts.WriteLine ""
  ts.WriteLine "    ' Dedup pass -- detect same AccountNumber from different PDFs"
  ts.WriteLine "    If acctIdx > 1 Then"
  ts.WriteLine "        Dim seenAccts As Object"
  ts.WriteLine "        Set seenAccts = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "        Dim writeIdx As Long"
  ts.WriteLine "        writeIdx = 0"
  ts.WriteLine "        For j = 0 To acctIdx - 1"
  ts.WriteLine "            Dim acctKey As String"
  ts.WriteLine "            acctKey = result.Accounts(j).AccountNumber"
  ts.WriteLine "            If seenAccts.Exists(acctKey) Then"
  ts.WriteLine "                ' Keep the one with more holdings"
  ts.WriteLine "                Dim prevIdx As Long"
  ts.WriteLine "                prevIdx = seenAccts(acctKey)"
  ts.WriteLine "                If result.Accounts(j).Extraction.HoldingCount > _"
  ts.WriteLine "                   result.Accounts(prevIdx).Extraction.HoldingCount Then"
  ts.WriteLine "                    result.Accounts(prevIdx) = result.Accounts(j)"
  ts.WriteLine "                End If"
  ts.WriteLine "                AddWarning result, ""[WARNING: Duplicate account "" & acctKey & _"
  ts.WriteLine "                    "" found across PDFs - kept version with more data]"""
  ts.WriteLine "            Else"
  ts.WriteLine "                seenAccts.Add acctKey, writeIdx"
  ts.WriteLine "                If writeIdx <> j Then result.Accounts(writeIdx) = result.Accounts(j)"
  ts.WriteLine "                writeIdx = writeIdx + 1"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        result.AccountCount = writeIdx"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Dedup pass for loan accounts"
  ts.WriteLine "    If loanIdx > 1 Then"
  ts.WriteLine "        Dim seenLoans As Object"
  ts.WriteLine "        Set seenLoans = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "        Dim loanWriteIdx As Long"
  ts.WriteLine "        loanWriteIdx = 0"
  ts.WriteLine "        For j = 0 To loanIdx - 1"
  ts.WriteLine "            Dim loanKey As String"
  ts.WriteLine "            loanKey = result.LoanAccounts(j).AccountNumber"
  ts.WriteLine "            If seenLoans.Exists(loanKey) Then"
  ts.WriteLine "                AddWarning result, ""[WARNING: Duplicate loan account "" & loanKey & _"
  ts.WriteLine "                    "" found across PDFs - kept first version]"""
  ts.WriteLine "            Else"
  ts.WriteLine "                seenLoans.Add loanKey, loanWriteIdx"
  ts.WriteLine "                If loanWriteIdx <> j Then result.LoanAccounts(loanWriteIdx) = result.LoanAccounts(j)"
  ts.WriteLine "                loanWriteIdx = loanWriteIdx + 1"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        result.LoanAccountCount = loanWriteIdx"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    MergePortfolios = result"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Sub AddWarning(ByRef portfolio As UBSSummary.PortfolioExtraction, msg As String)"
  ts.WriteLine "    If portfolio.WarningCount > UBound(portfolio.Warnings) Then"
  ts.WriteLine "        ReDim Preserve portfolio.Warnings(0 To portfolio.WarningCount + 10)"
  ts.WriteLine "    End If"
  ts.WriteLine "    portfolio.Warnings(portfolio.WarningCount) = msg"
  ts.WriteLine "    portfolio.WarningCount = portfolio.WarningCount + 1"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Helper: detect whether an Excel file is a Template (_DataMap) or QPR (Mapping)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function DetectExcelTypeFromWb(wb As Workbook) As String"
  ts.WriteLine "    ' Classify an already-open workbook as ""Template"", ""QPR"", or ""Unknown"""
  ts.WriteLine "    Dim sh As Worksheet"
  ts.WriteLine "    Dim hasDataMap As Boolean"
  ts.WriteLine "    Dim hasMapping As Boolean"
  ts.WriteLine "    For Each sh In wb.Worksheets"
  ts.WriteLine "        If sh.Name = ""_DataMap"" Then hasDataMap = True"
  ts.WriteLine "        If LCase$(Trim$(sh.Name)) = ""mapping"" Then hasMapping = True"
  ts.WriteLine "    Next sh"
  ts.WriteLine "    If hasDataMap Then"
  ts.WriteLine "        DetectExcelTypeFromWb = ""Template"""
  ts.WriteLine "    ElseIf hasMapping Then"
  ts.WriteLine "        DetectExcelTypeFromWb = ""QPR"""
  ts.WriteLine "    Else"
  ts.WriteLine "        DetectExcelTypeFromWb = ""Unknown"""
  ts.WriteLine "    End If"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Helper: process one client -- extract, optionally auto-pass, show viewer"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ProcessOneClient( _"
  ts.WriteLine "    clientName As String, _"
  ts.WriteLine "    clientPdfs() As String, _"
  ts.WriteLine "    clientQprs() As String, _"
  ts.WriteLine "    clientRowCount As Long, _"
  ts.WriteLine "    allowAutoPass As Boolean, _"
  ts.WriteLine "    statusPrefix As String _"
  ts.WriteLine ") As ProcessClientResult"
  ts.WriteLine "    ' --- Variable declarations ---"
  ts.WriteLine "    Dim result As ProcessClientResult"
  ts.WriteLine "    Dim pdfPortfolios() As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim pi As Long"
  ts.WriteLine "    Dim j As Long"
  ts.WriteLine "    Dim ai As Long"
  ts.WriteLine "    Dim rawText As String"
  ts.WriteLine "    Dim combinedRawText As String"
  ts.WriteLine "    Dim pdfSummaryRefs As UBSSummary.SummaryReferences"
  ts.WriteLine "    Dim mergedSummaryRefs As UBSSummary.SummaryReferences"
  ts.WriteLine "    Dim hasCoverage As Boolean"
  ts.WriteLine "    Dim mergedPortfolio As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim unclassified() As QPRWriter.UnclassifiedSecurity"
  ts.WriteLine "    Dim unclassCount As Long"
  ts.WriteLine "    Dim failedChecks As Long"
  ts.WriteLine "    Dim checkIdx As Long"
  ts.WriteLine "    Dim qprWb As Workbook"
  ts.WriteLine "    Dim uniqueQprs As Object"
  ts.WriteLine "    Dim qprPathKey As Variant"
  ts.WriteLine "    Dim html As String"
  ts.WriteLine "    Dim classResult As String"
  ts.WriteLine "    Dim overrides As Object"
  ts.WriteLine "    Dim viewerQprWb As Workbook"
  ts.WriteLine "    Dim writeResult As String"
  ts.WriteLine "    Dim coverageResult As UBSSummary.CoverageResult"
  ts.WriteLine "    Dim coverageHTML As String"
  ts.WriteLine "    Dim allocOpts() As String"
  ts.WriteLine "    Dim allocOptCount As Long"
  ts.WriteLine "    ReDim allocOpts(1 To 1)"
  ts.WriteLine "    allocOpts(1) = ""Other"""
  ts.WriteLine "    allocOptCount = 1"
  ts.WriteLine "    Dim emptySecs(1 To 1) As QPRWriter.UnclassifiedSecurity"
  ts.WriteLine "    Dim analysis As QPRWriter.QprAnalysis"
  ts.WriteLine "    Dim allMappedAccts As Object"
  ts.WriteLine "    Dim mappings() As QPRWriter.MappingRow"
  ts.WriteLine "    Dim mi As Long"
  ts.WriteLine "    Dim acctIdx As Long"
  ts.WriteLine "    Dim globalUncovered As Long"
  ts.WriteLine "    Dim batchParts() As String"
  ts.WriteLine "    Dim batchPartCount As Long"
  ts.WriteLine "    batchPartCount = 0"
  ts.WriteLine "    Dim reviewReason As String"
  ts.WriteLine "    Dim hasAnalysis As Boolean"
  ts.WriteLine "    Dim errNum As Long"
  ts.WriteLine "    Dim errSrc As String"
  ts.WriteLine "    Dim errDesc As String"
  ts.WriteLine "    Dim stepInfo As String"
  ts.WriteLine "    ' Template batch variables"
  ts.WriteLine "    Dim uniqueTemplates As Object"
  ts.WriteLine "    Dim tplPathKey As Variant"
  ts.WriteLine "    Dim tplWb As Workbook"
  ts.WriteLine "    Dim tplMapRows() As DataMapper.DataMapRow"
  ts.WriteLine "    Dim tplMapRowCount As Long"
  ts.WriteLine "    Dim tplResult As DataMapper.DataMapResult"
  ts.WriteLine "    Dim tplAlertCount As Long"
  ts.WriteLine "    Dim excelType As String"
  ts.WriteLine "    Dim hasTemplates As Boolean"
  ts.WriteLine ""
  ts.WriteLine "    On Error GoTo ProcessError"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""init"""
  ts.WriteLine "    result.Success = False"
  ts.WriteLine "    result.AutoCompleted = False"
  ts.WriteLine "    result.AutoCompletedTemplate = False"
  ts.WriteLine "    result.ViewerWroteQPR = False"
  ts.WriteLine "    result.ViewerWroteTemplate = False"
  ts.WriteLine "    result.StatusText = """""
  ts.WriteLine "    result.Notes = """""
  ts.WriteLine "    hasAnalysis = False"
  ts.WriteLine "    tplAlertCount = 0"
  ts.WriteLine "    hasTemplates = False"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""extracting PDFs"""
  ts.WriteLine "    ' --- Step 1: Extract all PDFs ---"
  ts.WriteLine "    combinedRawText = """""
  ts.WriteLine "    hasCoverage = False"
  ts.WriteLine "    mergedSummaryRefs.AccountCount = 0"
  ts.WriteLine "    mergedSummaryRefs.ChangeCount = 0"
  ts.WriteLine "    ReDim mergedSummaryRefs.Accounts(0 To 15)"
  ts.WriteLine "    ReDim mergedSummaryRefs.Changes(0 To 15)"
  ts.WriteLine ""
  ts.WriteLine "    ReDim pdfPortfolios(1 To clientRowCount)"
  ts.WriteLine "    Dim parsedPdfs As Object"
  ts.WriteLine "    Set parsedPdfs = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine ""
  ts.WriteLine "    For pi = 1 To clientRowCount"
  ts.WriteLine "        Application.StatusBar = statusPrefix & ""extracting PDF "" & pi & ""/"" & clientRowCount"
  ts.WriteLine ""
  ts.WriteLine "        If Dir(clientPdfs(pi)) = """" Then"
  ts.WriteLine "            result.StatusText = result.StatusText & ""SKIP PDF not found: "" & clientPdfs(pi) & vbCrLf"
  ts.WriteLine "            GoTo NextProcessPdf"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        ' Skip duplicate PDF paths — reuse the portfolio from the first parse"
  ts.WriteLine "        Dim pdfKey As String"
  ts.WriteLine "        pdfKey = LCase$(clientPdfs(pi))"
  ts.WriteLine "        If parsedPdfs.Exists(pdfKey) Then"
  ts.WriteLine "            pdfPortfolios(pi) = pdfPortfolios(CLng(parsedPdfs(pdfKey)))"
  ts.WriteLine "            GoTo NextProcessPdf"
  ts.WriteLine "        End If"
  ts.WriteLine "        parsedPdfs(pdfKey) = pi"
  ts.WriteLine ""
  ts.WriteLine "        rawText = """""
  ts.WriteLine "        pdfPortfolios(pi) = ExtractPDFToPortfolioFull(clientPdfs(pi), rawText, pdfSummaryRefs)"
  ts.WriteLine "        RegexHelper.ClearRegexCache"
  ts.WriteLine "        PDFDeflate.ClearInflateCache"
  ts.WriteLine ""
  ts.WriteLine "        ' Accumulate summary refs"
  ts.WriteLine "        If pdfSummaryRefs.ChangeCount > 0 Then"
  ts.WriteLine "            UBSSummary.MergeSummaryRefs mergedSummaryRefs, pdfSummaryRefs"
  ts.WriteLine "            hasCoverage = True"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        If Len(combinedRawText) > 0 Then combinedRawText = combinedRawText & vbLf & vbLf"
  ts.WriteLine "        combinedRawText = combinedRawText & ""--- PDF: "" & Dir(clientPdfs(pi)) & "" ---"" & vbLf & rawText"
  ts.WriteLine "NextProcessPdf:"
  ts.WriteLine "    Next pi"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Step 1b: Cross-PDF period consistency check ---"
  ts.WriteLine "    Dim firstPeriod As String"
  ts.WriteLine "    Dim periodMismatch As String"
  ts.WriteLine "    firstPeriod = """""
  ts.WriteLine "    periodMismatch = """""
  ts.WriteLine "    For pi = 1 To clientRowCount"
  ts.WriteLine "        For ai = 0 To pdfPortfolios(pi).AccountCount - 1"
  ts.WriteLine "            Dim acctPeriod As String"
  ts.WriteLine "            acctPeriod = pdfPortfolios(pi).Accounts(ai).Extraction.Summary.StatementPeriod"
  ts.WriteLine "            If Len(acctPeriod) > 0 Then"
  ts.WriteLine "                If Len(firstPeriod) = 0 Then"
  ts.WriteLine "                    firstPeriod = acctPeriod"
  ts.WriteLine "                ElseIf StrComp(acctPeriod, firstPeriod, vbTextCompare) <> 0 Then"
  ts.WriteLine "                    periodMismatch = periodMismatch & pdfPortfolios(pi).Accounts(ai).Extraction.Summary.AccountNumber & _"
  ts.WriteLine "                        "" ("" & acctPeriod & "" vs "" & firstPeriod & ""); """
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next ai"
  ts.WriteLine "    Next pi"
  ts.WriteLine "    If Len(periodMismatch) > 0 Then"
  ts.WriteLine "        result.Notes = result.Notes & ""[PERIOD MISMATCH: "" & periodMismatch & ""]"""
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""merging portfolios"""
  ts.WriteLine "    Application.StatusBar = statusPrefix & ""merging portfolios..."""
  ts.WriteLine "    ' --- Step 2: Merge portfolios ---"
  ts.WriteLine "    mergedPortfolio = MergePortfolios(pdfPortfolios, clientRowCount)"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""classifying Excel files"""
  ts.WriteLine "    Application.StatusBar = statusPrefix & ""classifying output files..."""
  ts.WriteLine "    ' --- Step 3: Classify Excel paths, open once, and analyze ---"
  ts.WriteLine "    ' Each QPR/template is opened once here and kept open for the rest of the function."
  ts.WriteLine "    Set uniqueQprs = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    Set uniqueTemplates = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    Dim pocOpenQprs As Object  ' key = qprPath, value = Workbook"
  ts.WriteLine "    Set pocOpenQprs = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    Dim pocOpenTpls As Object  ' key = tplPath, value = Workbook"
  ts.WriteLine "    Set pocOpenTpls = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine ""
  ts.WriteLine "    For pi = 1 To clientRowCount"
  ts.WriteLine "        If Len(clientQprs(pi)) > 0 Then"
  ts.WriteLine "            If Not uniqueQprs.Exists(clientQprs(pi)) And Not uniqueTemplates.Exists(clientQprs(pi)) Then"
  ts.WriteLine "                If Dir(clientQprs(pi)) = """" Then"
  ts.WriteLine "                    result.Notes = result.Notes & ""[File not found: "" & clientQprs(pi) & ""]"""
  ts.WriteLine "                    GoTo NextClassify"
  ts.WriteLine "                End If"
  ts.WriteLine "                ' Open once and classify by checking sheet names"
  ts.WriteLine "                Dim classWb As Workbook"
  ts.WriteLine "                Set classWb = Workbooks.Open(clientQprs(pi), UpdateLinks:=False)"
  ts.WriteLine "                classWb.Windows(1).Visible = False"
  ts.WriteLine "                excelType = DetectExcelTypeFromWb(classWb)"
  ts.WriteLine "                If excelType = ""Template"" Then"
  ts.WriteLine "                    uniqueTemplates(clientQprs(pi)) = True"
  ts.WriteLine "                    Set pocOpenTpls(clientQprs(pi)) = classWb"
  ts.WriteLine "                    hasTemplates = True"
  ts.WriteLine "                ElseIf excelType = ""QPR"" Then"
  ts.WriteLine "                    uniqueQprs(clientQprs(pi)) = True"
  ts.WriteLine "                    Set pocOpenQprs(clientQprs(pi)) = classWb"
  ts.WriteLine "                Else"
  ts.WriteLine "                    classWb.Close False"
  ts.WriteLine "                    result.Notes = result.Notes & ""[Unknown Excel type: "" & Dir(clientQprs(pi)) & ""]"""
  ts.WriteLine "                End If"
  ts.WriteLine "                Set classWb = Nothing"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "NextClassify:"
  ts.WriteLine "    Next pi"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""analyzing QPR"""
  ts.WriteLine "    Application.StatusBar = statusPrefix & ""analyzing QPR..."""
  ts.WriteLine ""
  ts.WriteLine "    ReDim unclassified(1 To 1)"
  ts.WriteLine "    unclassCount = 0"
  ts.WriteLine ""
  ts.WriteLine "    ' Union all mapped account numbers across all QPR workbooks for global uncovered count"
  ts.WriteLine "    Set allMappedAccts = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    Dim totalUnmapped As Long: totalUnmapped = 0"
  ts.WriteLine "    Dim totalPhantom As Long: totalPhantom = 0"
  ts.WriteLine ""
  ts.WriteLine "    For Each qprPathKey In pocOpenQprs.Keys"
  ts.WriteLine "        Set qprWb = pocOpenQprs(qprPathKey)"
  ts.WriteLine "        analysis = QPRWriter.AnalyzeQPR(mergedPortfolio, qprWb)"
  ts.WriteLine "        unclassCount = QPRWriter.FindUnclassifiedSecurities(mergedPortfolio, qprWb, unclassified)"
  ts.WriteLine ""
  ts.WriteLine "        ' Accumulate analysis counts across all QPRs"
  ts.WriteLine "        totalUnmapped = totalUnmapped + analysis.UnmappedCount"
  ts.WriteLine "        totalPhantom = totalPhantom + analysis.PhantomCount"
  ts.WriteLine ""
  ts.WriteLine "        ' Accumulate mapped accounts from this QPR's mapping sheet"
  ts.WriteLine "        mappings = QPRWriter.ReadMappingSheet(qprWb)"
  ts.WriteLine "        If mappings(0).Tab <> """" Then"
  ts.WriteLine "            For mi = 0 To UBound(mappings)"
  ts.WriteLine "                If mappings(mi).Account <> """" Then"
  ts.WriteLine "                    If Not allMappedAccts.Exists(mappings(mi).Account) Then"
  ts.WriteLine "                        allMappedAccts.Add mappings(mi).Account, True"
  ts.WriteLine "                    End If"
  ts.WriteLine "                End If"
  ts.WriteLine "            Next mi"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        Set qprWb = Nothing"
  ts.WriteLine "        hasAnalysis = True"
  ts.WriteLine "    Next qprPathKey"
  ts.WriteLine ""
  ts.WriteLine "    ' Compute global uncovered count (accounts not in ANY QPR's mapping sheet)"
  ts.WriteLine "    globalUncovered = 0"
  ts.WriteLine "    If hasAnalysis Then"
  ts.WriteLine "        For acctIdx = 0 To mergedPortfolio.AccountCount - 1"
  ts.WriteLine "            If Not allMappedAccts.Exists(mergedPortfolio.Accounts(acctIdx).Extraction.Summary.AccountNumber) Then"
  ts.WriteLine "                globalUncovered = globalUncovered + 1"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next acctIdx"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Build notes from accumulated analysis (informational -- written to Config ""Status Detail"" column by caller)"
  ts.WriteLine "    If hasAnalysis Then"
  ts.WriteLine "        analysis.UnmappedCount = totalUnmapped"
  ts.WriteLine "        analysis.PhantomCount = totalPhantom"
  ts.WriteLine "        result.Notes = result.Notes & BuildAnalysisNotes(analysis, globalUncovered)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Step 3b: Analyze templates (already open in pocOpenTpls) ---"
  ts.WriteLine "    If hasTemplates Then"
  ts.WriteLine "        stepInfo = ""analyzing templates"""
  ts.WriteLine "        Application.StatusBar = statusPrefix & ""analyzing templates..."""
  ts.WriteLine "        For Each tplPathKey In pocOpenTpls.Keys"
  ts.WriteLine "            Set tplWb = pocOpenTpls(tplPathKey)"
  ts.WriteLine "            tplMapRows = DataMapper.ReadDataMap(tplWb, tplMapRowCount)"
  ts.WriteLine "            If tplMapRowCount > 0 Then"
  ts.WriteLine "                tplResult = DataMapper.ProcessMapping(mergedPortfolio, tplMapRows, tplMapRowCount)"
  ts.WriteLine "                tplAlertCount = tplAlertCount + DataMapper.WarningAlertCount(tplResult)"
  ts.WriteLine "            End If"
  ts.WriteLine "            Set tplWb = Nothing"
  ts.WriteLine "        Next tplPathKey"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""auto-pass check"""
  ts.WriteLine "    Application.StatusBar = statusPrefix & ""validating..."""
  ts.WriteLine "    ' --- Step 4: Auto-pass decision (if allowed) ---"
  ts.WriteLine "    If allowAutoPass Then"
  ts.WriteLine "        ' Count failed recon checks across all accounts"
  ts.WriteLine "        failedChecks = 0"
  ts.WriteLine "        For pi = 1 To clientRowCount"
  ts.WriteLine "            For ai = 0 To pdfPortfolios(pi).AccountCount - 1"
  ts.WriteLine "                For checkIdx = 0 To pdfPortfolios(pi).Accounts(ai).Extraction.CheckCount - 1"
  ts.WriteLine "                    If Not pdfPortfolios(pi).Accounts(ai).Extraction.Checks(checkIdx).Pass Then"
  ts.WriteLine "                        failedChecks = failedChecks + 1"
  ts.WriteLine "                    End If"
  ts.WriteLine "                Next checkIdx"
  ts.WriteLine "            Next ai"
  ts.WriteLine "        Next pi"
  ts.WriteLine ""
  ts.WriteLine "        ' QPR auto-pass: no unclassified, no failed checks, no notes (or no QPRs at all)"
  ts.WriteLine "        ' Template auto-pass: no alerts and has values (or no templates at all)"
  ts.WriteLine "        Dim qprCanAutoPass As Boolean"
  ts.WriteLine "        Dim tplCanAutoPass As Boolean"
  ts.WriteLine "        qprCanAutoPass = (unclassCount = 0 And failedChecks = 0 And Len(result.Notes) = 0) Or (uniqueQprs.Count = 0)"
  ts.WriteLine "        tplCanAutoPass = (tplAlertCount = 0 And (Not hasTemplates Or tplResult.ValueCount > 0)) Or (Not hasTemplates)"
  ts.WriteLine ""
  ts.WriteLine "        stepInfo = ""auto-pass: unclass="" & unclassCount & "" failed="" & failedChecks & "" notes="" & Len(result.Notes) & "" tplAlerts="" & tplAlertCount"
  ts.WriteLine ""
  ts.WriteLine "        If qprCanAutoPass And tplCanAutoPass Then"
  ts.WriteLine "            stepInfo = ""auto-pass writing QPR"""
  ts.WriteLine "            Dim hasWriteWarnings As Boolean"
  ts.WriteLine "            hasWriteWarnings = False"
  ts.WriteLine ""
  ts.WriteLine "            ' Write QPR silently (already open read-write)"
  ts.WriteLine "            For Each qprPathKey In pocOpenQprs.Keys"
  ts.WriteLine "                Application.StatusBar = statusPrefix & ""writing QPR..."""
  ts.WriteLine "                Set qprWb = pocOpenQprs(qprPathKey)"
  ts.WriteLine ""
  ts.WriteLine "                For pi = 1 To clientRowCount"
  ts.WriteLine "                    If clientQprs(pi) = CStr(qprPathKey) Then"
  ts.WriteLine "                        writeResult = """""
  ts.WriteLine "                        QPRWriter.WriteAllQPR pdfPortfolios(pi), qprWb, True, writeResult"
  ts.WriteLine "                        batchPartCount = batchPartCount + 1"
  ts.WriteLine "                        ReDim Preserve batchParts(1 To batchPartCount)"
  ts.WriteLine "                        batchParts(batchPartCount) = writeResult"
  ts.WriteLine "                        If InStr(1, writeResult, ""[WARNING"", vbTextCompare) > 0 Then"
  ts.WriteLine "                            hasWriteWarnings = True"
  ts.WriteLine "                        End If"
  ts.WriteLine "                    End If"
  ts.WriteLine "                Next pi"
  ts.WriteLine ""
  ts.WriteLine "                If hasWriteWarnings Then"
  ts.WriteLine "                    ' Warnings found during write -- discard changes, reopen read-only for viewer"
  ts.WriteLine "                    qprWb.Close False"
  ts.WriteLine "                    Set qprWb = Workbooks.Open(CStr(qprPathKey), UpdateLinks:=False, ReadOnly:=True)"
  ts.WriteLine "                    qprWb.Windows(1).Visible = False"
  ts.WriteLine "                    Set pocOpenQprs(qprPathKey) = qprWb"
  ts.WriteLine "                    Set qprWb = Nothing"
  ts.WriteLine "                    GoTo AutoPassAbort"
  ts.WriteLine "                End If"
  ts.WriteLine ""
  ts.WriteLine "                ' Validate before saving"
  ts.WriteLine "                If ValidateQprStructure(qprWb) Then"
  ts.WriteLine "                    qprWb.Windows(1).Visible = True"
  ts.WriteLine "                    qprWb.Save"
  ts.WriteLine "                Else"
  ts.WriteLine "                    batchPartCount = batchPartCount + 1"
  ts.WriteLine "                    ReDim Preserve batchParts(1 To batchPartCount)"
  ts.WriteLine "                    batchParts(batchPartCount) = ""[WARNING: QPR validation failed -- file NOT saved]"""
  ts.WriteLine "                    qprWb.Close False"
  ts.WriteLine "                    Set qprWb = Workbooks.Open(CStr(qprPathKey), UpdateLinks:=False, ReadOnly:=True)"
  ts.WriteLine "                    qprWb.Windows(1).Visible = False"
  ts.WriteLine "                    Set pocOpenQprs(qprPathKey) = qprWb"
  ts.WriteLine "                    Set qprWb = Nothing"
  ts.WriteLine "                    GoTo AutoPassAbort"
  ts.WriteLine "                End If"
  ts.WriteLine "                qprWb.Close False"
  ts.WriteLine "                pocOpenQprs.Remove CStr(qprPathKey)"
  ts.WriteLine "                Set qprWb = Nothing"
  ts.WriteLine "            Next qprPathKey"
  ts.WriteLine ""
  ts.WriteLine "            If Not hasWriteWarnings Then"
  ts.WriteLine "                ' Auto-write templates (already open read-only in pocOpenTpls)"
  ts.WriteLine "                If hasTemplates Then"
  ts.WriteLine "                    stepInfo = ""auto-pass writing template"""
  ts.WriteLine "                    For Each tplPathKey In pocOpenTpls.Keys"
  ts.WriteLine "                        Application.StatusBar = statusPrefix & ""writing template..."""
  ts.WriteLine ""
  ts.WriteLine "                        ' Close read-only and reopen read-write for writing"
  ts.WriteLine "                        pocOpenTpls(tplPathKey).Close False"
  ts.WriteLine "                        Set tplWb = Workbooks.Open(CStr(tplPathKey), UpdateLinks:=False)"
  ts.WriteLine "                        tplWb.Windows(1).Visible = False"
  ts.WriteLine "                        Set pocOpenTpls(tplPathKey) = tplWb"
  ts.WriteLine ""
  ts.WriteLine "                        ' Backup before writing"
  ts.WriteLine "                        Dim tplDot As Long, tplBase As String, tplExt As String, tplBackup As String"
  ts.WriteLine "                        tplDot = InStrRev(CStr(tplPathKey), ""."")"
  ts.WriteLine "                        If tplDot > 0 Then"
  ts.WriteLine "                            tplBase = Left$(CStr(tplPathKey), tplDot - 1)"
  ts.WriteLine "                            tplExt = Mid$(CStr(tplPathKey), tplDot)"
  ts.WriteLine "                        Else"
  ts.WriteLine "                            tplBase = CStr(tplPathKey)"
  ts.WriteLine "                            tplExt = """""
  ts.WriteLine "                        End If"
  ts.WriteLine "                        tplBackup = tplBase & ""_backup_"" & Format$(Now, ""yyyymmdd\_hhmmss"") & tplExt"
  ts.WriteLine "                        On Error Resume Next"
  ts.WriteLine "                        tplWb.SaveCopyAs tplBackup"
  ts.WriteLine "                        On Error GoTo ProcessError"
  ts.WriteLine ""
  ts.WriteLine "                        ' Re-read DataMap and process mapping, then write"
  ts.WriteLine "                        tplMapRows = DataMapper.ReadDataMap(tplWb, tplMapRowCount)"
  ts.WriteLine "                        If tplMapRowCount > 0 Then"
  ts.WriteLine "                            tplResult = DataMapper.ProcessMapping(mergedPortfolio, tplMapRows, tplMapRowCount)"
  ts.WriteLine "                            DataMapper.WriteResults tplWb, tplResult"
  ts.WriteLine "                        End If"
  ts.WriteLine ""
  ts.WriteLine "                        tplWb.Windows(1).Visible = True"
  ts.WriteLine "                        tplWb.Save"
  ts.WriteLine "                        tplWb.Close False"
  ts.WriteLine "                        pocOpenTpls.Remove CStr(tplPathKey)"
  ts.WriteLine "                        Set tplWb = Nothing"
  ts.WriteLine "                        result.AutoCompletedTemplate = True"
  ts.WriteLine ""
  ts.WriteLine "                        batchPartCount = batchPartCount + 1"
  ts.WriteLine "                        ReDim Preserve batchParts(1 To batchPartCount)"
  ts.WriteLine "                        batchParts(batchPartCount) = ""Template auto-written: "" & Dir(CStr(tplPathKey))"
  ts.WriteLine "                    Next tplPathKey"
  ts.WriteLine "                End If"
  ts.WriteLine ""
  ts.WriteLine "                result.Success = True"
  ts.WriteLine "                result.AutoCompleted = True"
  ts.WriteLine "                Dim batchLines As String"
  ts.WriteLine "                If batchPartCount > 0 Then batchLines = Join(batchParts, vbCrLf) Else batchLines = """""
  ts.WriteLine "                result.StatusText = ""Auto-completed"" & vbCrLf & batchLines"
  ts.WriteLine "                ProcessOneClient = result"
  ts.WriteLine "                Exit Function"
  ts.WriteLine "            End If"
  ts.WriteLine ""
  ts.WriteLine "AutoPassAbort:"
  ts.WriteLine "            ' Write warnings or validation failure -- build review reason and fall through to viewer"
  ts.WriteLine "            If hasWriteWarnings Then"
  ts.WriteLine "                reviewReason = ""write warnings detected"""
  ts.WriteLine "            Else"
  ts.WriteLine "                reviewReason = ""QPR validation failed"""
  ts.WriteLine "            End If"
  ts.WriteLine "            result.StatusText = ""Needs review: "" & reviewReason & vbCrLf"
  ts.WriteLine "        Else"
  ts.WriteLine "            ' Build review reason for status"
  ts.WriteLine "            reviewReason = """""
  ts.WriteLine "            If unclassCount > 0 Then reviewReason = unclassCount & "" unclassified"""
  ts.WriteLine "            If failedChecks > 0 Then"
  ts.WriteLine "                If Len(reviewReason) > 0 Then reviewReason = reviewReason & "", """
  ts.WriteLine "                reviewReason = reviewReason & failedChecks & "" failed checks"""
  ts.WriteLine "            End If"
  ts.WriteLine "            If tplAlertCount > 0 Then"
  ts.WriteLine "                If Len(reviewReason) > 0 Then reviewReason = reviewReason & "", """
  ts.WriteLine "                reviewReason = reviewReason & tplAlertCount & "" template alerts"""
  ts.WriteLine "            End If"
  ts.WriteLine "            If Len(result.Notes) > 0 Then"
  ts.WriteLine "                If Len(reviewReason) > 0 Then reviewReason = reviewReason & "", """
  ts.WriteLine "                reviewReason = reviewReason & result.Notes"
  ts.WriteLine "            End If"
  ts.WriteLine "            ' Fall through to show viewer with reason noted"
  ts.WriteLine "            result.StatusText = ""Needs review: "" & reviewReason & vbCrLf"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""showing viewer"""
  ts.WriteLine "    ' --- Step 5: Show viewer (worksheet-based, non-blocking) ---"
  ts.WriteLine "    Application.StatusBar = statusPrefix & ""showing viewer..."""
  ts.WriteLine ""
  ts.WriteLine "    ' Initialize viewer state"
  ts.WriteLine "    ViewerSheet.InitState mergedPortfolio, combinedRawText"
  ts.WriteLine "    ViewerSheet.SetSummaryRefs mergedSummaryRefs"
  ts.WriteLine "    ViewerSheet.SetViewerPortfolio mergedPortfolio"
  ts.WriteLine ""
  ts.WriteLine "    ' Pre-load QPR for viewer (reuse already-open workbooks)"
  ts.WriteLine "    ViewerSheet.ClearViewerQprWb"
  ts.WriteLine "    Dim qprMissing As Long"
  ts.WriteLine "    qprMissing = 0"
  ts.WriteLine "    For Each qprPathKey In pocOpenQprs.Keys"
  ts.WriteLine "        ViewerSheet.AddViewerQprWb CStr(qprPathKey), pocOpenQprs(qprPathKey)"
  ts.WriteLine "    Next qprPathKey"
  ts.WriteLine "    ' Check for any QPRs that weren't opened (file not found during analysis)"
  ts.WriteLine "    For Each qprPathKey In uniqueQprs.Keys"
  ts.WriteLine "        If Not pocOpenQprs.Exists(CStr(qprPathKey)) Then"
  ts.WriteLine "            If Dir(CStr(qprPathKey)) = """" Then"
  ts.WriteLine "                result.Notes = result.Notes & ""QPR file not found: "" & CStr(qprPathKey) & vbCrLf"
  ts.WriteLine "                qprMissing = qprMissing + 1"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next qprPathKey"
  ts.WriteLine "    If uniqueQprs.Count > 0 Then ViewerSheet.SetAutoAnalyze True"
  ts.WriteLine ""
  ts.WriteLine "    ' Pre-load template so viewer shows template analysis"
  ts.WriteLine "    If hasTemplates Then"
  ts.WriteLine "        For Each tplPathKey In uniqueTemplates.Keys"
  ts.WriteLine "            If Dir(CStr(tplPathKey)) <> """" Then"
  ts.WriteLine "                ViewerSheet.SetViewerTemplate CStr(tplPathKey), mergedPortfolio"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next tplPathKey"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Hide Add PDF / Add Excel buttons -- config sheet manages PDFs for batch clients"
  ts.WriteLine "    ViewerSheet.SetHideAddData True"
  ts.WriteLine ""
  ts.WriteLine "    ' Render viewer sheet (non-blocking)"
  ts.WriteLine "    ViewerSheet.RenderViewerSheet mergedPortfolio"
  ts.WriteLine ""
  ts.WriteLine "    ' In batch mode, pause for user review with MsgBox"
  ts.WriteLine "    MsgBox ""Review the Viewer sheet for "" & clientName & ""."", vbInformation, ""Review: "" & clientName"
  ts.WriteLine ""
  ts.WriteLine "    stepInfo = ""after viewer"""
  ts.WriteLine "    ' --- Step 6: After viewer -- check if viewer wrote QPR/template ---"
  ts.WriteLine "    Dim wroteQpr As Boolean"
  ts.WriteLine "    Dim wroteTpl As Boolean"
  ts.WriteLine "    wroteQpr = ViewerSheet.GetViewerApplied()"
  ts.WriteLine "    wroteTpl = ViewerSheet.GetTemplateApplied()"
  ts.WriteLine ""
  ts.WriteLine "    If wroteQpr Or wroteTpl Then"
  ts.WriteLine "        ViewerSheet.ClearViewerApplied"
  ts.WriteLine "        ViewerSheet.ClearAccumulatedState"
  ts.WriteLine ""
  ts.WriteLine "        result.Success = True"
  ts.WriteLine "        result.ViewerWroteQPR = wroteQpr"
  ts.WriteLine "        result.ViewerWroteTemplate = wroteTpl"
  ts.WriteLine "        Dim viewerParts As String"
  ts.WriteLine "        If wroteQpr Then viewerParts = ""QPR updated via viewer"""
  ts.WriteLine "        If wroteTpl Then"
  ts.WriteLine "            If Len(viewerParts) > 0 Then viewerParts = viewerParts & "", """
  ts.WriteLine "            viewerParts = viewerParts & ""template updated via viewer"""
  ts.WriteLine "        End If"
  ts.WriteLine "        result.StatusText = result.StatusText & viewerParts"
  ts.WriteLine "        ' Close any remaining open workbooks (viewer may have already closed some)"
  ts.WriteLine "        On Error Resume Next"
  ts.WriteLine "        For Each qprPathKey In pocOpenQprs.Keys"
  ts.WriteLine "            pocOpenQprs(qprPathKey).Close False"
  ts.WriteLine "        Next qprPathKey"
  ts.WriteLine "        Set pocOpenQprs = Nothing"
  ts.WriteLine "        For Each tplPathKey In pocOpenTpls.Keys"
  ts.WriteLine "            pocOpenTpls(tplPathKey).Close False"
  ts.WriteLine "        Next tplPathKey"
  ts.WriteLine "        Set pocOpenTpls = Nothing"
  ts.WriteLine "        On Error GoTo 0"
  ts.WriteLine "        ProcessOneClient = result"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ViewerSheet.ClearViewerApplied"
  ts.WriteLine "    ViewerSheet.ClearAccumulatedState"
  ts.WriteLine ""
  ts.WriteLine "    ' If user closed without applying, note it"
  ts.WriteLine "    result.Success = True"
  ts.WriteLine "    result.StatusText = result.StatusText & ""Viewer closed without applying"""
  ts.WriteLine "    ' Close any remaining open workbooks"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    For Each qprPathKey In pocOpenQprs.Keys"
  ts.WriteLine "        pocOpenQprs(qprPathKey).Close False"
  ts.WriteLine "    Next qprPathKey"
  ts.WriteLine "    Set pocOpenQprs = Nothing"
  ts.WriteLine "    For Each tplPathKey In pocOpenTpls.Keys"
  ts.WriteLine "        pocOpenTpls(tplPathKey).Close False"
  ts.WriteLine "    Next tplPathKey"
  ts.WriteLine "    Set pocOpenTpls = Nothing"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    ProcessOneClient = result"
  ts.WriteLine "    Exit Function"
  ts.WriteLine ""
  ts.WriteLine "ProcessError:"
  ts.WriteLine "    ' Capture error info before cleanup clears it"
  ts.WriteLine "    errNum = Err.Number"
  ts.WriteLine "    errSrc = Err.Source"
  ts.WriteLine "    errDesc = Err.Description & "" [step: "" & stepInfo & ""]"""
  ts.WriteLine "    ' Clean up any open workbooks before re-raising"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    PDFCrypto.ReleaseCrypto"
  ts.WriteLine "    ViewerSheet.ResetAllViewerState"
  ts.WriteLine "    If Not qprWb Is Nothing Then qprWb.Close False: Set qprWb = Nothing"
  ts.WriteLine "    If Not tplWb Is Nothing Then tplWb.Close False: Set tplWb = Nothing"
  ts.WriteLine "    If Not pocOpenQprs Is Nothing Then"
  ts.WriteLine "        For Each qprPathKey In pocOpenQprs.Keys"
  ts.WriteLine "            pocOpenQprs(qprPathKey).Close False"
  ts.WriteLine "        Next qprPathKey"
  ts.WriteLine "        Set pocOpenQprs = Nothing"
  ts.WriteLine "    End If"
  ts.WriteLine "    If Not pocOpenTpls Is Nothing Then"
  ts.WriteLine "        For Each tplPathKey In pocOpenTpls.Keys"
  ts.WriteLine "            pocOpenTpls(tplPathKey).Close False"
  ts.WriteLine "        Next tplPathKey"
  ts.WriteLine "        Set pocOpenTpls = Nothing"
  ts.WriteLine "    End If"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    Err.Raise errNum, errSrc, errDesc"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' 9. Batch processing from Config sheet"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "'"
  ts.WriteLine "' Config sheet layout:"
  ts.WriteLine "'   Row 1: Headers  (Client | PDF File Path | QPR Excel Path)"
  ts.WriteLine "'   Row 2+: Data"
  ts.WriteLine "'"
  ts.WriteLine "' Groups rows by Client column. For each client:"
  ts.WriteLine "'   1. Extracts all PDFs -> combined portfolio"
  ts.WriteLine "'   2. Shows viewer with unclassified securities"
  ts.WriteLine "'   3. User classifies, submits (or closes to skip)"
  ts.WriteLine "'   4. Writes each account to the corresponding QPR"
  ts.WriteLine "'   5. Moves to next client"
  ts.WriteLine "'"
  ts.WriteLine "' The ""Status"" column (D) is set to ""Done"" after each client finishes,"
  ts.WriteLine "' enabling resume if interrupted."
  ts.WriteLine ""
  ts.WriteLine "Public Sub EnsureConfigSheet()"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    Dim dupKey As String"
  ts.WriteLine "    Dim dupDict As Object"
  ts.WriteLine "    Dim dupList As String"
  ts.WriteLine "    Dim rngD As Range"
  ts.WriteLine "    Dim rngC As Range"
  ts.WriteLine ""
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine ""
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        Set ws = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.count))"
  ts.WriteLine "        ws.name = ""Config"""
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Set headers"
  ts.WriteLine "    ws.Cells(1, 1).Value = ""Client"""
  ts.WriteLine "    ws.Cells(1, 2).Value = ""PDF File Path"""
  ts.WriteLine "    ws.Cells(1, 3).Value = ""QPR / Template Path"""
  ts.WriteLine "    ws.Cells(1, 4).Value = ""Status"""
  ts.WriteLine "    ws.Cells(1, 5).Value = ""Status Detail"""
  ts.WriteLine "    ws.Cells(1, 6).Value = ""Notes"""
  ts.WriteLine ""
  ts.WriteLine "    For i = 1 To 6"
  ts.WriteLine "        ws.Cells(1, i).Font.Bold = True"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ws.Columns(""A"").ColumnWidth = 20"
  ts.WriteLine "    ws.Columns(""B"").ColumnWidth = 60"
  ts.WriteLine "    ws.Columns(""C"").ColumnWidth = 60"
  ts.WriteLine "    ws.Columns(""D"").ColumnWidth = 12"
  ts.WriteLine "    ws.Columns(""E"").ColumnWidth = 50"
  ts.WriteLine "    ws.Columns(""F"").ColumnWidth = 40"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Data Validation on column D (rows 2:500): dropdown ""Done,NeedsReview"" ---"
  ts.WriteLine "    Set rngD = ws.Range(""D2:D500"")"
  ts.WriteLine "    rngD.Validation.Delete"
  ts.WriteLine "    rngD.Validation.Add Type:=3, AlertStyle:=1, Operator:=1, _"
  ts.WriteLine "        Formula1:=""Done,NeedsReview"""
  ts.WriteLine "    rngD.Validation.IgnoreBlank = True"
  ts.WriteLine "    rngD.Validation.InCellDropdown = True"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Conditional Formatting on column C (rows 2:500): red fill when blank but A is not blank ---"
  ts.WriteLine "    Set rngC = ws.Range(""C2:C500"")"
  ts.WriteLine "    rngC.FormatConditions.Delete"
  ts.WriteLine "    rngC.FormatConditions.Add Type:=2, Formula1:=""=AND($A2<>"""""""",$C2="""""""")"""
  ts.WriteLine "    rngC.FormatConditions(rngC.FormatConditions.count).Interior.Color = RGB(255, 199, 206)"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Scan existing rows for duplicate Client + PDF File Path ---"
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp = -4162"
  ts.WriteLine "    If lastRow >= 2 Then"
  ts.WriteLine "        Set dupDict = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "        dupList = """""
  ts.WriteLine "        For r = 2 To lastRow"
  ts.WriteLine "            If Len(Trim$(CStr(ws.Cells(r, 1).Value & """"))) > 0 And Len(Trim$(CStr(ws.Cells(r, 2).Value & """"))) > 0 Then"
  ts.WriteLine "                dupKey = LCase$(Trim$(CStr(ws.Cells(r, 1).Value & """"))) & ""|"" & LCase$(Trim$(CStr(ws.Cells(r, 2).Value & """")))"
  ts.WriteLine "                If dupDict.Exists(dupKey) Then"
  ts.WriteLine "                    dupList = dupList & ""Row "" & dupDict(dupKey) & "" and Row "" & r & "": "" & _"
  ts.WriteLine "                              Trim$(CStr(ws.Cells(r, 1).Value & """")) & "" / "" & Dir(Trim$(CStr(ws.Cells(r, 2).Value & """"))) & vbCrLf"
  ts.WriteLine "                Else"
  ts.WriteLine "                    dupDict(dupKey) = r"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next r"
  ts.WriteLine ""
  ts.WriteLine "        If Len(dupList) > 0 Then"
  ts.WriteLine "            MsgBox ""Warning: duplicate Client + PDF File Path found:"" & vbCrLf & vbCrLf & dupList, _"
  ts.WriteLine "                   vbExclamation, ""Config Sheet - Duplicates"""
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Auto-import from CSV if the file exists and sheet is empty ---"
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        If Dir(ConfigCsvPath()) <> """" Then"
  ts.WriteLine "            ImportConfigCsv"
  ts.WriteLine "            Exit Sub  ' ImportConfigCsv already shows its own message"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Public Sub RunBatchFromConfig()"
  ts.WriteLine "    ' --- Variable declarations ---"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim rows() As ConfigRow"
  ts.WriteLine "    Dim rowCount As Long"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    Dim clientName As String"
  ts.WriteLine "    Dim pdfPath As String"
  ts.WriteLine "    Dim qprPath As String"
  ts.WriteLine "    Dim clients() As String"
  ts.WriteLine "    Dim clientCount As Long"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    Dim j As Long"
  ts.WriteLine "    Dim found As Boolean"
  ts.WriteLine "    Dim startClient As Long"
  ts.WriteLine "    Dim allDone As Boolean"
  ts.WriteLine "    Dim resumeMsg As String"
  ts.WriteLine "    Dim ci As Long"
  ts.WriteLine "    Dim totalProcessed As Long"
  ts.WriteLine "    Dim clientPdfs() As String"
  ts.WriteLine "    Dim clientQprs() As String"
  ts.WriteLine "    Dim clientRowNums() As Long"
  ts.WriteLine "    Dim clientRowCount As Long"
  ts.WriteLine "    Dim pi As Long"
  ts.WriteLine "    Dim batchSummary As String"
  ts.WriteLine "    Dim validationErrors As String"
  ts.WriteLine "    Dim vi As Long"
  ts.WriteLine "    Dim clientErrorCount As Long"
  ts.WriteLine "    Dim summaryMsg As String"
  ts.WriteLine "    Dim errMsg As String"
  ts.WriteLine "    Dim logFile As String"
  ts.WriteLine "    Dim clientResult As ProcessClientResult"
  ts.WriteLine ""
  ts.WriteLine "    ' Create log file"
  ts.WriteLine "    logFile = ThisWorkbook.Path & ""\BatchLog_"" & Format$(Now, ""yyyymmdd_hhmmss"") & "".txt"""
  ts.WriteLine ""
  ts.WriteLine "    ' Reset backup tracking for this batch run"
  ts.WriteLine "    QPRWriter.ClearBackupTracking"
  ts.WriteLine ""
  ts.WriteLine "    ' Read config sheet"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine ""
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        MsgBox ""No 'Config' sheet found. Run EnsureConfigSheet first."", vbExclamation, ""Batch Processing"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Read rows"
  ts.WriteLine "    rowCount = 0"
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp = -4162"
  ts.WriteLine ""
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        MsgBox ""Config sheet is empty (no data rows)."", vbExclamation, ""Batch Processing"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ReDim rows(1 To lastRow - 1)"
  ts.WriteLine ""
  ts.WriteLine "    For r = 2 To lastRow"
  ts.WriteLine "        clientName = Trim$(CStr(ws.Cells(r, 1).Value & """"))"
  ts.WriteLine "        pdfPath = Trim$(CStr(ws.Cells(r, 2).Value & """"))"
  ts.WriteLine "        qprPath = Trim$(CStr(ws.Cells(r, 3).Value & """"))"
  ts.WriteLine ""
  ts.WriteLine "        If Len(clientName) = 0 Or Len(pdfPath) = 0 Then GoTo NextConfigRow"
  ts.WriteLine ""
  ts.WriteLine "        rowCount = rowCount + 1"
  ts.WriteLine "        rows(rowCount).Client = clientName"
  ts.WriteLine "        rows(rowCount).PdfPath = pdfPath"
  ts.WriteLine "        rows(rowCount).QprPath = qprPath"
  ts.WriteLine "        rows(rowCount).RowNum = r"
  ts.WriteLine "NextConfigRow:"
  ts.WriteLine "    Next r"
  ts.WriteLine ""
  ts.WriteLine "    If rowCount = 0 Then"
  ts.WriteLine "        MsgBox ""No valid config rows found."", vbExclamation, ""Batch Processing"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Upfront validation: check all files exist and QPR paths are set ---"
  ts.WriteLine "    validationErrors = """""
  ts.WriteLine "    For vi = 1 To rowCount"
  ts.WriteLine "        If CStr(ws.Cells(rows(vi).RowNum, 4).Value & """") = ""Done"" Then GoTo NextValidation"
  ts.WriteLine "        If Len(rows(vi).QprPath) = 0 Then"
  ts.WriteLine "            validationErrors = validationErrors & ""Row "" & rows(vi).RowNum & "" ("" & rows(vi).Client & ""): Output path is empty"" & vbCrLf"
  ts.WriteLine "        ElseIf Dir(rows(vi).QprPath) = """" Then"
  ts.WriteLine "            validationErrors = validationErrors & ""Row "" & rows(vi).RowNum & "" ("" & rows(vi).Client & ""): QPR not found: "" & rows(vi).QprPath & vbCrLf"
  ts.WriteLine "        End If"
  ts.WriteLine "        If Dir(rows(vi).PdfPath) = """" Then"
  ts.WriteLine "            validationErrors = validationErrors & ""Row "" & rows(vi).RowNum & "" ("" & rows(vi).Client & ""): PDF not found: "" & rows(vi).PdfPath & vbCrLf"
  ts.WriteLine "        End If"
  ts.WriteLine "NextValidation:"
  ts.WriteLine "    Next vi"
  ts.WriteLine ""
  ts.WriteLine "    If Len(validationErrors) > 0 Then"
  ts.WriteLine "        MsgBox ""Config validation failed -- fix these before running:"" & vbCrLf & vbCrLf & _"
  ts.WriteLine "               validationErrors, vbCritical, ""Batch Processing"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Get distinct clients in order"
  ts.WriteLine "    clientCount = 0"
  ts.WriteLine "    ReDim clients(1 To rowCount)"
  ts.WriteLine ""
  ts.WriteLine "    For i = 1 To rowCount"
  ts.WriteLine "        found = False"
  ts.WriteLine "        For j = 1 To clientCount"
  ts.WriteLine "            If clients(j) = rows(i).Client Then"
  ts.WriteLine "                found = True"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If Not found Then"
  ts.WriteLine "            clientCount = clientCount + 1"
  ts.WriteLine "            clients(clientCount) = rows(i).Client"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    WriteLog logFile, ""Batch started: "" & clientCount & "" clients"""
  ts.WriteLine ""
  ts.WriteLine "    ' Check for resume: skip already-processed clients"
  ts.WriteLine "    startClient = 1"
  ts.WriteLine "    For i = 1 To clientCount"
  ts.WriteLine "        allDone = True"
  ts.WriteLine "        For j = 1 To rowCount"
  ts.WriteLine "            If rows(j).Client = clients(i) Then"
  ts.WriteLine "                If CStr(ws.Cells(rows(j).RowNum, 4).Value & """") <> ""Done"" Then"
  ts.WriteLine "                    allDone = False"
  ts.WriteLine "                    Exit For"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If Not allDone Then"
  ts.WriteLine "            startClient = i"
  ts.WriteLine "            Exit For"
  ts.WriteLine "        End If"
  ts.WriteLine "        If i = clientCount And allDone Then"
  ts.WriteLine "            MsgBox ""All "" & clientCount & "" clients already processed."", vbInformation, ""Batch Processing"""
  ts.WriteLine "            Exit Sub"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    If startClient > 1 Then"
  ts.WriteLine "        resumeMsg = ""Resuming from client "" & startClient & "" of "" & clientCount & _"
  ts.WriteLine "                    "" ("" & clients(startClient) & "")."" & vbCrLf & _"
  ts.WriteLine "                    (startClient - 1) & "" client(s) already processed."""
  ts.WriteLine "        MsgBox resumeMsg, vbInformation, ""Batch Processing - Resume"""
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Process each client"
  ts.WriteLine "    totalProcessed = startClient - 1"
  ts.WriteLine "    clientErrorCount = 0"
  ts.WriteLine "    batchSummary = """""
  ts.WriteLine ""
  ts.WriteLine "    For ci = startClient To clientCount"
  ts.WriteLine "        On Error GoTo ClientError"
  ts.WriteLine ""
  ts.WriteLine "        ' Skip clients already marked Done"
  ts.WriteLine "        allDone = True"
  ts.WriteLine "        For j = 1 To rowCount"
  ts.WriteLine "            If rows(j).Client = clients(ci) Then"
  ts.WriteLine "                If CStr(ws.Cells(rows(j).RowNum, 4).Value & """") <> ""Done"" Then"
  ts.WriteLine "                    allDone = False"
  ts.WriteLine "                    Exit For"
  ts.WriteLine "                End If"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine "        If allDone Then GoTo NextBatchClient"
  ts.WriteLine ""
  ts.WriteLine "        Application.StatusBar = ""Client "" & ci & "" of "" & clientCount & "": "" & clients(ci) & ""..."""
  ts.WriteLine "        WriteLog logFile, ""Processing client: "" & clients(ci)"
  ts.WriteLine ""
  ts.WriteLine "        ' Collect PDFs and QPRs for this client"
  ts.WriteLine "        clientRowCount = 0"
  ts.WriteLine "        For j = 1 To rowCount"
  ts.WriteLine "            If rows(j).Client = clients(ci) Then"
  ts.WriteLine "                clientRowCount = clientRowCount + 1"
  ts.WriteLine "                ReDim Preserve clientPdfs(1 To clientRowCount)"
  ts.WriteLine "                ReDim Preserve clientQprs(1 To clientRowCount)"
  ts.WriteLine "                ReDim Preserve clientRowNums(1 To clientRowCount)"
  ts.WriteLine "                clientPdfs(clientRowCount) = rows(j).PdfPath"
  ts.WriteLine "                clientQprs(clientRowCount) = rows(j).QprPath"
  ts.WriteLine "                clientRowNums(clientRowCount) = rows(j).RowNum"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next j"
  ts.WriteLine ""
  ts.WriteLine "        ' Process this client (interactive -- no auto-pass)"
  ts.WriteLine "        clientResult = ProcessOneClient(clients(ci), clientPdfs, clientQprs, _"
  ts.WriteLine "            clientRowCount, False, ""Client "" & ci & ""/"" & clientCount & "" ("" & clients(ci) & ""): "")"
  ts.WriteLine ""
  ts.WriteLine "        ' Mark rows Done, write notes, and log result"
  ts.WriteLine "        For pi = 1 To clientRowCount"
  ts.WriteLine "            ws.Cells(clientRowNums(pi), 4).Value = ""Done"""
  ts.WriteLine "            ws.Cells(clientRowNums(pi), 5).Value = clientResult.Notes"
  ts.WriteLine "        Next pi"
  ts.WriteLine "        ThisWorkbook.Save"
  ts.WriteLine "        totalProcessed = totalProcessed + 1"
  ts.WriteLine "        batchSummary = batchSummary & clients(ci) & "": "" & clientResult.StatusText & vbCrLf"
  ts.WriteLine "        WriteLog logFile, ""  "" & clientResult.StatusText"
  ts.WriteLine "        WriteLog logFile, ""  Complete"""
  ts.WriteLine "        GoTo NextBatchClient"
  ts.WriteLine ""
  ts.WriteLine "ClientError:"
  ts.WriteLine "        ' Per-client error: log and continue with next client"
  ts.WriteLine "        clientErrorCount = clientErrorCount + 1"
  ts.WriteLine "        errMsg = Err.Description"
  ts.WriteLine "        batchSummary = batchSummary & clients(ci) & "": ERROR -- "" & errMsg & vbCrLf"
  ts.WriteLine "        WriteLog logFile, ""  ERROR: "" & errMsg"
  ts.WriteLine "        On Error Resume Next"
  ts.WriteLine "        PDFCrypto.ReleaseCrypto"
  ts.WriteLine "        ViewerSheet.ResetAllViewerState"
  ts.WriteLine "        On Error GoTo 0"
  ts.WriteLine "        Err.Clear"
  ts.WriteLine ""
  ts.WriteLine "NextBatchClient:"
  ts.WriteLine "    Next ci"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine ""
  ts.WriteLine "    ' Write final summary to log"
  ts.WriteLine "    WriteLog logFile, ""Batch complete: "" & totalProcessed & "" processed, "" & clientErrorCount & "" errors"""
  ts.WriteLine ""
  ts.WriteLine "    ' Batch summary"
  ts.WriteLine "    summaryMsg = ""Batch processing complete!"" & vbCrLf & _"
  ts.WriteLine "                 totalProcessed & "" of "" & clientCount & "" clients processed."""
  ts.WriteLine "    If clientErrorCount > 0 Then"
  ts.WriteLine "        summaryMsg = summaryMsg & vbCrLf & clientErrorCount & "" client(s) had errors."""
  ts.WriteLine "    End If"
  ts.WriteLine "    summaryMsg = summaryMsg & vbCrLf & vbCrLf & ""Log file: "" & logFile"
  ts.WriteLine "    If Len(batchSummary) > 0 Then"
  ts.WriteLine "        If Len(batchSummary) > 1000 Then batchSummary = Left$(batchSummary, 1000) & vbCrLf & ""... (truncated)"""
  ts.WriteLine "        summaryMsg = summaryMsg & vbCrLf & vbCrLf & ""Details:"" & vbCrLf & batchSummary"
  ts.WriteLine "    End If"
  ts.WriteLine "    MsgBox summaryMsg, IIf(clientErrorCount > 0, vbExclamation, vbInformation), ""Batch Processing"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Client picker: numbered InputBox list"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function ShowClientPicker(ws As Worksheet) As String"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    Dim clientName As String"
  ts.WriteLine "    Dim clientDict As Object"
  ts.WriteLine "    Dim clientList() As String"
  ts.WriteLine "    Dim clientCount As Long"
  ts.WriteLine "    Dim status As String"
  ts.WriteLine "    Dim prompt As String"
  ts.WriteLine "    Dim ci As Long"
  ts.WriteLine "    Dim userInput As String"
  ts.WriteLine "    Dim selectedIdx As Long"
  ts.WriteLine ""
  ts.WriteLine "    ShowClientPicker = """""
  ts.WriteLine ""
  ts.WriteLine "    ' Build unique client list with status"
  ts.WriteLine "    Set clientDict = CreateObject(""Scripting.Dictionary"")"
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp"
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        MsgBox ""Config sheet has no data rows."", vbExclamation, ""Run Single Client"""
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    clientCount = 0"
  ts.WriteLine "    For r = 2 To lastRow"
  ts.WriteLine "        clientName = Trim$(CStr(ws.Cells(r, 1).Value & """"))"
  ts.WriteLine "        If Len(clientName) > 0 Then"
  ts.WriteLine "            If Not clientDict.Exists(clientName) Then"
  ts.WriteLine "                clientDict(clientName) = 1"
  ts.WriteLine "                clientCount = clientCount + 1"
  ts.WriteLine "                ReDim Preserve clientList(1 To clientCount)"
  ts.WriteLine "                clientList(clientCount) = clientName"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next r"
  ts.WriteLine ""
  ts.WriteLine "    If clientCount = 0 Then"
  ts.WriteLine "        MsgBox ""No clients found in Config sheet."", vbExclamation, ""Run Single Client"""
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Build numbered prompt"
  ts.WriteLine "    prompt = ""Select a client to process:"" & vbLf & vbLf"
  ts.WriteLine "    For ci = 1 To clientCount"
  ts.WriteLine "        status = """""
  ts.WriteLine "        ' Find status for this client (first matching row)"
  ts.WriteLine "        For r = 2 To lastRow"
  ts.WriteLine "            If LCase$(Trim$(CStr(ws.Cells(r, 1).Value & """"))) = LCase$(clientList(ci)) Then"
  ts.WriteLine "                status = Trim$(CStr(ws.Cells(r, 4).Value & """"))"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next r"
  ts.WriteLine "        prompt = prompt & ci & "".  "" & clientList(ci)"
  ts.WriteLine "        If Len(status) > 0 Then prompt = prompt & ""  ["" & status & ""]"""
  ts.WriteLine "        prompt = prompt & vbLf"
  ts.WriteLine "    Next ci"
  ts.WriteLine "    prompt = prompt & vbLf & ""Enter number (1-"" & clientCount & ""):"""
  ts.WriteLine ""
  ts.WriteLine "    userInput = InputBox(prompt, ""Run Single Client"", ""1"")"
  ts.WriteLine "    If Len(userInput) = 0 Then Exit Function  ' cancelled"
  ts.WriteLine ""
  ts.WriteLine "    ' Validate input"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    selectedIdx = CLng(userInput)"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    If selectedIdx < 1 Or selectedIdx > clientCount Then"
  ts.WriteLine "        MsgBox ""Invalid selection: "" & userInput, vbExclamation, ""Run Single Client"""
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ShowClientPicker = clientList(selectedIdx)"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Single-client re-run: process one client by name from Config sheet"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Public Sub RunSingleClient()"
  ts.WriteLine "    ' Reset all viewer state from any previous session"
  ts.WriteLine "    ViewerSheet.ResetAllViewerState"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Variable declarations ---"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim inputName As String"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    Dim clientRowCount As Long"
  ts.WriteLine "    Dim clientPdfs() As String"
  ts.WriteLine "    Dim clientQprs() As String"
  ts.WriteLine "    Dim clientRowNums() As Long"
  ts.WriteLine "    Dim cellClient As String"
  ts.WriteLine "    Dim pi As Long"
  ts.WriteLine "    Dim errMsg As String"
  ts.WriteLine "    Dim clientResult As ProcessClientResult"
  ts.WriteLine ""
  ts.WriteLine "    ' Read config sheet"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine ""
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        MsgBox ""No 'Config' sheet found. Run EnsureConfigSheet first."", vbExclamation, ""Run Single Client"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Show client picker dropdown"
  ts.WriteLine "    inputName = ShowClientPicker(ws)"
  ts.WriteLine "    If Len(inputName) = 0 Then Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "    ' Find matching rows (case-insensitive)"
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp"
  ts.WriteLine "    clientRowCount = 0"
  ts.WriteLine ""
  ts.WriteLine "    For r = 2 To lastRow"
  ts.WriteLine "        cellClient = Trim$(CStr(ws.Cells(r, 1).Value & """"))"
  ts.WriteLine "        If LCase$(cellClient) = LCase$(inputName) Then"
  ts.WriteLine "            If Len(Trim$(CStr(ws.Cells(r, 2).Value & """"))) > 0 Then"
  ts.WriteLine "                clientRowCount = clientRowCount + 1"
  ts.WriteLine "                ReDim Preserve clientPdfs(1 To clientRowCount)"
  ts.WriteLine "                ReDim Preserve clientQprs(1 To clientRowCount)"
  ts.WriteLine "                ReDim Preserve clientRowNums(1 To clientRowCount)"
  ts.WriteLine "                clientPdfs(clientRowCount) = Trim$(CStr(ws.Cells(r, 2).Value & """"))"
  ts.WriteLine "                clientQprs(clientRowCount) = Trim$(CStr(ws.Cells(r, 3).Value & """"))"
  ts.WriteLine "                clientRowNums(clientRowCount) = r"
  ts.WriteLine "            End If"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next r"
  ts.WriteLine ""
  ts.WriteLine "    If clientRowCount = 0 Then"
  ts.WriteLine "        MsgBox ""No rows found for client '"" & inputName & ""'."", vbExclamation, ""Run Single Client"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    On Error GoTo SingleClientError"
  ts.WriteLine ""
  ts.WriteLine "    ' Reset backup tracking"
  ts.WriteLine "    QPRWriter.ClearBackupTracking"
  ts.WriteLine ""
  ts.WriteLine "    ' Process client with auto-pass enabled (shows viewer only if warnings)"
  ts.WriteLine "    clientResult = ProcessOneClient(inputName, clientPdfs, clientQprs, _"
  ts.WriteLine "        clientRowCount, True, ""Processing "" & inputName & "": "")"
  ts.WriteLine ""
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine ""
  ts.WriteLine "    ' If user closed viewer without submitting, don't mark Done"
  ts.WriteLine "    If Not clientResult.AutoCompleted And Not clientResult.ViewerWroteQPR _"
  ts.WriteLine "       And InStr(1, clientResult.StatusText, ""Viewer closed without submitting"") > 0 Then"
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Mark all client rows as Done and write notes"
  ts.WriteLine "    For pi = 1 To clientRowCount"
  ts.WriteLine "        ws.Cells(clientRowNums(pi), 4).Value = ""Done"""
  ts.WriteLine "        ws.Cells(clientRowNums(pi), 5).Value = clientResult.Notes"
  ts.WriteLine "    Next pi"
  ts.WriteLine "    ThisWorkbook.Save"
  ts.WriteLine ""
  ts.WriteLine "    If clientResult.AutoCompleted Then"
  ts.WriteLine "        Dim autoMsg As String"
  ts.WriteLine "        autoMsg = inputName & "": auto-completed"""
  ts.WriteLine "        If clientResult.AutoCompletedTemplate Then autoMsg = autoMsg & "" (template auto-completed)"""
  ts.WriteLine "        MsgBox autoMsg & ""."" & vbCrLf & vbCrLf & _"
  ts.WriteLine "               clientResult.StatusText, vbInformation, ""Run Single Client"""
  ts.WriteLine "    ElseIf clientResult.ViewerWroteQPR Or clientResult.ViewerWroteTemplate Then"
  ts.WriteLine "        Dim viewerMsg As String"
  ts.WriteLine "        viewerMsg = inputName & "": """
  ts.WriteLine "        If clientResult.ViewerWroteQPR And clientResult.ViewerWroteTemplate Then"
  ts.WriteLine "            viewerMsg = viewerMsg & ""QPR and template updated via viewer."""
  ts.WriteLine "        ElseIf clientResult.ViewerWroteTemplate Then"
  ts.WriteLine "            viewerMsg = viewerMsg & ""template updated via viewer."""
  ts.WriteLine "        Else"
  ts.WriteLine "            viewerMsg = viewerMsg & ""QPR updated via viewer."""
  ts.WriteLine "        End If"
  ts.WriteLine "        MsgBox viewerMsg, vbInformation, ""Run Single Client"""
  ts.WriteLine "    End If"
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "SingleClientError:"
  ts.WriteLine "    errMsg = Err.Description"
  ts.WriteLine "    If Len(errMsg) = 0 Then errMsg = ""Unknown error (Err "" & Err.Number & "")"""
  ts.WriteLine "    Application.StatusBar = """""
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    PDFCrypto.ReleaseCrypto"
  ts.WriteLine "    ViewerSheet.ResetAllViewerState"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    MsgBox ""Error processing "" & inputName & "":"" & vbCrLf & vbCrLf & errMsg, vbCritical, ""Run Single Client"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Auto batch: process clients that don't need user input, skip the rest"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Public Sub RunBatchAuto()"
  ts.WriteLine "    ' Two-pass batch: first processes all clients that need no user interaction"
  ts.WriteLine "    ' (no unclassified securities), marks the rest ""NeedsReview"", then offers"
  ts.WriteLine "    ' to run the interactive viewer for the remaining clients."
  ts.WriteLine ""
  ts.WriteLine "    ' --- Variable declarations ---"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim rows() As ConfigRow"
  ts.WriteLine "    Dim rowCount As Long"
  ts.WriteLine "    Dim lastRow As Long"
  ts.WriteLine "    Dim r As Long"
  ts.WriteLine "    Dim clientName As String"
  ts.WriteLine "    Dim pdfPath As String"
  ts.WriteLine "    Dim qprPath As String"
  ts.WriteLine "    Dim clients() As String"
  ts.WriteLine "    Dim clientCount As Long"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    Dim j As Long"
  ts.WriteLine "    Dim found As Boolean"
  ts.WriteLine "    Dim ci As Long"
  ts.WriteLine "    Dim autoProcessed As Long"
  ts.WriteLine "    Dim needsReviewCount As Long"
  ts.WriteLine "    Dim clientPdfs() As String"
  ts.WriteLine "    Dim clientQprs() As String"
  ts.WriteLine "    Dim clientRowNums() As Long"
  ts.WriteLine "    Dim clientRowCount As Long"
  ts.WriteLine "    Dim mergedPortfolio As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim pdfPortfolios() As UBSSummary.PortfolioExtraction"
  ts.WriteLine "    Dim pi As Long"
  ts.WriteLine "    Dim rawText As String"
  ts.WriteLine "    Dim unclassified() As QPRWriter.UnclassifiedSecurity"
  ts.WriteLine "    Dim unclassCount As Long"
  ts.WriteLine "    Dim qprWb As Workbook"
  ts.WriteLine "    Dim ai As Long"
  ts.WriteLine "    Dim uniqueQprs As Object"
  ts.WriteLine "    Dim qprPathKey As Variant"
  ts.WriteLine "    Dim batchSummary As String"
  ts.WriteLine "    Dim writeResult As String"
  ts.WriteLine "    Dim validationErrors As String"
  ts.WriteLine "    Dim vi As Long"
  ts.WriteLine "    Dim pdfSummaryRefs As UBSSummary.SummaryReferences"
  ts.WriteLine "    Dim allDone As Boolean"
  ts.WriteLine "    Dim needsReviewClients As String"
  ts.WriteLine "    Dim status As String"
  ts.WriteLine "    Dim summaryMsg As String"
  ts.WriteLine "    Dim errMsg As String"
  ts.WriteLine "    Dim clientErrorCount As Long"
  ts.WriteLine "    Dim failedChecks As Long"
  ts.WriteLine "    Dim checkIdx As Long"
  ts.WriteLine "    Dim reviewReason As String"
  ts.WriteLine "    Dim logFile As String"
  ts.WriteLine "    Dim analysis As QPRWriter.QprAnalysis"
  ts.WriteLine "    Dim notes As String"
  ts.WriteLine "    Dim allMappedAccts2 As Object"
  ts.WriteLine "    Dim mappings2() As QPRWriter.MappingRow"
  ts.WriteLine "    Dim mi2 As Long"
  ts.WriteLine "    Dim acctIdx2 As Long"
  ts.WriteLine "    Dim globalUncovered2 As Long"
  ts.WriteLine ""
  ts.WriteLine "    ' Create log file"
  ts.WriteLine "    logFile = ThisWorkbook.Path & ""\BatchLog_"" & Format$(Now, ""yyyymmdd_hhmmss"") & "".txt"""
  ts.WriteLine ""
  ts.WriteLine "    ' Reset backup tracking for this batch run"
  ts.WriteLine "    QPRWriter.ClearBackupTracking"
  ts.WriteLine ""
  ts.WriteLine "    ' Read config sheet"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(""Config"")"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine ""
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        MsgBox ""No 'Config' sheet found. Run EnsureConfigSheet first."", vbExclamation, ""Auto Batch"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Read rows"
  ts.WriteLine "    rowCount = 0"
  ts.WriteLine "    lastRow = ws.Cells(ws.rows.count, 1).End(-4162).Row  ' xlUp = -4162"
  ts.WriteLine ""
  ts.WriteLine "    If lastRow < 2 Then"
  ts.WriteLine "        MsgBox ""Config sheet is empty (no data rows)."", vbExclamation, ""Auto Batch"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ReDim rows(1 To lastRow - 1)"
  ts.WriteLine ""
  ts.WriteLine "    For r = 2 To lastRow"
  ts.WriteLine "        clientName = Trim$(CStr(ws.Cells(r, 1).Value & """"))"
  ts.WriteLine "        pdfPath = Trim$(CStr(ws.Cells(r, 2).Value & """"))"
  ts.WriteLine "        qprPath = Trim$(CStr(ws.Cells(r, 3).Value & """"))"
  ts.WriteLine ""
  ts.WriteLine "        If Len(clientName) = 0 Or Len(pdfPath) = 0 Then GoTo NextAutoRow"
  ts.WriteLine "        rowCount = rowCount + 1"
  ts.WriteLine "        rows(rowCount).Client = clientName"
  ts.WriteLine "        rows(rowCount).PdfPath = pdfPath"
  ts.WriteLine "        rows(rowCount).QprPath = qprPath"
  ts.WriteLine "        rows(rowCount).RowNum = r"
  ts.WriteLine "NextAutoRow:"
  ts.WriteLine "    Next r"
  ts.WriteLine ""
  ts.WriteLine "    If rowCount = 0 Then"
  ts.WriteLine "        MsgBox ""No valid config rows found."", vbExclamation, ""Auto Batch"""
  ts.WriteLine "        Exit Sub"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Upfront validation: check all files exist and QPR paths are set"
  ts.WriteLine "    validationErrors = """""
  ts.WriteLine "    For vi = 1 To rowCount"
  ts.WriteLine "        status = CStr(ws.Cells(rows(vi).RowNum, 4).Value & """")"
