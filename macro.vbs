ts.WriteLine ""
ts.WriteLine "Public Function BuildCoverageSection(ByRef coverage As UBSSummary.CoverageResult, ByVal hasCoverage As Boolean) As String"
ts.WriteLine "    If Not hasCoverage Then"
ts.WriteLine "        BuildCoverageSection = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim h As String"
ts.WriteLine "    Dim i As Long"
ts.WriteLine ""
ts.WriteLine "    If coverage.AllPresent Then"
ts.WriteLine "        ' All accounts present -- green banner"
ts.WriteLine "        h = ""<div class=""""coverage-pass"""">"" & vbLf"
ts.WriteLine "        h = h & ""<strong style=""""color:#155724;font-size:14px;"""">&#10003; Portfolio Coverage: All "" & _"
ts.WriteLine "                coverage.TotalSummaryAccounts & "" accounts from summary are present.</strong>"" & vbLf"
ts.WriteLine "    Else"
ts.WriteLine "        ' Missing accounts -- yellow warning banner"
ts.WriteLine "        h = ""<div class=""""coverage-fail"""">"" & vbLf"
ts.WriteLine "        h = h & ""<strong style=""""color:#856404;font-size:14px;"""">&#9888; Portfolio Coverage: "" & _"
ts.WriteLine "                (coverage.TotalSummaryAccounts - coverage.MissingAccountCount) & "" of "" & _"
ts.WriteLine "                coverage.TotalSummaryAccounts & "" accounts extracted. "" & _"
ts.WriteLine "                coverage.MissingAccountCount & "" missing:</strong>"" & vbLf"
ts.WriteLine "        h = h & ""<div style=""""margin-top:8px;"""">"" & vbLf"
ts.WriteLine "        h = h & ""<table class=""""qpr-table""""><thead><tr><th>Account</th><th>Name</th>"" & _"
ts.WriteLine "                ""<th class=""""num"""">Closing Value</th></tr></thead><tbody>"" & vbLf"
ts.WriteLine "        For i = 0 To coverage.MissingAccountCount - 1"
ts.WriteLine "            h = h & ""<tr><td>"" & Esc(coverage.MissingAccounts(i).AccountNumber) & ""</td>"" & _"
ts.WriteLine "                    ""<td>"" & Esc(coverage.MissingAccounts(i).FriendlyName) & ""</td>"" & _"
ts.WriteLine "                    ""<td class=""""num"""">"" & Fmt(coverage.MissingAccounts(i).ClosingValue) & ""</td></tr>"" & vbLf"
ts.WriteLine "        Next i"
ts.WriteLine "        h = h & ""</tbody></table></div>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Opening/closing totals checks"
ts.WriteLine "    If Not coverage.AllPresent Then"
ts.WriteLine "        h = h & ""<div style=""""margin-top:8px;font-size:12px;color:#664d03;"""">"""
ts.WriteLine "        h = h & ""Opening total: summary "" & Fmt(coverage.TotalOpeningCheck.Expected) & _"
ts.WriteLine "                "" vs extracted "" & Fmt(coverage.TotalOpeningCheck.Actual) & "" "" & _"
ts.WriteLine "                Badge(coverage.TotalOpeningCheck.Pass) & ""<br>"""
ts.WriteLine "        h = h & ""Closing total: summary "" & Fmt(coverage.TotalClosingCheck.Expected) & _"
ts.WriteLine "                "" vs extracted "" & Fmt(coverage.TotalClosingCheck.Actual) & "" "" & _"
ts.WriteLine "                Badge(coverage.TotalClosingCheck.Pass)"
ts.WriteLine "        h = h & ""</div>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    h = h & ""</div>"" & vbLf"
ts.WriteLine "    BuildCoverageSection = h"
ts.WriteLine "End Function"
