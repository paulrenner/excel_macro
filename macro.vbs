ts.WriteLine "    h = h & ""<tr><td>Taxable Dividends</td><td class=""""num"""">"" & Fmt(inc.TaxableDividendsMonth) & ""</td></tr>"" & vbLf"
ts.WriteLine "    If inc.TaxExemptDividendsMonth <> 0 Then"
ts.WriteLine "        h = h & ""<tr><td>Tax-Exempt Dividends</td><td class=""""num"""">"" & Fmt(inc.TaxExemptDividendsMonth) & ""</td></tr>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine "    h = h & ""<tr><td>Taxable Interest</td><td class=""""num"""">"" & Fmt(inc.TaxableInterestMonth) & ""</td></tr>"" & vbLf"
ts.WriteLine "    If inc.TaxExemptInterestMonth <> 0 Then"
ts.WriteLine "        h = h & ""<tr><td>Tax-Exempt Interest</td><td class=""""num"""">"" & Fmt(inc.TaxExemptInterestMonth) & ""</td></tr>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine "    If inc.MiscellaneousMonth <> 0 Then"
ts.WriteLine "        h = h & ""<tr><td>Miscellaneous</td><td class=""""num"""">"" & Fmt(inc.MiscellaneousMonth) & ""</td></tr>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine "    h = h & ""<tr style=""""font-weight:600;""""><td>Total</td><td class=""""num"""">"" & Fmt(inc.TotalMonth) & ""</td></tr>"" & vbLf"
ts.WriteLine "    h = h & ""</tbody></table></div></div></div>"" & vbLf"
ts.WriteLine "    BuildIncomeSection = h"
ts.WriteLine "End Function"
ts.WriteLine ""
