  ts.WriteLine "Public Sub RenderViewerSheet(ByRef portfolio As UBSSummary.PortfolioExtraction)"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Dim r As Long  ' current row"
  ts.WriteLine ""
  ts.WriteLine "    InitColors"
  ts.WriteLine ""
  ts.WriteLine "    Application.ScreenUpdating = False"
  ts.WriteLine "    Application.Calculation = xlCalculationManual"
  ts.WriteLine ""
  ts.WriteLine "    On Error GoTo RenderError"
  ts.WriteLine ""
  ts.WriteLine "    DeleteViewerSheet"
  ts.WriteLine "    Set ws = GetOrCreateViewerSheet()"
  ts.WriteLine "    ws.Outline.SummaryRow = xlAbove"
  ts.WriteLine "    ws.Cells.Interior.Color = vbWhite"
  ts.WriteLine ""
  ts.WriteLine "    mPortfolio = portfolio"
  ts.WriteLine ""
  ts.WriteLine "    r = 1"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Title ---"
  ts.WriteLine "    ws.Cells(r, 1).Value = ""UBS Statement Extraction"""
  ts.WriteLine "    ws.Cells(r, 1).Font.Size = 16"
  ts.WriteLine "    ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "    ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Merge"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Status line ---"
  ts.WriteLine "    Dim statusText As String"
  ts.WriteLine "    statusText = portfolio.AccountCount & "" account(s)"""
  ts.WriteLine "    If portfolio.LoanAccountCount > 0 Then"
  ts.WriteLine "        statusText = statusText & "", "" & portfolio.LoanAccountCount & "" loan account(s)"""
  ts.WriteLine "    End If"
  ts.WriteLine "    ws.Cells(r, 1).Value = statusText"
  ts.WriteLine "    ws.Cells(r, 1).Font.Italic = True"
  ts.WriteLine "    ws.Cells(r, 1).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "    ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Merge"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Buttons ---"
  ts.WriteLine "    r = AddButtons(ws, r)"
  ts.WriteLine "    r = r + 1  ' blank row"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Coverage check ---"
  ts.WriteLine "    If mHasCoverage Then"
  ts.WriteLine "        r = RenderCoverageCheck(ws, r, portfolio)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Reserve a row for success status banner (filled by Apply handlers)"
  ts.WriteLine "    mStatusRow = r"
  ts.WriteLine "    r = r + 2  ' +1 for status row, +1 for spacer"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Portfolio summary (collapsible) ---"
  ts.WriteLine "    If portfolio.AccountCount > 1 Then"
  ts.WriteLine "        Dim summaryStart As Long"
  ts.WriteLine "        summaryStart = r"
  ts.WriteLine "        r = RenderPortfolioSummary(ws, r, portfolio)"
  ts.WriteLine "        ' Group portfolio summary rows for collapse"
  ts.WriteLine "        If r > summaryStart + 1 Then"
  ts.WriteLine "            ws.Rows(summaryStart + 1 & "":"" & r - 1).Group"
  ts.WriteLine "        End If"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Per-account sections ---"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
  ts.WriteLine "        r = RenderAccountSection(ws, r, portfolio.Accounts(i).Extraction, i)"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' --- Loan accounts ---"
  ts.WriteLine "    If portfolio.LoanAccountCount > 0 Then"
  ts.WriteLine "        Dim li As Long"
  ts.WriteLine "        For li = 0 To portfolio.LoanAccountCount - 1"
  ts.WriteLine "            r = RenderLoanSection(ws, r, portfolio.LoanAccounts(li).Extraction, li)"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine "        Next li"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' --- QPR placeholder ---"
  ts.WriteLine "    mQprSectionStartRow = r"
  ts.WriteLine ""
  ts.WriteLine "    ' Auto-analyze if QPR pre-loaded"
  ts.WriteLine "    If mAutoAnalyzeQPR And Not mQprWb Is Nothing Then"
  ts.WriteLine "        r = RenderAutoQPRAnalysis(ws, r)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Template analysis if template loaded"
  ts.WriteLine "    If Not mTemplateWb Is Nothing Then"
  ts.WriteLine "        If mTemplateResult.ValueCount > 0 Or mTemplateResult.AlertCount > 0 Then"
  ts.WriteLine "            r = RenderTemplateAnalysis(ws, r, mTemplateResult, Dir(mTemplateWb.FullName))"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Add action buttons to top bar now that counts are known"
  ts.WriteLine "    AddActionButtons ws"
  ts.WriteLine ""
  ts.WriteLine "    SetFixedColumnWidths ws"
  ts.WriteLine ""
  ts.WriteLine "    ' Collapse all outline groups by default"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    ws.Outline.ShowLevels RowLevels:=1"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine ""
  ts.WriteLine "    ' Activate viewer sheet"
  ts.WriteLine "    ws.Activate"
  ts.WriteLine "    ws.Range(""A1"").Select"
  ts.WriteLine ""
  ts.WriteLine "    Application.Calculation = xlCalculationAutomatic"
  ts.WriteLine "    Application.ScreenUpdating = True"
  ts.WriteLine "    Exit Sub"
  ts.WriteLine ""
  ts.WriteLine "RenderError:"
  ts.WriteLine "    Application.Calculation = xlCalculationAutomatic"
  ts.WriteLine "    Application.ScreenUpdating = True"
  ts.WriteLine "    MsgBox ""Error rendering viewer: "" & Err.Description, vbCritical, ""Viewer Error"""
  ts.WriteLine "End Sub"
  ts.WriteLine ""
