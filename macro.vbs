ts.WriteLine "' ============================================================================"
ts.WriteLine "' ParseFilterString -- ""key1=val1,key2=val2"" -> flat array [key1,val1,key2,val2]"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub ParseFilterString(ByVal filterStr As String, ByRef filters() As String, ByRef filterCount As Long)"
ts.WriteLine "    filterCount = 0"
ts.WriteLine "    If Len(filterStr) = 0 Then"
ts.WriteLine "        ReDim filters(0 To 0)"
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Smart matching: if no ""="" found, interpret as bare value"
ts.WriteLine "    If InStr(1, filterStr, ""="") = 0 Then"
ts.WriteLine "        Dim bare As String"
ts.WriteLine "        bare = Trim$(filterStr)"
ts.WriteLine "        ReDim filters(0 To 1)"
ts.WriteLine ""
ts.WriteLine "        If LCase$(bare) = ""all"" Then"
ts.WriteLine "            ' ""all"" = no filter"
ts.WriteLine "            Exit Sub"
ts.WriteLine "        ElseIf LCase$(bare) = ""cash"" Then"
ts.WriteLine "            ' Cash = match cash-type holdings"
ts.WriteLine "            filters(0) = ""_cash"""
ts.WriteLine "            filters(1) = ""1"""
ts.WriteLine "            filterCount = 2"
ts.WriteLine "        ElseIf IsAssetClassName(bare) Then"
ts.WriteLine "            ' Asset class match"
ts.WriteLine "            filters(0) = ""asset_type"""
ts.WriteLine "            filters(1) = NormalizeAssetClass(bare)"
ts.WriteLine "            filterCount = 2"
ts.WriteLine "        Else"
ts.WriteLine "            ' Default: treat as symbol"
ts.WriteLine "            filters(0) = ""symbol"""
ts.WriteLine "            filters(1) = bare"
ts.WriteLine "            filterCount = 2"
ts.WriteLine "        End If"
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Existing key=value parsing"
ts.WriteLine "    Dim parts() As String"
ts.WriteLine "    parts = Split(filterStr, "","")"
ts.WriteLine ""
ts.WriteLine "    ReDim filters(0 To (UBound(parts) + 1) * 2 - 1)"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim eqPos As Long"
ts.WriteLine "    For i = 0 To UBound(parts)"
ts.WriteLine "        eqPos = InStr(1, parts(i), ""="")"
ts.WriteLine "        If eqPos > 0 Then"
ts.WriteLine "            filters(filterCount) = LCase$(Trim$(Left$(parts(i), eqPos - 1)))"
ts.WriteLine "            filters(filterCount + 1) = Trim$(Mid$(parts(i), eqPos + 1))"
ts.WriteLine "            filterCount = filterCount + 2"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' IsAssetClassName -- check if value is a known UBS asset class name"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function IsAssetClassName(ByVal spec As String) As Boolean"
ts.WriteLine "    Select Case LCase$(spec)"
ts.WriteLine "        Case ""cash and money balances"", ""cash alternatives"", ""equities"", _"
ts.WriteLine "             ""fixed income"", ""non-traditional"", ""commodities"", ""other"""
ts.WriteLine "            IsAssetClassName = True"
ts.WriteLine "        Case Else"
ts.WriteLine "            IsAssetClassName = False"
ts.WriteLine "    End Select"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' NormalizeAssetClass -- normalize ""other"" to ""non-traditional"""
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function NormalizeAssetClass(ByVal name As String) As String"
ts.WriteLine "    NormalizeAssetClass = LCase$(name)"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' NullToZero -- safely convert Variant (possibly Null) to Double"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function NullToZero(v As Variant) As Double"
ts.WriteLine "    If IsNull(v) Or IsEmpty(v) Then"
ts.WriteLine "        NullToZero = 0#"
ts.WriteLine "    Else"
ts.WriteLine "        NullToZero = CDbl(v)"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' ProcessMapping -- main orchestrator"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function ProcessMapping(portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "                               rows() As DataMapRow, _"
ts.WriteLine "                               ByVal rowCount As Long) As DataMapResult"
ts.WriteLine "    Dim result As DataMapResult"
ts.WriteLine "    result.ValueCount = 0"
ts.WriteLine "    result.AlertCount = 0"
ts.WriteLine "    ReDim result.Values(0 To rowCount)     ' generous initial size"
ts.WriteLine "    ReDim result.Alerts(0 To rowCount)"
ts.WriteLine ""
ts.WriteLine "    ' Build account lookup: account number -> index in portfolio.Accounts"
ts.WriteLine "    Dim acctIndex As Object"
ts.WriteLine "    Set acctIndex = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    acctIndex.CompareMode = vbTextCompare"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine "    For ai = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        acctIndex(portfolio.Accounts(ai).AccountNumber) = ai"
ts.WriteLine "    Next ai"
ts.WriteLine ""
ts.WriteLine "    ' Track which securities are covered per account (for unmapped detection)"
ts.WriteLine "    ' Key = ""ACCT|SYMBOL"", value = True"
ts.WriteLine "    Dim coveredSymbols As Object"
ts.WriteLine "    Set coveredSymbols = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    coveredSymbols.CompareMode = vbTextCompare"
ts.WriteLine ""
ts.WriteLine "    ' Process each mapping row"
ts.WriteLine "    Dim ri As Long"
ts.WriteLine "    Dim mr As DataMapRow"
ts.WriteLine "    Dim extIdx As Long"
ts.WriteLine "    Dim ext As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim resolved As Variant"
ts.WriteLine "    Dim resolvedIsText As Boolean"
ts.WriteLine "    Dim bracketPos As Long"
ts.WriteLine "    Dim arrName As String"
ts.WriteLine "    Dim colName As String"
ts.WriteLine "    Dim rv As ResolvedValue"
ts.WriteLine ""
ts.WriteLine "    For ri = 0 To rowCount - 1"
ts.WriteLine "        mr = rows(ri)"
ts.WriteLine ""
ts.WriteLine "        ' Find account"
ts.WriteLine "        If Not acctIndex.Exists(mr.Account) Then"
ts.WriteLine "            AddAlert result, ""warning"", ""Account '"" & mr.Account & ""' not found in extracted data"", mr.Account, mr.RowNum"
ts.WriteLine "            GoTo NextMapping"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        extIdx = acctIndex(mr.Account)"
ts.WriteLine "        ext = portfolio.Accounts(extIdx).Extraction"
ts.WriteLine ""
ts.WriteLine "        ' Parse field path"
ts.WriteLine "        resolvedIsText = IsTextField(mr.Field)"
ts.WriteLine ""
ts.WriteLine "        bracketPos = InStr(1, mr.Field, ""[]."")"
ts.WriteLine "        If bracketPos > 0 Then"
ts.WriteLine "            ' Array field"
ts.WriteLine "            arrName = Left$(mr.Field, bracketPos - 1)"
ts.WriteLine "            colName = Mid$(mr.Field, bracketPos + 3)"
ts.WriteLine ""
ts.WriteLine "            resolved = ResolveArrayField(ext, arrName, colName, mr.Filter)"
ts.WriteLine ""
ts.WriteLine "            ' Track covered symbols for holdings"
ts.WriteLine "            If LCase$(arrName) = ""holdings"" And Len(mr.Filter) > 0 Then"
ts.WriteLine "                TrackCoveredSymbols coveredSymbols, mr.Account, mr.Filter, ext"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            ' Check for phantom mapping"
ts.WriteLine "            If IsEmpty(resolved) And Len(mr.Filter) > 0 Then"
ts.WriteLine "                AddAlert result, ""phantom"", _"
ts.WriteLine "                    ""Filter '"" & mr.Filter & ""' on "" & mr.Field & "" matched nothing"", _"
ts.WriteLine "                    mr.Account, mr.RowNum"
ts.WriteLine "                GoTo NextMapping"
ts.WriteLine "            End If"
ts.WriteLine "        Else"
ts.WriteLine "            ' Scalar field"
ts.WriteLine "            resolved = ResolveScalarField(ext, mr.Field)"
ts.WriteLine "            If IsEmpty(resolved) Then"
ts.WriteLine "                AddAlert result, ""warning"", ""Unknown field path '"" & mr.Field & ""'"", mr.Account, mr.RowNum"
ts.WriteLine "                GoTo NextMapping"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Empty array result (no filter match, no filter) -- skip silently"
ts.WriteLine "        If IsEmpty(resolved) Then GoTo NextMapping"
ts.WriteLine ""
ts.WriteLine "        ' Build resolved value"
ts.WriteLine "        rv.TargetSheet = mr.TargetSheet"
ts.WriteLine "        rv.TargetCell = mr.TargetCell"
ts.WriteLine "        rv.SourceDesc = mr.Account & "" "" & mr.Field"
ts.WriteLine "        If Len(mr.Filter) > 0 Then rv.SourceDesc = rv.SourceDesc & "" "" & mr.Filter"
ts.WriteLine "        If mr.Pct <> 1# Then rv.SourceDesc = rv.SourceDesc & "" @"" & Format$(mr.Pct * 100, ""0"") & ""%"""
ts.WriteLine ""
ts.WriteLine "        If resolvedIsText Then"
ts.WriteLine "            rv.IsText = True"
ts.WriteLine "            rv.TextValue = CStr(resolved)"
ts.WriteLine "            rv.Value = 0#"
ts.WriteLine "        Else"
ts.WriteLine "            rv.IsText = False"
ts.WriteLine "            rv.Value = CDbl(resolved) * mr.Pct"
ts.WriteLine "            rv.TextValue = """""
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        result.Values(result.ValueCount) = rv"
ts.WriteLine "        result.ValueCount = result.ValueCount + 1"
ts.WriteLine "NextMapping:"
ts.WriteLine "    Next ri"
ts.WriteLine ""
ts.WriteLine "    ' Detect unmapped holdings per account"
ts.WriteLine "    DetectUnmappedHoldings result, portfolio, coveredSymbols, rows, rowCount"
ts.WriteLine ""
ts.WriteLine "    ' Trim arrays"
ts.WriteLine "    If result.ValueCount > 0 Then"
ts.WriteLine "        ReDim Preserve result.Values(0 To result.ValueCount - 1)"
ts.WriteLine "    End If"
ts.WriteLine "    If result.AlertCount > 0 Then"
ts.WriteLine "        ReDim Preserve result.Alerts(0 To result.AlertCount - 1)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ProcessMapping = result"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' TrackCoveredSymbols -- record which symbols are referenced by mapping rows"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Sub TrackCoveredSymbols(coveredSymbols As Object, ByVal acct As String, _"
ts.WriteLine "                                ByVal filterStr As String, ext As UBSExtract.StatementExtraction)"
ts.WriteLine "    ' If filter references symbol directly, track it"
ts.WriteLine "    Dim filters() As String"
ts.WriteLine "    Dim filterCount As Long"
ts.WriteLine "    ParseFilterString filterStr, filters, filterCount"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = 0 To filterCount - 1 Step 2"
ts.WriteLine "        If filters(i) = ""symbol"" Then"
ts.WriteLine "            coveredSymbols(acct & ""|"" & UCase$(filters(i + 1))) = True"
ts.WriteLine "            Exit Sub"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' If filter is by asset_type or other, find matching symbols and mark them"
ts.WriteLine "    Dim h As Long, s As Long"
ts.WriteLine "    Dim sec As UBSExtract.SecurityDetail"
ts.WriteLine "    For h = 0 To ext.HoldingCount - 1"
ts.WriteLine "        For s = 0 To ext.Holdings(h).SecurityCount - 1"
ts.WriteLine "            sec = ext.Holdings(h).Securities(s)"
ts.WriteLine "            If sec.IsEscrow Then GoTo NextSecTrack"
ts.WriteLine "            If Len(sec.Symbol) = 0 Then GoTo NextSecTrack"
ts.WriteLine ""
ts.WriteLine "            If MatchSecurityFilters(sec, ext.Holdings(h).AssetType, ext.Holdings(h).Name, filters, filterCount) Then"
ts.WriteLine "                coveredSymbols(acct & ""|"" & UCase$(sec.Symbol)) = True"
ts.WriteLine "            End If"
ts.WriteLine "NextSecTrack:"
ts.WriteLine "        Next s"
ts.WriteLine "    Next h"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' DetectUnmappedHoldings -- find holdings not covered by any mapping row"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Sub DetectUnmappedHoldings(ByRef result As DataMapResult, _"
ts.WriteLine "                                   portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "                                   coveredSymbols As Object, _"
ts.WriteLine "                                   rows() As DataMapRow, _"
ts.WriteLine "                                   ByVal rowCount As Long)"
ts.WriteLine "    ' Build set of accounts that have ANY holdings mapping rows"
ts.WriteLine "    Dim mappedAccounts As Object"
ts.WriteLine "    Set mappedAccounts = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    mappedAccounts.CompareMode = vbTextCompare"
ts.WriteLine ""
ts.WriteLine "    Dim ri As Long"
ts.WriteLine "    For ri = 0 To rowCount - 1"
ts.WriteLine "        If InStr(1, LCase$(rows(ri).Field), ""holdings[]."") > 0 Then"
ts.WriteLine "            mappedAccounts(rows(ri).Account) = True"
ts.WriteLine "        End If"
ts.WriteLine "    Next ri"
ts.WriteLine ""
ts.WriteLine "    ' For each mapped account, check which symbols are not covered"
ts.WriteLine "    Dim ai As Long"
ts.WriteLine "    Dim acctNum As String"
ts.WriteLine "    Dim ext As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim h As Long, s As Long"
ts.WriteLine "    Dim sec As UBSExtract.SecurityDetail"
ts.WriteLine "    Dim key As String"
ts.WriteLine ""
ts.WriteLine "    For ai = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        acctNum = portfolio.Accounts(ai).AccountNumber"
ts.WriteLine "        If Not mappedAccounts.Exists(acctNum) Then GoTo NextAcctUnmap"
ts.WriteLine ""
ts.WriteLine "        ext = portfolio.Accounts(ai).Extraction"
ts.WriteLine ""
ts.WriteLine "        For h = 0 To ext.HoldingCount - 1"
ts.WriteLine "            For s = 0 To ext.Holdings(h).SecurityCount - 1"
ts.WriteLine "                sec = ext.Holdings(h).Securities(s)"
ts.WriteLine "                If sec.IsEscrow Then GoTo NextSecUnmap"
ts.WriteLine "                If sec.Value = 0# Then GoTo NextSecUnmap"
ts.WriteLine "                If Len(sec.Symbol) = 0 Then GoTo NextSecUnmap"
ts.WriteLine ""
ts.WriteLine "                key = acctNum & ""|"" & UCase$(sec.Symbol)"
ts.WriteLine "                If Not coveredSymbols.Exists(key) Then"
ts.WriteLine "                    AddAlert result, ""unmapped"", _"
ts.WriteLine "                        sec.Name & "" ("" & sec.Symbol & "")"" & Chr$(1) & Format$(sec.Value, ""#,##0.00""), _"
ts.WriteLine "                        acctNum, 0"
ts.WriteLine "                End If"
ts.WriteLine "NextSecUnmap:"
ts.WriteLine "            Next s"
ts.WriteLine "        Next h"
ts.WriteLine "NextAcctUnmap:"
ts.WriteLine "    Next ai"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' AddAlert -- append alert to result"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Sub AddAlert(ByRef result As DataMapResult, ByVal alertType As String, _"
ts.WriteLine "                     ByVal msg As String, ByVal acct As String, ByVal rowNum As Long)"
ts.WriteLine "    If result.AlertCount > UBound(result.Alerts) Then"
ts.WriteLine "        ReDim Preserve result.Alerts(0 To result.AlertCount * 2)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    result.Alerts(result.AlertCount).AlertType = alertType"
ts.WriteLine "    result.Alerts(result.AlertCount).Message = msg"
ts.WriteLine "    result.Alerts(result.AlertCount).Account = acct"
ts.WriteLine "    result.Alerts(result.AlertCount).RowNum = rowNum"
ts.WriteLine "    result.AlertCount = result.AlertCount + 1"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' WriteResults -- write resolved values to cells + summary sheet"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub WriteResults(wb As Workbook, result As DataMapResult)"
ts.WriteLine "    ' Bucket values by Sheet+Cell"
ts.WriteLine "    Dim buckets As Object  ' key = ""Sheet|Cell"", value = summed Double or first text"
ts.WriteLine "    Set buckets = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim bucketIsText As Object"
ts.WriteLine "    Set bucketIsText = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim bucketDescs As Object  ' key = ""Sheet|Cell"", value = source descriptions joined"
ts.WriteLine "    Set bucketDescs = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim bucketCounts As Object"
ts.WriteLine "    Set bucketCounts = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine ""
ts.WriteLine "    Dim vi As Long"
ts.WriteLine "    Dim rv As ResolvedValue"
ts.WriteLine "    Dim bKey As String"
ts.WriteLine "    For vi = 0 To result.ValueCount - 1"
ts.WriteLine "        rv = result.Values(vi)"
ts.WriteLine ""
ts.WriteLine "        bKey = rv.TargetSheet & ""|"" & rv.TargetCell"
ts.WriteLine ""
ts.WriteLine "        If Not buckets.Exists(bKey) Then"
ts.WriteLine "            If rv.IsText Then"
ts.WriteLine "                buckets(bKey) = rv.TextValue"
ts.WriteLine "            Else"
ts.WriteLine "                buckets(bKey) = rv.Value"
ts.WriteLine "            End If"
ts.WriteLine "            bucketIsText(bKey) = rv.IsText"
ts.WriteLine "            bucketDescs(bKey) = rv.SourceDesc"
ts.WriteLine "            bucketCounts(bKey) = 1"
ts.WriteLine "        Else"
ts.WriteLine "            If rv.IsText Then"
ts.WriteLine "                ' Text: first value wins (already set)"
ts.WriteLine "            Else"
ts.WriteLine "                buckets(bKey) = CDbl(buckets(bKey)) + rv.Value"
ts.WriteLine "            End If"
ts.WriteLine "            bucketDescs(bKey) = bucketDescs(bKey) & ""; "" & rv.SourceDesc"
ts.WriteLine "            bucketCounts(bKey) = CLng(bucketCounts(bKey)) + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next vi"
ts.WriteLine ""
ts.WriteLine "    ' Write to cells"
ts.WriteLine "    Dim writeCount As Long"
ts.WriteLine "    writeCount = 0"
ts.WriteLine "    Dim keys As Variant"
ts.WriteLine "    keys = buckets.keys"
ts.WriteLine ""
ts.WriteLine "    Dim ki As Long"
ts.WriteLine "    Dim parts() As String"
ts.WriteLine "    Dim sheetName As String"
ts.WriteLine "    Dim cellRef As String"
ts.WriteLine "    Dim targetWs As Worksheet"
ts.WriteLine "    Dim cellErr As String"
ts.WriteLine ""
ts.WriteLine "    For ki = 0 To buckets.count - 1"
ts.WriteLine "        parts = Split(CStr(keys(ki)), ""|"")"
ts.WriteLine "        sheetName = parts(0)"
ts.WriteLine "        cellRef = parts(1)"
ts.WriteLine ""
ts.WriteLine "        ' Find target sheet"
ts.WriteLine "        Set targetWs = Nothing"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        Set targetWs = wb.Worksheets(sheetName)"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "        If targetWs Is Nothing Then"
ts.WriteLine "            AddAlert result, ""warning"", ""Sheet '"" & sheetName & ""' not found in workbook"", """", 0"
ts.WriteLine "            GoTo NextBucket"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Write value"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        If CBool(bucketIsText(keys(ki))) Then"
ts.WriteLine "            targetWs.Range(cellRef).Value = CStr(buckets(keys(ki)))"
ts.WriteLine "        Else"
ts.WriteLine "            targetWs.Range(cellRef).Value = CDbl(buckets(keys(ki)))"
ts.WriteLine "        End If"
ts.WriteLine "        If Err.Number <> 0 Then"
ts.WriteLine "            cellErr = Err.Description"
ts.WriteLine "            Err.Clear"
ts.WriteLine "            On Error GoTo 0"
ts.WriteLine "            AddAlert result, ""warning"", ""Failed to write to "" & sheetName & ""!"" & cellRef & "": "" & cellErr, """", 0"
ts.WriteLine "            GoTo NextBucket"
ts.WriteLine "        End If"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "        writeCount = writeCount + 1"
ts.WriteLine "NextBucket:"
ts.WriteLine "    Next ki"
ts.WriteLine ""
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
