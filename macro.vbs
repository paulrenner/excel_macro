  ts.WriteLine "Private Function RenderQPRAnalysis(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef analysis As QPRWriter.QprAnalysis, ByVal qprLabel As String) As Long"
  ts.WriteLine ""
  ts.WriteLine "    ' Early return if nothing to show"
  ts.WriteLine "    If analysis.WarningCount = 0 And analysis.UnmappedCount = 0 And _"
  ts.WriteLine "       analysis.PhantomCount = 0 And analysis.PhantomAcctCount = 0 And _"
  ts.WriteLine "       analysis.UpdateCount = 0 And analysis.UncoveredCount = 0 Then"
  ts.WriteLine "        RenderQPRAnalysis = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    WriteGroupHeader ws, r, ""QPR ANALYSIS"" & IIf(Len(qprLabel) > 0, "" "" & ChrW$(8212) & "" "" & qprLabel, """")"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    Dim secStart As Long  ' track start of each sub-section for borders"
  ts.WriteLine ""
  ts.WriteLine "    ' Uncovered Accounts"
  ts.WriteLine "    If analysis.UncoveredCount > 0 Then"
  ts.WriteLine "        r = RenderUncoveredTable(ws, r, ""Uncovered Accounts ("" & analysis.UncoveredCount & "")"", _"
  ts.WriteLine "            analysis.UncoveredAccounts, analysis.UncoveredCount)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Mapping Warnings"
  ts.WriteLine "    If analysis.WarningCount > 0 Then"
  ts.WriteLine "        r = RenderAlertTextList(ws, r, ""Mapping Warnings ("" & analysis.WarningCount & "")"", _"
  ts.WriteLine "            analysis.Warnings, analysis.WarningCount)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Unmapped Holdings — Account=1-2, AssetClass=3-4, Holding=5-8, Value=9-10"
  ts.WriteLine "    If analysis.UnmappedCount > 0 Then"
  ts.WriteLine "        r = r + 1  ' spacer"
  ts.WriteLine "        secStart = r"
  ts.WriteLine "        WriteSubHeader ws, r, ""Unmapped Holdings ("" & analysis.UnmappedCount & "")"""
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_WARN_BG"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim umH() As String, umS() As Long, umE() As Long, umA() As Long"
  ts.WriteLine "        ReDim umH(1 To 4): ReDim umS(1 To 4): ReDim umE(1 To 4): ReDim umA(1 To 4)"
  ts.WriteLine "        umH(1) = ""Account"": umS(1) = 1: umE(1) = 2: umA(1) = -4131"
  ts.WriteLine "        umH(2) = ""Asset Class"": umS(2) = 3: umE(2) = 4: umA(2) = -4131"
  ts.WriteLine "        umH(3) = ""Holding"": umS(3) = 5: umE(3) = 8: umA(3) = -4131"
  ts.WriteLine "        umH(4) = ""Value"": umS(4) = 9: umE(4) = 10: umA(4) = -4152"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, umH, umS, umE, umA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim ui As Long"
  ts.WriteLine "        For ui = 0 To analysis.UnmappedCount - 1"
  ts.WriteLine "            MergeWrite ws, r, 1, 2, analysis.UnmappedHoldings(ui).AccountNumber"
  ts.WriteLine "            MergeWrite ws, r, 3, 4, analysis.UnmappedHoldings(ui).AssetClass"
  ts.WriteLine "            MergeWrite ws, r, 5, 8, analysis.UnmappedHoldings(ui).HoldingName"
  ts.WriteLine "            MergeWriteCurrency ws, r, 9, 10, analysis.UnmappedHoldings(ui).Value"
  ts.WriteLine "            r = r + 1"
  ts.WriteLine "        Next ui"
  ts.WriteLine "        ws.Range(ws.Cells(secStart, 1), ws.Cells(r - 1, GCOLS)).BorderAround Weight:=4, Color:=RGB(255, 193, 7)"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Phantom Mappings — Account=1-2, Tab=3-4, Spec=5-10"
  ts.WriteLine "    If analysis.PhantomCount > 0 Then"
  ts.WriteLine "        r = r + 1  ' spacer"
  ts.WriteLine "        secStart = r"
  ts.WriteLine "        WriteSubHeader ws, r, ""Phantom Mappings ("" & analysis.PhantomCount & "")"""
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_WARN_BG"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim pmH() As String, pmS() As Long, pmE() As Long, pmA() As Long"
  ts.WriteLine "        ReDim pmH(1 To 3): ReDim pmS(1 To 3): ReDim pmE(1 To 3): ReDim pmA(1 To 3)"
  ts.WriteLine "        pmH(1) = ""Account"": pmS(1) = 1: pmE(1) = 2: pmA(1) = -4131"
  ts.WriteLine "        pmH(2) = ""Tab"": pmS(2) = 3: pmE(2) = 4: pmA(2) = -4131"
  ts.WriteLine "        pmH(3) = ""Holdings Spec"": pmS(3) = 5: pmE(3) = 10: pmA(3) = -4131"
  ts.WriteLine "        WriteTableHeadersMerged ws, r, pmH, pmS, pmE, pmA"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim pi As Long"
  ts.WriteLine "        For pi = 0 To analysis.PhantomCount - 1"
  ts.WriteLine "            MergeWrite ws, r, 1, 2, analysis.PhantomMappings(pi).Account"
  ts.WriteLine "            MergeWrite ws, r, 3, 4, analysis.PhantomMappings(pi).Tab"
