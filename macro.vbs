ts.WriteLine "' ============================================================================"
ts.WriteLine "' DOM injection helpers"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Sub InjectHTML(ByRef browser As Object, ByVal elementId As String, ByVal html As String)"
ts.WriteLine "    ' Sets innerHTML of a DOM element directly via VBA COM"
ts.WriteLine "    ' For large HTML, use chunked script injection to avoid COM string limits"
ts.WriteLine "    Dim el As Object"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    Set el = browser.Document.getElementById(elementId)"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    If el Is Nothing Then Exit Sub"
ts.WriteLine ""
ts.WriteLine "    ' Try direct assignment first (fast for small HTML)"
ts.WriteLine "    If Len(html) < 32000 Then"
ts.WriteLine "        On Error Resume Next"
ts.WriteLine "        el.innerHTML = html"
ts.WriteLine "        If Err.Number = 0 Then"
ts.WriteLine "            On Error GoTo 0"
ts.WriteLine "            Exit Sub"
ts.WriteLine "        End If"
ts.WriteLine "        Err.Clear"
ts.WriteLine "        On Error GoTo 0"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Fallback: inject via script in chunks"
ts.WriteLine "    Dim chunkSize As Long"
ts.WriteLine "    chunkSize = 20000"
ts.WriteLine "    Dim pos As Long"
ts.WriteLine "    Dim chunk As String"
ts.WriteLine "    Dim jsCode As String"
ts.WriteLine ""
ts.WriteLine "    ' Clear element first"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    el.innerHTML = """""
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine ""
ts.WriteLine "    ' Build up content via JS string concatenation"
ts.WriteLine "    InjectJS browser, ""window.__injectBuf = '';"""
ts.WriteLine "    pos = 1"
ts.WriteLine "    Do While pos <= Len(html)"
ts.WriteLine "        chunk = Mid$(html, pos, chunkSize)"
ts.WriteLine "        jsCode = ""window.__injectBuf += '"" & EscJS(chunk) & ""';"""
ts.WriteLine "        InjectJS browser, jsCode"
ts.WriteLine "        pos = pos + chunkSize"
ts.WriteLine "    Loop"
ts.WriteLine "    InjectJS browser, ""document.getElementById('"" & EscJS(elementId) & ""').innerHTML = window.__injectBuf; window.__injectBuf = null;"""
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "Private Sub InjectJS(ByRef browser As Object, ByVal js As String)"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    browser.Document.parentWindow.execScript js, ""JavaScript"""
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "Private Function EscJS(ByVal s As String) As String"
ts.WriteLine "    ' Escape string for JS literal"
ts.WriteLine "    s = Replace$(s, ""\"", ""\\"")"
ts.WriteLine "    s = Replace$(s, ""`"", ""\`"")"
ts.WriteLine "    s = Replace$(s, ""'"", ""\'"")"
ts.WriteLine "    s = Replace$(s, """""""", ""\"""""")"
ts.WriteLine "    s = Replace$(s, vbCr, """")"
ts.WriteLine "    s = Replace$(s, vbLf, ""\n"")"
ts.WriteLine "    s = Replace$(s, Chr$(0), """")"
ts.WriteLine "    EscJS = s"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function EscHTML(ByVal s As String) As String"
ts.WriteLine "    ' Escape string for safe HTML display (prevents XSS via innerHTML)"
ts.WriteLine "    EscHTML = Replace$(s, ""&"", ""&amp;"")"
ts.WriteLine "    EscHTML = Replace$(EscHTML, ""<"", ""&lt;"")"
ts.WriteLine "    EscHTML = Replace$(EscHTML, "">"", ""&gt;"")"
ts.WriteLine "    EscHTML = Replace$(EscHTML, """""""", ""&quot;"")"
ts.WriteLine "End Function"
ts.WriteLine ""
