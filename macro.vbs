ts.WriteLine "' Gains & Losses section"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function BuildGainsSection(ByRef g As UBSExtract.GainsAndLosses) As String"
ts.WriteLine "    Dim h As String"
ts.WriteLine "    h = ""<div class=""""section"""">"" & vbLf"
ts.WriteLine "    h = h & ""<button class=""""section-toggle"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" onclick=""""toggleSection(this)"""">"" & _"
ts.WriteLine "            ""<span>Gains &amp; Losses</span><span class=""""arrow"""">&#9654;</span></button>"" & vbLf"
ts.WriteLine "    h = h & ""<div class=""""section-body""""><div class=""""section-pad"""">"" & vbLf"
ts.WriteLine "    h = h & ""<table><thead><tr><th></th><th class=""""num"""">Realized (Month)</th>"" & _"
ts.WriteLine "            ""<th class=""""num"""">Realized (YTD)</th><th class=""""num"""">Unrealized</th></tr></thead><tbody>"" & vbLf"
ts.WriteLine "    h = h & GainsRow(""Short-Term"", g.ShortTermRealizedMonth, g.ShortTermRealizedYtd, g.ShortTermUnrealized)"
ts.WriteLine "    h = h & GainsRow(""Long-Term"", g.LongTermRealizedMonth, g.LongTermRealizedYtd, g.LongTermUnrealized)"
ts.WriteLine "    h = h & ""<tr style=""""font-weight:600;"""">"" & _"
ts.WriteLine "            ""<td>Total</td>"" & _"
ts.WriteLine "            ""<td class=""""num"""" style="""""" & CssNeg(g.TotalRealizedMonth) & """""">"" & Fmt(g.TotalRealizedMonth) & ""</td>"" & _"
ts.WriteLine "            ""<td class=""""num"""" style="""""" & CssNeg(g.TotalRealizedYtd) & """""">"" & Fmt(g.TotalRealizedYtd) & ""</td>"" & _"
ts.WriteLine "            ""<td class=""""num"""" style="""""" & CssGL(g.TotalUnrealized) & """""">"" & Fmt(g.TotalUnrealized) & ""</td></tr>"" & vbLf"
ts.WriteLine "    h = h & ""</tbody></table></div></div></div>"" & vbLf"
ts.WriteLine "    BuildGainsSection = h"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function GainsRow(ByVal label As String, ByVal rm As Double, ByVal ry As Double, ByVal u As Double) As String"
ts.WriteLine "    GainsRow = ""<tr><td>"" & label & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""" style="""""" & CssNeg(rm) & """""">"" & Fmt(rm) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""" style="""""" & CssNeg(ry) & """""">"" & Fmt(ry) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""" style="""""" & CssGL(u) & """""">"" & Fmt(u) & ""</td></tr>"" & vbLf"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Holdings section"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function BuildHoldingsSection(ByRef ext As UBSExtract.StatementExtraction) As String"
ts.WriteLine "    If ext.HoldingCount = 0 Then"
ts.WriteLine "        BuildHoldingsSection = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim totalSecs As Long"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim j As Long"
ts.WriteLine "    Dim k As Long"
ts.WriteLine "    Dim rows As String"
ts.WriteLine "    Dim hld As UBSExtract.Holding"
ts.WriteLine "    Dim costStr As String"
ts.WriteLine "    Dim glStr As String"
ts.WriteLine "    Dim glStyle As String"
ts.WriteLine "    Dim sec As UBSExtract.SecurityDetail"
ts.WriteLine "    Dim sCost As String"
ts.WriteLine "    Dim sGL As String"
ts.WriteLine "    Dim sGLStyle As String"
ts.WriteLine "    Dim valDisplay As String"
ts.WriteLine ""
ts.WriteLine "    ' Group holdings by AssetType (merge same asset class together)"
ts.WriteLine "    Dim grpCount As Long"
ts.WriteLine "    Dim grpKeys() As String"
ts.WriteLine "    Dim grpValues() As Double"
ts.WriteLine "    Dim grpCosts() As Variant   ' Double or Null"
ts.WriteLine "    Dim grpGLs() As Variant     ' Double or Null"
ts.WriteLine "    ' Collect all securities per group in flat arrays"
ts.WriteLine "    Dim grpSecStart() As Long   ' start index into allSecs for each group"
ts.WriteLine "    Dim grpSecCount() As Long   ' count of securities for each group"
ts.WriteLine "    Dim allSecs() As UBSExtract.SecurityDetail"
ts.WriteLine "    Dim allSecCount As Long"
ts.WriteLine "    Dim gi As Long"
ts.WriteLine "    Dim found As Boolean"
ts.WriteLine "    Dim grpKey As String"
ts.WriteLine ""
ts.WriteLine "    ReDim grpKeys(0 To ext.HoldingCount - 1)"
ts.WriteLine "    ReDim grpValues(0 To ext.HoldingCount - 1)"
ts.WriteLine "    ReDim grpCosts(0 To ext.HoldingCount - 1)"
ts.WriteLine "    ReDim grpGLs(0 To ext.HoldingCount - 1)"
ts.WriteLine "    ReDim grpSecStart(0 To ext.HoldingCount - 1)"
ts.WriteLine "    ReDim grpSecCount(0 To ext.HoldingCount - 1)"
ts.WriteLine ""
ts.WriteLine "    ' Count total securities for allSecs array"
ts.WriteLine "    allSecCount = 0"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        allSecCount = allSecCount + ext.Holdings(i).SecurityCount"
ts.WriteLine "    Next i"
ts.WriteLine "    If allSecCount = 0 Then allSecCount = 1"
ts.WriteLine "    ReDim allSecs(0 To allSecCount - 1)"
ts.WriteLine ""
ts.WriteLine "    grpCount = 0"
ts.WriteLine "    allSecCount = 0"
ts.WriteLine ""
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        hld = ext.Holdings(i)"
ts.WriteLine "        grpKey = hld.AssetType"
ts.WriteLine "        If Len(grpKey) = 0 Then grpKey = hld.Name"
ts.WriteLine ""
ts.WriteLine "        ' Find existing group"
ts.WriteLine "        found = False"
ts.WriteLine "        For gi = 0 To grpCount - 1"
ts.WriteLine "            If grpKeys(gi) = grpKey Then"
ts.WriteLine "                found = True"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next gi"
ts.WriteLine ""
ts.WriteLine "        If Not found Then"
ts.WriteLine "            gi = grpCount"
ts.WriteLine "            grpCount = grpCount + 1"
ts.WriteLine "            grpKeys(gi) = grpKey"
ts.WriteLine "            grpValues(gi) = 0"
ts.WriteLine "            grpCosts(gi) = Null"
ts.WriteLine "            grpGLs(gi) = Null"
ts.WriteLine "            grpSecStart(gi) = allSecCount"
ts.WriteLine "            grpSecCount(gi) = 0"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        grpValues(gi) = grpValues(gi) + hld.Value"
ts.WriteLine "        If Not IsNull(hld.CostBasis) And Not IsEmpty(hld.CostBasis) Then"
ts.WriteLine "            If IsNull(grpCosts(gi)) Then grpCosts(gi) = CDbl(hld.CostBasis) Else grpCosts(gi) = CDbl(grpCosts(gi)) + CDbl(hld.CostBasis)"
ts.WriteLine "        End If"
ts.WriteLine "        If Not IsNull(hld.UnrealizedGL) And Not IsEmpty(hld.UnrealizedGL) Then"
ts.WriteLine "            If IsNull(grpGLs(gi)) Then grpGLs(gi) = CDbl(hld.UnrealizedGL) Else grpGLs(gi) = CDbl(grpGLs(gi)) + CDbl(hld.UnrealizedGL)"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Append securities -- need to shift later groups if inserting into middle"
ts.WriteLine "        ' Since we process in order and append, just track where each group's secs go"
ts.WriteLine "        ' For simplicity, collect all secs in order and use start/count"
ts.WriteLine "        For j = 0 To hld.SecurityCount - 1"
ts.WriteLine "            ' If this group already had secs from a previous holding, we need to"
ts.WriteLine "            ' append at the right spot. Use a simple approach: always append at end"
ts.WriteLine "            ' and we'll render by scanning allSecs with group index."
ts.WriteLine "            allSecs(allSecCount) = hld.Securities(j)"
ts.WriteLine "            allSecCount = allSecCount + 1"
ts.WriteLine "            grpSecCount(gi) = grpSecCount(gi) + 1"
ts.WriteLine "        Next j"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Now render grouped holdings"
ts.WriteLine "    totalSecs = 0"
ts.WriteLine ""
ts.WriteLine "    ' We need to collect secs per group properly. Since groups can have secs"
ts.WriteLine "    ' added non-contiguously, let's build a group-index array for each sec."
ts.WriteLine "    Dim secGroupIdx() As Long"
ts.WriteLine "    If allSecCount > 0 Then"
ts.WriteLine "        ReDim secGroupIdx(0 To allSecCount - 1)"
ts.WriteLine "    Else"
ts.WriteLine "        ReDim secGroupIdx(0 To 0)"
ts.WriteLine "    End If"
ts.WriteLine "    Dim si As Long"
ts.WriteLine "    si = 0"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        hld = ext.Holdings(i)"
ts.WriteLine "        grpKey = hld.AssetType"
ts.WriteLine "        If Len(grpKey) = 0 Then grpKey = hld.Name"
ts.WriteLine "        ' Find group index"
ts.WriteLine "        For gi = 0 To grpCount - 1"
ts.WriteLine "            If grpKeys(gi) = grpKey Then Exit For"
ts.WriteLine "        Next gi"
ts.WriteLine "        For j = 0 To hld.SecurityCount - 1"
ts.WriteLine "            secGroupIdx(si) = gi"
ts.WriteLine "            si = si + 1"
ts.WriteLine "        Next j"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Build rows using array+Join"
ts.WriteLine "    Dim rowParts() As String"
ts.WriteLine "    Dim rc As Long"
ts.WriteLine "    ReDim rowParts(0 To grpCount + allSecCount * 2)"
ts.WriteLine "    rc = 0"
ts.WriteLine ""
ts.WriteLine "    For gi = 0 To grpCount - 1"
ts.WriteLine "        ' Category row"
ts.WriteLine "        If IsNull(grpCosts(gi)) Then costStr = ""&mdash;"" Else costStr = Fmt(CDbl(grpCosts(gi)))"
ts.WriteLine "        If IsNull(grpGLs(gi)) Then"
ts.WriteLine "            glStr = ""&mdash;"""
ts.WriteLine "            glStyle = """""
ts.WriteLine "        Else"
ts.WriteLine "            glStr = Fmt(CDbl(grpGLs(gi)))"
ts.WriteLine "            glStyle = CssGL(CDbl(grpGLs(gi)))"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        rowParts(rc) = ""<tr class=""""holding-cat""""><td>"" & Esc(grpKeys(gi)) & ""</td><td></td>"" & _"
ts.WriteLine "               ""<td class=""""num"""">"" & costStr & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""" style="""""" & glStyle & """""">"" & glStr & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""">"" & Fmt(grpValues(gi)) & ""</td></tr>"""
ts.WriteLine "        rc = rc + 1"
ts.WriteLine ""
ts.WriteLine "        ' Securities for this group"
ts.WriteLine "        For k = 0 To allSecCount - 1"
ts.WriteLine "            If secGroupIdx(k) = gi Then"
ts.WriteLine "                sec = allSecs(k)"
ts.WriteLine "                totalSecs = totalSecs + 1"
ts.WriteLine "                If IsNull(sec.CostBasis) Or IsEmpty(sec.CostBasis) Then sCost = ""&mdash;"" Else sCost = Fmt(CDbl(sec.CostBasis))"
ts.WriteLine "                If IsNull(sec.UnrealizedGL) Or IsEmpty(sec.UnrealizedGL) Then"
ts.WriteLine "                    sGL = ""&mdash;"""
ts.WriteLine "                    sGLStyle = """""
ts.WriteLine "                Else"
ts.WriteLine "                    sGL = Fmt(CDbl(sec.UnrealizedGL))"
ts.WriteLine "                    sGLStyle = CssGL(CDbl(sec.UnrealizedGL))"
ts.WriteLine "                End If"
ts.WriteLine ""
ts.WriteLine "                If sec.IsEscrow Then"
ts.WriteLine "                    valDisplay = Fmt(sec.Value) & "" <span class=""""detail-meta"""">(escrow)</span>"""
ts.WriteLine "                Else"
ts.WriteLine "                    valDisplay = Fmt(sec.Value)"
ts.WriteLine "                End If"
ts.WriteLine "                rowParts(rc) = ""<tr class=""""holding-sec""""><td>"" & Esc(sec.Name) & ""</td>"" & _"
ts.WriteLine "                       ""<td>"" & Esc(sec.Symbol) & ""</td>"" & _"
ts.WriteLine "                       ""<td class=""""num"""">"" & sCost & ""</td>"" & _"
ts.WriteLine "                       ""<td class=""""num"""" style="""""" & sGLStyle & """""">"" & sGL & ""</td>"" & _"
ts.WriteLine "                       ""<td class=""""num"""">"" & valDisplay & ""</td></tr>"""
ts.WriteLine "                rc = rc + 1"
ts.WriteLine ""
ts.WriteLine "                ' Insurance/annuity detail sub-row"
ts.WriteLine "                Dim detParts() As String"
ts.WriteLine "                Dim dp As Long: dp = 0"
ts.WriteLine "                ReDim detParts(0 To 7)"
ts.WriteLine "                If Not IsNull(sec.DeathBenefit) And Not IsEmpty(sec.DeathBenefit) Then"
ts.WriteLine "                    detParts(dp) = ""Death benefit: "" & Fmt(CDbl(sec.DeathBenefit)): dp = dp + 1"
ts.WriteLine "                End If"
ts.WriteLine "                If Not IsNull(sec.LivingBenefit) And Not IsEmpty(sec.LivingBenefit) Then"
ts.WriteLine "                    detParts(dp) = ""Living benefit: "" & Fmt(CDbl(sec.LivingBenefit)): dp = dp + 1"
ts.WriteLine "                End If"
ts.WriteLine "                If Not IsNull(sec.SurrenderValue) And Not IsEmpty(sec.SurrenderValue) Then"
ts.WriteLine "                    detParts(dp) = ""Surrender value: "" & Fmt(CDbl(sec.SurrenderValue)): dp = dp + 1"
ts.WriteLine "                End If"
ts.WriteLine "                If Not IsNull(sec.TotalWithdrawal) And Not IsEmpty(sec.TotalWithdrawal) Then"
ts.WriteLine "                    detParts(dp) = ""Total withdrawal: "" & Fmt(CDbl(sec.TotalWithdrawal)): dp = dp + 1"
ts.WriteLine "                End If"
ts.WriteLine "                If Len(sec.ContractNumber) > 0 Then"
ts.WriteLine "                    detParts(dp) = ""Contract: "" & Esc(sec.ContractNumber): dp = dp + 1"
ts.WriteLine "                End If"
ts.WriteLine "                If Len(sec.IssueDate) > 0 Then"
ts.WriteLine "                    detParts(dp) = ""Issue date: "" & Esc(sec.IssueDate): dp = dp + 1"
ts.WriteLine "                End If"
ts.WriteLine "                If dp > 0 Then"
ts.WriteLine "                    ReDim Preserve detParts(0 To dp - 1)"
ts.WriteLine "                    rowParts(rc) = ""<tr class=""""holding-sec""""><td colspan=""""5"""" style=""""padding-left:40px"""">"" & _"
ts.WriteLine "                        ""<span class=""""detail-meta"""">"" & Join(detParts, "" &middot; "") & ""</span></td></tr>"""
ts.WriteLine "                    rc = rc + 1"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        Next k"
ts.WriteLine "    Next gi"
ts.WriteLine ""
ts.WriteLine "    ReDim Preserve rowParts(0 To rc - 1)"
ts.WriteLine "    BuildHoldingsSection = ""<div class=""""section"""">"" & vbLf & _"
ts.WriteLine "        ""<button class=""""section-toggle"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" onclick=""""toggleSection(this)"""">"" & _"
ts.WriteLine "        ""<span>Holdings ("" & totalSecs & "")</span><span class=""""arrow"""">&#9654;</span></button>"" & vbLf & _"
ts.WriteLine "        ""<div class=""""section-body""""><div class=""""section-pad"""">"" & vbLf & _"
ts.WriteLine "        ""<table><thead><tr><th>Name</th><th>Symbol</th><th class=""""num"""">Cost Basis</th>"" & _"
ts.WriteLine "        ""<th class=""""num"""">Unrealized G/L</th><th class=""""num"""">Value</th></tr></thead><tbody>"" & vbLf & _"
ts.WriteLine "        Join(rowParts, vbLf) & vbLf & _"
ts.WriteLine "        ""</tbody></table></div></div></div>"" & vbLf"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Transactions section"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function BuildTransactionsSection(ByRef ext As UBSExtract.StatementExtraction) As String"
ts.WriteLine "    If ext.TransactionCount = 0 Then"
ts.WriteLine "        BuildTransactionsSection = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim j As Long"
ts.WriteLine "    Dim rows As String"
ts.WriteLine "    Dim count As Long"
ts.WriteLine "    Dim tx As UBSExtract.Transaction"
ts.WriteLine "    Dim desc As String"
ts.WriteLine "    Dim badge As String"
ts.WriteLine "    Dim acClass As String"
ts.WriteLine "    Dim descUpper As String"
ts.WriteLine "    Dim descLow As String"
ts.WriteLine "    Dim hld As UBSExtract.Holding"
ts.WriteLine "    Dim sec As UBSExtract.SecurityDetail"
ts.WriteLine ""
ts.WriteLine "    ' Build symbol/name -> asset class lookup from holdings using Dictionary for O(1) lookup"
ts.WriteLine "    Dim lookupDict As Object"
ts.WriteLine "    Set lookupDict = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    lookupDict.CompareMode = vbTextCompare"
ts.WriteLine ""
ts.WriteLine "    ' Also keep parallel arrays for substring matching against descriptions"
ts.WriteLine "    Dim lookupKeys() As String"
ts.WriteLine "    Dim lookupVals() As String"
ts.WriteLine "    Dim lookupCount As Long"
ts.WriteLine "    lookupCount = 0"
ts.WriteLine ""
ts.WriteLine "    Dim totalLookup As Long"
ts.WriteLine "    totalLookup = 0"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        totalLookup = totalLookup + ext.Holdings(i).SecurityCount * 2"
ts.WriteLine "    Next i"
ts.WriteLine "    If totalLookup = 0 Then totalLookup = 1"
ts.WriteLine "    ReDim lookupKeys(0 To totalLookup - 1)"
ts.WriteLine "    ReDim lookupVals(0 To totalLookup - 1)"
ts.WriteLine ""
ts.WriteLine "    Dim acVal As String"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        hld = ext.Holdings(i)"
ts.WriteLine "        For j = 0 To hld.SecurityCount - 1"
ts.WriteLine "            sec = hld.Securities(j)"
ts.WriteLine "            acVal = IIf(Len(hld.AssetType) > 0, hld.AssetType, hld.Name)"
ts.WriteLine "            If Len(sec.Symbol) > 0 Then"
ts.WriteLine "                If Not lookupDict.Exists(UCase$(sec.Symbol)) Then"
ts.WriteLine "                    lookupDict.Add UCase$(sec.Symbol), acVal"
ts.WriteLine "                End If"
ts.WriteLine "                lookupKeys(lookupCount) = UCase$(sec.Symbol)"
ts.WriteLine "                lookupVals(lookupCount) = acVal"
ts.WriteLine "                lookupCount = lookupCount + 1"
ts.WriteLine "            End If"
ts.WriteLine "            If Len(sec.Name) > 0 Then"
ts.WriteLine "                If Not lookupDict.Exists(UCase$(sec.Name)) Then"
ts.WriteLine "                    lookupDict.Add UCase$(sec.Name), acVal"
ts.WriteLine "                End If"
ts.WriteLine "                lookupKeys(lookupCount) = UCase$(sec.Name)"
ts.WriteLine "                lookupVals(lookupCount) = acVal"
ts.WriteLine "                lookupCount = lookupCount + 1"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    Dim rowParts() As String"
ts.WriteLine "    ReDim rowParts(0 To ext.TransactionCount - 1)"
ts.WriteLine "    count = 0"
ts.WriteLine ""
ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
ts.WriteLine "        tx = ext.Transactions(i)"
ts.WriteLine ""
ts.WriteLine "        ' Skip balance forward and FDIC closing entries"
ts.WriteLine "        If LCase$(tx.Description) = ""balance forward"" Then GoTo NextTx"
ts.WriteLine "        If tx.Activity = ""Closing"" And InStr(1, tx.Description, ""FDIC"", vbTextCompare) > 0 Then GoTo NextTx"
ts.WriteLine ""
ts.WriteLine "        ' Look up asset class from holdings (Dictionary for exact match)"
ts.WriteLine "        acClass = """""
ts.WriteLine "        If Len(tx.Symbol) > 0 Then"
ts.WriteLine "            If lookupDict.Exists(UCase$(tx.Symbol)) Then"
ts.WriteLine "                acClass = lookupDict(UCase$(tx.Symbol))"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "        If Len(acClass) = 0 And Len(tx.Description) > 0 Then"
ts.WriteLine "            descUpper = UCase$(tx.Description)"
ts.WriteLine "            For j = 0 To lookupCount - 1"
ts.WriteLine "                If InStr(1, descUpper, lookupKeys(j)) > 0 Then"
ts.WriteLine "                    acClass = lookupVals(j)"
ts.WriteLine "                    Exit For"
ts.WriteLine "                End If"
ts.WriteLine "            Next j"
ts.WriteLine "        End If"
ts.WriteLine "        ' Fallback: cash patterns"
ts.WriteLine "        If Len(acClass) = 0 Then"
ts.WriteLine "            descLow = LCase$(tx.Description)"
ts.WriteLine "            If InStr(1, descLow, ""money market"") > 0 Or _"
ts.WriteLine "               InStr(1, descLow, ""ubs select government"") > 0 Then"
ts.WriteLine "                acClass = ""Cash"""
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        badge = AcBadgeHTML(acClass)"
ts.WriteLine "        desc = badge & Esc(tx.Description)"
ts.WriteLine "        If Len(tx.RefNumber) > 0 Then desc = desc & ""<br><span class=""""detail-meta"""">REF#:"" & Esc(tx.RefNumber) & ""</span>"""
ts.WriteLine "        If Len(tx.Symbol) > 0 Then desc = desc & ""<br><span class=""""detail-meta"""">SYMBOL: "" & Esc(tx.Symbol) & ""</span>"""
ts.WriteLine "        If Len(tx.Cusip) > 0 Then desc = desc & ""<br><span class=""""detail-meta"""">CUSIP: "" & Esc(tx.Cusip) & ""</span>"""
ts.WriteLine ""
ts.WriteLine "        rowParts(count) = ""<tr>"" & _"
ts.WriteLine "               ""<td style=""""white-space:nowrap;"""">"" & Esc(tx.TxDate) & ""</td>"" & _"
ts.WriteLine "               ""<td>"" & Esc(tx.Activity) & ""</td>"" & _"
ts.WriteLine "               ""<td>"" & desc & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""" style=""""white-space:nowrap;"" & CssNegV(tx.Quantity) & """""">"" & FmtQty(tx.Quantity) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""" style=""""white-space:nowrap;"" & CssNegV(tx.Price) & """""">"" & FmtPrice(tx.Price) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""" style=""""white-space:nowrap;"" & CssNeg(tx.Amount) & """""">"" & Fmt(tx.Amount) & ""</td>"" & _"
ts.WriteLine "               ""</tr>"""
ts.WriteLine "        count = count + 1"
ts.WriteLine "NextTx:"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    If count = 0 Then"
ts.WriteLine "        BuildTransactionsSection = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ReDim Preserve rowParts(0 To count - 1)"
ts.WriteLine "    BuildTransactionsSection = ""<div class=""""section"""">"" & vbLf & _"
ts.WriteLine "        ""<button class=""""section-toggle"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" onclick=""""toggleSection(this)"""">"" & _"
ts.WriteLine "        ""<span>Transactions ("" & count & "")</span><span class=""""arrow"""">&#9654;</span></button>"" & vbLf & _"
ts.WriteLine "        ""<div class=""""section-body""""><div class=""""section-pad"""">"" & vbLf & _"
ts.WriteLine "        ""<table><thead><tr><th>Date</th><th>Activity</th><th>Description</th>"" & _"
ts.WriteLine "        ""<th class=""""num"""">Quantity</th><th class=""""num"""">Price</th><th class=""""num"""">Amount</th></tr></thead><tbody>"" & vbLf & _"
ts.WriteLine "        Join(rowParts, vbLf) & vbLf & _"
ts.WriteLine "        ""</tbody></table></div></div></div>"" & vbLf"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Data Integrity Checks section"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function BuildChecksSection(ByRef ext As UBSExtract.StatementExtraction) As String"
ts.WriteLine "    If ext.CheckCount = 0 Then"
ts.WriteLine "        BuildChecksSection = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim allPass As Boolean"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim rows As String"
ts.WriteLine "    Dim chk As UBSExtract.TickAndTieCheck"
ts.WriteLine "    Dim diffHint As String"
ts.WriteLine ""
ts.WriteLine "    allPass = True"
ts.WriteLine "    Dim rowParts() As String"
ts.WriteLine "    ReDim rowParts(0 To ext.CheckCount - 1)"
ts.WriteLine ""
ts.WriteLine "    For i = 0 To ext.CheckCount - 1"
ts.WriteLine "        chk = ext.Checks(i)"
ts.WriteLine "        If Not chk.Pass Then allPass = False"
ts.WriteLine "        If chk.Pass Then"
ts.WriteLine "            diffHint = """""
ts.WriteLine "        Else"
ts.WriteLine "            diffHint = ""<br><span class=""""diff-hint"""">diff: "" & Fmt(chk.Actual - chk.Expected) & ""</span>"""
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        rowParts(i) = ""<tr><td"" & CheckTooltip(chk.Name) & "">"" & Esc(chk.Name) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""">"" & Fmt(chk.Expected) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""">"" & Fmt(chk.Actual) & ""</td>"" & _"
ts.WriteLine "               ""<td class=""""num"""">"" & Badge(chk.Pass) & diffHint & ""</td></tr>"""
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    BuildChecksSection = ""<div class=""""section"""">"" & vbLf & _"
ts.WriteLine "        ""<button class=""""section-toggle"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" onclick=""""toggleSection(this)"""">"" & _"
ts.WriteLine "        ""<span>Data Integrity Checks <span class=""""detail-meta"""">("" & ext.CheckCount & "" checks)</span> "" & _"
ts.WriteLine "        Badge(allPass) & ""</span><span class=""""arrow"""">&#9654;</span></button>"" & vbLf & _"
ts.WriteLine "        ""<div class=""""section-body""""><div class=""""section-pad"""">"" & vbLf & _"
ts.WriteLine "        ""<table><thead><tr><th>Check</th><th class=""""num"""">Expected</th>"" & _"
ts.WriteLine "        ""<th class=""""num"""">Calculated</th><th class=""""num"""">Status</th></tr></thead><tbody>"" & vbLf & _"
ts.WriteLine "        Join(rowParts, vbLf) & vbLf & _"
ts.WriteLine "        ""</tbody></table></div></div></div>"" & vbLf"
ts.WriteLine "End Function"
