ts.WriteLine "    Dim layoutPages() As String"
ts.WriteLine "    PDFTextExtract.ExtractAllPagesTextAndLayout doc, pages, layoutPages"
ts.WriteLine "    PDFCrypto.ReleaseCrypto"
ts.WriteLine "    PDFReader.CleanupPDFDocument doc"
ts.WriteLine ""
ts.WriteLine "    ' Build raw text and layout text for viewer"
ts.WriteLine "    rawText = BuildFullText(pages)"
ts.WriteLine "    Dim layoutText As String"
ts.WriteLine "    layoutText = BuildFullText(layoutPages)"
ts.WriteLine "    ViewerHTML.SetRawLayoutText layoutText"
ts.WriteLine ""
ts.WriteLine "    ExtractPDFToPortfolioWithText = DetectAndExtractPages(pages)"
ts.WriteLine "End Function"
