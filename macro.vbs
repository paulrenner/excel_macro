ts.WriteLine "' CleanupViewerWorkbooks -- close any hidden workbooks opened during viewer session"
ts.WriteLine "' ---------------------------------------------------------------------------"
ts.WriteLine "Private Sub CleanupViewerWorkbooks()"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine ""
ts.WriteLine "    ' Close QPR workbook opened via Analyze QPR (only if hidden)"
ts.WriteLine "    If Not mQprWb Is Nothing Then"
ts.WriteLine "        If Not mQprWb.Windows(1).Visible Then"
ts.WriteLine "            mQprWb.Close False"
ts.WriteLine "        End If"
ts.WriteLine "        Set mQprWb = Nothing"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Close QPR workbooks opened via Add Excel (only if hidden)"
ts.WriteLine "    If Not mQprWorkbooks Is Nothing Then"
ts.WriteLine "        Dim k As Variant"
ts.WriteLine "        For Each k In mQprWorkbooks.Keys"
ts.WriteLine "            Dim wb As Workbook"
ts.WriteLine "            Set wb = mQprWorkbooks(k)"
ts.WriteLine "            If Not wb Is Nothing Then"
ts.WriteLine "                If Not wb.Windows(1).Visible Then wb.Close False"
ts.WriteLine "            End If"
ts.WriteLine "        Next k"
ts.WriteLine "        mQprWorkbooks.RemoveAll"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Close template workbook opened via Add Template (only if hidden)"
ts.WriteLine "    If Not mTemplateWb Is Nothing Then"
ts.WriteLine "        If Not mTemplateWb.Windows(1).Visible Then"
ts.WriteLine "            mTemplateWb.Close False"
ts.WriteLine "        End If"
ts.WriteLine "        Set mTemplateWb = Nothing"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "End Sub"
