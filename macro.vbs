ts.WriteLine "        Application.StatusBar = ""Extracting layout: page "" & (i + 1) & "" of "" & doc.pageCount & ""..."""
ts.WriteLine "        pages(i) = ExtractPageLayout(doc, i)"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ExtractAllPagesLayout = pages"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' Build layout text from already-extracted items (avoids second ExtractTextItems call)"
ts.WriteLine "Private Function FormatLayoutFromItems(items() As TextItem) As String"
ts.WriteLine "    Dim itemCount As Long"
ts.WriteLine "    itemCount = UBound(items) - LBound(items) + 1"
ts.WriteLine ""
ts.WriteLine "    Dim filtered() As TextItem"
ts.WriteLine "    Dim filteredCount As Long"
ts.WriteLine "    ReDim filtered(0 To itemCount - 1)"
ts.WriteLine "    filteredCount = 0"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = LBound(items) To UBound(items)"
ts.WriteLine "        If Len(items(i).str) > 0 Then"
ts.WriteLine "            filtered(filteredCount) = items(i)"
ts.WriteLine "            filteredCount = filteredCount + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    If filteredCount = 0 Then"
ts.WriteLine "        FormatLayoutFromItems = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ReDim Preserve filtered(0 To filteredCount - 1)"
ts.WriteLine "    SortItemsByY filtered, filteredCount"
ts.WriteLine ""
ts.WriteLine "    ' Array+Join to avoid O(n^2) concatenation"
ts.WriteLine "    Dim outLines() As String"
ts.WriteLine "    ReDim outLines(0 To filteredCount + 1)"
ts.WriteLine "    outLines(0) = ""Y"" & vbTab & ""X"" & vbTab & ""W"" & vbTab & ""Text"""
ts.WriteLine "    outLines(1) = String$(60, ""-"")"
ts.WriteLine ""
ts.WriteLine "    For i = 0 To filteredCount - 1"
ts.WriteLine "        outLines(i + 2) = Format$(filtered(i).y, ""0.0"") & vbTab & _"
ts.WriteLine "                 Format$(filtered(i).x, ""0.0"") & vbTab & _"
ts.WriteLine "                 Format$(filtered(i).width, ""0.0"") & vbTab & _"
ts.WriteLine "                 filtered(i).str"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    FormatLayoutFromItems = Join(outLines, vbLf)"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' Extract text and layout for all pages in a single pass"
ts.WriteLine "' Each page calls ExtractTextItems once, then produces both text and layout output"
ts.WriteLine "Public Sub ExtractAllPagesTextAndLayout(doc As PDFReader.PDFDocument, _"
ts.WriteLine "    ByRef textPages() As String, ByRef layoutPages() As String)"
ts.WriteLine ""
ts.WriteLine "    ReDim textPages(0 To doc.pageCount - 1)"
ts.WriteLine "    ReDim layoutPages(0 To doc.pageCount - 1)"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = 0 To doc.pageCount - 1"
ts.WriteLine "        Application.StatusBar = ""Extracting text: page "" & (i + 1) & "" of "" & doc.pageCount & ""..."""
ts.WriteLine ""
ts.WriteLine "        Dim contentStream As String"
ts.WriteLine "        contentStream = PDFReader.GetPageContentStreamExpanded(doc, i)"
ts.WriteLine ""
ts.WriteLine "        Dim rotation As Long"
ts.WriteLine "        rotation = PDFReader.GetPageRotation(doc, i)"
ts.WriteLine ""
ts.WriteLine "        Dim fonts As Object"
ts.WriteLine "        Set fonts = PDFReader.GetPageFontWidths(doc, i)"
ts.WriteLine ""
ts.WriteLine "        Dim items() As TextItem"
ts.WriteLine "        items = ExtractTextItems(contentStream, rotation, fonts)"
ts.WriteLine ""
ts.WriteLine "        ' Produce reconstructed text"
ts.WriteLine "        textPages(i) = ReconstructText(items)"
ts.WriteLine ""
ts.WriteLine "        ' Produce layout debug text from same items"
ts.WriteLine "        layoutPages(i) = FormatLayoutFromItems(items)"
ts.WriteLine "    Next i"
ts.WriteLine "End Sub"
