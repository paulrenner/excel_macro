  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Single account section (grouped, outline level 1)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderAccountSection(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef ext As UBSExtract.StatementExtraction, ByVal acctIdx As Long) As Long"
  ts.WriteLine ""
  ts.WriteLine "    Dim startRow As Long"
  ts.WriteLine "    startRow = r"
  ts.WriteLine ""
  ts.WriteLine "    ' Account header"
  ts.WriteLine "    Dim acctLabel As String"
  ts.WriteLine "    acctLabel = ext.Summary.FriendlyName"
  ts.WriteLine "    If Len(acctLabel) = 0 Then acctLabel = ext.Summary.AccountName"
  ts.WriteLine "    WriteHeader ws, r, acctLabel & "" "" & ChrW$(8212) & "" "" & ext.Summary.AccountNumber & "" "" & ChrW$(8212) & "" "" & Fmt(ext.Summary.ClosingValue)"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Meta info"
  ts.WriteLine "    Dim periodStr As String"
  ts.WriteLine "    periodStr = ext.Summary.StatementPeriod"
  ts.WriteLine "    If Len(periodStr) > 0 Then"
  ts.WriteLine "        On Error Resume Next"
  ts.WriteLine "        Dim periodDt As Date"
  ts.WriteLine "        periodDt = CDate(periodStr)"
  ts.WriteLine "        If Err.Number = 0 Then"
  ts.WriteLine "            periodStr = Format$(periodDt, ""mm/dd/yy"")"
  ts.WriteLine "        Else"
  ts.WriteLine "            Err.Clear"
  ts.WriteLine "        End If"
  ts.WriteLine "        On Error GoTo 0"
  ts.WriteLine "    End If"
  ts.WriteLine "    MergeWrite ws, r, 1, 2, ""Period:  "" & periodStr"
  ts.WriteLine "    ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "    MergeWrite ws, r, 3, 7, ""Advisor:  "" & ext.Summary.FinancialAdvisor"
  ts.WriteLine "    ws.Cells(r, 3).Font.Bold = True"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Summary cards"
  ts.WriteLine "    r = RenderSummaryCards(ws, r, ext.Summary.OpeningValue, ext.Summary.ClosingValue, _"
  ts.WriteLine "        ext.Summary.NetDepositsWithdrawals, ext.Summary.DividendInterestIncome, _"
  ts.WriteLine "        ext.Summary.ChangeInMarketValue)"
  ts.WriteLine ""
  ts.WriteLine "    ' Allocation"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderAllocationTable(ws, r, ext)"
  ts.WriteLine ""
  ts.WriteLine "    ' Holdings"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderHoldingsTable(ws, r, ext)"
  ts.WriteLine ""
  ts.WriteLine "    ' Income"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderIncomeTable(ws, r, ext.Income, ""Income"")"
  ts.WriteLine ""
  ts.WriteLine "    ' Gains"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderGainsTable(ws, r, ext.Gains, ""Gains & Losses"")"
  ts.WriteLine ""
  ts.WriteLine "    ' Transactions"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderTransactionsTable(ws, r, ext)"
  ts.WriteLine ""
  ts.WriteLine "    ' Checks"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    r = RenderChecksTable(ws, r, ext)"
  ts.WriteLine ""
  ts.WriteLine "    ' Group the account section rows (outline level 1)"
  ts.WriteLine "    If r > startRow + 1 Then"
  ts.WriteLine "        ws.Rows(startRow + 1 & "":"" & r - 1).Group"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    RenderAccountSection = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Allocation table"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderAllocationTable(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef ext As UBSExtract.StatementExtraction) As Long"
  ts.WriteLine ""
  ts.WriteLine "    If ext.AllocationCount = 0 Then"
  ts.WriteLine "        RenderAllocationTable = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    WriteSubHeader ws, r, ""Asset Allocation"""
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    Dim aHdrs() As String, aSC() As Long, aEC() As Long, aAL() As Long"
  ts.WriteLine "    ReDim aHdrs(1 To 3): ReDim aSC(1 To 3): ReDim aEC(1 To 3): ReDim aAL(1 To 3)"
  ts.WriteLine "    aHdrs(1) = ""Category"": aSC(1) = 1: aEC(1) = 5: aAL(1) = -4131"
  ts.WriteLine "    aHdrs(2) = ""Value"": aSC(2) = 6: aEC(2) = 8: aAL(2) = -4152"
  ts.WriteLine "    aHdrs(3) = ""%"": aSC(3) = 9: aEC(3) = 10: aAL(3) = -4152"
  ts.WriteLine "    WriteTableHeadersMerged ws, r, aHdrs, aSC, aEC, aAL"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    Dim i As Long, totalVal As Double"
  ts.WriteLine "    For i = 0 To ext.AllocationCount - 1"
  ts.WriteLine "        If ext.Allocations(i).Value = 0 And ext.Allocations(i).Percentage = 0 Then GoTo NextAlloc"
  ts.WriteLine "        MergeWrite ws, r, 1, 5, ext.Allocations(i).Category"
  ts.WriteLine "        MergeWriteCurrency ws, r, 6, 8, ext.Allocations(i).Value"
  ts.WriteLine "        With ws.Range(ws.Cells(r, 9), ws.Cells(r, 10))"
  ts.WriteLine "            .Merge"
  ts.WriteLine "            .Value = ext.Allocations(i).Percentage / 100"
  ts.WriteLine "            .NumberFormat = ""0.00%"""
  ts.WriteLine "        End With"
  ts.WriteLine "        totalVal = totalVal + ext.Allocations(i).Value"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "NextAlloc:"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Total"
  ts.WriteLine "    MergeWrite ws, r, 1, 5, ""Total"""
  ts.WriteLine "    ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "    MergeWriteCurrency ws, r, 6, 8, totalVal"
  ts.WriteLine "    ws.Range(ws.Cells(r, 6), ws.Cells(r, 8)).Font.Bold = True"
  ts.WriteLine "    If ext.Summary.ClosingValue <> 0 Then"
  ts.WriteLine "        With ws.Range(ws.Cells(r, 9), ws.Cells(r, 10))"
  ts.WriteLine "            .Merge"
  ts.WriteLine "            .Value = totalVal / ext.Summary.ClosingValue"
  ts.WriteLine "            .NumberFormat = ""0.00%"""
  ts.WriteLine "            .Font.Bold = True"
  ts.WriteLine "        End With"
  ts.WriteLine "    End If"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    RenderAllocationTable = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "' ============================================================================"
  ts.WriteLine "' Holdings table (grouped by asset type)"
  ts.WriteLine "' ============================================================================"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderHoldingsTable(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef ext As UBSExtract.StatementExtraction) As Long"
  ts.WriteLine ""
  ts.WriteLine "    If ext.HoldingCount = 0 Then"
  ts.WriteLine "        RenderHoldingsTable = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Count total securities"
  ts.WriteLine "    Dim totalSecs As Long, i As Long, j As Long"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        totalSecs = totalSecs + ext.Holdings(i).SecurityCount"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    If totalSecs > 0 Then"
  ts.WriteLine "        WriteSubHeader ws, r, ""Holdings ("" & totalSecs & "" securities)"""
  ts.WriteLine "    Else"
  ts.WriteLine "        WriteSubHeader ws, r, ""Holdings"""
  ts.WriteLine "    End If"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    Dim hHdrs() As String, hSC() As Long, hEC() As Long, hAL() As Long"
  ts.WriteLine "    ReDim hHdrs(1 To 5): ReDim hSC(1 To 5): ReDim hEC(1 To 5): ReDim hAL(1 To 5)"
  ts.WriteLine "    hHdrs(1) = ""Name"": hSC(1) = 1: hEC(1) = 4: hAL(1) = -4131"
  ts.WriteLine "    hHdrs(2) = ""Symbol"": hSC(2) = 5: hEC(2) = 5: hAL(2) = -4108"
  ts.WriteLine "    hHdrs(3) = ""Cost Basis"": hSC(3) = 6: hEC(3) = 7: hAL(3) = -4152"
  ts.WriteLine "    hHdrs(4) = ""Unrealized G/L"": hSC(4) = 8: hEC(4) = 9: hAL(4) = -4152"
  ts.WriteLine "    hHdrs(5) = ""Value"": hSC(5) = 10: hEC(5) = 10: hAL(5) = -4152"
  ts.WriteLine "    WriteTableHeadersMerged ws, r, hHdrs, hSC, hEC, hAL"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "    ' Group holdings by AssetType"
  ts.WriteLine "    Dim grpCount As Long, gi As Long"
  ts.WriteLine "    Dim grpKeys() As String, grpValues() As Double"
  ts.WriteLine "    Dim grpCosts() As Variant, grpGLs() As Variant"
  ts.WriteLine "    Dim found As Boolean, grpKey As String"
  ts.WriteLine "    Dim hld As UBSExtract.Holding"
  ts.WriteLine ""
  ts.WriteLine "    ReDim grpKeys(0 To ext.HoldingCount - 1)"
  ts.WriteLine "    ReDim grpValues(0 To ext.HoldingCount - 1)"
  ts.WriteLine "    ReDim grpCosts(0 To ext.HoldingCount - 1)"
  ts.WriteLine "    ReDim grpGLs(0 To ext.HoldingCount - 1)"
  ts.WriteLine ""
  ts.WriteLine "    grpCount = 0"
  ts.WriteLine ""
  ts.WriteLine "    ' First pass: build groups"
  ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "        hld = ext.Holdings(i)"
  ts.WriteLine "        grpKey = hld.AssetType"
  ts.WriteLine "        If Len(grpKey) = 0 Then grpKey = hld.Name"
  ts.WriteLine ""
  ts.WriteLine "        found = False"
  ts.WriteLine "        For gi = 0 To grpCount - 1"
  ts.WriteLine "            If grpKeys(gi) = grpKey Then found = True: Exit For"
  ts.WriteLine "        Next gi"
  ts.WriteLine ""
  ts.WriteLine "        If Not found Then"
  ts.WriteLine "            gi = grpCount"
  ts.WriteLine "            grpCount = grpCount + 1"
  ts.WriteLine "            grpKeys(gi) = grpKey"
  ts.WriteLine "            grpValues(gi) = 0"
  ts.WriteLine "            grpCosts(gi) = Null"
  ts.WriteLine "            grpGLs(gi) = Null"
  ts.WriteLine "        End If"
  ts.WriteLine ""
  ts.WriteLine "        grpValues(gi) = grpValues(gi) + hld.Value"
  ts.WriteLine "        If Not IsNull(hld.CostBasis) And Not IsEmpty(hld.CostBasis) Then"
  ts.WriteLine "            If IsNull(grpCosts(gi)) Then grpCosts(gi) = CDbl(hld.CostBasis) Else grpCosts(gi) = CDbl(grpCosts(gi)) + CDbl(hld.CostBasis)"
  ts.WriteLine "        End If"
  ts.WriteLine "        If Not IsNull(hld.UnrealizedGL) And Not IsEmpty(hld.UnrealizedGL) Then"
  ts.WriteLine "            If IsNull(grpGLs(gi)) Then grpGLs(gi) = CDbl(hld.UnrealizedGL) Else grpGLs(gi) = CDbl(grpGLs(gi)) + CDbl(hld.UnrealizedGL)"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next i"
  ts.WriteLine ""
  ts.WriteLine "    ' Second pass: render groups and their securities"
  ts.WriteLine "    For gi = 0 To grpCount - 1"
  ts.WriteLine "        ' Category row — background across all GCOLS, value in col 10"
  ts.WriteLine "        MergeWrite ws, r, 1, 4, grpKeys(gi)"
  ts.WriteLine "        ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "        MergeWriteVariantCurrency ws, r, 6, 7, grpCosts(gi)"
  ts.WriteLine "        ws.Range(ws.Cells(r, 6), ws.Cells(r, 7)).Font.Bold = True"
  ts.WriteLine "        MergeWriteVariantGL ws, r, 8, 9, grpGLs(gi)"
  ts.WriteLine "        ws.Range(ws.Cells(r, 8), ws.Cells(r, 9)).Font.Bold = True"
  ts.WriteLine "        WriteCurrencyCell ws, r, 10, grpValues(gi)"
  ts.WriteLine "        ws.Cells(r, 10).Font.Bold = True"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine ""
  ts.WriteLine "        ' Securities under this group"
  ts.WriteLine "        For i = 0 To ext.HoldingCount - 1"
  ts.WriteLine "            hld = ext.Holdings(i)"
  ts.WriteLine "            Dim secKey As String"
  ts.WriteLine "            secKey = hld.AssetType"
  ts.WriteLine "            If Len(secKey) = 0 Then secKey = hld.Name"
  ts.WriteLine "            If secKey <> grpKeys(gi) Then GoTo NextHolding"
  ts.WriteLine ""
  ts.WriteLine "            For j = 0 To hld.SecurityCount - 1"
  ts.WriteLine "                Dim sec As UBSExtract.SecurityDetail"
  ts.WriteLine "                sec = hld.Securities(j)"
  ts.WriteLine "                MergeWrite ws, r, 1, 4, sec.Name"
  ts.WriteLine "                ws.Cells(r, 5).NumberFormat = ""@"""
  ts.WriteLine "                ws.Cells(r, 5).Value = sec.Symbol"
  ts.WriteLine "                ws.Cells(r, 5).HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "                MergeWriteVariantCurrency ws, r, 6, 7, sec.CostBasis"
  ts.WriteLine "                MergeWriteVariantGL ws, r, 8, 9, sec.UnrealizedGL"
  ts.WriteLine "                WriteCurrencyCell ws, r, 10, sec.Value"
  ts.WriteLine "                If sec.IsEscrow Then"
  ts.WriteLine "                    ws.Cells(r, 10).Value = sec.Value"
  ts.WriteLine "                    ws.Cells(r, 10).NumberFormat = ""$ #,##0.00;-$ #,##0.00;""""-"""""""
  ts.WriteLine "                    Dim cmt As String"
  ts.WriteLine "                    cmt = ""Escrow"""
  ts.WriteLine "                    ws.Cells(r, 10).AddComment cmt"
  ts.WriteLine "                End If"
  ts.WriteLine "                ' Insurance/annuity detail sub-row"
  ts.WriteLine "                Dim detParts() As String"
  ts.WriteLine "                Dim dp As Long"
  ts.WriteLine "                dp = 0"
  ts.WriteLine "                ReDim detParts(0 To 7)"
  ts.WriteLine "                If Not IsNull(sec.DeathBenefit) And Not IsEmpty(sec.DeathBenefit) Then"
  ts.WriteLine "                    detParts(dp) = ""Death benefit: "" & Fmt(CDbl(sec.DeathBenefit)): dp = dp + 1"
  ts.WriteLine "                End If"
  ts.WriteLine "                If Not IsNull(sec.LivingBenefit) And Not IsEmpty(sec.LivingBenefit) Then"
  ts.WriteLine "                    detParts(dp) = ""Living benefit: "" & Fmt(CDbl(sec.LivingBenefit)): dp = dp + 1"
  ts.WriteLine "                End If"
  ts.WriteLine "                If Not IsNull(sec.SurrenderValue) And Not IsEmpty(sec.SurrenderValue) Then"
  ts.WriteLine "                    detParts(dp) = ""Surrender value: "" & Fmt(CDbl(sec.SurrenderValue)): dp = dp + 1"
  ts.WriteLine "                End If"
  ts.WriteLine "                If Not IsNull(sec.TotalWithdrawal) And Not IsEmpty(sec.TotalWithdrawal) Then"
  ts.WriteLine "                    detParts(dp) = ""Total withdrawal: "" & Fmt(CDbl(sec.TotalWithdrawal)): dp = dp + 1"
  ts.WriteLine "                End If"
  ts.WriteLine "                If Len(sec.ContractNumber) > 0 Then"
  ts.WriteLine "                    detParts(dp) = ""Contract: "" & sec.ContractNumber: dp = dp + 1"
  ts.WriteLine "                End If"
  ts.WriteLine "                If Len(sec.IssueDate) > 0 Then"
  ts.WriteLine "                    detParts(dp) = ""Issue date: "" & sec.IssueDate: dp = dp + 1"
  ts.WriteLine "                End If"
  ts.WriteLine "                If dp > 0 Then"
  ts.WriteLine "                    ReDim Preserve detParts(0 To dp - 1)"
  ts.WriteLine "                    r = r + 1"
  ts.WriteLine "                    MergeWrite ws, r, 1, GCOLS, ""    "" & Join(detParts, ""  "" & ChrW$(183) & ""  "")"
  ts.WriteLine "                    ws.Cells(r, 1).Font.Size = 9"
  ts.WriteLine "                    ws.Cells(r, 1).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                End If"
  ts.WriteLine ""
  ts.WriteLine "                ' Hairline bottom border"
  ts.WriteLine "                ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).LineStyle = 1"
  ts.WriteLine "                ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).Weight = 1"
  ts.WriteLine "                ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Borders(9).Color = RGB(200, 200, 200)"
  ts.WriteLine "                r = r + 1"
  ts.WriteLine "            Next j"
  ts.WriteLine "NextHolding:"
  ts.WriteLine "        Next i"
  ts.WriteLine "    Next gi"
  ts.WriteLine ""
  ts.WriteLine "    RenderHoldingsTable = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
