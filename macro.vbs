  ts.WriteLine "Private Sub MergeWrite(ws As Worksheet, r As Long, c1 As Long, c2 As Long, ByVal val As Variant, Optional align As Long = -4131)"
  ts.WriteLine "    With ws.Range(ws.Cells(r, c1), ws.Cells(r, c2))"
