  ts.WriteLine "Private Sub WriteCurrencyCell(ws As Worksheet, r As Long, c As Long, ByVal v As Double)"
  ts.WriteLine "    ws.Cells(r, c).Value = v"
  ts.WriteLine "    ws.Cells(r, c).NumberFormat = ""$ #,##0.00;-$ #,##0.00;""""-"""""""
  ts.WriteLine "    If v < 0 Then ws.Cells(r, c).Font.Color = CLR_NEG"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Sub WriteGLCell(ws As Worksheet, r As Long, c As Long, ByVal v As Double)"
  ts.WriteLine "    ws.Cells(r, c).Value = v"
  ts.WriteLine "    ws.Cells(r, c).NumberFormat = ""$ #,##0.00;-$ #,##0.00;""""-"""""""
  ts.WriteLine "    If v > 0 Then"
  ts.WriteLine "        ws.Cells(r, c).Font.Color = CLR_POS"
  ts.WriteLine "    ElseIf v < 0 Then"
  ts.WriteLine "        ws.Cells(r, c).Font.Color = CLR_NEG"
  ts.WriteLine "    End If"
  ts.WriteLine "End Sub"
  ts.WriteLine ""
  ts.WriteLine "Private Sub WriteVariantCurrency(ws As Worksheet, r As Long, c As Long, ByVal v As Variant)"
