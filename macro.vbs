  ts.WriteLine "' ---------------------------------------------------------------------------"
  ts.WriteLine "' RenderGlobalUncovered -- show accounts not covered by ANY loaded QPR"
  ts.WriteLine "' ---------------------------------------------------------------------------"
  ts.WriteLine "Private Function RenderGlobalUncovered(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByRef globalMapped As Object) As Long"
  ts.WriteLine ""
  ts.WriteLine "    ' Collect uncovered accounts"
  ts.WriteLine "    Dim uncAccts() As QPRWriter.UncoveredAccount"
  ts.WriteLine "    Dim uncCount As Long"
  ts.WriteLine "    uncCount = 0"
  ts.WriteLine "    ReDim uncAccts(0 To 10)"
  ts.WriteLine ""
  ts.WriteLine "    Dim ai As Long"
  ts.WriteLine "    For ai = 0 To mPortfolio.AccountCount - 1"
  ts.WriteLine "        Dim acctNum As String"
  ts.WriteLine "        acctNum = mPortfolio.Accounts(ai).Extraction.Summary.AccountNumber"
  ts.WriteLine "        If Not globalMapped.Exists(acctNum) Then"
  ts.WriteLine "            If uncCount > UBound(uncAccts) Then ReDim Preserve uncAccts(0 To uncCount + 10)"
  ts.WriteLine "            uncAccts(uncCount).AccountNumber = acctNum"
  ts.WriteLine "            uncAccts(uncCount).AccountName = mPortfolio.Accounts(ai).Extraction.Summary.FriendlyName"
  ts.WriteLine "            If uncAccts(uncCount).AccountName = """" Then"
  ts.WriteLine "                uncAccts(uncCount).AccountName = mPortfolio.Accounts(ai).Extraction.Summary.AccountName"
  ts.WriteLine "            End If"
  ts.WriteLine "            uncAccts(uncCount).ClosingValue = mPortfolio.Accounts(ai).Extraction.Summary.ClosingValue"
  ts.WriteLine "            uncCount = uncCount + 1"
  ts.WriteLine "        End If"
  ts.WriteLine "    Next ai"
  ts.WriteLine ""
  ts.WriteLine "    If uncCount = 0 Then"
  ts.WriteLine "        ' All accounts covered — show pass message"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        Dim secStart As Long"
  ts.WriteLine "        secStart = r"
  ts.WriteLine "        MergeWrite ws, r, 1, GCOLS, ChrW$(10003) & "" All "" & mPortfolio.AccountCount & _"
  ts.WriteLine "            "" extracted accounts are covered by loaded QPR workbook(s)."""
  ts.WriteLine "        ws.Cells(r, 1).Font.Color = RGB(21, 87, 36)"
  ts.WriteLine "        ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "        ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_PASS_BG"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "        RenderGlobalUncovered = r"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine ""
  ts.WriteLine "    ' Render uncovered table"
  ts.WriteLine "    r = RenderUncoveredTable(ws, r, ""Uncovered Accounts ("" & uncCount & "")"", uncAccts, uncCount)"
  ts.WriteLine ""
  ts.WriteLine "    RenderGlobalUncovered = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
