  ts.WriteLine "             ""Dividend"", ""Distribution"", ""St Cap Gain"", ""Lt Cap Gain"", _"
  ts.WriteLine "             ""Receive Dtc"", ""Deliver Dtc"""
  ts.WriteLine "            IsInvestmentActivity = True"
  ts.WriteLine "        Case Else"
