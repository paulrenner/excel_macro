  ts.WriteLine "Private Function DeleteSheetIfExists(wsName As String, Optional confirm As Boolean = False) As Boolean"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Dim ws As Worksheet"
  ts.WriteLine "    Set ws = ThisWorkbook.Worksheets(wsName)"
  ts.WriteLine "    On Error GoTo 0"
  ts.WriteLine "    If ws Is Nothing Then"
  ts.WriteLine "        DeleteSheetIfExists = True"
  ts.WriteLine "        Exit Function"
  ts.WriteLine "    End If"
  ts.WriteLine "    If confirm Then"
  ts.WriteLine "        If MsgBox(""Replace existing '"" & wsName & ""' sheet?"", vbYesNo + vbQuestion, ""Confirm"") = vbNo Then"
  ts.WriteLine "            DeleteSheetIfExists = False"
  ts.WriteLine "            Exit Function"
  ts.WriteLine "        End If"
  ts.WriteLine "    End If"
  ts.WriteLine "    Application.DisplayAlerts = False"
  ts.WriteLine "    ws.Delete"
  ts.WriteLine "    Application.DisplayAlerts = True"
  ts.WriteLine "    DeleteSheetIfExists = True"
  ts.WriteLine "End Function"
