  ts.WriteLine "Public Sub SetViewerTemplate(ByVal filePath As String, ByRef portfolio As UBSSummary.PortfolioExtraction)"
  ts.WriteLine "    ' Pre-load a template workbook for batch processing (mirrors AddExcelFile template path)"
  ts.WriteLine "    Dim wbName As String"
  ts.WriteLine "    wbName = Dir(filePath)"
  ts.WriteLine "    Dim wb As Workbook"
  ts.WriteLine "    On Error Resume Next"
  ts.WriteLine "    Set wb = Workbooks(wbName)"
