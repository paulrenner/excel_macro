ts.WriteLine ""
ts.WriteLine "Public Function BuildTemplateAnalysisHTML(ByRef result As DataMapper.DataMapResult, _"
ts.WriteLine "                                          ByVal templateName As String) As String"
ts.WriteLine "    Dim h As String"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim warnCount As Long"
ts.WriteLine "    Dim phantomCount As Long"
ts.WriteLine "    Dim unmapCount As Long"
ts.WriteLine "    h = """""
ts.WriteLine ""
ts.WriteLine "    h = h & ""<div style=""""margin-top:16px;border-top:2px solid #e0e0e0;padding-top:16px;"""">"" & vbLf"
ts.WriteLine "    h = h & ""<h3 style=""""margin:0 0 12px 0;color:#1a1a2e;"""">Template Mapping: "" & Esc(templateName) & ""</h3>"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    ' Count alerts by type"
ts.WriteLine "    For i = 0 To result.AlertCount - 1"
ts.WriteLine "        Select Case result.Alerts(i).AlertType"
ts.WriteLine "            Case ""warning"": warnCount = warnCount + 1"
ts.WriteLine "            Case ""phantom"": phantomCount = phantomCount + 1"
ts.WriteLine "            Case ""unmapped"": unmapCount = unmapCount + 1"
ts.WriteLine "        End Select"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Warning alerts banner"
ts.WriteLine "    If warnCount > 0 Then"
ts.WriteLine "        h = h & ""<div class=""""qpr-warn-banner"""">"" & _"
ts.WriteLine "                ""<strong>Warnings ("" & warnCount & "")</strong>"" & _"
ts.WriteLine "                ""<div style=""""font-size:12px;margin-top:4px;"""">Issues encountered while resolving mapped fields.</div>"" & _"
ts.WriteLine "                ""<div style=""""margin-top:10px;"""">"" & vbLf"
ts.WriteLine "        h = h & ""<table class=""""qpr-table""""><thead><tr>"" & _"
ts.WriteLine "                ""<th>Account</th><th>Row</th><th>Message</th>"" & _"
ts.WriteLine "                ""</tr></thead><tbody>"" & vbLf"
ts.WriteLine "        For i = 0 To result.AlertCount - 1"
ts.WriteLine "            If result.Alerts(i).AlertType = ""warning"" Then"
ts.WriteLine "                h = h & ""<tr><td>"" & Esc(result.Alerts(i).Account) & ""</td>"" & _"
ts.WriteLine "                        ""<td>"" & IIf(result.Alerts(i).RowNum > 0, ""Row "" & result.Alerts(i).RowNum, """") & ""</td>"" & _"
ts.WriteLine "                        ""<td>"" & Esc(result.Alerts(i).Message) & ""</td></tr>"" & vbLf"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "        h = h & ""</tbody></table></div></div>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Phantom alerts banner"
ts.WriteLine "    If phantomCount > 0 Then"
ts.WriteLine "        h = h & ""<div class=""""qpr-warn-banner"""">"" & _"
ts.WriteLine "                ""<strong>Phantom Mappings ("" & phantomCount & "")</strong>"" & _"
ts.WriteLine "                ""<div style=""""font-size:12px;margin-top:4px;"""">These mapping rows matched no data in the extracted statements. Check for typos or fields that no longer exist.</div>"" & _"
ts.WriteLine "                ""<div style=""""margin-top:10px;"""">"" & vbLf"
ts.WriteLine "        h = h & ""<table class=""""qpr-table""""><thead><tr>"" & _"
ts.WriteLine "                ""<th>Account</th><th>Message</th>"" & _"
ts.WriteLine "                ""</tr></thead><tbody>"" & vbLf"
ts.WriteLine "        For i = 0 To result.AlertCount - 1"
ts.WriteLine "            If result.Alerts(i).AlertType = ""phantom"" Then"
ts.WriteLine "                h = h & ""<tr><td>"" & Esc(result.Alerts(i).Account) & ""</td>"" & _"
ts.WriteLine "                        ""<td>"" & Esc(result.Alerts(i).Message) & ""</td></tr>"" & vbLf"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "        h = h & ""</tbody></table></div></div>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Unmapped alerts banner"
ts.WriteLine "    If unmapCount > 0 Then"
ts.WriteLine "        h = h & ""<div class=""""qpr-info-banner"""">"" & _"
ts.WriteLine "                ""<strong>Unmapped Holdings ("" & unmapCount & "")</strong>"" & _"
ts.WriteLine "                ""<div style=""""font-size:12px;margin-top:4px;"""">These holdings exist in the extracted data but aren&#39;t referenced by any mapping row.</div>"" & _"
ts.WriteLine "                ""<div style=""""margin-top:10px;"""">"" & vbLf"
ts.WriteLine "        h = h & ""<table class=""""qpr-table""""><thead><tr>"" & _"
ts.WriteLine "                ""<th>Account</th><th>Security</th><th class=""""num"""">Value</th>"" & _"
ts.WriteLine "                ""</tr></thead><tbody>"" & vbLf"
ts.WriteLine "        Dim parts() As String"
ts.WriteLine "        For i = 0 To result.AlertCount - 1"
ts.WriteLine "            If result.Alerts(i).AlertType = ""unmapped"" Then"
ts.WriteLine "                parts = Split(result.Alerts(i).Message, Chr$(1))"
ts.WriteLine "                h = h & ""<tr><td>"" & Esc(result.Alerts(i).Account) & ""</td>"" & _"
ts.WriteLine "                        ""<td>"" & Esc(parts(0)) & ""</td>"" & _"
ts.WriteLine "                        ""<td class=""""num"""">"" & Esc(parts(1)) & ""</td></tr>"" & vbLf"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "        h = h & ""</tbody></table></div></div>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Cell updates table"
ts.WriteLine "    If result.ValueCount > 0 Then"
ts.WriteLine "        h = h & ""<div style=""""font-weight:600;font-size:14px;margin:12px 0 6px 0;"""">"" & _"
ts.WriteLine "                result.ValueCount & "" cell update(s) to apply:</div>"" & vbLf"
ts.WriteLine "        h = h & ""<table class=""""qpr-table""""><thead><tr>"" & _"
ts.WriteLine "                ""<th>Sheet</th><th>Cell</th><th>Source</th><th class=""""num"""">Value</th>"" & _"
ts.WriteLine "                ""</tr></thead><tbody>"" & vbLf"
ts.WriteLine "        For i = 0 To result.ValueCount - 1"
ts.WriteLine "            h = h & ""<tr><td>"" & Esc(result.Values(i).TargetSheet) & ""</td>"" & _"
ts.WriteLine "                    ""<td>"" & Esc(result.Values(i).TargetCell) & ""</td>"" & _"
ts.WriteLine "                    ""<td>"" & Esc(result.Values(i).SourceDesc) & ""</td>"""
ts.WriteLine "            If result.Values(i).IsText Then"
ts.WriteLine "                h = h & ""<td class=""""num"""">"" & Esc(result.Values(i).TextValue) & ""</td></tr>"" & vbLf"
ts.WriteLine "            Else"
ts.WriteLine "                h = h & ""<td class=""""num"""">"" & Fmt(result.Values(i).Value) & ""</td></tr>"" & vbLf"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "        h = h & ""</tbody></table>"" & vbLf"
ts.WriteLine "    Else"
ts.WriteLine "        h = h & ""<div class=""""qpr-info-banner"""">No cell updates &mdash; no mapping rows resolved to values.</div>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Apply button"
ts.WriteLine "    If result.ValueCount > 0 Then"
ts.WriteLine "        h = h & ""<button class=""""qpr-apply-btn"""" id=""""apply-template-btn"""" onclick=""""applyTemplate()"""">"" & _"
ts.WriteLine "                ""Apply "" & result.ValueCount & "" Updates to File</button>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Status area"
ts.WriteLine "    h = h & ""<div id=""""template-apply-status""""></div>"" & vbLf"
ts.WriteLine "    h = h & ""</div>"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    BuildTemplateAnalysisHTML = h"
ts.WriteLine "End Function"
