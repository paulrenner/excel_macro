  ts.WriteLine "    With ws.Range(ws.Cells(r, c1), ws.Cells(r, c2))"
  ts.WriteLine "        .Merge"
  ts.WriteLine "        .Value = v"
  ts.WriteLine "        .NumberFormat = ""$ #,##0.00;-$ #,##0.00;""""-"""""""
  ts.WriteLine "        .HorizontalAlignment = -4152  ' xlRight"
  ts.WriteLine "        If v < 0 Then .Font.Color = CLR_NEG"
  ts.WriteLine "    End With"
  ts.WriteLine "End Sub"
