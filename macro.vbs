ts.WriteLine "' ============================================================================"
ts.WriteLine "' Income extraction"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function ExtractIncome(text As String) As IncomeDetail"
ts.WriteLine "    Dim income As IncomeDetail"
ts.WriteLine ""
ts.WriteLine "    Dim startM() As String: startM = SArr(""Dividend and interest income"")"
ts.WriteLine "    Dim endM() As String: endM = SArr3(""Summary of gains and losses"", ""Your assets"", ""Account activity this month"")"
ts.WriteLine "    Dim section As String"
ts.WriteLine "    section = ExtractSection(text, startM, endM)"
ts.WriteLine ""
ts.WriteLine "    Dim lines() As String"
ts.WriteLine "    lines = Split(section, vbLf)"
ts.WriteLine ""
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    For i = LBound(lines) To UBound(lines)"
ts.WriteLine "        Dim line As String"
ts.WriteLine "        line = Trim$(lines(i))"
ts.WriteLine "        If line = """" Then GoTo NextIncomeLine"
ts.WriteLine ""
ts.WriteLine "        Dim m As Object"
ts.WriteLine ""
ts.WriteLine "        ' Taxable dividends (or plain ""Dividends"" for IRA)"
ts.WriteLine "        Set m = RegexMatch(line, ""^(?:Taxable d|D)ividends\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.TaxableDividendsMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "        ' Tax-exempt dividends"
ts.WriteLine "        Set m = RegexMatch(line, ""^Tax-exempt dividends\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.TaxExemptDividendsMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "        ' Taxable interest"
ts.WriteLine "        Set m = RegexMatch(line, ""^(?:Taxable i|I)nterest\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.TaxableInterestMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "        ' Tax-exempt interest"
ts.WriteLine "        Set m = RegexMatch(line, ""^Tax-exempt interest\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.TaxExemptInterestMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "        ' Miscellaneous"
ts.WriteLine "        Set m = RegexMatch(line, ""^Miscellaneous\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.MiscellaneousMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "        ' Prior year adjustment"
ts.WriteLine "        Set m = RegexMatch(line, ""^Prior year adjustment\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.MiscellaneousMonth = income.MiscellaneousMonth + SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "        ' Accrued interest received"
ts.WriteLine "        Set m = RegexMatch(line, ""^Total accrued interest received\s+\$?("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.AccruedInterestReceived = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "        ' Total"
ts.WriteLine "        Set m = RegexMatch(line, ""^Total dividend & interest\s+\$?("" & NUM_PAT & "")\s+\$?("" & NUM_PAT & "")"")"
ts.WriteLine "        If Not m Is Nothing Then income.TotalMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "NextIncomeLine:"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Fallback: compute total from categories"
ts.WriteLine "    If income.TotalMonth = 0# Then"
ts.WriteLine "        income.TotalMonth = income.TaxableDividendsMonth + income.TaxExemptDividendsMonth + _"
ts.WriteLine "            income.TaxableInterestMonth + income.TaxExemptInterestMonth + income.MiscellaneousMonth"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ExtractIncome = income"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Gains and Losses extraction"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function ExtractGainsLosses(text As String) As GainsAndLosses"
ts.WriteLine "    Dim gains As GainsAndLosses"
ts.WriteLine ""
ts.WriteLine "    Dim tl As String"
ts.WriteLine "    tl = LCase$(text)"
ts.WriteLine "    Dim gainsStart As Long"
ts.WriteLine "    gainsStart = InStr(1, tl, ""summary of gains and losses"")"
ts.WriteLine "    If gainsStart = 0 Then"
ts.WriteLine "        ExtractGainsLosses = gains"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim closePos As Long"
ts.WriteLine "    closePos = InStr(gainsStart, tl, ""closing account value"")"
ts.WriteLine "    If closePos = 0 Then closePos = gainsStart + SECTION_LOOKAHEAD"
ts.WriteLine "    Dim le As Long"
ts.WriteLine "    le = LineEnd(text, closePos)"
ts.WriteLine "    Dim section As String"
ts.WriteLine "    section = Mid$(text, gainsStart, le - gainsStart)"
ts.WriteLine ""
ts.WriteLine "    Dim m As Object"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(section, ""Short term\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "    If Not m Is Nothing Then"
ts.WriteLine "        gains.ShortTermRealizedMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine "        gains.ShortTermRealizedYtd = SafeFloat(m.SubMatches(1))"
ts.WriteLine "        gains.ShortTermUnrealized = SafeFloat(m.SubMatches(2))"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(section, ""Long term\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")\s+("" & NUM_PAT & "")"")"
ts.WriteLine "    If Not m Is Nothing Then"
ts.WriteLine "        gains.LongTermRealizedMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine "        gains.LongTermRealizedYtd = SafeFloat(m.SubMatches(1))"
ts.WriteLine "        gains.LongTermUnrealized = SafeFloat(m.SubMatches(2))"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(section, ""Total\s+(-?\$?[\d,]+\.\d{2})\s+(-?\$?[\d,]+\.\d{2})\s+(-?\$?[\d,]+\.\d{2})"")"
ts.WriteLine "    If Not m Is Nothing Then"
ts.WriteLine "        gains.TotalRealizedMonth = SafeFloat(m.SubMatches(0))"
ts.WriteLine "        gains.TotalRealizedYtd = SafeFloat(m.SubMatches(1))"
ts.WriteLine "        gains.TotalUnrealized = SafeFloat(m.SubMatches(2))"
ts.WriteLine "    Else"
ts.WriteLine "        gains.TotalRealizedMonth = gains.ShortTermRealizedMonth + gains.LongTermRealizedMonth"
ts.WriteLine "        gains.TotalRealizedYtd = gains.ShortTermRealizedYtd + gains.LongTermRealizedYtd"
ts.WriteLine "        gains.TotalUnrealized = gains.ShortTermUnrealized + gains.LongTermUnrealized"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ExtractGainsLosses = gains"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' Reconciliation"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub RunReconciliation(ext As StatementExtraction, Optional text As String = """")"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim act As String"
ts.WriteLine "    Dim closingValue As Double"
ts.WriteLine "    closingValue = ext.Summary.ClosingValue"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 1: reconciliation"
ts.WriteLine "    ' opening + cashActivity + market_change + accrued = closing"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim cashActivity As Double"
ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
ts.WriteLine "        act = ext.Transactions(i).Activity"
ts.WriteLine "        ' Skip investment activities"
ts.WriteLine "        If act = ""Sale"" Or act = ""Purchase"" Or act = ""Reinvestment"" Or act = ""Call Redemption"" Or act = ""Cash In Lieu"" Then"
ts.WriteLine "            ' Investment activity -- skip"
ts.WriteLine "        Else"
ts.WriteLine "            cashActivity = cashActivity + ext.Transactions(i).Amount"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Use monthly change in market value for reconciliation"
ts.WriteLine "    Dim marketChange As Double"
ts.WriteLine "    If ext.Summary.ChangeInMarketValue <> ext.Summary.ChangeInMarketValueMonth Then"
ts.WriteLine "        marketChange = ext.Summary.ChangeInMarketValueMonth"
ts.WriteLine "    Else"
ts.WriteLine "        marketChange = ext.Summary.ChangeInMarketValue"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim expectedClosing As Double"
ts.WriteLine "    expectedClosing = ext.Summary.OpeningValue + cashActivity + _"
ts.WriteLine "        marketChange + ext.Summary.ChangeInAccruedInterest + _"
ts.WriteLine "        ext.Income.AccruedInterestReceived"
ts.WriteLine ""
ts.WriteLine "    AddCheck ext, ""reconciliation"", closingValue, expectedClosing"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 2: holdings_sum"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim holdingsSum As Double"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        holdingsSum = holdingsSum + ext.Holdings(i).Value"
ts.WriteLine "    Next i"
ts.WriteLine "    AddCheck ext, ""holdings_sum"", closingValue, holdingsSum"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 3: securities_sum:{name}"
ts.WriteLine "    ' For each holding with securities, sum(securities.value) = holding.value"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim j As Long"
ts.WriteLine "    Dim secValSum As Double"
ts.WriteLine "    Dim hLabel As String"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        If ext.Holdings(i).SecurityCount > 0 Then"
ts.WriteLine "            secValSum = 0#"
ts.WriteLine "            For j = 0 To ext.Holdings(i).SecurityCount - 1"
ts.WriteLine "                secValSum = secValSum + ext.Holdings(i).Securities(j).Value"
ts.WriteLine "            Next j"
ts.WriteLine "            If ext.Holdings(i).AssetType <> """" Then"
ts.WriteLine "                hLabel = ext.Holdings(i).Name & "" ("" & ext.Holdings(i).AssetType & "")"""
ts.WriteLine "            Else"
ts.WriteLine "                hLabel = ext.Holdings(i).Name"
ts.WriteLine "            End If"
ts.WriteLine "            AddCheck ext, ""securities_sum:"" & hLabel, ext.Holdings(i).Value, secValSum"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 4: unrealized_gl"
ts.WriteLine "    ' sum(holdings.unrealized_gl) = gains.total_unrealized"
ts.WriteLine "    ' Skip if no holding has unrealized data"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim hasUnrealizedData As Boolean"
ts.WriteLine "    hasUnrealizedData = False"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        If Not IsNull(ext.Holdings(i).UnrealizedGL) Then"
ts.WriteLine "            hasUnrealizedData = True"
ts.WriteLine "            Exit For"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine "    If hasUnrealizedData Or ext.Gains.TotalUnrealized = 0 Then"
ts.WriteLine "        Dim unrealizedSum As Double"
ts.WriteLine "        unrealizedSum = 0#"
ts.WriteLine "        For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "            If Not IsNull(ext.Holdings(i).UnrealizedGL) Then"
ts.WriteLine "                unrealizedSum = unrealizedSum + CDbl(ext.Holdings(i).UnrealizedGL)"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine "        AddCheck ext, ""unrealized_gl"", ext.Gains.TotalUnrealized, unrealizedSum"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 5: income_transactions"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim incomeTxSum As Double"
ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
ts.WriteLine "        act = ext.Transactions(i).Activity"
ts.WriteLine "        If (act = ""Dividend"" Or act = ""Interest"" Or act = ""Distribution"" Or act = ""St Cap Gain"" Or act = ""Lt Cap Gain"") Then"
ts.WriteLine "            If ext.Transactions(i).Amount > 0 Then"
ts.WriteLine "                incomeTxSum = incomeTxSum + ext.Transactions(i).Amount"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine "    AddCheck ext, ""income_transactions"", ext.Income.TotalMonth, incomeTxSum + ext.Income.AccruedInterestReceived"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 6: asset_allocation_sum"
ts.WriteLine "    ' sum(allocation.value) = closing_value"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim hasAllocations As Boolean"
ts.WriteLine "    hasAllocations = False"
ts.WriteLine "    Dim allocValSum As Double"
ts.WriteLine "    allocValSum = 0#"
ts.WriteLine "    For i = 0 To 6  ' Always 7 allocation categories"
ts.WriteLine "        If ext.Allocations(i).Value <> 0 Or ext.Allocations(i).Percentage <> 0 Then"
ts.WriteLine "            hasAllocations = True"
ts.WriteLine "        End If"
ts.WriteLine "        allocValSum = allocValSum + ext.Allocations(i).Value"
ts.WriteLine "    Next i"
ts.WriteLine "    If hasAllocations Then"
ts.WriteLine "        AddCheck ext, ""asset_allocation_sum"", closingValue, allocValSum"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 7: realized_gains_month"
ts.WriteLine "    ' short + long realized month = total realized month"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    If ext.Gains.TotalRealizedMonth <> 0 Or ext.Gains.ShortTermRealizedMonth <> 0 Or ext.Gains.LongTermRealizedMonth <> 0 Then"
ts.WriteLine "        AddCheck ext, ""realized_gains_month"", ext.Gains.TotalRealizedMonth, _"
ts.WriteLine "            ext.Gains.ShortTermRealizedMonth + ext.Gains.LongTermRealizedMonth"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 8: realized_gains_ytd"
ts.WriteLine "    ' short + long realized YTD = total realized YTD"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    If ext.Gains.TotalRealizedYtd <> 0 Or ext.Gains.ShortTermRealizedYtd <> 0 Or ext.Gains.LongTermRealizedYtd <> 0 Then"
ts.WriteLine "        AddCheck ext, ""realized_gains_ytd"", ext.Gains.TotalRealizedYtd, _"
ts.WriteLine "            ext.Gains.ShortTermRealizedYtd + ext.Gains.LongTermRealizedYtd"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 9: detail_rollup"
ts.WriteLine "    ' sum(security values for non-cash) + cash holding values = closing_value"
ts.WriteLine "    ' Cash holdings = ""Cash and money balances"", ""Money market funds"", ""Total accrued interest"""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim detailSum As Double"
ts.WriteLine "    Dim hName As String"
ts.WriteLine "    detailSum = 0#"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        hName = ext.Holdings(i).Name"
ts.WriteLine "        If hName = ""Cash and money balances"" Or hName = ""Money market funds"" Or hName = ""Total accrued interest"" Then"
ts.WriteLine "            ' Cash-like holding -- use holding value directly"
ts.WriteLine "            detailSum = detailSum + ext.Holdings(i).Value"
ts.WriteLine "        Else"
ts.WriteLine "            ' Non-cash -- must contribute sum(securities.value); 0 if no securities (exposing gap)"
ts.WriteLine "            For j = 0 To ext.Holdings(i).SecurityCount - 1"
ts.WriteLine "                detailSum = detailSum + ext.Holdings(i).Securities(j).Value"
ts.WriteLine "            Next j"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine "    AddCheck ext, ""detail_rollup"", closingValue, detailSum"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 10: income_categories_sum_month"
ts.WriteLine "    ' sum(income categories) + accrued_interest_received = total_month"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim catSum As Double"
ts.WriteLine "    catSum = ext.Income.TaxableDividendsMonth + ext.Income.TaxExemptDividendsMonth _"
ts.WriteLine "        + ext.Income.TaxableInterestMonth + ext.Income.TaxExemptInterestMonth _"
ts.WriteLine "        + ext.Income.MiscellaneousMonth + ext.Income.AccruedInterestReceived"
ts.WriteLine "    If catSum <> 0 And ext.Income.TotalMonth <> 0 Then"
ts.WriteLine "        AddCheck ext, ""income_categories_sum_month"", ext.Income.TotalMonth, catSum"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 11: unrealized_components"
ts.WriteLine "    ' short + long unrealized = total unrealized"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    If ext.Gains.TotalUnrealized <> 0 Or ext.Gains.ShortTermUnrealized <> 0 Or ext.Gains.LongTermUnrealized <> 0 Then"
ts.WriteLine "        AddCheck ext, ""unrealized_components"", ext.Gains.TotalUnrealized, _"
ts.WriteLine "            ext.Gains.ShortTermUnrealized + ext.Gains.LongTermUnrealized"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 12: securities_cost_basis:{name}"
ts.WriteLine "    ' Per holding: sum(securities.cost_basis) = holding.cost_basis"
ts.WriteLine "    ' Skip if holding cost_basis is null or any security has null cost_basis"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim allSecHaveCB As Boolean"
ts.WriteLine "    Dim secCBSum As Double"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        If ext.Holdings(i).SecurityCount = 0 Then GoTo NextCB"
ts.WriteLine "        If IsNull(ext.Holdings(i).CostBasis) Then GoTo NextCB"
ts.WriteLine "        allSecHaveCB = True"
ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
ts.WriteLine "            If IsNull(ext.Holdings(i).Securities(j).CostBasis) Then"
ts.WriteLine "                allSecHaveCB = False"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "        If Not allSecHaveCB Then GoTo NextCB"
ts.WriteLine "        secCBSum = 0#"
ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
ts.WriteLine "            secCBSum = secCBSum + CDbl(ext.Holdings(i).Securities(j).CostBasis)"
ts.WriteLine "        Next j"
ts.WriteLine "        If ext.Holdings(i).AssetType <> """" Then"
ts.WriteLine "            hLabel = ext.Holdings(i).Name & "" ("" & ext.Holdings(i).AssetType & "")"""
ts.WriteLine "        Else"
ts.WriteLine "            hLabel = ext.Holdings(i).Name"
ts.WriteLine "        End If"
ts.WriteLine "        AddCheck ext, ""securities_cost_basis:"" & hLabel, CDbl(ext.Holdings(i).CostBasis), secCBSum"
ts.WriteLine "NextCB:"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 13: securities_unrealized:{name}"
ts.WriteLine "    ' Per holding: sum(securities.unrealized_gl) = holding.unrealized_gl"
ts.WriteLine "    ' Skip if holding unrealized_gl is null or any security has null unrealized_gl"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim allSecHaveUR As Boolean"
ts.WriteLine "    Dim secURSum As Double"
ts.WriteLine "    For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "        If ext.Holdings(i).SecurityCount = 0 Then GoTo NextUR"
ts.WriteLine "        If IsNull(ext.Holdings(i).UnrealizedGL) Then GoTo NextUR"
ts.WriteLine "        allSecHaveUR = True"
ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
ts.WriteLine "            If IsNull(ext.Holdings(i).Securities(j).UnrealizedGL) Then"
ts.WriteLine "                allSecHaveUR = False"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "        If Not allSecHaveUR Then GoTo NextUR"
ts.WriteLine "        secURSum = 0#"
ts.WriteLine "        For j = 0 To ext.Holdings(i).SecurityCount - 1"
ts.WriteLine "            secURSum = secURSum + CDbl(ext.Holdings(i).Securities(j).UnrealizedGL)"
ts.WriteLine "        Next j"
ts.WriteLine "        If ext.Holdings(i).AssetType <> """" Then"
ts.WriteLine "            hLabel = ext.Holdings(i).Name & "" ("" & ext.Holdings(i).AssetType & "")"""
ts.WriteLine "        Else"
ts.WriteLine "            hLabel = ext.Holdings(i).Name"
ts.WriteLine "        End If"
ts.WriteLine "        AddCheck ext, ""securities_unrealized:"" & hLabel, CDbl(ext.Holdings(i).UnrealizedGL), secURSum"
ts.WriteLine "NextUR:"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 14: asset_allocation_pct"
ts.WriteLine "    ' sum(allocation.percentage) approximately = 100% (tolerance: abs(sum - 100) < 0.05)"
ts.WriteLine "    ' Skip for zero-balance accounts"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    If hasAllocations And closingValue <> 0 Then"
ts.WriteLine "        Dim pctSum As Double"
ts.WriteLine "        pctSum = 0#"
ts.WriteLine "        For i = 0 To 6"
ts.WriteLine "            pctSum = pctSum + ext.Allocations(i).Percentage"
ts.WriteLine "        Next i"
ts.WriteLine "        AddCheckEx ext, ""asset_allocation_pct"", 100#, pctSum, (Abs(pctSum - 100#) < 0.05)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Check 15: deposits_transferred_in"
ts.WriteLine "    ' account_summary.deposits_transferred_in = sum(Deposit txns excl ATM FEE REBATE + positive Transfer txns)"
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    Dim depositTxSum As Double"
ts.WriteLine "    depositTxSum = 0#"
ts.WriteLine "    For i = 0 To ext.TransactionCount - 1"
ts.WriteLine "        act = ext.Transactions(i).Activity"
ts.WriteLine "        If act = ""Deposit"" And ext.Transactions(i).Description <> ""ATM FEE REBATE"" Then"
ts.WriteLine "            depositTxSum = depositTxSum + ext.Transactions(i).Amount"
ts.WriteLine "        ElseIf act = ""Transfer"" And ext.Transactions(i).Amount > 0 Then"
ts.WriteLine "            depositTxSum = depositTxSum + ext.Transactions(i).Amount"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine "    If ext.Summary.DepositsTransferredIn <> 0 Or depositTxSum <> 0 Then"
ts.WriteLine "        AddCheck ext, ""deposits_transferred_in"", ext.Summary.DepositsTransferredIn, depositTxSum"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    ' Checks 16-20: Cash activity summary cross-validation"
ts.WriteLine "    ' These compare the ""Cash activity summary"" section (independent data source)"
ts.WriteLine "    ' against extracted transactions and holdings."
ts.WriteLine "    ' ---------------------------------------------------------------"
ts.WriteLine "    If Len(text) > 0 Then"
ts.WriteLine "        Dim cashClosing As Variant"
ts.WriteLine "        Dim cashDeposits As Variant"
ts.WriteLine "        Dim cashProceeds As Variant"
ts.WriteLine "        Dim cashInvested As Variant"
ts.WriteLine "        Dim cashCardPay As Variant"
ts.WriteLine "        ExtractCashActivitySummary text, cashClosing, cashDeposits, cashProceeds, cashInvested, cashCardPay"
ts.WriteLine ""
ts.WriteLine "        ' Check 16: cash_closing"
ts.WriteLine "        ' Cash activity ""Closing balances"" = ""Cash and money balances"" holding value"
ts.WriteLine "        If Not IsNull(cashClosing) Then"
ts.WriteLine "            Dim cashHoldingVal As Variant"
ts.WriteLine "            cashHoldingVal = Null"
ts.WriteLine "            For i = 0 To ext.HoldingCount - 1"
ts.WriteLine "                If ext.Holdings(i).Name = ""Cash and money balances"" Then"
ts.WriteLine "                    cashHoldingVal = ext.Holdings(i).Value"
ts.WriteLine "                    Exit For"
ts.WriteLine "                End If"
ts.WriteLine "            Next i"
ts.WriteLine "            If Not IsNull(cashHoldingVal) Then"
ts.WriteLine "                AddCheck ext, ""cash_closing"", CDbl(cashClosing), CDbl(cashHoldingVal)"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Single pass over transactions to classify into cash activity buckets"
ts.WriteLine "        Dim cDepositSum As Double"
ts.WriteLine "        Dim cSaleSum As Double"
ts.WriteLine "        Dim cInvestedSum As Double"
ts.WriteLine "        Dim cCardSum As Double"
ts.WriteLine "        cDepositSum = 0#"
ts.WriteLine "        cSaleSum = 0#"
ts.WriteLine "        cInvestedSum = 0#"
ts.WriteLine "        cCardSum = 0#"
ts.WriteLine "        For i = 0 To ext.TransactionCount - 1"
ts.WriteLine "            act = ext.Transactions(i).Activity"
ts.WriteLine "            If act = ""Deposit"" And ext.Transactions(i).Description <> ""ATM FEE REBATE"" Then"
ts.WriteLine "                cDepositSum = cDepositSum + ext.Transactions(i).Amount"
ts.WriteLine "            ElseIf act = ""Transfer"" And ext.Transactions(i).Amount > 0 Then"
ts.WriteLine "                cDepositSum = cDepositSum + ext.Transactions(i).Amount"
ts.WriteLine "            ElseIf act = ""Sale"" Or act = ""Call Redemption"" Or act = ""Cash In Lieu"" Then"
ts.WriteLine "                cSaleSum = cSaleSum + ext.Transactions(i).Amount"
ts.WriteLine "            ElseIf act = ""Purchase"" Or act = ""Reinvestment"" Then"
ts.WriteLine "                cInvestedSum = cInvestedSum + ext.Transactions(i).Amount"
ts.WriteLine "            ElseIf act = ""Credit Card Payment"" Or act = ""Card Purchase"" Then"
ts.WriteLine "                cCardSum = cCardSum + ext.Transactions(i).Amount"
ts.WriteLine "            End If"
ts.WriteLine "        Next i"
ts.WriteLine ""
ts.WriteLine "        ' Check 17: cash_deposits"
ts.WriteLine "        ' Cash activity deposits = sum(Deposit + Transfer-in txns, excl ATM FEE REBATE)"
ts.WriteLine "        ' Skipped when securities transfers are detected (deposits_transferred_in != cash deposits)"
ts.WriteLine "        If Not IsNull(cashDeposits) Then"
ts.WriteLine "            Dim hasSecTransfers As Boolean"
ts.WriteLine "            hasSecTransfers = (Abs(Round((ext.Summary.DepositsTransferredIn - CDbl(cashDeposits)) * 100, 0)) <> 0)"
ts.WriteLine "            If Not hasSecTransfers Then"
ts.WriteLine "                AddCheck ext, ""cash_deposits"", CDbl(cashDeposits), cDepositSum"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Check 18: cash_proceeds"
ts.WriteLine "        ' Cash activity proceeds = sum(Sale + Call Redemption + Cash In Lieu txn amounts)"
ts.WriteLine "        If Not IsNull(cashProceeds) Then"
ts.WriteLine "            AddCheck ext, ""cash_proceeds"", CDbl(cashProceeds), cSaleSum"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Check 19: cash_invested"
ts.WriteLine "        ' Cash activity funds invested = sum(Purchase + Reinvestment amounts)"
ts.WriteLine "        If Not IsNull(cashInvested) Then"
ts.WriteLine "            AddCheck ext, ""cash_invested"", CDbl(cashInvested), cInvestedSum"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        ' Check 20: cash_card_payments"
ts.WriteLine "        ' Cash activity card payments = sum(Credit Card Payment + Card Purchase amounts)"
ts.WriteLine "        If Not IsNull(cashCardPay) Then"
ts.WriteLine "            AddCheck ext, ""cash_card_payments"", CDbl(cashCardPay), cCardSum"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' Extract cash activity summary values from raw statement text."
ts.WriteLine "' Returns Null for any value not found in the text."
ts.WriteLine "Private Sub ExtractCashActivitySummary(text As String, _"
ts.WriteLine "    ByRef closingBalance As Variant, ByRef deposits As Variant, _"
ts.WriteLine "    ByRef proceeds As Variant, ByRef fundsInvested As Variant, _"
ts.WriteLine "    ByRef cardPayments As Variant)"
ts.WriteLine ""
ts.WriteLine "    closingBalance = Null"
ts.WriteLine "    deposits = Null"
ts.WriteLine "    proceeds = Null"
ts.WriteLine "    fundsInvested = Null"
ts.WriteLine "    cardPayments = Null"
ts.WriteLine ""
ts.WriteLine "    Dim m As Object"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(text, ""Closing balances\s+\$([\d,]+\.\d{2})"")"
ts.WriteLine "    If Not m Is Nothing Then closingBalance = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(text, ""Deposits and other funds credited\s+([\d,]+\.\d{2})"")"
ts.WriteLine "    If Not m Is Nothing Then deposits = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(text, ""Proceeds from investment transactions\s+([\d,]+\.\d{2})"")"
ts.WriteLine "    If Not m Is Nothing Then proceeds = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(text, ""bought\s+(-?[\d,]+\.\d{2})"")"
ts.WriteLine "    If Not m Is Nothing Then fundsInvested = SafeFloat(m.SubMatches(0))"
ts.WriteLine ""
ts.WriteLine "    Set m = RegexMatch(text, ""Card payments\s+(-?[\d,]+\.\d{2})"")"
ts.WriteLine "    If Not m Is Nothing Then cardPayments = SafeFloat(m.SubMatches(0))"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "Private Sub AddCheck(ext As StatementExtraction, checkName As String, expected As Double, actual As Double)"
ts.WriteLine "    If ext.CheckCount > UBound(ext.Checks) Then ReDim Preserve ext.Checks(0 To ext.CheckCount + 10)"
ts.WriteLine "    ext.Checks(ext.CheckCount).name = checkName"
ts.WriteLine "    ext.Checks(ext.CheckCount).Expected = expected"
ts.WriteLine "    ext.Checks(ext.CheckCount).Actual = actual"
ts.WriteLine "    ext.Checks(ext.CheckCount).Diff = Round(expected - actual, 2)"
ts.WriteLine "    ext.Checks(ext.CheckCount).Pass = (Abs(Round((expected - actual) * 100, 0)) = 0)"
ts.WriteLine "    ext.CheckCount = ext.CheckCount + 1"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "Private Sub AddCheckEx(ext As StatementExtraction, checkName As String, expected As Double, actual As Double, passed As Boolean)"
ts.WriteLine "    If ext.CheckCount > UBound(ext.Checks) Then ReDim Preserve ext.Checks(0 To ext.CheckCount + 10)"
ts.WriteLine "    ext.Checks(ext.CheckCount).name = checkName"
ts.WriteLine "    ext.Checks(ext.CheckCount).Expected = expected"
ts.WriteLine "    ext.Checks(ext.CheckCount).Actual = actual"
ts.WriteLine "    ext.Checks(ext.CheckCount).Diff = Round(expected - actual, 2)"
ts.WriteLine "    ext.Checks(ext.CheckCount).Pass = passed"
ts.WriteLine "    ext.CheckCount = ext.CheckCount + 1"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.WriteLine "' Validate extraction completeness -- flag warnings when expected sections appear"
ts.WriteLine "' in the raw text but nothing was extracted (likely SafeFloat masking missing data)"
ts.WriteLine "Private Sub ValidateExtraction(ByRef ext As StatementExtraction, ByVal text As String)"
ts.WriteLine "    ' Warn if both opening and closing are zero on a non-loan account"
ts.WriteLine "    ' (loan accounts legitimately lack these values)"
ts.WriteLine "    If ext.Summary.OpeningValue = 0 And ext.Summary.ClosingValue = 0 Then"
ts.WriteLine "        ' Only warn if the text doesn't literally show $0.00 values"
ts.WriteLine "        If InStr(1, text, ""Account value"", vbTextCompare) > 0 Or _"
ts.WriteLine "           InStr(1, text, ""Your assets"", vbTextCompare) > 0 Then"
ts.WriteLine "            If InStr(1, text, ""0.00"" & vbLf, vbTextCompare) = 0 Then"
ts.WriteLine "                AddCheckEx ext, ""completeness:summary_values"", 1, 0, False"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if ""Asset allocation"" header present but no allocations extracted"
ts.WriteLine "    If InStr(1, text, ""Asset allocation"", vbTextCompare) > 0 Then"
ts.WriteLine "        Dim allocFound As Long"
ts.WriteLine "        Dim ai As Long"
ts.WriteLine "        For ai = 0 To ext.AllocationCount - 1"
ts.WriteLine "            If ext.Allocations(ai).Value <> 0 Then allocFound = allocFound + 1"
ts.WriteLine "        Next ai"
ts.WriteLine "        If allocFound = 0 Then"
ts.WriteLine "            AddCheckEx ext, ""completeness:asset_allocation"", 1, 0, False"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if ""Holdings"" section header present but no holdings extracted"
ts.WriteLine "    If InStr(1, text, ""Holdings"", vbTextCompare) > 0 And ext.HoldingCount = 0 Then"
ts.WriteLine "        ' Exclude cases where only ""Cash and money balances"" appears (no holdings expected)"
ts.WriteLine "        If InStr(1, text, ""Common stock"", vbTextCompare) > 0 Or _"
ts.WriteLine "           InStr(1, text, ""Municipal securities"", vbTextCompare) > 0 Or _"
ts.WriteLine "           InStr(1, text, ""Money market funds"", vbTextCompare) > 0 Or _"
ts.WriteLine "           InStr(1, text, ""Private equity"", vbTextCompare) > 0 Then"
ts.WriteLine "            AddCheckEx ext, ""completeness:holdings"", 1, 0, False"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if transaction date patterns exist but no transactions extracted"
ts.WriteLine "    If ext.TransactionCount = 0 Then"
ts.WriteLine "        Dim rxTxDate As Object"
ts.WriteLine "        Set rxTxDate = RegexMatch(text, ""\d{2}/\d{2}/\d{2,4}\s+(Buy|Sell|Dividend|Interest|Transfer|Reinvest)"")"
ts.WriteLine "        If Not rxTxDate Is Nothing Then"
ts.WriteLine "            AddCheckEx ext, ""completeness:transactions"", 1, 0, False"
ts.WriteLine "        End If"
ts.WriteLine "        Set rxTxDate = Nothing"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if statement period was not extracted"
ts.WriteLine "    If Len(ext.Summary.StatementPeriod) = 0 Then"
ts.WriteLine "        AddCheckEx ext, ""completeness:statement_period"", 1, 0, False"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if account number was not extracted"
ts.WriteLine "    If Len(ext.Summary.AccountNumber) = 0 Then"
ts.WriteLine "        AddCheckEx ext, ""completeness:account_identity"", 1, 0, False"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if income header present but nothing extracted"
ts.WriteLine "    If InStr(1, text, ""Dividend and interest income"", vbTextCompare) > 0 Then"
ts.WriteLine "        If ext.Income.TotalMonth = 0 Then"
ts.WriteLine "            Dim incPos As Long"
ts.WriteLine "            incPos = InStr(1, text, ""Dividend and interest income"", vbTextCompare)"
ts.WriteLine "            Dim incSlice As String"
ts.WriteLine "            incSlice = Mid$(text, incPos, 500)"
ts.WriteLine "            If Not RegexMatch(incSlice, ""\d+\.\d{2}"") Is Nothing Then"
ts.WriteLine "                AddCheckEx ext, ""completeness:income"", 1, 0, False"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if gains header present but nothing extracted"
ts.WriteLine "    If InStr(1, text, ""Summary of gains and losses"", vbTextCompare) > 0 Then"
ts.WriteLine "        If ext.Gains.TotalRealizedMonth = 0 And ext.Gains.TotalRealizedYtd = 0 _"
ts.WriteLine "           And ext.Gains.TotalUnrealized = 0 Then"
ts.WriteLine "            Dim gainsPos As Long"
ts.WriteLine "            gainsPos = InStr(1, text, ""Summary of gains and losses"", vbTextCompare)"
ts.WriteLine "            Dim gainsSlice As String"
ts.WriteLine "            gainsSlice = Mid$(text, gainsPos, 500)"
ts.WriteLine "            If Not RegexMatch(gainsSlice, ""\d+\.\d{2}"") Is Nothing Then"
ts.WriteLine "                AddCheckEx ext, ""completeness:gains"", 1, 0, False"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Warn if too few major section headers found (possible format change)"
ts.WriteLine "    Dim hdrCount As Long"
ts.WriteLine "    hdrCount = 0"
ts.WriteLine "    If InStr(1, text, ""Account name:"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
ts.WriteLine "    If InStr(1, text, ""Your assets"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
ts.WriteLine "    If InStr(1, text, ""Summary of your assets"", vbTextCompare) > 0 Or _"
ts.WriteLine "       InStr(1, text, ""Your total assets"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
ts.WriteLine "    If InStr(1, text, ""Account activity this month"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
ts.WriteLine "    If InStr(1, text, ""Dividend and interest income"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
ts.WriteLine "    If InStr(1, text, ""Summary of gains and losses"", vbTextCompare) > 0 Then hdrCount = hdrCount + 1"
ts.WriteLine "    If hdrCount < 3 Then"
ts.WriteLine "        AddCheckEx ext, ""completeness:section_headers"", 3, CDbl(hdrCount), False"
ts.WriteLine "    End If"
ts.WriteLine "End Sub"
ts.WriteLine ""
