ts.WriteLine "' RenderAndReload -- rebuild HTML and reload the browser"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Sub RenderAndReload(ByRef browser As Object)"
ts.WriteLine "    Dim secs(1 To 1) As QPRWriter.UnclassifiedSecurity"
ts.WriteLine "    Dim allocOpts() As String"
ts.WriteLine "    Dim allocOptCount As Long"
ts.WriteLine "    allocOptCount = 0"
ts.WriteLine "    If Not mQprWb Is Nothing Then"
ts.WriteLine "        allocOptCount = QPRWriter.ReadMasterAssetClassNames(mQprWb, allocOpts)"
ts.WriteLine "    End If"
ts.WriteLine "    If allocOptCount = 0 Then"
ts.WriteLine "        ReDim allocOpts(1 To 1)"
ts.WriteLine "        allocOpts(1) = ""Other"""
ts.WriteLine "        allocOptCount = 1"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Set raw text for viewer"
ts.WriteLine "    ViewerHTML.SetRawPageText mAccumulatedRawText"
ts.WriteLine "    ViewerHTML.SetRawLayoutText mAccumulatedLayoutText"
ts.WriteLine ""
ts.WriteLine "    ' Build coverage HTML if applicable"
ts.WriteLine "    Dim coverageHTML As String"
ts.WriteLine "    coverageHTML = """""
ts.WriteLine "    If mHasCoverage Then"
ts.WriteLine "        Dim coverageResult As UBSSummary.CoverageResult"
ts.WriteLine "        coverageResult = UBSSummary.BuildCoverageCheck(mSummaryRefs, mAccumulatedPortfolio)"
ts.WriteLine "        coverageHTML = ViewerHTML.BuildCoverageSection(coverageResult, True)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Find unclassified securities if QPR is loaded"
ts.WriteLine "    Dim unclassified() As QPRWriter.UnclassifiedSecurity"
ts.WriteLine "    Dim unclassCount As Long"
ts.WriteLine "    ReDim unclassified(1 To 1)"
ts.WriteLine "    unclassCount = 0"
ts.WriteLine "    If Not mQprWb Is Nothing Then"
ts.WriteLine "        unclassCount = QPRWriter.FindUnclassifiedSecurities(mAccumulatedPortfolio, mQprWb, unclassified)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Render full HTML"
ts.WriteLine "    Dim html As String"
ts.WriteLine "    If unclassCount > 0 Then"
ts.WriteLine "        html = ViewerHTML.RenderPortfolioWithUnclassifiedHTML( _"
ts.WriteLine "            mAccumulatedPortfolio, unclassified, unclassCount, allocOpts, allocOptCount, coverageHTML)"
ts.WriteLine "    Else"
ts.WriteLine "        html = ViewerHTML.RenderPortfolioWithUnclassifiedHTML( _"
ts.WriteLine "            mAccumulatedPortfolio, secs, 0, allocOpts, allocOptCount, coverageHTML)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Patch for VBA polling"
ts.WriteLine "    html = PatchHTMLForPolling(html)"
ts.WriteLine ""
ts.WriteLine "    ' Reload browser content"
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    browser.Document.Open"
ts.WriteLine "    browser.Document.Write html"
ts.WriteLine "    browser.Document.Close"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine ""
ts.WriteLine "    ' Update mPortfolio for QPR analysis"
ts.WriteLine "    mPortfolio = mAccumulatedPortfolio"
ts.WriteLine ""
ts.WriteLine "    ' Re-inject QPR analysis if loaded"
ts.WriteLine "    If Not mQprWb Is Nothing Then"
ts.WriteLine "        Dim analysis As QPRWriter.QprAnalysis"
ts.WriteLine "        analysis = QPRWriter.AnalyzeQPR(mPortfolio, mQprWb, mOverrides)"
ts.WriteLine "        Dim analysisHTML As String"
ts.WriteLine "        analysisHTML = ViewerHTML.BuildQPRAnalysisHTML(analysis)"
ts.WriteLine "        InjectHTML browser, ""qpr-analysis"", analysisHTML"
ts.WriteLine "        InjectJS browser, ""document.getElementById('qpr-analysis').style.display='block';"""
ts.WriteLine "        InjectJS browser, ""var z=document.getElementById('qpr-load-zone'); if(z) z.style.display='none';"""
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Re-inject uncovered accounts from multi-QPR"
ts.WriteLine "    If mQprWorkbooks.count > 0 Then"
