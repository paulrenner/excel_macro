ts.WriteLine "' ============================================================================"
ts.WriteLine "' Show Extracted Fields: discover available field paths from a PDF"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub ShowExtractedFields()"
ts.WriteLine "    ' Prompt for PDF"
ts.WriteLine "    Dim fileResult As Variant"
ts.WriteLine "    fileResult = Application.GetOpenFilename( _"
ts.WriteLine "        FileFilter:=""PDF Files (*.pdf), *.pdf"", _"
ts.WriteLine "        Title:=""Select PDF to inspect fields"")"
ts.WriteLine "    If fileResult = False Then Exit Sub"
ts.WriteLine "    Dim filePath As String"
ts.WriteLine "    filePath = CStr(fileResult)"
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = ""Extracting PDF..."""
ts.WriteLine "    Application.ScreenUpdating = False"
ts.WriteLine "    On Error GoTo FieldsError"
ts.WriteLine ""
ts.WriteLine "    ' Extract"
ts.WriteLine "    Dim portfolio As UBSSummary.PortfolioExtraction"
ts.WriteLine "    portfolio = ExtractPDFToPortfolio(filePath)"
ts.WriteLine ""
ts.WriteLine "    ' Cleanup caches"
ts.WriteLine "    PDFDeflate.ClearInflateCache"
ts.WriteLine "    RegexHelper.ClearRegexCache"
ts.WriteLine ""
ts.WriteLine "    If portfolio.AccountCount = 0 Then"
ts.WriteLine "        MsgBox ""No accounts extracted from PDF."", vbExclamation, ""Show Extracted Fields"""
ts.WriteLine "        GoTo FieldsCleanup"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = ""Writing fields sheet..."""
ts.WriteLine ""
ts.WriteLine "    ' Extract filename for display"
ts.WriteLine "    Dim pdfName As String"
ts.WriteLine "    pdfName = Mid$(filePath, InStrRev(filePath, ""\"") + 1)"
ts.WriteLine ""
ts.WriteLine "    ' Write fields sheet"
ts.WriteLine "    Dim targetWb As Workbook"
ts.WriteLine "    Set targetWb = ActiveWorkbook"
ts.WriteLine "    DataMapper.WriteFieldsSheet portfolio, targetWb, pdfName"
ts.WriteLine ""
ts.WriteLine "    MsgBox ""Fields sheet created!"" & vbCrLf & vbCrLf & _"
ts.WriteLine "           ""See the '_Fields' sheet for all available field paths."" & vbCrLf & _"
ts.WriteLine "           ""Copy field paths into your _DataMap sheet to build mappings."", _"
ts.WriteLine "           vbInformation, ""Show Extracted Fields"""
ts.WriteLine "    GoTo FieldsCleanup"
ts.WriteLine ""
ts.WriteLine "FieldsError:"
ts.WriteLine "    PDFCrypto.ReleaseCrypto"
ts.WriteLine "    MsgBox ""Error: "" & Err.Description, vbCritical, ""Show Extracted Fields"""
ts.WriteLine ""
ts.WriteLine "FieldsCleanup:"
ts.WriteLine "    Application.StatusBar = False"
ts.WriteLine "    Application.ScreenUpdating = True"
ts.WriteLine "End Sub"
ts.WriteLine ""
ts.Close

Dim modules
modules = Array("RegexHelper.bas", "PDFCrypto.bas", "PDFDeflate.bas", "PDFReader.bas", _
                "PDFTextExtract.bas", "UBSExtract.bas", "UBSLoanExtract.bas", "UBSSummary.bas", _
                "QPRWriter.bas", "DataMapper.bas", "ViewerHTML.bas", "ViewerFormLauncher.bas", _
                "PDFExtractorMain.bas")

If fso.FileExists(xlsmPath) Then fso.DeleteFile xlsmPath
Err.Clear

Set xl = CreateObject("Excel.Application")
xl.Visible = False
xl.DisplayAlerts = False
Set wb = xl.Workbooks.Add

For i = 0 To UBound(modules)
    basPath = fso.BuildPath(tempDir, modules(i))
    If fso.FileExists(basPath) Then
        wb.VBProject.VBComponents.Import basPath
        If Err.Number <> 0 Then
            MsgBox "Error importing " & modules(i) & vbCrLf & vbCrLf & Err.Description & vbCrLf & vbCrLf & _
                "Make sure VBA project access is enabled in Excel:" & vbCrLf & _
                "File > Options > Trust Center > Trust Center Settings > Macro Settings", vbCritical, "Build Failed"
            wb.Close False
            xl.Quit
            fso.DeleteFolder tempDir, True
            WScript.Quit 1
        End If
    End If
Next

' Add reference to Microsoft VBScript Regular Expressions 5.5
wb.VBProject.References.AddFromGuid "{3F4DACA7-160D-11D2-A8E9-00104B365C9F}", 5, 5
Err.Clear

Err.Clear
xl.Run "PDFExtractorMain.SetupMainSheet"
Err.Clear

For Each sht In wb.Worksheets
    If sht.Name = "Sheet1" And wb.Worksheets.Count > 1 Then
        sht.Delete
        Exit For
    End If
Next
Err.Clear
wb.Worksheets("Main").Activate
Err.Clear

wb.SaveAs xlsmPath, 52
If Err.Number <> 0 Then
    MsgBox "Error saving .xlsm: " & Err.Description, vbCritical, "Build Failed"
    wb.Close False
    xl.Quit
    fso.DeleteFolder tempDir, True
    WScript.Quit 1
End If

csvPath = fso.BuildPath(scriptDir, "ExcelMacroConfig.csv")
If fso.FileExists(csvPath) Then
    Err.Clear
    xl.Run "PDFExtractorMain.EnsureConfigSheet"
    Err.Clear
    wb.Worksheets("Main").Activate
    Err.Clear
    wb.Save
End If

wb.Close False
xl.Quit
fso.DeleteFolder tempDir, True

MsgBox "ExcelMacro.xlsm created successfully!" & vbCrLf & vbCrLf & xlsmPath, vbInformation, "Build Complete"
