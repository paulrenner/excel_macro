ts.WriteLine ""
ts.WriteLine "    If mQprWb Is Nothing Then"
ts.WriteLine "        InjectHTML browser, ""apply-status"", ""<div class=""""qpr-warn-banner"""">No QPR workbook loaded.</div>"""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim prevCalc As Long"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim writeResult As String"
ts.WriteLine "    Dim totalWritten As Long"
ts.WriteLine "    Dim summaryParts() As String"
ts.WriteLine "    Dim summaryPartCount As Long"
ts.WriteLine "    summaryPartCount = 0"
ts.WriteLine "    Dim qprPath As String"
ts.WriteLine "    Dim writeWb As Workbook"
ts.WriteLine "    Dim validationOK As Boolean"
ts.WriteLine ""
ts.WriteLine "    ' Determine QPR path -- use stored path, or derive from workbook"
ts.WriteLine "    qprPath = mQprPath"
ts.WriteLine "    If Len(qprPath) = 0 Then qprPath = mQprWb.FullName"
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = ""Writing to QPR..."""
ts.WriteLine ""
ts.WriteLine "    ' Close the read-only workbook before reopening read-write"
ts.WriteLine "    If mQprWb.ReadOnly Then"
ts.WriteLine "        mQprWb.Close False"
ts.WriteLine "        Set mQprWb = Nothing"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Open read-write (or use if already open read-write)"
ts.WriteLine "    Set writeWb = QPRWriter.GetOpenWorkbook(qprPath)"
ts.WriteLine "    If writeWb Is Nothing Then"
ts.WriteLine "        Set writeWb = Workbooks.Open(qprPath, UpdateLinks:=False)"
ts.WriteLine "        writeWb.Windows(1).Visible = False"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    prevCalc = Application.Calculation"
ts.WriteLine "    Application.Calculation = xlCalculationManual"
ts.WriteLine "    totalWritten = 0"
ts.WriteLine ""
ts.WriteLine "    ' Write each account using existing WriteQPR"
ts.WriteLine "    For i = 0 To mPortfolio.AccountCount - 1"
ts.WriteLine "        If mPortfolio.Accounts(i).Extraction.Summary.AccountNumber <> """" Then"
ts.WriteLine "            writeResult = """""
ts.WriteLine "            QPRWriter.WriteQPR mPortfolio.Accounts(i).Extraction, writeWb, _"
ts.WriteLine "                True, writeResult, mOverrides"
ts.WriteLine "            summaryPartCount = summaryPartCount + 1"
ts.WriteLine "            ReDim Preserve summaryParts(1 To summaryPartCount)"
ts.WriteLine "            summaryParts(summaryPartCount) = writeResult"
ts.WriteLine "            totalWritten = totalWritten + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    Application.Calculation = prevCalc"
ts.WriteLine ""
ts.WriteLine "    ' Validate QPR structure before saving"
ts.WriteLine "    validationOK = ValidateQprBeforeSave(writeWb)"
ts.WriteLine "    If Not validationOK Then"
ts.WriteLine "        ' Don't save -- close without saving to protect the file"
ts.WriteLine "        writeWb.Close False"
ts.WriteLine "        Set writeWb = Nothing"
ts.WriteLine "        InjectHTML browser, ""apply-status"", _"
ts.WriteLine "            ""<div class=""""qpr-warn-banner"""">QPR validation failed -- Mapping sheet "" & _"
ts.WriteLine "            ""appears damaged. File was NOT saved. Please check the QPR manually.</div>"""
ts.WriteLine "        Application.StatusBar = """""
ts.WriteLine "        Exit Sub"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Restore window visibility before saving (prevent hidden-window persistence)"
ts.WriteLine "    writeWb.Windows(1).Visible = True"
ts.WriteLine "    writeWb.Save"
ts.WriteLine "    Set mQprWb = writeWb"
ts.WriteLine "    mViewerApplied = True"
ts.WriteLine ""
ts.WriteLine "    ' Update DOM with success"
ts.WriteLine "    Dim summaryLines As String"
ts.WriteLine "    If summaryPartCount > 0 Then"
ts.WriteLine "        summaryLines = Join(summaryParts, ""<br>"")"
ts.WriteLine "    Else"
ts.WriteLine "        summaryLines = """""
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim statusHTML As String"
ts.WriteLine "    statusHTML = ""<div style=""""background:#d4edda;border:2px solid #28a745;border-radius:8px;"" & _"
ts.WriteLine "                 ""padding:12px 16px;margin-top:8px;"""">"" & _"
ts.WriteLine "                 ""<strong style=""""color:#155724;font-size:14px;"""">&#10003; QPR updated successfully</strong>"" & _"
ts.WriteLine "                 ""<div style=""""margin-top:6px;font-size:12px;color:#155724;"""">"" & _"
ts.WriteLine "                 summaryLines & ""</div>"" & _"
ts.WriteLine "                 ""<div style=""""margin-top:6px;font-size:12px;color:#666;"""">QPR workbook saved.</div>"" & _"
ts.WriteLine "                 ""</div>"""
ts.WriteLine "    InjectHTML browser, ""apply-status"", statusHTML"
ts.WriteLine ""
ts.WriteLine "    ' Disable the apply button"
ts.WriteLine "    InjectJS browser, ""var b=document.getElementById('apply-qpr-btn');if(b){b.disabled=true;b.innerHTML='Applied';b.style.background='#6c757d';b.style.cursor='default';}"""
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = ""QPR updated -- "" & totalWritten & "" account(s) written"""
ts.WriteLine "    Exit Sub"
ts.WriteLine ""
ts.WriteLine "ApplyErr:"
ts.WriteLine "    Application.StatusBar = """""
ts.WriteLine "    On Error Resume Next"
ts.WriteLine "    If Not writeWb Is Nothing Then writeWb.Close False"
ts.WriteLine "    Application.Calculation = prevCalc"
ts.WriteLine "    On Error GoTo 0"
ts.WriteLine "    Dim applyErrMsg As String"
ts.WriteLine "    applyErrMsg = ""Error applying QPR: "" & EscHTML(Err.Description)"
ts.WriteLine "    InjectHTML browser, ""apply-status"", ""<div class=""""qpr-warn-banner"""">"" & applyErrMsg & ""</div>"""
ts.WriteLine "    InjectJS browser, ""var b=document.getElementById('apply-qpr-btn');if(b){b.disabled=false;b.innerHTML='Apply Updates to QPR';}"""
ts.WriteLine "End Sub"
