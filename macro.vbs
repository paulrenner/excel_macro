ts.WriteLine "' Validate QPR structure before saving -- checks Mapping sheet still has headers and data"
ts.WriteLine "Private Function ValidateQprBeforeSave(wb As Workbook) As Boolean"
ts.WriteLine "    On Error GoTo ValidationFail"
ts.WriteLine "    Dim ws As Worksheet"
ts.WriteLine "    Dim sh As Worksheet"
ts.WriteLine "    Dim found As Boolean"
ts.WriteLine "    found = False"
ts.WriteLine "    For Each sh In wb.Worksheets"
ts.WriteLine "        If LCase$(Trim$(sh.name)) = ""mapping"" Then"
ts.WriteLine "            Set ws = sh"
ts.WriteLine "            found = True"
ts.WriteLine "            Exit For"
ts.WriteLine "        End If"
ts.WriteLine "    Next sh"
ts.WriteLine ""
ts.WriteLine "    If Not found Then"
ts.WriteLine "        ' No Mapping sheet -- might be OK for some QPR formats"
ts.WriteLine "        ValidateQprBeforeSave = True"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Check that header row has at least ""Tab"" and ""Account"" columns"
ts.WriteLine "    Dim c As Long"
ts.WriteLine "    Dim hasTab As Boolean"
ts.WriteLine "    Dim hasAcct As Boolean"
ts.WriteLine "    hasTab = False"
ts.WriteLine "    hasAcct = False"
ts.WriteLine "    For c = 1 To 20"
ts.WriteLine "        Dim cellVal As Variant"
ts.WriteLine "        cellVal = ws.Cells(1, c).Value"
ts.WriteLine "        If Not IsNull(cellVal) Then"
ts.WriteLine "            Dim hdr As String"
ts.WriteLine "            hdr = LCase$(Trim$(CStr(cellVal)))"
ts.WriteLine "            If hdr = ""tab"" Then hasTab = True"
ts.WriteLine "            If hdr = ""account"" Then hasAcct = True"
ts.WriteLine "        End If"
ts.WriteLine "    Next c"
ts.WriteLine ""
ts.WriteLine "    If Not hasTab Or Not hasAcct Then"
ts.WriteLine "        ValidateQprBeforeSave = False"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Check at least one data row exists"
ts.WriteLine "    Dim tabVal As Variant"
ts.WriteLine "    tabVal = ws.Cells(2, 1).Value"
ts.WriteLine "    ' Row 2 can be empty if headers are in different columns -- just check sheet isn't blank"
ts.WriteLine "    Dim lastRow As Long"
ts.WriteLine "    lastRow = ws.Cells(ws.Rows.count, 1).End(-4162).row  ' xlUp = -4162"
ts.WriteLine "    If lastRow < 2 Then"
ts.WriteLine "        ValidateQprBeforeSave = False"
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ValidateQprBeforeSave = True"
ts.WriteLine "    Exit Function"
ts.WriteLine ""
ts.WriteLine "ValidationFail:"
ts.WriteLine "    ValidateQprBeforeSave = False"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ============================================================================"
ts.WriteLine "' HandleRecomputeQPR -- user reclassified securities and clicked Recompute"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Sub HandleRecomputeQPR(ByRef browser As Object, ByVal classData As String)"
ts.WriteLine "    On Error GoTo RecomputeErr"
ts.WriteLine ""
ts.WriteLine "    If mQprWb Is Nothing Then Exit Sub"
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = ""Recomputing QPR with updated classifications..."""
ts.WriteLine ""
ts.WriteLine "    ' Parse the classification string into overrides"
ts.WriteLine "    ' Format: ""SYM1|ACCT1=Class1;SYM2|ACCT2=Class2"""
ts.WriteLine "    If mOverrides Is Nothing Then"
ts.WriteLine "        Set mOverrides = CreateObject(""Scripting.Dictionary"")"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Dim pairs() As String"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim pair As String"
ts.WriteLine "    Dim eqPos As Long"
ts.WriteLine "    Dim key As String"
ts.WriteLine "    Dim val As String"
ts.WriteLine ""
ts.WriteLine "    pairs = Split(classData, "";"")"
ts.WriteLine "    For i = LBound(pairs) To UBound(pairs)"
ts.WriteLine "        pair = Trim$(pairs(i))"
ts.WriteLine "        If Len(pair) > 0 Then"
ts.WriteLine "            eqPos = InStr(1, pair, ""="")"
ts.WriteLine "            If eqPos > 0 Then"
ts.WriteLine "                key = UCase$(Left$(pair, eqPos - 1))"
ts.WriteLine "                val = Mid$(pair, eqPos + 1)"
ts.WriteLine "                If Len(key) > 0 And Len(val) > 0 Then"
ts.WriteLine "                    mOverrides(key) = val"
ts.WriteLine "                End If"
ts.WriteLine "            End If"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Re-run analysis with updated overrides"
ts.WriteLine "    Dim analysis As QPRWriter.QprAnalysis"
ts.WriteLine "    analysis = QPRWriter.AnalyzeQPR(mPortfolio, mQprWb, mOverrides)"
ts.WriteLine ""
ts.WriteLine "    ' Rebuild analysis HTML"
ts.WriteLine "    Dim analysisHTML As String"
ts.WriteLine "    analysisHTML = ViewerHTML.BuildQPRAnalysisHTML(analysis)"
ts.WriteLine "    InjectHTML browser, ""qpr-analysis"", analysisHTML"
ts.WriteLine ""
ts.WriteLine "    ' Re-find unclassified securities, filtering out those now overridden"
ts.WriteLine "    Dim unclassified() As QPRWriter.UnclassifiedSecurity"
ts.WriteLine "    Dim unclassCount As Long"
ts.WriteLine "    Dim filteredCount As Long"
ts.WriteLine "    unclassCount = QPRWriter.FindUnclassifiedSecurities(mPortfolio, mQprWb, unclassified)"
ts.WriteLine ""
ts.WriteLine "    ' Filter out securities that have overrides"
ts.WriteLine "    filteredCount = 0"
ts.WriteLine "    If unclassCount > 0 Then"
ts.WriteLine "        Dim filtered() As QPRWriter.UnclassifiedSecurity"
ts.WriteLine "        ReDim filtered(1 To unclassCount)"
ts.WriteLine "        Dim fi As Long"
ts.WriteLine "        Dim overKey As String"
ts.WriteLine "        For fi = 1 To unclassCount"
ts.WriteLine "            overKey = UCase$(unclassified(fi).Symbol & ""|"" & unclassified(fi).AccountNumber)"
ts.WriteLine "            If Not mOverrides.Exists(overKey) Then"
ts.WriteLine "                filteredCount = filteredCount + 1"
ts.WriteLine "                filtered(filteredCount) = unclassified(fi)"
ts.WriteLine "            End If"
ts.WriteLine "        Next fi"
ts.WriteLine "        If filteredCount > 0 Then ReDim Preserve filtered(1 To filteredCount)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    If filteredCount > 0 Then"
ts.WriteLine "        Dim allocOpts() As String"
ts.WriteLine "        Dim allocOptCount As Long"
ts.WriteLine "        allocOptCount = QPRWriter.ReadMasterAssetClassNames(mQprWb, allocOpts)"
ts.WriteLine "        Dim unclassHTML As String"
ts.WriteLine "        unclassHTML = ViewerHTML.BuildUnclassifiedSection(filtered, filteredCount, allocOpts, allocOptCount, True)"
ts.WriteLine "        InjectHTML browser, ""qpr-unclassified"", unclassHTML"
ts.WriteLine "    Else"
ts.WriteLine "        InjectHTML browser, ""qpr-unclassified"", """""
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    Application.StatusBar = ""QPR recomputed -- "" & analysis.UpdateCount & "" updates previewed"""
ts.WriteLine "    Exit Sub"
ts.WriteLine ""
ts.WriteLine "RecomputeErr:"
ts.WriteLine "    Application.StatusBar = """""
ts.WriteLine "    Dim recompErrMsg As String"
ts.WriteLine "    recompErrMsg = ""Error recomputing QPR: "" & EscHTML(Err.Description)"
ts.WriteLine "    InjectHTML browser, ""apply-status"", ""<div class=""""qpr-warn-banner"""">"" & recompErrMsg & ""</div>"""
ts.WriteLine "End Sub"
ts.WriteLine ""
