ts.WriteLine "    End If"
ts.WriteLine "    If oiMatch Is Nothing Then Exit Sub"
ts.WriteLine ""
ts.WriteLine "    Dim oiStart As Long"
ts.WriteLine "    oiStart = oiMatch.FirstIndex + 1"
ts.WriteLine "    Dim oiSection As String"
