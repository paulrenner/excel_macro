ts.WriteLine "Public Function BuildUnclassifiedSection( _"
ts.WriteLine "    ByRef securities() As QPRWriter.UnclassifiedSecurity, _"
ts.WriteLine "    ByVal secCount As Long, _"
ts.WriteLine "    ByRef allocationOptions() As String, _"
ts.WriteLine "    ByVal optionCount As Long, _"
ts.WriteLine "    Optional ByVal recomputeMode As Boolean = False _"
ts.WriteLine ") As String"
ts.WriteLine ""
ts.WriteLine "    If secCount = 0 Then"
ts.WriteLine "        BuildUnclassifiedSection = """""
ts.WriteLine "        Exit Function"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Split into departed vs current"
ts.WriteLine "    Dim departedCount As Long"
ts.WriteLine "    Dim currentCount As Long"
ts.WriteLine "    Dim k As Long"
ts.WriteLine "    departedCount = 0"
ts.WriteLine "    currentCount = 0"
ts.WriteLine "    For k = 1 To secCount"
ts.WriteLine "        If securities(k).IsDeparted Then"
ts.WriteLine "            departedCount = departedCount + 1"
ts.WriteLine "        Else"
ts.WriteLine "            currentCount = currentCount + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next k"
ts.WriteLine ""
ts.WriteLine "    ' Build the options HTML once (reused for every select)"
ts.WriteLine "    Dim opts As String"
ts.WriteLine "    Dim m As Long"
ts.WriteLine "    opts = ""<option value="""""""">(skip)</option>"""
ts.WriteLine "    For m = 1 To optionCount"
ts.WriteLine "        opts = opts & ""<option value="""""" & Esc(allocationOptions(m)) & """""">"" & _"
ts.WriteLine "               Esc(allocationOptions(m)) & ""</option>"""
ts.WriteLine "    Next m"
ts.WriteLine ""
ts.WriteLine "    Dim h As String"
ts.WriteLine "    h = ""<div class=""""unclass-banner"""">"" & vbLf"
ts.WriteLine "    h = h & ""<div class=""""unclass-banner-title"""">"" & _"
ts.WriteLine "            ""&#9888; "" & secCount & "" securities need manual classification</div>"" & vbLf"
ts.WriteLine "    h = h & ""<div class=""""unclass-banner-body"""">"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    ' Current (non-departed) securities sub-table"
ts.WriteLine "    If currentCount > 0 Then"
ts.WriteLine "        h = h & ""<div class=""""unclass-subtitle"""">Current Holdings</div>"" & vbLf"
ts.WriteLine "        h = h & BuildUnclassifiedTable(securities, secCount, False, opts)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Departed securities sub-table"
ts.WriteLine "    If departedCount > 0 Then"
ts.WriteLine "        h = h & ""<div class=""""unclass-subtitle"""">Departed Securities (sold/transferred)</div>"" & vbLf"
ts.WriteLine "        h = h & BuildUnclassifiedTable(securities, secCount, True, opts)"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Submit/Recompute button"
ts.WriteLine "    If recomputeMode Then"
ts.WriteLine "        h = h & ""<button class=""""unclass-submit"""" onclick=""""recomputeQPR()"""">Recompute</button>"" & vbLf"
ts.WriteLine "    Else"
ts.WriteLine "        h = h & ""<button class=""""unclass-submit"""" onclick=""""submitClassifications()"""">Submit Classifications</button>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine "    h = h & ""</div></div>"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    BuildUnclassifiedSection = h"
ts.WriteLine "End Function"
