  ts.WriteLine "                ws.Range(ws.Cells(r, 9), ws.Cells(r, 10)).Font.Bold = True"
  ts.WriteLine "                ws.Range(ws.Cells(r, 9), ws.Cells(r, 10)).Font.Size = 9"
  ts.WriteLine "                ws.Range(ws.Cells(r, 9), ws.Cells(r, 10)).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = RGB(248, 249, 250)"
  ts.WriteLine "                r = r + 1"
  ts.WriteLine "                Dim hdi As Long"
  ts.WriteLine "                For hdi = 0 To cu.HoldingsDetailCount - 1"
  ts.WriteLine "                    ws.Cells(r, 1).Value = cu.HoldingsDetails(hdi).Account"
  ts.WriteLine "                    ws.Cells(r, 1).Font.Size = 9"
