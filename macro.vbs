  ts.WriteLine "Private Function RenderAlertTextList(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByVal title As String, msgs() As String, ByVal count As Long, _"
  ts.WriteLine "    Optional ByVal textColor As Long = -1) As Long"
  ts.WriteLine "    ' Renders: spacer, subheader with CLR_WARN_BG, text rows, yellow BorderAround"
  ts.WriteLine "    If textColor = -1 Then textColor = RGB(128, 64, 0)"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    Dim secStart As Long"
  ts.WriteLine "    secStart = r"
  ts.WriteLine "    WriteSubHeader ws, r, title"
  ts.WriteLine "    ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_WARN_BG"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = 0 To count - 1"
  ts.WriteLine "        MergeWrite ws, r, 1, GCOLS, msgs(i)"
  ts.WriteLine "        ws.Cells(r, 1).Font.Color = textColor"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next i"
  ts.WriteLine "    ws.Range(ws.Cells(secStart, 1), ws.Cells(r - 1, GCOLS)).BorderAround Weight:=4, Color:=RGB(255, 193, 7)"
  ts.WriteLine "    RenderAlertTextList = r"
  ts.WriteLine "End Function"
  ts.WriteLine ""
  ts.WriteLine "Private Function RenderUncoveredTable(ws As Worksheet, r As Long, _"
  ts.WriteLine "    ByVal title As String, accts() As QPRWriter.UncoveredAccount, _"
  ts.WriteLine "    ByVal count As Long) As Long"
  ts.WriteLine "    ' Renders: spacer, subheader + CLR_WARN_BG, table headers, data rows, yellow BorderAround"
  ts.WriteLine "    r = r + 1  ' spacer"
  ts.WriteLine "    Dim secStart As Long"
  ts.WriteLine "    secStart = r"
  ts.WriteLine "    WriteSubHeader ws, r, title"
  ts.WriteLine "    ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = CLR_WARN_BG"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    Dim ucH() As String, ucS() As Long, ucE() As Long, ucA() As Long"
  ts.WriteLine "    ReDim ucH(1 To 3): ReDim ucS(1 To 3): ReDim ucE(1 To 3): ReDim ucA(1 To 3)"
  ts.WriteLine "    ucH(1) = ""Account"": ucS(1) = 1: ucE(1) = 3: ucA(1) = -4131"
  ts.WriteLine "    ucH(2) = ""Name"": ucS(2) = 4: ucE(2) = 7: ucA(2) = -4131"
  ts.WriteLine "    ucH(3) = ""Closing Value"": ucS(3) = 8: ucE(3) = 10: ucA(3) = -4152"
  ts.WriteLine "    WriteTableHeadersMerged ws, r, ucH, ucS, ucE, ucA"
  ts.WriteLine "    r = r + 1"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    For i = 0 To count - 1"
  ts.WriteLine "        MergeWrite ws, r, 1, 3, accts(i).AccountNumber"
  ts.WriteLine "        MergeWrite ws, r, 4, 7, accts(i).AccountName"
  ts.WriteLine "        MergeWriteCurrency ws, r, 8, 10, accts(i).ClosingValue"
  ts.WriteLine "        r = r + 1"
  ts.WriteLine "    Next i"
  ts.WriteLine "    ws.Range(ws.Cells(secStart, 1), ws.Cells(r - 1, GCOLS)).BorderAround Weight:=4, Color:=RGB(255, 193, 7)"
  ts.WriteLine "    RenderUncoveredTable = r"
  ts.WriteLine "End Function"
