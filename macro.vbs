ts.WriteLine "' ============================================================================"
ts.WriteLine "' Holdings resolution -- flattens Securities within Holdings"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Function ResolveHoldingsColumn(ext As UBSExtract.StatementExtraction, _"
ts.WriteLine "                                       ByVal colName As String, _"
ts.WriteLine "                                       ByVal filterStr As String) As Variant"
ts.WriteLine "    Dim filters() As String"
ts.WriteLine "    Dim filterCount As Long"
ts.WriteLine "    ParseFilterString filterStr, filters, filterCount"
ts.WriteLine ""
ts.WriteLine "    Dim numSum As Double"
ts.WriteLine "    Dim textVal As String"
ts.WriteLine "    Dim matchCount As Long"
ts.WriteLine "    Dim isText As Boolean"
ts.WriteLine "    numSum = 0#"
ts.WriteLine "    matchCount = 0"
ts.WriteLine ""
ts.WriteLine "    ' Determine if text column"
ts.WriteLine "    Select Case colName"
ts.WriteLine "        Case ""description"", ""symbol"", ""asset_type"""
ts.WriteLine "            isText = True"
ts.WriteLine "    End Select"
ts.WriteLine ""
ts.WriteLine "    Dim h As Long, s As Long"
ts.WriteLine "    Dim hld As UBSExtract.Holding"
ts.WriteLine "    Dim sec As UBSExtract.SecurityDetail"
ts.WriteLine "    For h = 0 To ext.HoldingCount - 1"
ts.WriteLine "        hld = ext.Holdings(h)"
ts.WriteLine ""
ts.WriteLine "        If hld.SecurityCount = 0 Then"
ts.WriteLine "            ' Holdings with no securities (e.g., cash) -- match at holding level"
ts.WriteLine "            If filterCount > 0 Then"
ts.WriteLine "                If Not MatchHoldingFilter(hld, filters, filterCount) Then GoTo NextHold"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            matchCount = matchCount + 1"
ts.WriteLine ""
ts.WriteLine "            If isText Then"
ts.WriteLine "                If Len(textVal) = 0 Then"
ts.WriteLine "                    Select Case colName"
ts.WriteLine "                        Case ""description"": textVal = hld.Name"
ts.WriteLine "                        Case ""asset_type"":  textVal = hld.AssetType"
ts.WriteLine "                    End Select"
ts.WriteLine "                End If"
ts.WriteLine "            Else"
ts.WriteLine "                Select Case colName"
ts.WriteLine "                    Case ""market_value"": numSum = numSum + hld.Value"
ts.WriteLine "                    Case ""cost_basis"":   numSum = numSum + NullToZero(hld.CostBasis)"
ts.WriteLine "                    Case ""unrealized_gl"": numSum = numSum + NullToZero(hld.UnrealizedGL)"
ts.WriteLine "                End Select"
ts.WriteLine "            End If"
ts.WriteLine "            GoTo NextHold"
ts.WriteLine "        End If"
ts.WriteLine ""
ts.WriteLine "        For s = 0 To hld.SecurityCount - 1"
ts.WriteLine "            sec = hld.Securities(s)"
ts.WriteLine "            If sec.IsEscrow Then GoTo NextSec"
ts.WriteLine ""
ts.WriteLine "            ' Check filters"
ts.WriteLine "            If filterCount > 0 Then"
ts.WriteLine "                If Not MatchSecurityFilters(sec, hld.AssetType, hld.Name, filters, filterCount) Then GoTo NextSec"
ts.WriteLine "            End If"
ts.WriteLine ""
ts.WriteLine "            matchCount = matchCount + 1"
ts.WriteLine ""
ts.WriteLine "            If isText Then"
ts.WriteLine "                If Len(textVal) = 0 Then"
ts.WriteLine "                    textVal = GetSecurityTextColumn(sec, hld.AssetType, colName)"
ts.WriteLine "                End If"
ts.WriteLine "            Else"
ts.WriteLine "                numSum = numSum + GetSecurityNumColumn(sec, colName)"
ts.WriteLine "            End If"
ts.WriteLine "NextSec:"
ts.WriteLine "        Next s"
ts.WriteLine "NextHold:"
ts.WriteLine "    Next h"
ts.WriteLine ""
ts.WriteLine "    If matchCount = 0 Then"
ts.WriteLine "        ResolveHoldingsColumn = Empty"
ts.WriteLine "    ElseIf isText Then"
ts.WriteLine "        ResolveHoldingsColumn = textVal"
ts.WriteLine "    Else"
ts.WriteLine "        ResolveHoldingsColumn = numSum"
ts.WriteLine "    End If"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "' ---------------------------------------------------------------------------"
ts.WriteLine "' MatchHoldingFilter -- filter at the holding level (for holdings with no securities)"
ts.WriteLine "' ---------------------------------------------------------------------------"
ts.WriteLine "Private Function MatchHoldingFilter(hld As UBSExtract.Holding, _"
ts.WriteLine "                                    filters() As String, _"
ts.WriteLine "                                    ByVal filterCount As Long) As Boolean"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim key As String, val As String"
ts.WriteLine "    For i = 0 To filterCount - 1 Step 2"
ts.WriteLine "        key = filters(i)"
ts.WriteLine "        val = filters(i + 1)"
ts.WriteLine ""
ts.WriteLine "        Select Case key"
ts.WriteLine "            Case ""_cash"""
ts.WriteLine "                If LCase$(hld.Name) <> ""cash and money balances"" And _"
ts.WriteLine "                   LCase$(hld.Name) <> ""money market funds"" Then Exit Function"
ts.WriteLine "            Case ""asset_type"""
ts.WriteLine "                If InStr(1, NormalizeAssetClass(hld.AssetType), val, vbTextCompare) = 0 Then Exit Function"
ts.WriteLine "            Case ""description"""
ts.WriteLine "                If InStr(1, hld.Name, val, vbTextCompare) = 0 Then Exit Function"
ts.WriteLine "            Case ""symbol"""
ts.WriteLine "                Exit Function  ' Holdings without securities have no symbol"
ts.WriteLine "            Case Else"
ts.WriteLine "                Exit Function"
ts.WriteLine "        End Select"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    MatchHoldingFilter = True"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.WriteLine "Private Function MatchSecurityFilters(sec As UBSExtract.SecurityDetail, _"
ts.WriteLine "                                      ByVal assetType As String, _"
ts.WriteLine "                                      ByVal holdingName As String, _"
ts.WriteLine "                                      filters() As String, _"
ts.WriteLine "                                      ByVal filterCount As Long) As Boolean"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim key As String, val As String"
ts.WriteLine "    For i = 0 To filterCount - 1 Step 2"
ts.WriteLine "        key = filters(i)"
ts.WriteLine "        val = filters(i + 1)"
ts.WriteLine ""
ts.WriteLine "        Select Case key"
ts.WriteLine "            Case ""symbol"""
ts.WriteLine "                If StrComp(sec.Symbol, val, vbTextCompare) <> 0 Then Exit Function"
ts.WriteLine "            Case ""asset_type"""
ts.WriteLine "                If InStr(1, NormalizeAssetClass(assetType), val, vbTextCompare) = 0 Then Exit Function"
ts.WriteLine "            Case ""description"""
ts.WriteLine "                If InStr(1, sec.Name, val, vbTextCompare) = 0 Then Exit Function"
ts.WriteLine "            Case ""_cash"""
ts.WriteLine "                If LCase$(holdingName) <> ""cash and money balances"" And _"
ts.WriteLine "                   LCase$(holdingName) <> ""money market funds"" Then Exit Function"
ts.WriteLine "            Case Else"
ts.WriteLine "                Exit Function  ' unknown filter key = no match"
ts.WriteLine "        End Select"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    MatchSecurityFilters = True"
ts.WriteLine "End Function"
