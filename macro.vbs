  ts.WriteLine "        totalG.ShortTermRealizedYtd = totalG.ShortTermRealizedYtd + g.ShortTermRealizedYtd"
  ts.WriteLine "        totalG.ShortTermUnrealized = totalG.ShortTermUnrealized + g.ShortTermUnrealized"
  ts.WriteLine "        totalG.LongTermRealizedMonth = totalG.LongTermRealizedMonth + g.LongTermRealizedMonth"
  ts.WriteLine "        totalG.LongTermRealizedYtd = totalG.LongTermRealizedYtd + g.LongTermRealizedYtd"
  ts.WriteLine "        totalG.LongTermUnrealized = totalG.LongTermUnrealized + g.LongTermUnrealized"
  ts.WriteLine "        totalG.TotalRealizedMonth = totalG.TotalRealizedMonth + g.TotalRealizedMonth"
  ts.WriteLine "        totalG.TotalRealizedYtd = totalG.TotalRealizedYtd + g.TotalRealizedYtd"
  ts.WriteLine "        totalG.TotalUnrealized = totalG.TotalUnrealized + g.TotalUnrealized"
