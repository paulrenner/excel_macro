ts.WriteLine "' MergePortfolioInto -- merge source portfolio accounts into target"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Private Sub MergePortfolioInto(ByRef target As UBSSummary.PortfolioExtraction, ByRef source As UBSSummary.PortfolioExtraction)"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim j As Long"
ts.WriteLine "    Dim found As Boolean"
ts.WriteLine ""
ts.WriteLine "    ' Merge investment accounts (replace if same account number, else append)"
ts.WriteLine "    For i = 0 To source.AccountCount - 1"
ts.WriteLine "        found = False"
ts.WriteLine "        For j = 0 To target.AccountCount - 1"
ts.WriteLine "            If target.Accounts(j).AccountNumber = source.Accounts(i).AccountNumber Then"
ts.WriteLine "                target.Accounts(j) = source.Accounts(i)"
ts.WriteLine "                found = True"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "        If Not found Then"
ts.WriteLine "            If target.AccountCount > UBound(target.Accounts) Then _"
ts.WriteLine "                ReDim Preserve target.Accounts(0 To target.AccountCount + 15)"
ts.WriteLine "            target.Accounts(target.AccountCount) = source.Accounts(i)"
ts.WriteLine "            target.AccountCount = target.AccountCount + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Merge loan accounts"
ts.WriteLine "    For i = 0 To source.LoanAccountCount - 1"
ts.WriteLine "        found = False"
ts.WriteLine "        For j = 0 To target.LoanAccountCount - 1"
ts.WriteLine "            If target.LoanAccounts(j).AccountNumber = source.LoanAccounts(i).AccountNumber Then"
ts.WriteLine "                target.LoanAccounts(j) = source.LoanAccounts(i)"
ts.WriteLine "                found = True"
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "        If Not found Then"
ts.WriteLine "            If target.LoanAccountCount > UBound(target.LoanAccounts) Then _"
ts.WriteLine "                ReDim Preserve target.LoanAccounts(0 To target.LoanAccountCount + 7)"
ts.WriteLine "            target.LoanAccounts(target.LoanAccountCount) = source.LoanAccounts(i)"
ts.WriteLine "            target.LoanAccountCount = target.LoanAccountCount + 1"
ts.WriteLine "        End If"
ts.WriteLine "    Next i"
ts.WriteLine "End Sub"
ts.WriteLine ""
