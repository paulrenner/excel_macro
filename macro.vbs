  ts.WriteLine "                ws.Range(ws.Cells(r, 7), ws.Cells(r, 8)).Font.Size = 9"
  ts.WriteLine "                ws.Range(ws.Cells(r, 7), ws.Cells(r, 8)).Font.Color = RGB(128, 128, 128)"
