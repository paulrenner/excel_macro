  ts.WriteLine "    Dim errMsg As String"
  ts.WriteLine "    Dim clientErrorCount As Long"
  ts.WriteLine "    Dim summaryMsg As String"
  ts.WriteLine ""
  ts.WriteLine "    ' Distinct client tracking"
  ts.WriteLine "    Dim clients() As String"
  ts.WriteLine "    Dim clientCount As Long"
  ts.WriteLine "    Dim i As Long"
  ts.WriteLine "    Dim j As Long"
