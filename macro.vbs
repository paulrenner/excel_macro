ts.WriteLine "' Public: Render portfolio HTML with unclassified securities section"
ts.WriteLine "' ============================================================================"
ts.WriteLine ""
ts.WriteLine "Public Function RenderPortfolioWithUnclassifiedHTML( _"
ts.WriteLine "    ByRef portfolio As UBSSummary.PortfolioExtraction, _"
ts.WriteLine "    ByRef securities() As QPRWriter.UnclassifiedSecurity, _"
ts.WriteLine "    ByVal secCount As Long, _"
ts.WriteLine "    ByRef allocationOptions() As String, _"
ts.WriteLine "    ByVal optionCount As Long, _"
ts.WriteLine "    Optional ByVal coverageHTML As String = """" _"
ts.WriteLine ") As String"
ts.WriteLine ""
ts.WriteLine "    Dim body As String"
ts.WriteLine "    Dim i As Long"
ts.WriteLine "    Dim j As Long"
ts.WriteLine "    Dim s As UBSExtract.AccountSummary"
ts.WriteLine "    Dim ext As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim totalOpening As Double"
ts.WriteLine "    Dim totalClosing As Double"
ts.WriteLine "    Dim totalDeposits As Double"
ts.WriteLine "    Dim totalIncome As Double"
ts.WriteLine "    Dim totalMarket As Double"
ts.WriteLine "    Dim failBanner As String"
ts.WriteLine "    Dim countLabel As String"
ts.WriteLine "    Dim portfolioCards As String"
ts.WriteLine "    Dim acctExt As UBSExtract.StatementExtraction"
ts.WriteLine "    Dim acctNum As String"
ts.WriteLine "    Dim acctLabel As String"
ts.WriteLine "    Dim failCls As String"
ts.WriteLine "    Dim acctId As String"
ts.WriteLine ""
ts.WriteLine "    body = """""
ts.WriteLine ""
ts.WriteLine "    ' Aggregate totals"
ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        s = portfolio.Accounts(i).Extraction.Summary"
ts.WriteLine "        totalOpening = totalOpening + s.OpeningValue"
ts.WriteLine "        totalClosing = totalClosing + s.ClosingValue"
ts.WriteLine "        totalDeposits = totalDeposits + s.NetDepositsWithdrawals"
ts.WriteLine "        totalIncome = totalIncome + s.DividendInterestIncome"
ts.WriteLine "        totalMarket = totalMarket + s.ChangeInMarketValue"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Check for any failures across all accounts"
ts.WriteLine "    failBanner = """""
ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        ext = portfolio.Accounts(i).Extraction"
ts.WriteLine "        For j = 0 To ext.CheckCount - 1"
ts.WriteLine "            If Not ext.Checks(j).Pass Then"
ts.WriteLine "                failBanner = failBanner & ""<div>"" & _"
ts.WriteLine "                    Esc(ext.Summary.AccountNumber) & "" / "" & Esc(ext.Checks(j).Name) & _"
ts.WriteLine "                    "": expected "" & Fmt(ext.Checks(j).Expected) & _"
ts.WriteLine "                    "", calculated "" & Fmt(ext.Checks(j).Actual) & ""</div>"""
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    If Len(failBanner) > 0 Then"
ts.WriteLine "        body = body & ""<div class=""""banner-error"""">"" & _"
ts.WriteLine "               ""<strong class=""""banner-error-title"""">Data Integrity Check Failed</strong>"" & _"
ts.WriteLine "               ""<div class=""""banner-error-body"""">"" & failBanner & ""</div></div>"" & vbLf"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Coverage section (if provided)"
ts.WriteLine "    If Len(coverageHTML) > 0 Then"
ts.WriteLine "        body = body & coverageHTML"
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    ' Add Data zone (Add PDF / Add Excel buttons)"
ts.WriteLine "    body = body & BuildAddDataZone()"
ts.WriteLine ""
ts.WriteLine "    ' Success banner (hidden, shown by JS after classification submit)"
ts.WriteLine "    body = body & ""<div class=""""banner-success"""" id=""""success-banner""""></div>"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    ' Unclassified securities section (after failure banner, before portfolio accordion)"
ts.WriteLine "    body = body & BuildUnclassifiedSection(securities, secCount, allocationOptions, optionCount)"
ts.WriteLine ""
ts.WriteLine "    ' Portfolio total accordion"
ts.WriteLine "    countLabel = portfolio.AccountCount & "" accounts"""
ts.WriteLine "    If portfolio.LoanAccountCount > 0 Then"
ts.WriteLine "        countLabel = countLabel & "" + "" & portfolio.LoanAccountCount & "" loan"""
ts.WriteLine "        If portfolio.LoanAccountCount > 1 Then countLabel = countLabel & ""s"""
ts.WriteLine "    End If"
ts.WriteLine ""
ts.WriteLine "    portfolioCards = BuildCards(totalOpening, totalClosing, totalDeposits, totalIncome, totalMarket)"
ts.WriteLine ""
ts.WriteLine "    body = body & ""<div class=""""acct-accordion acct-accordion-portfolio"""">"" & vbLf"
ts.WriteLine "    body = body & ""<button class=""""acct-toggle acct-toggle-portfolio"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" data-target=""""portfolio-detail"""" onclick=""""toggleAcct(this)"""">"" & _"
ts.WriteLine "                  ""<span>Total Portfolio Value ("" & countLabel & "") &mdash; "" & Fmt(totalClosing) & ""</span>"" & _"
ts.WriteLine "                  ""<span class=""""arrow"""" style=""""color:rgba(255,255,255,0.6);"""">&#9654;</span></button>"" & vbLf"
ts.WriteLine "    body = body & ""<div class=""""acct-body"""" id=""""portfolio-detail""""><div class=""""acct-inner"""">"" & _"
ts.WriteLine "                  portfolioCards & _"
ts.WriteLine "                  BuildPortfolioAllocationSection(portfolio, totalClosing) & _"
ts.WriteLine "                  BuildPortfolioIncomeSection(portfolio) & _"
ts.WriteLine "                  BuildPortfolioGainsSection(portfolio) & _"
ts.WriteLine "                  ""</div></div></div>"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    ' Per-account accordions (lazy load: only first account rendered inline)"
ts.WriteLine "    For i = 0 To portfolio.AccountCount - 1"
ts.WriteLine "        acctExt = portfolio.Accounts(i).Extraction"
ts.WriteLine "        acctNum = acctExt.Summary.AccountNumber"
ts.WriteLine "        acctLabel = acctExt.Summary.FriendlyName"
ts.WriteLine "        If Len(acctLabel) = 0 Then acctLabel = acctExt.Summary.AccountName"
ts.WriteLine ""
ts.WriteLine "        failCls = """""
ts.WriteLine "        For j = 0 To acctExt.CheckCount - 1"
ts.WriteLine "            If Not acctExt.Checks(j).Pass Then"
ts.WriteLine "                failCls = "" acct-accordion-fail"""
ts.WriteLine "                Exit For"
ts.WriteLine "            End If"
ts.WriteLine "        Next j"
ts.WriteLine ""
ts.WriteLine "        acctId = ""acct-"" & i"
ts.WriteLine ""
ts.WriteLine "        body = body & ""<div class=""""acct-accordion"" & failCls & """""">"" & vbLf"
ts.WriteLine "        body = body & ""<button class=""""acct-toggle"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" data-target="""""" & acctId & """""" "" & _"
ts.WriteLine "                      ""data-acct="""""" & Esc(acctNum) & """""" onclick=""""toggleAcct(this); selectAccount('"" & Esc(acctNum) & ""');"""">"" & _"
ts.WriteLine "                      ""<span>"" & Esc(acctLabel) & "" &mdash; "" & Esc(acctNum) & "" &mdash; "" & _"
ts.WriteLine "                      Fmt(acctExt.Summary.ClosingValue) & ""</span>"" & _"
ts.WriteLine "                      ""<span class=""""arrow"""">&#9654;</span></button>"" & vbLf"
ts.WriteLine "        body = body & ""<div class=""""acct-body"""" id="""""" & acctId & """"""><div class=""""acct-inner"""">"" & _"
ts.WriteLine "                      RenderAccountBody(acctExt) & ""</div></div></div>"" & vbLf"
ts.WriteLine "    Next i"
ts.WriteLine ""
ts.WriteLine "    ' Loan account accordions"
ts.WriteLine "    Dim li As Long"
ts.WriteLine "    Dim loanExt As UBSLoanExtract.LoanExtraction"
ts.WriteLine "    Dim loanLabel As String"
ts.WriteLine "    Dim loanId As String"
ts.WriteLine "    For li = 0 To portfolio.LoanAccountCount - 1"
ts.WriteLine "        loanExt = portfolio.LoanAccounts(li).Extraction"
ts.WriteLine "        loanLabel = loanExt.Summary.AccountName"
ts.WriteLine "        If Len(loanLabel) = 0 Then loanLabel = ""Loan Account"""
ts.WriteLine "        loanId = ""loan-"" & li"
ts.WriteLine ""
ts.WriteLine "        body = body & ""<div class=""""acct-accordion"""">"" & vbLf"
ts.WriteLine "        body = body & ""<button class=""""acct-toggle"""" tabindex=""""0"""" role=""""button"""" aria-expanded=""""false"""" data-target="""""" & loanId & """""" onclick=""""toggleAcct(this)"""">"" & _"
ts.WriteLine "                      ""<span>"" & Esc(loanLabel) & "" &mdash; "" & Esc(loanExt.Summary.AccountNumbers) & "" &mdash; "" & _"
ts.WriteLine "                      Fmt(loanExt.Summary.ClosingBalance) & ""</span>"" & _"
ts.WriteLine "                      ""<span class=""""arrow"""">&#9654;</span></button>"" & vbLf"
ts.WriteLine "        body = body & ""<div class=""""acct-body"""" id="""""" & loanId & """"""><div class=""""acct-inner"""">"" & _"
ts.WriteLine "                      BuildLoanAccountBody(loanExt) & ""</div></div></div>"" & vbLf"
ts.WriteLine "    Next li"
ts.WriteLine ""
ts.WriteLine "    ' Raw text section (if set via SetRawPageText)"
ts.WriteLine "    body = body & BuildRawTextSection()"
ts.WriteLine "    body = body & BuildLayoutSection()"
ts.WriteLine ""
ts.WriteLine "    ' Template analysis container (below layout, matching QPR position)"
ts.WriteLine "    body = body & ""<div id=""""template-analysis""""></div>"" & vbLf"
ts.WriteLine ""
ts.WriteLine "    ' QPR load button + analysis container (below all viewer content)"
ts.WriteLine "    body = body & BuildQPRLoadButton()"
ts.WriteLine ""
ts.WriteLine "    RenderPortfolioWithUnclassifiedHTML = WrapPage(""Statement Reader"", body)"
ts.WriteLine "End Function"
ts.WriteLine ""
ts.Close

Set ts = fso.CreateTextFile(fso.BuildPath(tempDir, "ViewerFormLauncher.bas"), True)
ts.WriteLine "Attribute VB_Name = ""ViewerFormLauncher"""
ts.WriteLine "Option Explicit"
ts.WriteLine ""
ts.WriteLine "' ViewerFormLauncher.bas -- Embedded viewer for ViewerHTML output."
ts.WriteLine "'"
ts.WriteLine "' Creates a VBA UserForm at runtime with an embedded WebBrowser control"
ts.WriteLine "' (Shell.Explorer.2). Viewer runs inside Excel as a modal dialog."
ts.WriteLine "' JS writes to a hidden input field; VBA polls it via DoEvents loop."
ts.WriteLine "' When classifications are submitted, the form auto-closes and the"
ts.WriteLine "' result string is returned to the caller."
ts.WriteLine "'"
ts.WriteLine "' Public API:"
