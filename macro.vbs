  ts.WriteLine "            End If"
  ts.WriteLine ""
  ts.WriteLine "            ' Cash flow detail rows (grouped)"
  ts.WriteLine "            If cu.CashFlowDetailCount > 0 Then"
  ts.WriteLine "                Dim cfStart As Long"
  ts.WriteLine "                cfStart = r"
  ts.WriteLine "                ' Detail header"
  ts.WriteLine "                ws.Cells(r, 1).Value = ""Account"""
  ts.WriteLine "                ws.Cells(r, 1).Font.Bold = True"
  ts.WriteLine "                ws.Cells(r, 1).Font.Size = 9"
  ts.WriteLine "                ws.Cells(r, 1).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                MergeWrite ws, r, 2, 3, ""Activity"""
  ts.WriteLine "                ws.Range(ws.Cells(r, 2), ws.Cells(r, 3)).Font.Bold = True"
  ts.WriteLine "                ws.Range(ws.Cells(r, 2), ws.Cells(r, 3)).Font.Size = 9"
  ts.WriteLine "                ws.Range(ws.Cells(r, 2), ws.Cells(r, 3)).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                MergeWrite ws, r, 4, 7, ""Description"""
  ts.WriteLine "                ws.Range(ws.Cells(r, 4), ws.Cells(r, 7)).Font.Bold = True"
  ts.WriteLine "                ws.Range(ws.Cells(r, 4), ws.Cells(r, 7)).Font.Size = 9"
  ts.WriteLine "                ws.Range(ws.Cells(r, 4), ws.Cells(r, 7)).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                ws.Cells(r, 8).Value = ""Amount"""
  ts.WriteLine "                ws.Cells(r, 8).Font.Bold = True"
  ts.WriteLine "                ws.Cells(r, 8).Font.Size = 9"
  ts.WriteLine "                ws.Cells(r, 8).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                ws.Cells(r, 8).HorizontalAlignment = -4152  ' xlRight"
  ts.WriteLine "                ws.Cells(r, 9).Value = ""Date"""
  ts.WriteLine "                ws.Cells(r, 9).Font.Bold = True"
  ts.WriteLine "                ws.Cells(r, 9).Font.Size = 9"
  ts.WriteLine "                ws.Cells(r, 9).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                ws.Cells(r, 9).HorizontalAlignment = -4108  ' xlCenter"
  ts.WriteLine "                ws.Cells(r, 10).Value = ""Weighted"""
  ts.WriteLine "                ws.Cells(r, 10).Font.Bold = True"
  ts.WriteLine "                ws.Cells(r, 10).Font.Size = 9"
  ts.WriteLine "                ws.Cells(r, 10).Font.Color = RGB(128, 128, 128)"
  ts.WriteLine "                ws.Cells(r, 10).HorizontalAlignment = -4152  ' xlRight"
  ts.WriteLine "                ws.Range(ws.Cells(r, 1), ws.Cells(r, GCOLS)).Interior.Color = RGB(248, 249, 250)"
